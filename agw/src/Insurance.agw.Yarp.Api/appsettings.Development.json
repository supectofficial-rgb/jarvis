{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
      //"Elastic.Apm": "Trace"
    }
  },

  "Jwt": {
    "SecretKey": "Your-Very-Long-Secret-Key-At-Least-32-Characters-Long",
    "Issuer": "YourApp",
    "Audience": "YourAppClients"
  },

  "ApiKeys": {
    "user-service-route": "ABC",
    "core-service-route": "ABC"
  },

  "AllowedHosts": "*",

  "Consul": {
    "Enabled": true,
    "Address": "http://localhost:8500",
    "Key": "yarp-api-gateway/appsettings.json",
    "Token": ""
  },

  "ElasticApm": {
    "ServerUrl": "http://localhost:8200",
    "SecretToken": "your_secret_token",
    "ServiceName": "yarp-api-gateway",
    "Environment": "development",
    "TransactionSampleRate": 1.0,
    "CaptureHeaders": true,
    "CaptureBody": "all",
    "LogLevel": "Debug",
    "Enabled": true
  },
  "ReverseProxy": {
    "Routes": {
      "core-service-route": {
        "ClusterId": "core-service-cluster",
        "Match": {
          "Path": "/api/CoreService/{**catch-all}"
        },
        "Metadata": {
          "ApiKey": "core-service-api-key"
        },
        //"Transforms": [
        //  {
        //    "PathPattern": "{**catch-all}"
        //  }
        //],
        "Order": 1
        //"AuthorizationPolicy": "Authenticated"
      },
      "user-service-route": {
        "ClusterId": "user-service-cluster",
        "Match": {
          "Path": "/api/UserService/{**catch-all}"
        },
        "Metadata": {
          "ApiKey": "user-service-api-key"
        },
        //"Transforms": [
        //  {
        //    "PathPattern": "{**catch-all}"
        //  }
        //],
        "Order": 2
        //"AuthorizationPolicy": "Authenticated"
      }
    },
    "Clusters": {
      "core-service-cluster": {
        "Destinations": {
          "core-service-destination": {
            "Address": "https://localhost:7200/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Path": "/health"
          },
          "Passive": {
            "Enabled": true,
            "ReactivationPeriod": "00:02:00"
          }
        }
      },
      "user-service-cluster": {
        "Destinations": {
          "user-service-destination": {
            "Address": "https://localhost:7209/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Path": "/health"
          },
          "Passive": {
            "Enabled": true,
            "ReactivationPeriod": "00:02:00"
          }
        }
      }
    }
  }
}