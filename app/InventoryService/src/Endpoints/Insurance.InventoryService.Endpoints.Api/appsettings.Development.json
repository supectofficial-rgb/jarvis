{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=inventory_service_dev;Username=postgres;Password=postgres",
    "CommandDb": "Host=localhost;Port=5432;Database=inventory_service_dev;Username=postgres;Password=postgres",
    "QueryDb": "Host=localhost;Port=5432;Database=inventory_service_dev;Username=postgres;Password=postgres"
  },
  "GraphService": {
    "Enabled": true,
    "BaseUrl": "https://localhost:7263/",
