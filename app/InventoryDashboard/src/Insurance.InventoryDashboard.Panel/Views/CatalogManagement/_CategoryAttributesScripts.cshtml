@using System.Text.Json
@model Insurance.InventoryDashboard.Panel.Models.CategoryManagementPageViewModel
<script>
    (function () {
        function showBootstrapTab(selector) {
            var target = document.querySelector(selector);
            if (target && window.jQuery) {
                window.jQuery(target).tab('show');
            }
        }

        function escapeHtml(value) {
            return (value || '')
                .toString()
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function escapeSelector(value) {
            if (window.CSS && window.CSS.escape) {
                return window.CSS.escape(value);
            }

            return String(value || '').replace(/["\\]/g, '\\$&');
        }

        function getJson(response) {
            return response.json().catch(function () {
                return { isSuccess: false, errorMessage: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.serverResponseUnreadable"])) };
            });
        }

        var optionEndpoints = {
            list: '@Url.Action("GetAttributeOptions", "CategoryManagement")',
            add: '@Url.Action("AddAttributeOptionAjax", "CategoryManagement")',
            update: '@Url.Action("UpdateAttributeOptionAjax", "CategoryManagement")',
            delete: '@Url.Action("DeleteAttributeOptionAjax", "CategoryManagement")'
        };

        var optionTexts = {
            none: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.none"])),
            active: @Html.Raw(JsonSerializer.Serialize(UiText["common.active"])),
            inactive: @Html.Raw(JsonSerializer.Serialize(UiText["common.inactive"])),
            edit: @Html.Raw(JsonSerializer.Serialize(UiText["common.edit"])),
            delete: @Html.Raw(JsonSerializer.Serialize(UiText["common.delete"])),
            loading: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.loading"])),
            unavailable: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.serverUnavailable"])),
            loadFailed: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.loadFailed"])),
            submitting: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.submitting"])),
            submitFailed: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.submitFailed"])),
            submitSucceeded: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.submitSucceeded"])),
            deleteConfirm: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.deleteConfirm"])),
            deleting: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.deleting"])),
            deleteFailed: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.deleteFailed"])),
            deleteSucceeded: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.deleteSucceeded"]))
        };

        function setOptionsMessage(row, message, isError) {
            var box = row ? row.querySelector('[data-options-message]') : null;
            if (!box) return;
            box.className = 'attribute-options-message small mb-2 ' + (isError ? 'text-danger' : 'text-success');
            box.textContent = message || '';
        }

        function renderOptions(row, options) {
            var tbody = row ? row.querySelector('[data-options-tbody]') : null;
            if (!tbody) return;
            if (!options || !options.length) {
                tbody.innerHTML = '<tr><td colspan="5">' + optionTexts.none + '</td></tr>';
                return;
            }

            tbody.innerHTML = options.slice().sort(function (a, b) {
                return (a.displayOrder || a.DisplayOrder || 0) - (b.displayOrder || b.DisplayOrder || 0)
                    || String(a.optionName || a.OptionName || '').localeCompare(String(b.optionName || b.OptionName || ''));
            }).map(function (option) {
                var id = escapeHtml(option.id || option.Id);
                var name = escapeHtml(option.optionName || option.OptionName);
                var value = escapeHtml(option.optionValue || option.OptionValue);
                var order = option.displayOrder || option.DisplayOrder || 0;
                var isActive = option.isActive !== undefined ? option.isActive : option.IsActive;
                return '<tr>'
                    + '<td><span class="text-monospace">' + value + '</span></td>'
                    + '<td>' + name + '</td>'
                    + '<td>' + order + '</td>'
                    + '<td>' + (isActive ? optionTexts.active : optionTexts.inactive) + '</td>'
                    + '<td class="text-nowrap">'
                    + '<button type="button" class="btn btn-outline-secondary btn-xs option-edit-btn" data-option-id="' + id + '" data-option-name="' + name + '" data-option-value="' + value + '" data-display-order="' + order + '">' + optionTexts.edit + '</button> '
                    + '<button type="button" class="btn btn-outline-danger btn-xs ajax-option-delete-btn" data-option-id="' + id + '">' + optionTexts.delete + '</button>'
                    + '</td>'
                    + '</tr>';
            }).join('');
        }

        function loadOptions(row, attributeId) {
            setOptionsMessage(row, optionTexts.loading, false);
            return fetch(optionEndpoints.list + '?attributeId=' + encodeURIComponent(attributeId), {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
                .then(getJson)
                .then(function (payload) {
                    if (!payload.isSuccess) {
                        setOptionsMessage(row, payload.errorMessage || optionTexts.loadFailed, true);
                        return;
                    }
                    renderOptions(row, payload.items || []);
                    setOptionsMessage(row, '', false);
                })
                .catch(function () {
                    setOptionsMessage(row, optionTexts.unavailable, true);
                });
        }

        function submitOptionForm(form, url) {
            var row = form.closest('.attribute-options-row');
            var buttons = form.querySelectorAll('button[type="submit"]');
            buttons.forEach(function (button) { button.disabled = true; });
            setOptionsMessage(row, optionTexts.submitting, false);
            return fetch(url, {
                method: 'POST',
                body: new FormData(form),
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
                .then(getJson)
                .then(function (payload) {
                    if (!payload.isSuccess) {
                        setOptionsMessage(row, payload.errorMessage || optionTexts.submitFailed, true);
                        return;
                    }
                    renderOptions(row, payload.items || []);
                    setOptionsMessage(row, payload.message || optionTexts.submitSucceeded, false);
                    form.reset();
                    if (form.matches('[data-option-update-form]')) {
                        form.style.display = 'none';
                    }
                })
                .catch(function () {
                    setOptionsMessage(row, optionTexts.unavailable, true);
                })
                .finally(function () {
                    buttons.forEach(function (button) { button.disabled = false; });
                });
        }

        document.addEventListener('click', function (event) {
            var attributeEditButton = event.target.closest('.attribute-edit-btn');
            if (attributeEditButton) {
                var pairs = {
                    'attribute-update-id': 'data-attribute-id',
                    'attribute-update-selected': 'data-attribute-name',
                    'AttributeUpdateForm_Code': 'data-attribute-code',
                    'AttributeUpdateForm_Name': 'data-attribute-name',
                    'AttributeUpdateForm_DataType': 'data-attribute-datatype',
                    'AttributeUpdateForm_Scope': 'data-attribute-scope',
                    'AttributeUpdateForm_DisplayOrder': 'data-attribute-display-order'
                };
                Object.keys(pairs).forEach(function (id) {
                    var field = document.getElementById(id);
                    if (field) field.value = attributeEditButton.getAttribute(pairs[id]) || '';
                });
                var isActiveField = document.getElementById('AttributeUpdateForm_IsActive');
                if (isActiveField) {
                    isActiveField.value = (attributeEditButton.getAttribute('data-attribute-isactive') || '').toLowerCase() === 'true' ? 'true' : 'false';
                }

                showBootstrapTab('#attribute-section-tabs .nav-link[href="#attribute-section-bank"]');
                var editPanel = document.getElementById('attribute-edit-panel');
                if (editPanel) editPanel.style.display = '';
                var form = document.getElementById('attribute-update-form');
                if (form) form.scrollIntoView({ behavior: 'smooth', block: 'center' });
                return;
            }

            var optionsButton = event.target.closest('.attribute-options-btn');
            if (optionsButton) {
                var attributeId = optionsButton.getAttribute('data-attribute-id') || '';
                var row = document.querySelector('.attribute-options-row[data-options-for="' + escapeSelector(attributeId) + '"]');
                if (!row) return;
                var isVisible = row.style.display !== 'none';
                document.querySelectorAll('.attribute-options-row').forEach(function (optionsRow) {
                    optionsRow.style.display = 'none';
                });
                row.style.display = isVisible ? 'none' : '';
                if (!isVisible) {
                    loadOptions(row, attributeId);
                }
                return;
            }

            var optionEditButton = event.target.closest('.option-edit-btn');
            if (optionEditButton) {
                var optionRow = optionEditButton.closest('.attribute-options-row');
                var updateForm = optionRow ? optionRow.querySelector('[data-option-update-form]') : null;
                if (!updateForm) return;
                var fields = {
                    '[data-option-update-id]': 'data-option-id',
                    '[data-option-update-name]': 'data-option-name',
                    '[data-option-update-value]': 'data-option-value',
                    '[data-option-update-order]': 'data-display-order'
                };
                Object.keys(fields).forEach(function (selector) {
                    var field = updateForm.querySelector(selector);
                    if (field) field.value = optionEditButton.getAttribute(fields[selector]) || '';
                });
                updateForm.style.display = '';
                updateForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
                return;
            }

            var optionDeleteButton = event.target.closest('.ajax-option-delete-btn');
            if (optionDeleteButton) {
                var deleteRow = optionDeleteButton.closest('.attribute-options-row');
                var deleteToken = deleteRow ? deleteRow.querySelector('input[name="__RequestVerificationToken"]') : null;
                var deleteAttributeId = deleteRow ? deleteRow.getAttribute('data-options-for') || '' : '';
                var deleteOptionId = optionDeleteButton.getAttribute('data-option-id') || '';
                if (!deleteRow || !deleteToken || !deleteAttributeId || !deleteOptionId || !window.confirm(optionTexts.deleteConfirm)) return;
                var data = new FormData();
                data.append('__RequestVerificationToken', deleteToken.value);
                data.append('attributeId', deleteAttributeId);
                data.append('optionId', deleteOptionId);
                setOptionsMessage(deleteRow, optionTexts.deleting, false);
                fetch(optionEndpoints.delete, {
                    method: 'POST',
                    body: data,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(getJson)
                    .then(function (payload) {
                        if (!payload.isSuccess) {
                            setOptionsMessage(deleteRow, payload.errorMessage || optionTexts.deleteFailed, true);
                            return;
                        }
                        renderOptions(deleteRow, payload.items || []);
                        setOptionsMessage(deleteRow, payload.message || optionTexts.deleteSucceeded, false);
                    })
                    .catch(function () {
                        setOptionsMessage(deleteRow, optionTexts.unavailable, true);
                    });
            }
        }, true);

        document.addEventListener('submit', function (event) {
            var form = event.target;
            if (!(form instanceof HTMLFormElement)) return;
            if (form.matches('[data-option-add-form]')) {
                event.preventDefault();
                submitOptionForm(form, optionEndpoints.add);
                return;
            }
            if (form.matches('[data-option-update-form]')) {
                event.preventDefault();
                submitOptionForm(form, optionEndpoints.update);
            }
        }, true);

        var attributeListSearch = document.getElementById('attribute-list-search');
        if (attributeListSearch) {
            attributeListSearch.addEventListener('input', function () {
                var needle = (attributeListSearch.value || '').trim().toLowerCase();
                document.querySelectorAll('[data-attribute-list-row]').forEach(function (row) {
                    var haystack = (row.getAttribute('data-attribute-search') || '').toLowerCase();
                    var visible = !needle || haystack.indexOf(needle) >= 0;
                    row.style.display = visible ? '' : 'none';
                    var optionsButton = row.querySelector('.attribute-options-btn');
                    var attributeId = optionsButton ? optionsButton.getAttribute('data-attribute-id') || '' : '';
                    var optionsRow = attributeId ? document.querySelector('.attribute-options-row[data-options-for="' + escapeSelector(attributeId) + '"]') : null;
                    if (optionsRow && !visible) {
                        optionsRow.style.display = 'none';
                    }
                });
            });
        }
    })();
</script>
