                                                                            <button type="submit" class="btn btn-outline-success btn-xs" @(Can("Catalog.Category.Activate", "Category.Activate") ? null : "disabled")>@UiText["common.active"]</button>
                                                                        </form>
                                                                    }
                                                                    <form asp-action="DeleteCategory" method="post" class="d-inline" data-loading-form>
