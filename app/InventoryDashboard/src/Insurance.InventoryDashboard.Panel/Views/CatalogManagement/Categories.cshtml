@using System
@using System.Linq
@model Insurance.InventoryDashboard.Panel.Models.CategoryManagementPageViewModel
@{
    ViewData["Title"] = "مدیریت دسته‌بندی";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;
    var isEditMode = !string.IsNullOrWhiteSpace(Model.CategoryForm.CategoryId);

    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x => string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase));
    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    var parentLookup = Model.FlatCategories
        .GroupBy(x => x.Id, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);
    var childrenLookup = Model.FlatCategories
        .GroupBy(x => x.ParentCategoryId ?? string.Empty, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(x => x.Key, x => x.Select(c => c.Id).ToList(), StringComparer.OrdinalIgnoreCase);

    bool HasChildren(string categoryId) => childrenLookup.TryGetValue(categoryId ?? string.Empty, out var children) && children.Count > 0;

    int GetDepth(Insurance.InventoryDashboard.Panel.Models.CategoryNodeModel category)
    {
        var depth = 0;
        var currentParentId = category.ParentCategoryId;
        var guard = 0;
        while (!string.IsNullOrWhiteSpace(currentParentId) &&
               guard < 1024 &&
               parentLookup.TryGetValue(currentParentId, out var parent))
        {
            depth++;
            currentParentId = parent.ParentCategoryId;
            guard++;
        }

        return depth;
    }

    string GetCategoryPathById(string? categoryId)
    {
        if (string.IsNullOrWhiteSpace(categoryId) || !parentLookup.TryGetValue(categoryId, out var current))
        {
            return "-";
        }

        var parts = new List<string>();
        var guard = 0;
        while (current is not null && guard < 1024)
        {
            parts.Add(current.Name);
            if (string.IsNullOrWhiteSpace(current.ParentCategoryId) || !parentLookup.TryGetValue(current.ParentCategoryId, out current))
            {
                break;
            }
            guard++;
        }

        parts.Reverse();
        return string.Join(" / ", parts);
    }

    var hasRestrictedActions = !Can("Catalog.Category.Create", "Catalog.Category.Update", "Category.Create", "Category.Update")
        || !Can("Catalog.Category.Move", "Category.Move")
        || !Can("Catalog.Category.Activate", "Category.Activate")
        || !Can("Catalog.Category.Deactivate", "Category.Deactivate")
        || !Can("Catalog.Category.Delete", "Category.Delete")
        || !Can("Catalog.AttributeDefinition.Update", "AttributeDefinition.Update")
        || !Can("Catalog.AttributeOption.Update", "AttributeOption.Update")
        || !Can("Catalog.Category.Rule.Update", "CategoryAttributeRule.Update");
    var hasCatalogSuccess = TempData.ContainsKey("CatalogSuccess");
    var selectedCategoryPath = GetCategoryPathById(Model.SelectedCategoryId);
    var selectedCategory = Model.FlatCategories.FirstOrDefault(x => string.Equals(x.Id, Model.SelectedCategoryId, StringComparison.OrdinalIgnoreCase));
    var selectedCategoryChildrenCount = selectedCategory is null
        ? 0
        : Model.FlatCategories.Count(x => string.Equals(x.ParentCategoryId, selectedCategory.Id, StringComparison.OrdinalIgnoreCase));
    var optionCapableAttributes = Model.CategoryAttributes
        .Where(x =>
            string.Equals(x.DataType, "Option", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.DataType, "Enum", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.DataType, "Select", StringComparison.OrdinalIgnoreCase))
        .OrderBy(x => x.DisplayOrder)
        .ThenBy(x => x.Name)
        .ToList();
}

<main id="categories-page"
      class="catalog-page"
      data-selected-category-id="@Model.SelectedCategoryId"
      data-catalog-success="@hasCatalogSuccess.ToString().ToLowerInvariant()">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h1>مدیریت دسته‌بندی‌ها</h1>
                <p class="text-muted">مدیریت دسته‌بندی، ویژگی، گزینه و قوانین ویژگی دسته‌بندی.</p>
                <div class="mb-3">
                    <span class="badge badge-pill badge-outline-primary mb-1">هدف اصلی: مدیریت ساختار درختی دسته‌بندی</span>
                    <span class="badge badge-pill badge-outline-primary mb-1">عملیات فرعی: ویژگی، گزینه و قانون</span>
                    <span class="badge badge-pill badge-outline-primary mb-1">کل دسته‌ها: @Model.FlatCategories.Count</span>
                    <span class="badge badge-pill badge-outline-primary mb-1">نتیجه فیلتر: @Model.FilteredFlatCategories.Count</span>
                    @if (!string.IsNullOrWhiteSpace(Model.SelectedCategoryId))
                    {
                        <span class="badge badge-pill badge-outline-primary mb-1">مسیر انتخاب‌شده: @selectedCategoryPath</span>
                    }
                </div>
                <p class="small text-muted mb-3">
                    راهنمای سریع: ابتدا دسته را از جدول انتخاب کنید، سپس عملیات ویژگی/قانون را از تب‌های کناری انجام دهید.
                </p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) || TempData["CatalogError"] is string)
        {
            <div class="row">
                <div class="col-12">
                    <div class="alert alert-warning mb-3">
                        @(TempData["CatalogError"] as string ?? Model.ErrorMessage)
                    </div>
                </div>
            </div>
        }

        @if (TempData["CatalogSuccess"] is string successMessage)
        {
            <div class="row">
                <div class="col-12">
                    <div class="alert alert-success mb-3">@successMessage</div>
                </div>
            </div>
        }

        @await Html.PartialAsync("~/Views/Shared/_CatalogPermissionNotice.cshtml", hasRestrictedActions)

        <div class="row">
            <div class="col-12">
                <ul class="nav nav-tabs separator-tabs mb-4" role="tablist" id="category-tabs">
                    <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#category-tab" role="tab">دسته‌بندی</a></li>
                    <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#attribute-tab" role="tab">ویژگی و گزینه</a></li>
                    <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#rule-tab" role="tab">قوانین ویژگی</a></li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane show active" id="category-tab" role="tabpanel">
                        <ul class="nav nav-tabs separator-tabs mb-4" role="tablist" id="category-section-tabs">
                            <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#category-section-edit" role="tab">ایجاد / ویرایش</a></li>
                            <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#category-section-list" role="tab">لیست دسته‌بندی‌ها</a></li>
                            <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#category-section-details" role="tab">جزئیات</a></li>
                        </ul>
                        <div class="tab-content">
                            <div class="tab-pane show active" id="category-section-edit" role="tabpanel">
                        <div class="row">
                            <div class="col-12 mb-4">
                                <div class="card mb-4">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <h5 class="card-title mb-0">@(isEditMode ? "ویرایش دسته‌بندی" : "ایجاد دسته‌بندی")</h5>
                                            @if (isEditMode)
                                            {
                                                <a asp-action="Categories" class="btn btn-outline-secondary btn-xs">ایجاد جدید</a>
                                            }
                                        </div>

                                        <form asp-action="SaveCategory" method="post" id="category-upsert-form" data-loading-form data-dirty-watch>
                                            @Html.AntiForgeryToken()
                                            <input asp-for="CategoryForm.CategoryId" type="hidden" />
                                            <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                                            <div class="form-group">
                                                <label>کد دسته‌بندی</label>
                                                <input asp-for="CategoryForm.Code" class="form-control" required maxlength="64" />
                                            </div>

                                            <div class="form-group">
                                                <label>نام دسته‌بندی</label>
                                                <input asp-for="CategoryForm.Name" class="form-control" required />
                                            </div>

                                            <div class="form-group">
                                                <label>ترتیب نمایش</label>
                                                <input asp-for="CategoryForm.DisplayOrder" class="form-control" type="number" min="0" />
                                            </div>

                                            <div class="form-group">
                                                <label>دسته والد</label>
                                                <select asp-for="CategoryForm.ParentCategoryId" class="form-control js-search-select" data-placeholder="جستجوی دسته والد">
                                                    <option value="">بدون والد</option>
                                                    @foreach (var category in Model.FlatCategories.Where(x => x.Id != Model.CategoryForm.CategoryId))
                                                    {
                                                        <option value="@category.Id">@category.Name</option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="mt-3">
                                                <button class="btn btn-primary" type="submit" @(Can("Catalog.Category.Create", "Catalog.Category.Update", "Category.Create", "Category.Update") ? null : "disabled")>
                                                    @(isEditMode ? "به‌روزرسانی دسته‌بندی" : "ایجاد دسته‌بندی")
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(Model.SelectedCategoryId))
                                {
                                    <div class="card">
                                        <div class="card-body">
                                            <h5 class="card-title">انتقال دسته‌بندی</h5>
                                            <form asp-action="MoveCategory" method="post" id="move-category-form" data-loading-form data-dirty-watch>
                                                @Html.AntiForgeryToken()
                                                <input asp-for="MoveCategoryForm.CategoryId" type="hidden" value="@Model.SelectedCategoryId" />
                                                <div class="form-group">
                                                    <label>والد جدید</label>
                                                    <select asp-for="MoveCategoryForm.ParentCategoryId" class="form-control js-search-select" data-placeholder="انتخاب والد جدید">
                                                        <option value="">بدون والد</option>
                                                        @foreach (var category in Model.FlatCategories.Where(x => x.Id != Model.SelectedCategoryId))
                                                        {
                                                            <option value="@category.Id">@category.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="mt-3">
                                                    <button type="submit" class="btn btn-outline-primary" @(Can("Catalog.Category.Move", "Category.Move") ? null : "disabled")>انتقال</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                            </div>

                            <div class="tab-pane" id="category-section-list" role="tabpanel">
                        <div class="row">
                            <div class="col-12 mb-4">
                                <div class="card">
                                    <div class="card-body" id="category-list-scope">
                                        <h5 class="card-title mb-3">لیست دسته‌بندی‌ها</h5>

                                        <form method="get" asp-action="Categories" class="row mb-3" id="category-search-form" data-state-form>
                                            <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                            <div class="col-md-6 mb-2">
                                                <label class="text-muted small">جستجو</label>
                                                <input name="searchTerm" value="@Model.CategorySearchTerm" class="form-control" data-filter-label="جستجو" placeholder="نام یا کد دسته‌بندی..." />
                                            </div>
                                            <div class="col-md-2 mb-2">
                                                <label class="text-muted small">وضعیت</label>
                                                <select name="statusFilter" class="form-control" data-filter-label="وضعیت">
                                                    <option value="">همه</option>
                                                    <option value="active" selected="@(string.Equals(Model.CategoryStatusFilter, "active", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">فعال</option>
                                                    <option value="inactive" selected="@(string.Equals(Model.CategoryStatusFilter, "inactive", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">غیرفعال</option>
                                                </select>
                                            </div>
                                            <div class="col-md-2 mb-2">
                                                <label class="text-muted small">مرتب‌سازی</label>
                                                <select name="sort" class="form-control" data-filter-label="مرتب‌سازی">
                                                    <option value="">نام (صعودی)</option>
                                                    <option value="name_desc" selected="@(string.Equals(Model.CategorySort, "name_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">نام (نزولی)</option>
                                                    <option value="code_asc" selected="@(string.Equals(Model.CategorySort, "code_asc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">کد (صعودی)</option>
                                                    <option value="code_desc" selected="@(string.Equals(Model.CategorySort, "code_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">کد (نزولی)</option>
                                                    <option value="displayorder_asc" selected="@(string.Equals(Model.CategorySort, "displayorder_asc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">ترتیب نمایش (صعودی)</option>
                                                    <option value="displayorder_desc" selected="@(string.Equals(Model.CategorySort, "displayorder_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">ترتیب نمایش (نزولی)</option>
                                                    <option value="status_asc" selected="@(string.Equals(Model.CategorySort, "status_asc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">وضعیت (فعال اول)</option>
                                                    <option value="status_desc" selected="@(string.Equals(Model.CategorySort, "status_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">وضعیت (غیرفعال اول)</option>
                                                </select>
                                            </div>
                                            <div class="col-md-1 mb-2">
                                                <label class="text-muted small">تعداد</label>
                                                <select name="pageSize" class="form-control" data-filter-label="تعداد">
                                                    @foreach (var size in Model.CategoryPageSizeOptions)
                                                    {
                                                        <option value="@size" selected="@(size == Model.CategoryPageSize ? "selected" : null)">@size</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-md-1 mb-2 d-flex align-items-end">
                                                <button type="submit" class="btn btn-primary btn-block">اعمال</button>
                                            </div>
                                        </form>

                                        <div class="d-flex align-items-center justify-content-between flex-wrap mb-2">
                                            <div class="btn-group btn-group-sm mb-2">
                                                <button type="button" class="btn btn-outline-secondary" data-tree-expand-all>بازکردن همه</button>
                                                <button type="button" class="btn btn-outline-secondary" data-tree-collapse-all>بستن همه</button>
                                            </div>
                                            <span class="small text-muted mb-2">برای عملیات گروهی، چند ردیف را انتخاب کنید.</span>
                                        </div>

                                        <form asp-action="ApplyCategoryBulkAction"
                                              method="post"
                                              class="form-inline mb-3"
                                              data-loading-form
                                              data-bulk-form
                                              data-bulk-scope="#category-list-scope">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="selectedIds" data-bulk-target />
                                            <input type="hidden" name="bulkAction" data-bulk-action-input />
                                            <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                            <input type="hidden" name="searchTerm" value="@Model.CategorySearchTerm" />
                                            <input type="hidden" name="statusFilter" value="@Model.CategoryStatusFilter" />
                                            <input type="hidden" name="sort" value="@Model.CategorySort" />
                                            <input type="hidden" name="page" value="@Model.CategoryPage" />
                                            <input type="hidden" name="pageSize" value="@Model.CategoryPageSize" />
                                            <div class="small text-muted mr-2 mb-2">
                                                تعداد انتخاب‌شده: <span data-bulk-count>0</span>
                                            </div>
                                            <div class="btn-group btn-group-sm mb-2">
                                                <button type="submit"
                                                        class="btn btn-outline-success btn-xs"
                                                        data-bulk-action="activate"
                                                        data-bulk-permission="@(Can("Catalog.Category.Activate", "Category.Activate") ? "allowed" : "denied")"
                                                        data-confirm-title="فعال‌سازی گروهی دسته‌بندی"
                                                        data-confirm="دسته‌بندی‌های انتخاب‌شده فعال شوند؟"
                                                        disabled
                                                        @(Can("Catalog.Category.Activate", "Category.Activate") ? null : "disabled")>
                                                    فعال‌سازی گروهی
                                                </button>
                                                <button type="submit"
                                                        class="btn btn-outline-warning btn-xs"
                                                        data-bulk-action="deactivate"
                                                        data-bulk-permission="@(Can("Catalog.Category.Deactivate", "Category.Deactivate") ? "allowed" : "denied")"
                                                        data-confirm-title="غیرفعال‌سازی گروهی دسته‌بندی"
                                                        data-confirm="دسته‌بندی‌های انتخاب‌شده غیرفعال شوند؟"
                                                        disabled
                                                        @(Can("Catalog.Category.Deactivate", "Category.Deactivate") ? null : "disabled")>
                                                    غیرفعال‌سازی گروهی
                                                </button>
                                                <button type="submit"
                                                        class="btn btn-outline-danger btn-xs"
                                                        data-bulk-action="delete"
                                                        data-bulk-permission="@(Can("Catalog.Category.Delete", "Category.Delete") ? "allowed" : "denied")"
                                                        data-confirm-title="حذف گروهی دسته‌بندی"
                                                        data-confirm="دسته‌بندی‌های انتخاب‌شده حذف شوند؟ این عملیات غیرقابل بازگشت است."
                                                        disabled
                                                        @(Can("Catalog.Category.Delete", "Category.Delete") ? null : "disabled")>
                                                    حذف گروهی
                                                </button>
                                            </div>
                                        </form>

                                        <div class="table-responsive">
                                            <table class="table table-sm table-striped">
                                                <thead>
                                                    <tr>
                                                        <th>
                                                            <input type="checkbox" data-bulk-toggle aria-label="انتخاب همه" />
                                                        </th>
                                                        <th>کد</th>
                                                        <th>نام</th>
                                                        <th>وضعیت</th>
                                                        <th>مسیر</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @if (Model.FilteredFlatCategories.Count == 0)
                                                    {
                                                        <tr>
                                                            <td colspan="6">
                                                                <div class="alert alert-light my-2">
                                                                    <h6>رکوردی یافت نشد</h6>
                                                                    <p class="mb-0 text-muted">فیلتر را تغییر دهید یا دسته‌بندی جدید بسازید.</p>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var category in Model.FilteredFlatCategories)
                                                        {
                                                            var parentName = Model.FlatCategories.FirstOrDefault(x => x.Id == category.ParentCategoryId)?.Name;
                                                            var depth = GetDepth(category);
                                                            var hasChildren = HasChildren(category.Id);
                                                            var childCount = Model.FlatCategories.Count(x => string.Equals(x.ParentCategoryId, category.Id, StringComparison.OrdinalIgnoreCase));
                                                            <tr class="@(string.Equals(category.Id, Model.SelectedCategoryId, StringComparison.OrdinalIgnoreCase) ? "table-primary" : null)"
                                                                data-category-row
                                                                data-category-id="@category.Id"
                                                                data-parent-id="@(category.ParentCategoryId ?? string.Empty)"
                                                                data-has-children="@(hasChildren ? "true" : "false")">
                                                                <td>
                                                                    <input type="checkbox" data-bulk-row value="@category.Id" aria-label="انتخاب @category.Name" />
                                                                </td>
                                                                <td><span class="text-monospace">@category.Code</span></td>
                                                                <td>
                                                                    <span class="d-inline-block">
                                                                        @Html.Raw(string.Concat(Enumerable.Repeat("&nbsp;", depth * 4)))
                                                                        @if (hasChildren)
                                                                        {
                                                                            <button type="button"
                                                                                    class="btn btn-link btn-xs p-0 mr-1"
                                                                                    data-category-toggle="@category.Id"
                                                                                    aria-label="toggle">
                                                                                <span data-toggle-icon>-</span>
                                                                            </button>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span class="text-muted small mr-1">.</span>
                                                                        }
                                                                        <span>@category.Name</span>
                                                                        @if (childCount > 0)
                                                                        {
                                                                            <span class="badge badge-pill badge-outline-primary ml-1">@childCount زیرمجموعه</span>
                                                                        }
                                                                    </span>
                                                                </td>
                                                                <td>
                                                                    <span class="badge badge-pill @(category.IsActive ? "badge-primary" : "badge-secondary")">
                                                                        @(category.IsActive ? "فعال" : "غیرفعال")
                                                                    </span>
                                                                </td>
                                                                <td><span class="small text-muted">@GetCategoryPathById(category.Id)</span></td>
                                                                <td class="text-nowrap">
                                                                    <a class="btn btn-outline-primary btn-xs"
                                                                       asp-action="Categories"
                                                                       asp-route-categoryId="@category.Id"
                                                                       asp-route-searchTerm="@Model.CategorySearchTerm"
                                                                       asp-route-statusFilter="@Model.CategoryStatusFilter"
                                                                       asp-route-sort="@Model.CategorySort"
                                                                       asp-route-page="@Model.CategoryPage"
                                                                       asp-route-pageSize="@Model.CategoryPageSize">مستقیم</a>
                                                                    @if (category.IsActive)
                                                                    {
                                                                        <form asp-action="DeactivateCategory" method="post" class="d-inline" data-loading-form>
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="categoryId" value="@category.Id" />
                                                                            <button type="submit" class="btn btn-outline-warning btn-xs" @(Can("Catalog.Category.Deactivate", "Category.Deactivate") ? null : "disabled")>غیرفعال</button>
                                                                        </form>
                                                                    }
                                                                    else
                                                                    {
                                                                        <form asp-action="ActivateCategory" method="post" class="d-inline" data-loading-form>
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="categoryId" value="@category.Id" />
                                                                            <button type="submit" class="btn btn-outline-success btn-xs" @(Can("Catalog.Category.Activate", "Category.Activate") ? null : "disabled")>فعال</button>
                                                                        </form>
                                                                    }
                                                                    <form asp-action="DeleteCategory" method="post" class="d-inline" data-loading-form>
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="categoryId" value="@category.Id" />
                                                                        <button type="submit" class="btn btn-outline-danger btn-xs" data-confirm-title="حذف دسته‌بندی" data-confirm="این دسته‌بندی حذف شود؟ این عملیات قابل بازگشت نیست." @(Can("Catalog.Category.Delete", "Category.Delete") ? null : "disabled")>حذف</button>
                                                                    </form>
                                                                </td>
                                                            </tr>
                                                        }
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                        @if (Model.CategoryTotalPages > 1)
                                        {
                                            <nav class="mt-3">
                                                <ul class="pagination pagination-sm mb-0">
                                                    @for (var i = 1; i <= Model.CategoryTotalPages; i++)
                                                    {
                                                        <li class="page-item @(i == Model.CategoryPage ? "active" : null)">
                                                            <a class="page-link"
                                                               asp-action="Categories"
                                                               asp-route-categoryId="@Model.SelectedCategoryId"
                                                               asp-route-searchTerm="@Model.CategorySearchTerm"
                                                               asp-route-statusFilter="@Model.CategoryStatusFilter"
