                                            <div class="form-group">
                                                <label>دسته‌بندی</label>
                                                <select asp-for="AssignForm.CategoryId" class="form-control js-search-select" data-placeholder="انتخاب آخرین سطح دسته‌بندی">
                                                    <option value="">انتخاب آخرین سطح دسته‌بندی</option>
                                                    @foreach (var category in Model.LeafCategories)
                                                    {
                                                        <option value="@category.Id" selected="@(category.Id == Model.SelectedCategoryId ? "selected" : null)">@category.Name</option>
                                                    }
                                                </select>
                                                <small class="form-text text-muted">فقط آخرین سطح دسته‌بندی برای اختصاص اتریبیوت قابل انتخاب است.</small>
