                                                                        <input type="hidden" name="categoryId" value="@category.Id" />
                                                                        <button type="submit" class="btn btn-outline-danger btn-xs" data-confirm-title="@UiText["catalog.categories.deleteTitle"]" data-confirm="@UiText["catalog.categories.deleteConfirm"]" @(Can("Catalog.Category.Delete", "Category.Delete") ? null : "disabled")>@UiText["common.delete"]</button>
                                                                    </form>
                                                                </td>
                                                            </tr>
                                                        }
                                                    }
                                                </tbody>
                                            </table>
