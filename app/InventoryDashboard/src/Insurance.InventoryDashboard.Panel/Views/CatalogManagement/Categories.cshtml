            var formulaCreateUrl = '@Url.Action("CreateVariantNameFormula", "CategoryManagement")';
            var formulaUpdateUrl = '@Url.Action("UpdateVariantNameFormula", "CategoryManagement")';
            var formulaForm = document.getElementById('variant-name-formula-form');
            var formulaFormTitle = document.getElementById('formula-form-title');
            var formulaSubmitBtn = document.getElementById('formula-submit-btn');
            var formulaResetBtn = document.getElementById('formula-reset-btn');
            var formulaEditCancel = document.getElementById('formula-edit-cancel');
            var formulaIdField = document.getElementById('VariantNameFormulaForm_FormulaId');
            var formulaNameField = document.getElementById('VariantNameFormulaForm_Name');
            var formulaSeparatorField = document.getElementById('VariantNameFormulaForm_Separator');
            var formulaDisplayOrderField = document.getElementById('VariantNameFormulaForm_DisplayOrder');
            var formulaIsActiveField = document.getElementById('VariantNameFormulaForm_IsActive');
            var formulaPartsJsonField = document.getElementById('VariantNameFormulaForm_PartsJson');
            var formulaAttributePicker = document.getElementById('formula-attribute-picker');
            var formulaAddPartBtn = document.getElementById('formula-add-part-btn');
            var formulaPartsList = document.getElementById('formula-parts-list');
            var formulaPartsEmpty = document.getElementById('formula-parts-empty');
            var formulaState = { parts: [] };

            function getFormulaById(formulaId) {
                if (!formulaId || !Array.isArray(formulaRegistry)) {
                    return null;
                }

                for (var i = 0; i < formulaRegistry.length; i++) {
                    if (String(formulaRegistry[i].formulaId || '').toLowerCase() === String(formulaId).toLowerCase()) {
                        return formulaRegistry[i];
                    }
                }

                return null;
            }

            function getFormulaAttribute(attributeId) {
                if (!attributeId || !Array.isArray(formulaAttributeRegistry)) {
                    return null;
                }

                for (var i = 0; i < formulaAttributeRegistry.length; i++) {
                    if (String(formulaAttributeRegistry[i].attributeId || '').toLowerCase() === String(attributeId).toLowerCase()) {
                        return formulaAttributeRegistry[i];
                    }
                }

                return null;
            }

            function updateFormulaSubmitState() {
                if (!formulaSubmitBtn) {
                    return;
                }

                formulaSubmitBtn.disabled = !canManageFormulas || formulaState.parts.length === 0;
            }

            function syncFormulaPartsJson() {
                if (!formulaPartsJsonField) {
                    return;
                }

                formulaPartsJsonField.value = JSON.stringify(formulaState.parts);
            }

            function getSelectedFormulaAttributeId() {
                if (!formulaAttributePicker) {
                    return '';
                }

                if (window.jQuery) {
                    var selectedValue = window.jQuery(formulaAttributePicker).val();
                    if (Array.isArray(selectedValue)) {
                        return selectedValue.length > 0 ? (selectedValue[0] || '') : '';
                    }
                    if (selectedValue) {
                        return selectedValue;
                    }
                }

                return formulaAttributePicker.value || '';
            }

            function setFormulaMode(isEditMode) {
                if (formulaForm) {
                    formulaForm.action = isEditMode ? formulaUpdateUrl : formulaCreateUrl;
                }

                if (formulaFormTitle) {
                    formulaFormTitle.textContent = isEditMode ? @JsonSerializer.Serialize(UiText["catalog.categories.variantFormulaEdit"]) : @JsonSerializer.Serialize(UiText["catalog.categories.variantFormulaCreate"]);
                }

                if (formulaSubmitBtn) {
                    formulaSubmitBtn.textContent = isEditMode ? categoryTexts.formulaUpdate : categoryTexts.formulaSave;
                }
            }

            function toFormulaSeparatorSelectValue(separator) {
                return separator === '' ? '__none' : (separator || ' ');
            }

            function renderFormulaParts() {
                if (!formulaPartsList || !formulaPartsEmpty) {
                    return;
                }

                formulaPartsList.innerHTML = '';
                if (formulaState.parts.length === 0) {
                    formulaPartsEmpty.style.display = '';
                    updateFormulaSubmitState();
                    syncFormulaPartsJson();
                    return;
                }

                formulaPartsEmpty.style.display = 'none';
                formulaState.parts.forEach(function (attributeId, index) {
                    var attribute = getFormulaAttribute(attributeId);
                    var item = document.createElement('div');
                    item.className = 'list-group-item';
                    item.innerHTML = ''
                        + '<div class="d-flex justify-content-between align-items-center flex-wrap">'
                        + '<div class="pr-2 mb-2 mb-md-0">'
                        + '<div class="font-weight-bold">' + escapeHtml(attribute ? attribute.attributeName : attributeId) + '</div>'
                        + '<div class="small text-muted">' + escapeHtml(attribute ? attribute.attributeCode : '') + (attribute && attribute.isInherited ? categoryTexts.formulaInheritedSuffix : '') + '</div>'
                        + '</div>'
                        + '<div class="btn-group btn-group-sm" role="group">'
                        + '<button type="button" class="btn btn-outline-secondary formula-part-action" data-formula-action="up" data-formula-index="' + index + '"' + (index === 0 ? ' disabled' : '') + '>↑</button>'
                        + '<button type="button" class="btn btn-outline-secondary formula-part-action" data-formula-action="down" data-formula-index="' + index + '"' + (index === formulaState.parts.length - 1 ? ' disabled' : '') + '>↓</button>'
                        + '<button type="button" class="btn btn-outline-danger formula-part-action" data-formula-action="remove" data-formula-index="' + index + '">�</button>'
                        + '</div>'
                        + '</div>';
                    formulaPartsList.appendChild(item);
                });

                updateFormulaSubmitState();
                syncFormulaPartsJson();
            }

            function resetFormulaForm() {
                if (formulaIdField) formulaIdField.value = '';
                if (formulaNameField) formulaNameField.value = '';
                if (formulaSeparatorField) formulaSeparatorField.value = ' ';
                if (formulaDisplayOrderField) formulaDisplayOrderField.value = '0';
                if (formulaIsActiveField) formulaIsActiveField.checked = true;
                if (formulaAttributePicker) formulaAttributePicker.value = '';
                if (formulaAttributePicker && window.jQuery) {
                    window.jQuery(formulaAttributePicker).val('').trigger('change');
                }
                formulaState.parts = [];
                setFormulaMode(false);
                renderFormulaParts();
                if (formulaForm) {
                    formulaForm.dataset.isDirty = 'false';
                }
            }

            function loadFormulaIntoForm(formula) {
                if (!formula) {
                    return;
                }

                if (formulaIdField) formulaIdField.value = formula.formulaId || '';
                if (formulaNameField) formulaNameField.value = formula.name || '';
                if (formulaSeparatorField) formulaSeparatorField.value = toFormulaSeparatorSelectValue(formula.separator);
                if (formulaDisplayOrderField) formulaDisplayOrderField.value = formula.displayOrder != null ? formula.displayOrder : '0';
                if (formulaIsActiveField) formulaIsActiveField.checked = !!formula.isActive;
                formulaState.parts = (formula.parts || []).map(function (part) { return part.attributeId; }).filter(function (partId) { return !!partId; });
                setFormulaMode(true);
                renderFormulaParts();
                if (formulaForm) {
                    formulaForm.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            }

            function addFormulaPart(attributeId) {
                if (!attributeId) {
                    return;
                }

                if (formulaState.parts.some(function (partId) { return String(partId).toLowerCase() === String(attributeId).toLowerCase(); })) {
                    return;
                }

                formulaState.parts.push(attributeId);
                if (formulaAttributePicker) {
                    formulaAttributePicker.value = '';
                    if (window.jQuery) {
                        window.jQuery(formulaAttributePicker).val('').trigger('change');
                    }
                }
                renderFormulaParts();
            }

            function moveFormulaPart(index, delta) {
                var targetIndex = index + delta;
                if (targetIndex < 0 || targetIndex >= formulaState.parts.length) {
                    return;
                }

                var swapped = formulaState.parts[index];
                formulaState.parts[index] = formulaState.parts[targetIndex];
                formulaState.parts[targetIndex] = swapped;
                renderFormulaParts();
            }

            function removeFormulaPart(index) {
                if (index < 0 || index >= formulaState.parts.length) {
                    return;
                }

                formulaState.parts.splice(index, 1);
                renderFormulaParts();
            }

            if (formulaPartsJsonField && formulaPartsJsonField.value) {
                try {
                    var initialParts = JSON.parse(formulaPartsJsonField.value || '[]');
                    if (Array.isArray(initialParts)) {
                        formulaState.parts = initialParts.filter(function (partId) { return !!partId; });
                    }
                } catch (e) {
                    formulaState.parts = [];
                }
            }

            if (formulaIdField && formulaIdField.value) {
                setFormulaMode(true);
            }
            renderFormulaParts();

            if (formulaAddPartBtn) {
                formulaAddPartBtn.addEventListener('click', function () {
                    var selectedAttributeId = getSelectedFormulaAttributeId();
                    addFormulaPart(selectedAttributeId);
                });
            }

            if (formulaAttributePicker) {
                formulaAttributePicker.addEventListener('change', function () {
                    var selectedAttributeId = getSelectedFormulaAttributeId();
                    if (selectedAttributeId) {
                        addFormulaPart(selectedAttributeId);
                    }
                });

                if (window.jQuery) {
                    window.jQuery(formulaAttributePicker).on('select2:select', function () {
                        var selectedAttributeId = getSelectedFormulaAttributeId();
                        if (selectedAttributeId) {
                            addFormulaPart(selectedAttributeId);
                        }
                    });
                }
            }

            document.addEventListener('click', function (event) {
                var partAction = event.target.closest('.formula-part-action');
                if (!partAction) {
                    return;
                }

                var index = parseInt(partAction.getAttribute('data-formula-index') || '-1', 10);
                var action = partAction.getAttribute('data-formula-action') || '';
                if (action === 'up') {
                    moveFormulaPart(index, -1);
                } else if (action === 'down') {
                    moveFormulaPart(index, 1);
                } else if (action === 'remove') {
                    removeFormulaPart(index);
                }
            });

            document.querySelectorAll('.formula-edit-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    var formula = getFormulaById(button.getAttribute('data-formula-id') || '');
                    if (!formula) {
                        return;
                    }

                    localStorage.setItem(formulaSectionTabKey, '#formula-section-edit');
                    loadFormulaIntoForm(formula);
                });
            });

            document.querySelectorAll('.formula-parts-manage-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    var formula = getFormulaById(button.getAttribute('data-formula-id') || '');
                    if (!formula) {
                        return;
                    }

                    localStorage.setItem(formulaSectionTabKey, '#formula-section-edit');
                    loadFormulaIntoForm(formula);
                });
            });

            document.querySelectorAll('.formula-part-manage-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    var formula = getFormulaById(button.getAttribute('data-formula-id') || '');
                    var partIndex = parseInt(button.getAttribute('data-formula-part-index') || '-1', 10);
                    if (!formula) {
                        return;
                    }

                    localStorage.setItem(formulaSectionTabKey, '#formula-section-edit');
                    loadFormulaIntoForm(formula);

                    if (!isNaN(partIndex) && partIndex >= 0 && formulaPartsList) {
                        var targetItem = formulaPartsList.querySelector('[data-formula-index="' + partIndex + '"]');
                        if (targetItem && targetItem.scrollIntoView) {
                            targetItem.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }
                    }
                });
            });

            document.querySelectorAll('.formula-part-remove-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    var formula = getFormulaById(button.getAttribute('data-formula-id') || '');
                    var partIndex = parseInt(button.getAttribute('data-formula-part-index') || '-1', 10);
                    if (!formula || isNaN(partIndex) || partIndex < 0) {
                        return;
                    }

                    localStorage.setItem(formulaSectionTabKey, '#formula-section-edit');
                    loadFormulaIntoForm(formula);
                    removeFormulaPart(partIndex);
                    if (formulaForm && formulaForm.scrollIntoView) {
                        formulaForm.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                });
            });

            document.addEventListener('click', function (event) {
                var formulaButton = event.target.closest('.formula-edit-btn, .formula-parts-manage-btn, .formula-part-manage-btn, .formula-part-remove-btn');
                if (!formulaButton) {
                    return;
                }

                event.preventDefault();
                event.stopImmediatePropagation();

                var formula = getFormulaById(formulaButton.getAttribute('data-formula-id') || '');
                if (!formula) {
                    return;
                }

                localStorage.setItem(formulaSectionTabKey, '#formula-section-edit');
                loadFormulaIntoForm(formula);

                var partIndex = parseInt(formulaButton.getAttribute('data-formula-part-index') || '-1', 10);
                if (formulaButton.classList.contains('formula-part-remove-btn') && !isNaN(partIndex) && partIndex >= 0) {
                    removeFormulaPart(partIndex);
                    if (formulaForm && formulaForm.scrollIntoView) {
                        formulaForm.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                    return;
                }

                if (formulaButton.classList.contains('formula-part-manage-btn') && !isNaN(partIndex) && partIndex >= 0 && formulaPartsList) {
                    var targetItem = formulaPartsList.querySelector('[data-formula-index="' + partIndex + '"]');
                    if (targetItem && targetItem.scrollIntoView) {
                        targetItem.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                }
            }, true);

            function resetFormulaEditor() {
                resetFormulaForm();
                if (formulaForm) {
                    formulaForm.action = formulaCreateUrl;
                }
            }

            if (formulaResetBtn) {
                formulaResetBtn.addEventListener('click', resetFormulaEditor);
            }

            if (formulaEditCancel) {
                formulaEditCancel.addEventListener('click', resetFormulaEditor);
            }

            if (formulaForm) {
                formulaForm.addEventListener('submit', function (event) {
                    var selectedAttributeId = getSelectedFormulaAttributeId();
                    if (selectedAttributeId) {
                        addFormulaPart(selectedAttributeId);
                    }

                    syncFormulaPartsJson();
                    if (formulaState.parts.length === 0) {
                        event.preventDefault();
                        event.stopImmediatePropagation();
                        if (formulaPartsEmpty) {
                            formulaPartsEmpty.style.display = '';
                            formulaPartsEmpty.classList.remove('alert-light');
                            formulaPartsEmpty.classList.add('alert-warning');
                            formulaPartsEmpty.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }
                    }
                });
            }

            var ruleSectionEditTab = document.querySelector('#rule-section-tabs .nav-link[href="#rule-section-edit"]');
            var ruleInlineEditCard = document.getElementById('rule-inline-edit-card');
            var ruleInlineEditCancel = document.getElementById('rule-inline-edit-cancel');
            var ruleEditSelect = document.getElementById('RuleForm_AttributeId');
            var ruleEditDisplayOrder = document.getElementById('RuleForm_DisplayOrder');
            var ruleEditRequired = document.getElementById('RuleForm_IsRequired');
            var ruleEditVariant = document.getElementById('RuleForm_IsVariant');
            var ruleEditCodeCovered = document.getElementById('RuleForm_IsVariantCodeCovered');
            var ruleEditOverridden = document.getElementById('RuleForm_IsOverridden');
            var ruleEditActive = document.getElementById('RuleForm_IsActive');
            var ruleEditCategoryId = document.getElementById('RuleForm_CategoryId');

            function applyRuleOptionToEditForm() {
                if (!ruleEditSelect) {
                    return;
                }

                var selected = ruleEditSelect.options[ruleEditSelect.selectedIndex];
                if (!selected) {
                    return;
                }

                if (ruleEditDisplayOrder) ruleEditDisplayOrder.value = selected.getAttribute('data-rule-display-order') || '0';
                if (ruleEditRequired) ruleEditRequired.checked = (selected.getAttribute('data-rule-required') || '').toLowerCase() === 'true';
                if (ruleEditVariant) ruleEditVariant.checked = (selected.getAttribute('data-rule-variant') || '').toLowerCase() === 'true';
                if (ruleEditCodeCovered) ruleEditCodeCovered.checked = (selected.getAttribute('data-rule-code-covered') || '').toLowerCase() === 'true';
                if (ruleEditOverridden) ruleEditOverridden.checked = (selected.getAttribute('data-rule-overridden') || '').toLowerCase() === 'true';
                if (ruleEditActive) ruleEditActive.checked = (selected.getAttribute('data-rule-active') || '').toLowerCase() === 'true';
            }

            if (ruleEditSelect) {
                ruleEditSelect.addEventListener('change', applyRuleOptionToEditForm);
                applyRuleOptionToEditForm();
            }

            function openRuleInlineEdit(button) {
                if (!button) {
                    return;
                }

                localStorage.setItem(ruleSectionTabKey, '#rule-section-edit');
                if (ruleSectionEditTab && window.jQuery) {
                    window.jQuery(ruleSectionEditTab).tab('show');
                }

                if (ruleInlineEditCard) {
                    ruleInlineEditCard.style.display = '';
                }

                if (ruleEditCategoryId) {
                    ruleEditCategoryId.value = button.getAttribute('data-rule-category-id') || '@Model.SelectedCategoryId';
                }
                if (ruleEditSelect) {
                    ruleEditSelect.value = button.getAttribute('data-rule-attribute-id') || '';
                }
                if (ruleEditDisplayOrder) {
                    ruleEditDisplayOrder.value = button.getAttribute('data-rule-display-order') || '0';
                }
                if (ruleEditRequired) {
                    ruleEditRequired.checked = (button.getAttribute('data-rule-required') || '').toLowerCase() === 'true';
                }
                if (ruleEditVariant) {
                    ruleEditVariant.checked = (button.getAttribute('data-rule-variant') || '').toLowerCase() === 'true';
                }
                if (ruleEditCodeCovered) {
                    ruleEditCodeCovered.checked = (button.getAttribute('data-rule-code-covered') || '').toLowerCase() === 'true';
                }
                if (ruleEditOverridden) {
                    ruleEditOverridden.checked = (button.getAttribute('data-rule-overridden') || '').toLowerCase() === 'true';
                }
                if (ruleEditActive) {
                    ruleEditActive.checked = (button.getAttribute('data-rule-active') || '').toLowerCase() === 'true';
                }

                if (ruleEditSelect) {
                    ruleEditSelect.dispatchEvent(new Event('change'));
                    ruleEditSelect.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            }

            function closeRuleInlineEdit() {
                if (!ruleInlineEditCard) {
                    return;
                }

                ruleInlineEditCard.style.display = 'none';
                if (ruleEditSelect) {
                    ruleEditSelect.selectedIndex = 0;
                    ruleEditSelect.dispatchEvent(new Event('change'));
                }
            }

            document.querySelectorAll('.rule-inline-edit-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    openRuleInlineEdit(button);
                });
            });

            document.addEventListener('click', function (event) {
                var button = event.target.closest('.rule-inline-edit-btn');
                if (!button) {
                    return;
                }

                event.preventDefault();
                event.stopImmediatePropagation();
                openRuleInlineEdit(button);
            }, true);

            if (ruleInlineEditCancel) {
                ruleInlineEditCancel.addEventListener('click', closeRuleInlineEdit);
            }

            var assignAttributeToCategoryForm = document.getElementById('assign-attribute-to-category-form');
            if (assignAttributeToCategoryForm) {
                assignAttributeToCategoryForm.addEventListener('submit', function () {
                    localStorage.setItem(ruleSectionTabKey, '#rule-section-edit');
                });
            }

            var updateCategoryAttributeRuleForm = document.getElementById('update-category-attribute-rule-form');
            if (updateCategoryAttributeRuleForm) {
                updateCategoryAttributeRuleForm.addEventListener('submit', function () {
                    localStorage.setItem(ruleSectionTabKey, '#rule-section-edit');
                });
            }

            document.querySelectorAll('form[action$="RemoveCategoryAttributeRule"], form[action$="ActivateCategoryAttributeRule"], form[action$="DeactivateCategoryAttributeRule"]').forEach(function (form) {
                form.addEventListener('submit', function () {
                    localStorage.setItem(ruleSectionTabKey, '#rule-section-list');
                });
            });

            document.querySelectorAll('form[data-loading-form]').forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (form.id && watchedFormIds.indexOf(form.id) >= 0) {
                        saveFormDraft(form);
                        localStorage.setItem(submittedFormKey, getFormDraftKey(form));
                    }

                    var submitButtons = form.querySelectorAll('button[type="submit"]');
                    submitButtons.forEach(function (button) {
                        button.setAttribute('disabled', 'disabled');
                    });
                });
            });

            watchedForms.forEach(function (form) {
                form.querySelectorAll('input, textarea, select').forEach(function (field) {
                    field.addEventListener('change', function () {
                        saveFormDraft(form);
                    });
                    field.addEventListener('input', function () {
                        saveFormDraft(form);
                    });
                });
            });

            document.querySelectorAll('form[data-dirty-watch]').forEach(function (form) {
                form.querySelectorAll('input, textarea, select').forEach(function (field) {
                    field.addEventListener('change', function () {
                        form.dataset.isDirty = 'true';
                        dirtyForms.add(form);
                    });
                    field.addEventListener('input', function () {
                        form.dataset.isDirty = 'true';
                        dirtyForms.add(form);
                    });
                });

                form.addEventListener('submit', function () {
                    form.dataset.isDirty = 'false';
                    dirtyForms.delete(form);
                });
            });

            window.addEventListener('beforeunload', function (event) {
                var hasDirty = Array.from(dirtyForms).some(function (form) {
                    return form.dataset.isDirty === 'true';
                });

                if (!hasDirty) {
                    return;
                }

                event.preventDefault();
                event.returnValue = '';
            });
        })();
    </script>
    <script>
        (function () {
            var optionEndpoints = {
                list: '@Url.Action("GetAttributeOptions", "CategoryManagement")',
                add: '@Url.Action("AddAttributeOptionAjax", "CategoryManagement")',
                update: '@Url.Action("UpdateAttributeOptionAjax", "CategoryManagement")',
                delete: '@Url.Action("DeleteAttributeOptionAjax", "CategoryManagement")'
            };
            var optionTexts = {
                none: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.none"])),
                active: @Html.Raw(JsonSerializer.Serialize(UiText["common.active"])),
                inactive: @Html.Raw(JsonSerializer.Serialize(UiText["common.inactive"])),
                edit: @Html.Raw(JsonSerializer.Serialize(UiText["common.edit"])),
                delete: @Html.Raw(JsonSerializer.Serialize(UiText["common.delete"])),
                loading: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.loading"])),
                loadFailed: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.loadFailed"])),
                unavailable: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.serverUnavailable"])),
                unreadable: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.serverResponseUnreadable"])),
                submitting: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.submitting"])),
                submitFailed: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.submitFailed"])),
                submitSucceeded: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.submitSucceeded"])),
                deleteConfirm: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.deleteConfirm"])),
                deleting: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.deleting"])),
                deleteFailed: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.deleteFailed"])),
                deleteSucceeded: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.deleteSucceeded"]))
            };

            function showBootstrapTab(selector) {
                var link = document.querySelector(selector);
                if (!link) return;
                if (window.jQuery && window.jQuery.fn && window.jQuery.fn.tab) {
                    window.jQuery(link).tab('show');
                    return;
                }

                var target = document.querySelector(link.getAttribute('href') || '');
                var container = link.closest('.nav');
                if (container) {
                    container.querySelectorAll('.nav-link').forEach(function (item) { item.classList.remove('active'); });
                }
                link.classList.add('active');
                if (target && target.parentElement) {
                    target.parentElement.querySelectorAll(':scope > .tab-pane').forEach(function (pane) {
                        pane.classList.remove('show', 'active');
                    });
                    target.classList.add('show', 'active');
                }
            }

            function escapeHtml(value) {
                return String(value || '').replace(/[&<>"']/g, function (char) {
                    return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[char];
                });
            }

            function escapeSelector(value) {
                if (window.CSS && typeof window.CSS.escape === 'function') {
                    return window.CSS.escape(value || '');
                }

                return String(value || '').replace(/["\\]/g, '\\$&');
            }

            function getJson(response) {
                return response.json().catch(function () {
                    return { isSuccess: false, errorMessage: optionTexts.unreadable };
                });
            }

            function setOptionsMessage(row, message, isError) {
                var box = row ? row.querySelector('[data-options-message]') : null;
                if (!box) return;
                box.className = 'attribute-options-message small mb-2 ' + (isError ? 'text-danger' : 'text-success');
                box.textContent = message || '';
            }

            function renderOptions(row, options) {
                var tbody = row ? row.querySelector('[data-options-tbody]') : null;
                if (!tbody) return;
                if (!options || !options.length) {
                    tbody.innerHTML = '<tr><td colspan="5">' + optionTexts.none + '</td></tr>';
                    return;
                }

                tbody.innerHTML = options.slice().sort(function (a, b) {
                    return (a.displayOrder || a.DisplayOrder || 0) - (b.displayOrder || b.DisplayOrder || 0)
                        || String(a.optionName || a.OptionName || '').localeCompare(String(b.optionName || b.OptionName || ''));
                }).map(function (option) {
                    var id = escapeHtml(option.id || option.Id);
                    var name = escapeHtml(option.optionName || option.OptionName);
                    var value = escapeHtml(option.optionValue || option.OptionValue);
                    var order = option.displayOrder || option.DisplayOrder || 0;
                    var isActive = option.isActive !== undefined ? option.isActive : option.IsActive;
                    return '<tr>'
                        + '<td><span class="text-monospace">' + value + '</span></td>'
                        + '<td>' + name + '</td>'
                        + '<td>' + order + '</td>'
                        + '<td>' + (isActive ? optionTexts.active : optionTexts.inactive) + '</td>'
                        + '<td class="text-nowrap">'
                        + '<button type="button" class="btn btn-outline-secondary btn-xs option-edit-btn" data-option-id="' + id + '" data-option-name="' + name + '" data-option-value="' + value + '" data-display-order="' + order + '">' + optionTexts.edit + '</button> '
                        + '<button type="button" class="btn btn-outline-danger btn-xs ajax-option-delete-btn" data-option-id="' + id + '">' + optionTexts.delete + '</button>'
                        + '</td>'
                        + '</tr>';
                }).join('');
            }

            function loadOptions(row, attributeId) {
                setOptionsMessage(row, optionTexts.loading, false);
                return fetch(optionEndpoints.list + '?attributeId=' + encodeURIComponent(attributeId), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(getJson)
                    .then(function (payload) {
                        if (!payload.isSuccess) {
                            setOptionsMessage(row, payload.errorMessage || optionTexts.loadFailed, true);
                            return;
                        }
                        renderOptions(row, payload.items || []);
                        setOptionsMessage(row, '', false);
                    })
                    .catch(function () {
                        setOptionsMessage(row, optionTexts.unavailable, true);
                    });
            }

            function submitOptionForm(form, url) {
                var row = form.closest('.attribute-options-row');
                var buttons = form.querySelectorAll('button[type="submit"]');
                buttons.forEach(function (button) { button.disabled = true; });
                setOptionsMessage(row, optionTexts.submitting, false);
                return fetch(url, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(getJson)
                    .then(function (payload) {
                        if (!payload.isSuccess) {
                            setOptionsMessage(row, payload.errorMessage || optionTexts.submitFailed, true);
                            return;
                        }
                        renderOptions(row, payload.items || []);
                        setOptionsMessage(row, payload.message || optionTexts.submitSucceeded, false);
                        form.reset();
                        if (form.matches('[data-option-update-form]')) {
                            form.style.display = 'none';
                        }
                    })
                    .catch(function () {
                        setOptionsMessage(row, optionTexts.unavailable, true);
                    })
                    .finally(function () {
                        buttons.forEach(function (button) { button.disabled = false; });
                    });
            }

            document.addEventListener('click', function (event) {
                var attributeEditButton = event.target.closest('.attribute-edit-btn');
                if (attributeEditButton) {
                    event.preventDefault();
                    event.stopImmediatePropagation();

                    var pairs = {
                        'attribute-update-id': 'data-attribute-id',
                        'attribute-update-selected': 'data-attribute-name',
                        'AttributeUpdateForm_Code': 'data-attribute-code',
                        'AttributeUpdateForm_Name': 'data-attribute-name',
                        'AttributeUpdateForm_DataType': 'data-attribute-datatype',
                        'AttributeUpdateForm_Scope': 'data-attribute-scope',
                        'AttributeUpdateForm_DisplayOrder': 'data-attribute-display-order'
                    };
                    Object.keys(pairs).forEach(function (id) {
                        var field = document.getElementById(id);
                        if (field) field.value = attributeEditButton.getAttribute(pairs[id]) || '';
                    });
                    var isActiveField = document.getElementById('AttributeUpdateForm_IsActive');
                    if (isActiveField) {
                        isActiveField.value = (attributeEditButton.getAttribute('data-attribute-isactive') || '').toLowerCase() === 'true' ? 'true' : 'false';
                    }

                    showBootstrapTab('#category-tabs .nav-link[href="#attribute-tab"]');
                    showBootstrapTab('#attribute-section-tabs .nav-link[href="#attribute-section-bank"]');
                    var editPanel = document.getElementById('attribute-edit-panel');
                    if (editPanel) editPanel.style.display = '';
                    var form = document.getElementById('attribute-update-form');
                    if (form) form.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }

                var optionsButton = event.target.closest('.attribute-options-btn');
                if (optionsButton) {
                    event.preventDefault();
                    event.stopImmediatePropagation();
                    var attributeId = optionsButton.getAttribute('data-attribute-id') || '';
                    var row = document.querySelector('.attribute-options-row[data-options-for="' + escapeSelector(attributeId) + '"]');
                    if (!row) return;
                    var isVisible = row.style.display !== 'none';
                    document.querySelectorAll('.attribute-options-row').forEach(function (optionsRow) {
                        optionsRow.style.display = 'none';
                    });
                    row.style.display = isVisible ? 'none' : '';
                    if (!isVisible) {
                        loadOptions(row, attributeId).then(function () {
                            row.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        });
                    }
                    return;
                }

                var optionEditButton = event.target.closest('.option-edit-btn');
                if (optionEditButton) {
                    event.preventDefault();
                    event.stopImmediatePropagation();
                    var optionRow = optionEditButton.closest('.attribute-options-row');
                    var updateForm = optionRow ? optionRow.querySelector('[data-option-update-form]') : null;
                    if (!updateForm) return;
                    var fields = {
                        '[data-option-update-id]': 'data-option-id',
                        '[data-option-update-name]': 'data-option-name',
                        '[data-option-update-value]': 'data-option-value',
                        '[data-option-update-order]': 'data-display-order'
                    };
                    Object.keys(fields).forEach(function (selector) {
                        var field = updateForm.querySelector(selector);
                        if (field) field.value = optionEditButton.getAttribute(fields[selector]) || '';
                    });
                    updateForm.style.display = '';
                    updateForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }

                var optionDeleteButton = event.target.closest('.ajax-option-delete-btn');
                if (optionDeleteButton) {
                    event.preventDefault();
                    event.stopImmediatePropagation();
                    var deleteRow = optionDeleteButton.closest('.attribute-options-row');
                    var deleteToken = deleteRow ? deleteRow.querySelector('input[name="__RequestVerificationToken"]') : null;
                    var deleteAttributeId = deleteRow ? deleteRow.getAttribute('data-options-for') || '' : '';
                    var deleteOptionId = optionDeleteButton.getAttribute('data-option-id') || '';
                    if (!deleteRow || !deleteToken || !deleteAttributeId || !deleteOptionId || !window.confirm(optionTexts.deleteConfirm)) return;
                    var data = new FormData();
                    data.append('__RequestVerificationToken', deleteToken.value);
                    data.append('attributeId', deleteAttributeId);
                    data.append('optionId', deleteOptionId);
                    setOptionsMessage(deleteRow, optionTexts.deleting, false);
                    fetch(optionEndpoints.delete, {
                        method: 'POST',
                        body: data,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                        .then(getJson)
                        .then(function (payload) {
                            if (!payload.isSuccess) {
                                setOptionsMessage(deleteRow, payload.errorMessage || optionTexts.deleteFailed, true);
                                return;
                            }
                            renderOptions(deleteRow, payload.items || []);
                            setOptionsMessage(deleteRow, payload.message || optionTexts.deleteSucceeded, false);
                        })
                        .catch(function () {
                            setOptionsMessage(deleteRow, optionTexts.unavailable, true);
                        });
                }
            }, true);

            document.addEventListener('submit', function (event) {
                var form = event.target;
                if (!(form instanceof HTMLFormElement)) return;
                if (form.matches('[data-option-add-form]')) {
                    event.preventDefault();
                    event.stopImmediatePropagation();
                    submitOptionForm(form, optionEndpoints.add);
                    return;
                }
                if (form.matches('[data-option-update-form]')) {
                    event.preventDefault();
                    event.stopImmediatePropagation();
                    submitOptionForm(form, optionEndpoints.update);
                }
            }, true);
        })();
    </script>
    <script>
        (function () {
            var root = document.querySelector('[data-media-uploader][data-policy="category-image"]');
            if (!root) return;
            var baseUrl = (root.getAttribute('data-base-url') || '').replace(/\/$/, '');
            var label = root.querySelector('label');
            var fileInput = root.querySelector('[data-media-file]');
            var progressWrap = root.querySelector('[data-media-progress-wrap]');
            var progressBar = root.querySelector('[data-media-progress]');
            var status = root.querySelector('[data-media-status]');
            var previewWrap = root.querySelector('[data-media-preview-wrap]');
            var preview = root.querySelector('[data-media-preview]');
            var removeButton = root.querySelector('[data-media-remove]');
            var form = document.getElementById('category-upsert-form');
            if (!fileInput || !form || !baseUrl) return;
            var fileKeyField = form.querySelector('[name="CategoryForm.ImageFileKey"]');
            var imageUrlField = form.querySelector('[name="CategoryForm.ImageUrl"]');
            var thumbField = form.querySelector('[name="CategoryForm.ImageThumbnailUrl"]');
            if (label) label.textContent = '\u062a\u0635\u0648\u06cc\u0631 \u062f\u0633\u062a\u0647\u200c\u0628\u0646\u062f\u06cc';
            if (label) label.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["category.image"]));
            if (status) status.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["media.imageHelp"]));
            if (removeButton) removeButton.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["media.removeImage"]));

            function getUploadErrorMessage(xhr, fallbackMessage) {
                try {
                    var errorPayload = JSON.parse(xhr.responseText || '{}');
                    if (errorPayload && errorPayload.message) {
                        return errorPayload.message;
                    }
                } catch (e) {
                }

                return fallbackMessage;
            }

            function syncPreview() {
                var previewUrl = (thumbField.value || imageUrlField.value || '').trim();
                if (!previewUrl) {
                    previewWrap.classList.add('d-none');
                    removeButton.classList.add('d-none');
                    return;
                }
                preview.src = toMediaUrl(previewUrl);
                previewWrap.classList.remove('d-none');
                removeButton.classList.remove('d-none');
            }

            function toMediaUrl(value) {
                if (!value || value.indexOf('http') === 0) {
                    return value;
                }

                return baseUrl + (value.charAt(0) === '/' ? value : '/' + value);
            }

            fileInput.addEventListener('change', function () {
                if (!fileInput.files || !fileInput.files.length) return;
                var xhr = new XMLHttpRequest();
                var formData = new FormData();
                formData.append('file', fileInput.files[0]);
                xhr.open('POST', baseUrl + '/api/FileService/files/upload?policy=category-image');
                progressWrap.classList.remove('d-none');
                xhr.upload.addEventListener('progress', function (event) {
                    if (!event.lengthComputable) return;
                    progressBar.style.width = Math.round((event.loaded / event.total) * 100) + '%';
                });
                xhr.addEventListener('loadend', function () {
                    if (xhr.status >= 200 && xhr.status < 300) {
                        if (!status.textContent || status.textContent.indexOf('�') >= 0 || status.textContent.indexOf('�') >= 0 || status.textContent.indexOf('�') >= 0) {
                            status.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["media.imageSaved"]));
                        }
                    } else if (xhr.status > 0) {
                        status.textContent = getUploadErrorMessage(xhr, @Html.Raw(JsonSerializer.Serialize(UiText["media.uploadImageFailed"])));
                    } else {
                        status.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["media.fileServiceUnavailable"]));
                    }
                });

                xhr.onload = function () {
                    progressWrap.classList.add('d-none');
                    progressBar.style.width = '0%';
                    if (xhr.status < 200 || xhr.status >= 300) {
                        status.textContent = getUploadErrorMessage(xhr, @Html.Raw(JsonSerializer.Serialize(UiText["media.uploadImageFailed"])));
                        return;
                    }
                    var result = JSON.parse(xhr.responseText);
                    fileKeyField.value = result.fileKey || '';
                    imageUrlField.value = result.url || '';
                    thumbField.value = result.thumbnailUrl || '';
                    status.textContent = result.originalFileName || @Html.Raw(JsonSerializer.Serialize(UiText["media.imageSaved"]));
                    syncPreview();
                };
                xhr.onerror = function () {
                    progressWrap.classList.add('d-none');
                    progressBar.style.width = '0%';
                    status.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["media.fileServiceUnavailable"]));
                };
                xhr.send(formData);
            });

            removeButton.addEventListener('click', function () {
                fileInput.value = '';
                fileKeyField.value = '';
                imageUrlField.value = '';
                thumbField.value = '';
                status.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["media.imageRemoved"]));
                syncPreview();
            });

            syncPreview();
        })();
    </script>
}



