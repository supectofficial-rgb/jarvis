                                                                        <input type="hidden" name="OptionUpdateForm.AttributeId" value="@attr.Id" />
                                                                        <input type="hidden" name="OptionUpdateForm.OptionId" data-option-update-id />
                                                                        <div class="form-row">
                                                                            <div class="form-group col-md-4"><label>کد آپشن</label><input name="OptionUpdateForm.OptionValue" class="form-control text-monospace" data-option-update-value required /></div>
                                                                            <div class="form-group col-md-4"><label>نام آپشن</label><input name="OptionUpdateForm.OptionName" class="form-control" data-option-update-name required /></div>
                                                                            <div class="form-group col-md-2"><label>اولویت</label><input name="OptionUpdateForm.DisplayOrder" type="number" min="0" class="form-control" data-option-update-order /></div>
                                                                            <div class="form-group col-md-2 d-flex align-items-end"><button class="btn btn-outline-primary btn-block" type="submit" @(Can("Catalog.AttributeOption.Update", "AttributeOption.Update") ? null : "disabled")>ثبت ادیت</button></div>
                                                                        </div>
                                                                    </form>
                                                                    <div class="table-responsive">
                                                                        <table class="table table-sm table-striped mb-0">
                                                                            <thead><tr><th>کد</th><th>نام</th><th>اولویت</th><th>وضعیت</th><th></th></tr></thead>
                                                                            <tbody data-options-tbody data-attribute-id="@attr.Id">
