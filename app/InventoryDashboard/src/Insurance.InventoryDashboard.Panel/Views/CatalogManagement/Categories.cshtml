                }

                var error = document.createElement('div');
                error.className = 'alert alert-danger mb-3';
                error.setAttribute('data-scoped-list-error', 'true');
                error.textContent = title + ' - ' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.serverUnavailable"]));
                scope.insertBefore(error, scope.firstChild);
            }

            function extractJsonAssignment(documentNode, variableName, nextVariableName) {
                var marker = 'var ' + variableName + ' = ';
                var nextMarker = nextVariableName ? ';' + '\n' + '            var ' + nextVariableName : ';';
                var scripts = Array.prototype.slice.call(documentNode.querySelectorAll('script'));

                for (var i = 0; i < scripts.length; i++) {
                    var text = scripts[i].textContent || '';
                    var start = text.indexOf(marker);
                    if (start < 0) {
                        continue;
                    }

                    start += marker.length;
                    var end = nextVariableName ? text.indexOf(nextMarker, start) : text.indexOf(';', start);
                    if (end < 0 && nextVariableName) {
                        end = text.indexOf(';' + '\r\n' + '            var ' + nextVariableName, start);
                    }
                    if (end < 0) {
                        continue;
                    }

                    try {
                        return JSON.parse(text.substring(start, end).trim());
                    } catch (e) {
                        return null;
                    }
                }

                return null;
            }

            function updateFormulaRegistries(documentNode) {
                var nextFormulaRegistry = extractJsonAssignment(documentNode, 'formulaRegistry', 'formulaAttributeRegistry');
                if (Array.isArray(nextFormulaRegistry)) {
                    formulaRegistry = nextFormulaRegistry;
                }

                var nextFormulaAttributeRegistry = extractJsonAssignment(documentNode, 'formulaAttributeRegistry', 'dirtyForms');
                if (Array.isArray(nextFormulaAttributeRegistry)) {
                    formulaAttributeRegistry = nextFormulaAttributeRegistry;
                }
            }

            function captureFormDraft(form) {
                var values = {};
                form.querySelectorAll('input, textarea, select').forEach(function (field) {
                    if (!field.name || field.name === '__RequestVerificationToken') {
                        try {
                            var errorPayload = JSON.parse(xhr.responseText || '{}');
                            if (errorPayload && errorPayload.message) {
                                status.textContent = errorPayload.message;
                            }
                        } catch (e) {
                        }
                        return;
                    }

                    if (field.type === 'checkbox') {
                        values[field.name] = { type: 'checkbox', value: field.checked };
                        return;
                    }

                    if (field.type === 'radio') {
                        if (!values[field.name]) {
                            values[field.name] = { type: 'radio', value: '' };
                        }
                        if (field.checked) {
                            values[field.name].value = field.value || '';
                        }
                        return;
                    }

                    values[field.name] = { type: 'value', value: field.value || '' };
                });

                return values;
            }

            function applyFormDraft(form, values) {
                if (!values || typeof values !== 'object') {
                    return;
                }

                Object.keys(values).forEach(function (fieldName) {
                    var meta = values[fieldName];
                    if (!meta) {
                        return;
                    }

                    if (meta.type === 'radio') {
                        form.querySelectorAll('input[type="radio"][name="' + fieldName + '"]').forEach(function (radio) {
                            radio.checked = (radio.value || '') === (meta.value || '');
                        });
                        return;
                    }

                    var field = form.querySelector('[name="' + fieldName + '"]');
                    if (!field) {
                        return;
                    }

                    if (meta.type === 'checkbox') {
                        field.checked = !!meta.value;
                        return;
                    }

                    field.value = meta.value || '';
                });
            }

            function getFormDraftKey(form) {
                if (form.id === 'category-upsert-form') {
                    var categoryId = form.querySelector('[name="CategoryForm.CategoryId"]');
                    return form.id + ':' + ((categoryId && categoryId.value) || 'new');
                }

                if (form.id === 'variant-name-formula-form') {
                    var formulaCategoryId = form.querySelector('[name="VariantNameFormulaForm.CategoryId"]');
                    return form.id + ':' + ((formulaCategoryId && formulaCategoryId.value) || 'new');
                }

                return form.id;
            }

            function saveFormDraft(form) {
                var allDrafts = readJson(draftStateKey, {});
                allDrafts[getFormDraftKey(form)] = captureFormDraft(form);
                writeJson(draftStateKey, allDrafts);
            }

            function restoreFormDrafts() {
                var allDrafts = readJson(draftStateKey, {});
                watchedForms.forEach(function (form) {
                    if (form.id === 'category-upsert-form' && isCategoryCreateMode) {
                        return;
                    }

                    applyFormDraft(form, allDrafts[getFormDraftKey(form)]);
                });
            }

            function clearCategoryCreateDraft() {
                if (!isCategoryCreateMode) {
                    return;
                }

                var allDrafts = readJson(draftStateKey, {});
                delete allDrafts['category-upsert-form:new'];
                writeJson(draftStateKey, allDrafts);
            }

            function clearSubmittedDraftAfterSuccess() {
                if (!@hasCatalogSuccess.ToString().ToLowerInvariant()) {
