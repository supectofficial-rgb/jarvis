                                                                                <input type="hidden" name="optionId" value="@option.Id" />
                                                                                <button type="submit" class="btn btn-link btn-xs p-0" @(Can("Catalog.AttributeOption.Activate", "AttributeOption.Activate") ? null : "disabled")>فعال</button>
                                                                            </form>
                                                                            <span>/</span>
                                                                            <form asp-action="DeactivateAttributeOption" method="post" class="d-inline" data-loading-form>
                                                                                @Html.AntiForgeryToken()
                                                                                <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                                                                <input type="hidden" name="attributeId" value="@attr.Id" />
                                                                                <input type="hidden" name="optionId" value="@option.Id" />
                                                                                <button type="submit" class="btn btn-link btn-xs p-0" @(Can("Catalog.AttributeOption.Deactivate", "AttributeOption.Deactivate") ? null : "disabled")>غیرفعال</button>
                                                                            </form>
                                                                            <span>/</span>
                                                                            <form asp-action="DeleteAttributeOption" method="post" class="d-inline" data-loading-form>
                                                                                @Html.AntiForgeryToken()
                                                                                <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                                                                <input type="hidden" name="attributeId" value="@attr.Id" />
                                                                                <input type="hidden" name="optionId" value="@option.Id" />
                                                                                <button type="submit" class="btn btn-link text-danger btn-xs p-0" data-confirm-title="حذف گزینه" data-confirm="این گزینه حذف شود؟" @(Can("Catalog.AttributeOption.Delete", "AttributeOption.Delete") ? null : "disabled")>حذف</button>
                                                                            </form>
                                                                        </div>
                                                                    }
                                                                }
                                                            </td>
                                                            <td class="text-nowrap">
                                                                <button type="button"
                                                                        class="btn btn-outline-primary btn-xs option-quick-add-btn"
                                                                        data-attribute-id="@attr.Id"
