                                                                                        <td>@(option.IsActive ? "فعال" : "غیرفعال")</td>
                                                                                        <td class="text-nowrap">
                                                                                            <button type="button" class="btn btn-outline-secondary btn-xs option-edit-btn" data-option-id="@option.Id" data-option-name="@option.OptionName" data-option-value="@option.OptionValue" data-display-order="@option.DisplayOrder" @(Can("Catalog.AttributeOption.Update", "AttributeOption.Update") ? null : "disabled")>ادیت</button>
                                                                                            <form asp-action="DeleteAttributeOption" method="post" class="d-inline option-delete-form" data-option-delete-form data-loading-form>
                                                                                                @Html.AntiForgeryToken()
                                                                                                <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                                                                                <input type="hidden" name="attributeId" value="@attr.Id" />
                                                                                                <input type="hidden" name="optionId" value="@option.Id" />
                                                                                                <button type="submit" class="btn btn-outline-danger btn-xs" data-confirm-title="حذف آپشن" data-confirm="این آپشن حذف شود؟" @(Can("Catalog.AttributeOption.Delete", "AttributeOption.Delete") ? null : "disabled")>حذف</button>
                                                                                            </form>
                                                                                        </td>
                                                                                    </tr>
                                                                                }
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                        }
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                            </div>
                        </div>
                    </div>

