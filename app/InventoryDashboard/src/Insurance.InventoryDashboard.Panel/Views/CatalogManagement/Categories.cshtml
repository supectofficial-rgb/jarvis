                    }
                });
            });

            var activeTab = '@(showAttributes ? "#attribute-tab" : showRules ? "#rule-tab" : showFormulas ? "#formula-tab" : "#category-tab")';
            if (activeTab) {
                var target = document.querySelector('#category-tabs .nav-link[href="' + activeTab + '"]');
                if (target && window.jQuery) {
                    window.jQuery(target).tab('show');
                }
            }

            if (activeTab === '#rule-tab') {
                var activeRuleSectionTab = localStorage.getItem(ruleSectionTabKey) || '#rule-section-edit';
                var ruleTarget = document.querySelector('#rule-section-tabs .nav-link[href="' + activeRuleSectionTab + '"]');
                if (ruleTarget && window.jQuery) {
                    window.jQuery(ruleTarget).tab('show');
                }
            }

            if (activeTab === '#formula-tab') {
                var activeFormulaSectionTab = localStorage.getItem(formulaSectionTabKey) || '#formula-section-edit';
                var formulaTarget = document.querySelector('#formula-section-tabs .nav-link[href="' + activeFormulaSectionTab + '"]');
                if (formulaTarget && window.jQuery) {
                    window.jQuery(formulaTarget).tab('show');
                }
            }

            clearSubmittedDraftAfterSuccess();
            clearCategoryCreateDraft();
            restoreFormDrafts();

            if (searchForm) {
                var filterState = readJson(filterStateKey, {});
                var params = new URLSearchParams(window.location.search);
                ['searchTerm', 'statusFilter', 'sort', 'pageSize'].forEach(function (name) {
                    var field = searchForm.querySelector('[name="' + name + '"]');
                    if (!field) {
                        return;
                    }

                    if (!params.has(name) && !field.value && filterState[name]) {
                        field.value = filterState[name];
                    }

                    function saveFilterState() {
                        filterState[name] = field.value || '';
                        writeJson(filterStateKey, filterState);
                    }

                    field.addEventListener('change', saveFilterState);
                    field.addEventListener('input', saveFilterState);
                });
            }

