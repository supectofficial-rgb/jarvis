@section Scripts {
    <script>
        (function () {
            function refreshScopedList(form, scopeId) {
                var scope = document.getElementById(scopeId);
                if (!scope || !(form instanceof HTMLFormElement)) {
                    return;
                }

                var method = (form.getAttribute('method') || 'GET').toUpperCase();
                var requestUrl = new URL(form.getAttribute('action') || window.location.pathname, window.location.origin);
                var formData = new FormData(form);
                var requestInit = {
                    method: method,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                };

                if (method === 'GET') {
                    var params = new URLSearchParams(formData);
                    params.forEach(function (value, key) {
                        requestUrl.searchParams.set(key, value);
                    });
                } else {
                    requestInit.body = formData;
                }

                scope.classList.add('opacity-50');
                scope.style.pointerEvents = 'none';

                fetch(requestUrl.toString(), requestInit)
                    .then(function (response) {
                        if (!response.ok) {
                            throw new Error('Request failed with status ' + response.status);
                        }

                        return response.text().then(function (html) {
                            return { html: html, url: response.url || requestUrl.toString() };
                        });
                    })
                    .then(function (result) {
                        var parser = new DOMParser();
                        var nextDocument = parser.parseFromString(result.html, 'text/html');
                        var nextScope = nextDocument.getElementById(scopeId);
                        var currentScope = document.getElementById(scopeId);

                        if (!nextScope || !currentScope) {
                            throw new Error('Scoped list was not found in response.');
                        }

                        currentScope.innerHTML = nextScope.innerHTML;

                        if (window.history && window.history.replaceState) {
                            window.history.replaceState({}, '', result.url);
                        }
                    })
                    .catch(function () {
                        var currentScope = document.getElementById(scopeId);
                        if (!currentScope) {
                            return;
                        }

                        var error = document.createElement('div');
                        error.className = 'alert alert-danger mb-3';
                        error.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.serverUnavailable"]));
                        currentScope.prepend(error);
                    })
                    .finally(function () {
                        var currentScope = document.getElementById(scopeId);
                        if (!currentScope) {
                            return;
                        }

                        currentScope.classList.remove('opacity-50');
                        currentScope.style.pointerEvents = '';
                    });
            }

            document.addEventListener('submit', function (event) {
                var form = event.target instanceof HTMLFormElement
                    ? event.target
                    : event.target.closest && event.target.closest('form');

                if (!form) {
                    return;
                }

                if (form.id === 'rule-category-list-form' || form.closest('#rule-list-scope')) {
                    event.preventDefault();
                    event.stopImmediatePropagation();
                    localStorage.setItem('catalog-categories-rule-section-tab', '#rule-section-list');
                    refreshScopedList(form, 'rule-list-scope');
                    return;
                }

                if (form.id === 'formula-category-list-form' || form.closest('#formula-list-scope')) {
                    event.preventDefault();
                    event.stopImmediatePropagation();
                    localStorage.setItem('catalog-categories-formula-section-tab', '#formula-section-list');
                    refreshScopedList(form, 'formula-list-scope');
                }
            }, true);
        })();
    </script>
