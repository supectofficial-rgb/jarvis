            function setOptionsMessage(row, message, isError) {
                var box = row ? row.querySelector('[data-options-message]') : null;
                if (!box) {
                    return;
                }

                box.className = 'attribute-options-message small mb-2 ' + (isError ? 'text-danger' : 'text-success');
                box.textContent = message || '';
            }

            function escapeHtml(value) {
                return (value || '').replace(/[&<>"']/g, function (char) {
                    return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[char];
                });
            }

            function optionRowsHtml(options) {
                if (!options || !options.length) {
                    return '<tr><td colspan="5">' + categoryTexts.optionNone + '</td></tr>';
                }

                return options
                    .slice()
                    .sort(function (a, b) {
                        return (a.displayOrder || 0) - (b.displayOrder || 0)
                            || (a.optionName || '').localeCompare(b.optionName || '');
                    })
                    .map(function (option) {
                        var id = escapeHtml(option.id || option.Id || '');
                        var name = escapeHtml(option.optionName || option.OptionName || '');
                        var value = escapeHtml(option.optionValue || option.OptionValue || '');
                        var order = option.displayOrder || option.DisplayOrder || 0;
                        var isActive = option.isActive !== undefined ? option.isActive : option.IsActive;
                        return '<tr>'
                            + '<td><span class="text-monospace">' + value + '</span></td>'
                            + '<td>' + name + '</td>'
                            + '<td>' + order + '</td>'
                            + '<td>' + (isActive ? categoryTexts.optionActive : categoryTexts.optionInactive) + '</td>'
                            + '<td class="text-nowrap">'
                            + '<button type="button" class="btn btn-outline-secondary btn-xs option-edit-btn" data-option-id="' + id + '" data-option-name="' + name + '" data-option-value="' + value + '" data-display-order="' + order + '"' + (canUpdateOptions ? '' : ' disabled') + '>' + categoryTexts.optionEdit + '</button> '
                            + '<button type="button" class="btn btn-outline-danger btn-xs ajax-option-delete-btn" data-option-id="' + id + '"' + (canDeleteOptions ? '' : ' disabled') + '>' + categoryTexts.optionDelete + '</button>'
                            + '</td>'
                            + '</tr>';
                    })
                    .join('');
            }

            function renderOptions(row, options) {
                var tbody = row ? row.querySelector('[data-options-tbody]') : null;
                if (!tbody) {
                    return;
                }

                tbody.innerHTML = optionRowsHtml(options || []);
            }

            function getJson(response) {
                return response.json().catch(function () {
                    return { isSuccess: false, errorMessage: categoryTexts.optionResponseUnreadable };
                });
            }

            function loadOptions(row, attributeId) {
                if (!row || !attributeId) {
                    return Promise.resolve();
                }

                setOptionsMessage(row, categoryTexts.optionLoading, false);
                return fetch(optionEndpoints.list + '?attributeId=' + encodeURIComponent(attributeId), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(getJson)
                    .then(function (payload) {
                        if (!payload.isSuccess) {
                            setOptionsMessage(row, payload.errorMessage || categoryTexts.optionLoadFailed, true);
                            return;
                        }

                        renderOptions(row, payload.items || []);
                        setOptionsMessage(row, '', false);
                    })
                    .catch(function () {
                        setOptionsMessage(row, categoryTexts.optionServerUnavailable, true);
                    });
            }

            function submitOptionForm(form, url, row, successCallback) {
                var submitButtons = form.querySelectorAll('button[type="submit"]');
                submitButtons.forEach(function (button) { button.setAttribute('disabled', 'disabled'); });
                setOptionsMessage(row, categoryTexts.optionSubmitting, false);

                return fetch(url, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(getJson)
                    .then(function (payload) {
                        if (!payload.isSuccess) {
                            setOptionsMessage(row, payload.errorMessage || categoryTexts.optionSubmitFailed, true);
                            return;
                        }

                        renderOptions(row, payload.items || []);
                        setOptionsMessage(row, payload.message || categoryTexts.optionSubmitSucceeded, false);
                        if (typeof successCallback === 'function') {
                            successCallback();
                        }
                    })
                    .catch(function () {
                        setOptionsMessage(row, categoryTexts.optionServerUnavailable, true);
                    })
                    .finally(function () {
                        submitButtons.forEach(function (button) { button.removeAttribute('disabled'); });
                    });
            }

            document.addEventListener('click', function (event) {
                var editButton = event.target.closest('.option-edit-btn');
                if (editButton) {
                    var row = editButton.closest('.attribute-options-row');
                    var inlineForm = row ? row.querySelector('.option-inline-edit-form') : null;
                    if (!inlineForm) {
                        return;
                    }

                    var idField = inlineForm.querySelector('[data-option-update-id]');
                    var nameField = inlineForm.querySelector('[data-option-update-name]');
                    var valueField = inlineForm.querySelector('[data-option-update-value]');
                    var orderField = inlineForm.querySelector('[data-option-update-order]');
                    if (idField) idField.value = editButton.getAttribute('data-option-id') || '';
                    if (nameField) nameField.value = editButton.getAttribute('data-option-name') || '';
                    if (valueField) valueField.value = editButton.getAttribute('data-option-value') || '';
                    if (orderField) orderField.value = editButton.getAttribute('data-display-order') || '0';
                    inlineForm.style.display = '';
                    inlineForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }

                var deleteButton = event.target.closest('.ajax-option-delete-btn');
                if (deleteButton) {
                    var optionsRow = deleteButton.closest('.attribute-options-row');
                    var attributeId = optionsRow ? optionsRow.getAttribute('data-options-for') || '' : '';
                    var optionId = deleteButton.getAttribute('data-option-id') || '';
                    var tokenField = optionsRow ? optionsRow.querySelector('input[name="__RequestVerificationToken"]') : null;
                    if (!attributeId || !optionId || !tokenField) {
                        return;
                    }
                    if (!window.confirm(categoryTexts.optionDeleteConfirm)) {
                        return;
                    }

                    var data = new FormData();
                    data.append('__RequestVerificationToken', tokenField.value);
                    data.append('attributeId', attributeId);
                    data.append('optionId', optionId);
                    setOptionsMessage(optionsRow, categoryTexts.optionDeleting, false);
                    fetch(optionEndpoints.delete, {
                        method: 'POST',
                        body: data,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                        .then(getJson)
                        .then(function (payload) {
                            if (!payload.isSuccess) {
                                setOptionsMessage(optionsRow, payload.errorMessage || categoryTexts.optionDeleteFailed, true);
                                return;
                            }
                            renderOptions(optionsRow, payload.items || []);
                            setOptionsMessage(optionsRow, payload.message || categoryTexts.optionDeleteSucceeded, false);
                        })
                        .catch(function () {
                            setOptionsMessage(optionsRow, categoryTexts.optionServerUnavailable, true);
                        });
                }
            });

