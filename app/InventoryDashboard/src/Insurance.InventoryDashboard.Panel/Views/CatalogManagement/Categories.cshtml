                                                               asp-route-page="@i"
                                                               asp-route-pageSize="@Model.CategoryPageSize">@i</a>
                                                        </li>
                                                    }
                                                </ul>
                                            </nav>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
