                                            <div class="custom-control custom-checkbox mt-2"><input asp-for="RuleForm.IsVariant" class="custom-control-input" /><label class="custom-control-label" asp-for="RuleForm.IsVariant">سطح واریانت</label></div>
                                            <div class="custom-control custom-checkbox mt-2"><input asp-for="RuleForm.IsOverridden" class="custom-control-input" /><label class="custom-control-label" asp-for="RuleForm.IsOverridden">بازنویسی‌شده</label></div>
                                            <div class="custom-control custom-checkbox mt-2"><input asp-for="RuleForm.IsActive" class="custom-control-input" /><label class="custom-control-label" asp-for="RuleForm.IsActive">فعال</label></div>
                                            @if (localRules.Count == 0)
                                            {
                                                <small class="form-text text-warning">قانون مستقیمی برای ویرایش وجود ندارد.</small>
                                            }
                                            <div class="mt-3">
                                                <button class="btn btn-outline-primary" type="submit" @((Can("Inventory.CategoryAttributeRule.Update", "Catalog.Category.Rule.Update", "CategoryAttributeRule.Update") && localRules.Count > 0) ? null : "disabled")>به‌روزرسانی قانون</button>
                                                <button class="btn btn-outline-secondary" type="button" id="rule-inline-edit-cancel">انصراف از ویرایش</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                            </div>

                            <div class="tab-pane" id="rule-section-list" role="tabpanel">
                        <div class="row">
                            <div class="col-12 mb-4">
                                <div class="card">
                                    <div class="card-body">
                                        <h5 class="card-title">قوانین دسته‌بندی</h5>
                                        <div class="table-responsive">
                                            <table class="table table-sm table-striped">
                                                <thead>
                                                    <tr>
                                                        <th>ویژگی</th>
                                                        <th>الزامی</th>
                                                        <th>سطح واریانت</th>
                                                        <th>ترتیب</th>
                                                        <th>بازنویسی‌شده</th>
                                                        <th>فعال</th>
                                                        <th>منبع</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var rule in Model.CategoryAttributeRules)
                                                    {
                                                        <tr>
                                                            <td>@rule.AttributeName <span class="text-muted small">(@rule.DataType)</span></td>
                                                            <td>@(rule.RuleIsRequired ? "بله" : "خیر")</td>
                                                            <td>@(rule.RuleIsVariant ? "بله" : "خیر")</td>
                                                            <td>@rule.RuleDisplayOrder</td>
                                                            <td>@(rule.RuleIsOverridden ? "بله" : "خیر")</td>
                                                            <td>@(rule.RuleIsActive ? "فعال" : "غیرفعال")</td>
                                                            <td>@(rule.IsInherited ? $"ارث‌رسیده از {rule.SourceCategoryName}" : "مستقیم")</td>
                                                            <td class="text-nowrap">
                                                                @if (!rule.IsInherited)
                                                                {
                                                                    <button type="button"
                                                                            class="btn btn-outline-secondary btn-xs rule-inline-edit-btn"
                                                                            data-rule-category-id="@Model.SelectedCategoryId"
                                                                            data-rule-attribute-id="@rule.AttributeId"
                                                                            data-rule-attribute-name="@rule.AttributeName"
                                                                            data-rule-display-order="@rule.RuleDisplayOrder"
                                                                            data-rule-required="@(rule.RuleIsRequired ? "true" : "false")"
                                                                            data-rule-variant="@(rule.RuleIsVariant ? "true" : "false")"
                                                                            data-rule-overridden="@(rule.RuleIsOverridden ? "true" : "false")"
                                                                            data-rule-active="@(rule.RuleIsActive ? "true" : "false")"
                                                                            @(Can("Inventory.CategoryAttributeRule.Update", "Catalog.Category.Rule.Update", "CategoryAttributeRule.Update") ? null : "disabled")>
                                                                        ویرایش
                                                                    </button>
                                                                    <form asp-action="ActivateCategoryAttributeRule" method="post" class="d-inline" data-loading-form>
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                                                        <input type="hidden" name="attributeId" value="@rule.AttributeId" />
                                                                        <button class="btn btn-outline-success btn-xs" type="submit" @(Can("Inventory.CategoryAttributeRule.Update", "Catalog.Category.Rule.Activate", "CategoryAttributeRule.Activate") ? null : "disabled")>فعال</button>
                                                                    </form>
                                                                    <form asp-action="DeactivateCategoryAttributeRule" method="post" class="d-inline" data-loading-form>
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                                                        <input type="hidden" name="attributeId" value="@rule.AttributeId" />
                                                                        <button class="btn btn-outline-warning btn-xs" type="submit" @(Can("Inventory.CategoryAttributeRule.Update", "Catalog.Category.Rule.Deactivate", "CategoryAttributeRule.Deactivate") ? null : "disabled")>غیرفعال</button>
                                                                    </form>
                                                                    <form asp-action="RemoveCategoryAttributeRule" method="post" class="d-inline" data-loading-form>
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                                                        <input type="hidden" name="attributeId" value="@rule.AttributeId" />
                                                                        <button class="btn btn-outline-danger btn-xs" type="submit" data-confirm-title="حذف قانون" data-confirm="این قانون دسته‌بندی حذف شود؟" @(Can("Inventory.CategoryAttributeRule.Remove", "Catalog.Category.Rule.Remove", "CategoryAttributeRule.Remove", "CategoryAttributeRule.Delete") ? null : "disabled")>حذف</button>
                                                                    </form>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        (function () {
            var tabKey = 'catalog-categories-active-tab';
            var ruleSectionTabKey = 'catalog-categories-rule-section-tab';
            var treeStateKey = 'catalog-categories-collapsed-v1';
            var filterStateKey = 'catalog-categories-filters-v1';
            var draftStateKey = 'catalog-categories-form-drafts-v1';
            var submittedFormKey = 'catalog-categories-last-submitted-form-v1';
            var isCategoryCreateMode = @Model.IsCategoryCreateMode.ToString().ToLowerInvariant();
            var optionEndpoints = {
                list: '@Url.Action("GetAttributeOptions", "CategoryManagement")',
                add: '@Url.Action("AddAttributeOptionAjax", "CategoryManagement")',
                update: '@Url.Action("UpdateAttributeOptionAjax", "CategoryManagement")',
                delete: '@Url.Action("DeleteAttributeOptionAjax", "CategoryManagement")'
            };
            var canUpdateOptions = @Can("Catalog.AttributeOption.Update", "AttributeOption.Update").ToString().ToLowerInvariant();
            var canDeleteOptions = @Can("Catalog.AttributeOption.Delete", "AttributeOption.Delete").ToString().ToLowerInvariant();
            var dirtyForms = new Set();
            var tabs = document.querySelectorAll('#category-tabs .nav-link');
            var ruleSectionTabs = document.querySelectorAll('#rule-section-tabs .nav-link');
            var searchForm = document.getElementById('category-search-form');
            var watchedFormIds = [
                'category-upsert-form',
                'move-category-form',
                'create-category-attribute-form',
                'attribute-update-form',
                'assign-attribute-to-category-form',
                'update-category-attribute-rule-form'
            ];
            var watchedForms = watchedFormIds
                .map(function (formId) { return document.getElementById(formId); })
                .filter(function (form) { return form instanceof HTMLFormElement; });

            function readJson(key, fallback) {
                try {
                    return JSON.parse(localStorage.getItem(key) || '');
                } catch (e) {
                    return fallback;
                }
            }

            function writeJson(key, value) {
                localStorage.setItem(key, JSON.stringify(value));
            }

            function captureFormDraft(form) {
                var values = {};
                form.querySelectorAll('input, textarea, select').forEach(function (field) {
                    if (!field.name || field.name === '__RequestVerificationToken') {
                        return;
                    }

                    if (field.type === 'checkbox') {
                        values[field.name] = { type: 'checkbox', value: field.checked };
                        return;
                    }

                    if (field.type === 'radio') {
                        if (!values[field.name]) {
                            values[field.name] = { type: 'radio', value: '' };
                        }
                        if (field.checked) {
                            values[field.name].value = field.value || '';
                        }
                        return;
                    }

                    values[field.name] = { type: 'value', value: field.value || '' };
                });

                return values;
            }

            function applyFormDraft(form, values) {
                if (!values || typeof values !== 'object') {
                    return;
                }

                Object.keys(values).forEach(function (fieldName) {
                    var meta = values[fieldName];
                    if (!meta) {
                        return;
                    }

                    if (meta.type === 'radio') {
                        form.querySelectorAll('input[type="radio"][name="' + fieldName + '"]').forEach(function (radio) {
                            radio.checked = (radio.value || '') === (meta.value || '');
                        });
                        return;
                    }

                    var field = form.querySelector('[name="' + fieldName + '"]');
                    if (!field) {
                        return;
                    }

                    if (meta.type === 'checkbox') {
                        field.checked = !!meta.value;
                        return;
                    }

                    field.value = meta.value || '';
                });
            }

            function getFormDraftKey(form) {
                if (form.id === 'category-upsert-form') {
                    var categoryId = form.querySelector('[name="CategoryForm.CategoryId"]');
                    return form.id + ':' + ((categoryId && categoryId.value) || 'new');
                }

                return form.id;
            }

            function saveFormDraft(form) {
                var allDrafts = readJson(draftStateKey, {});
                allDrafts[getFormDraftKey(form)] = captureFormDraft(form);
                writeJson(draftStateKey, allDrafts);
            }

            function restoreFormDrafts() {
                var allDrafts = readJson(draftStateKey, {});
                watchedForms.forEach(function (form) {
                    if (form.id === 'category-upsert-form' && isCategoryCreateMode) {
                        return;
                    }

                    applyFormDraft(form, allDrafts[getFormDraftKey(form)]);
                });
            }

            function clearCategoryCreateDraft() {
                if (!isCategoryCreateMode) {
                    return;
                }

                var allDrafts = readJson(draftStateKey, {});
                delete allDrafts['category-upsert-form:new'];
                writeJson(draftStateKey, allDrafts);
            }

            function clearSubmittedDraftAfterSuccess() {
                if (!@hasCatalogSuccess.ToString().ToLowerInvariant()) {
                    return;
                }

                var submittedFormId = localStorage.getItem(submittedFormKey);
                if (!submittedFormId) {
                    return;
                }

                var allDrafts = readJson(draftStateKey, {});
                if (allDrafts && allDrafts[submittedFormId]) {
                    delete allDrafts[submittedFormId];
                    writeJson(draftStateKey, allDrafts);
                }

                localStorage.removeItem(submittedFormKey);
            }

            tabs.forEach(function (tab) {
                tab.addEventListener('shown.bs.tab', function () {
                    var href = tab.getAttribute('href');
                    if (href) {
                        localStorage.setItem(tabKey, href);
                    }
                });
            });

            ruleSectionTabs.forEach(function (tab) {
                tab.addEventListener('shown.bs.tab', function () {
                    var href = tab.getAttribute('href');
                    if (href) {
                        localStorage.setItem(ruleSectionTabKey, href);
                    }
                });
            });

            var activeTab = '@(showAttributes ? "#attribute-tab" : showRules ? "#rule-tab" : "#category-tab")';
            if (activeTab) {
                var target = document.querySelector('#category-tabs .nav-link[href="' + activeTab + '"]');
                if (target && window.jQuery) {
                    window.jQuery(target).tab('show');
                }
            }

            if (activeTab === '#rule-tab') {
                var activeRuleSectionTab = localStorage.getItem(ruleSectionTabKey) || '#rule-section-edit';
                var ruleTarget = document.querySelector('#rule-section-tabs .nav-link[href="' + activeRuleSectionTab + '"]');
                if (ruleTarget && window.jQuery) {
                    window.jQuery(ruleTarget).tab('show');
                }
            }

            clearSubmittedDraftAfterSuccess();
            clearCategoryCreateDraft();
            restoreFormDrafts();

            if (searchForm) {
                var filterState = readJson(filterStateKey, {});
                var params = new URLSearchParams(window.location.search);
                ['searchTerm', 'statusFilter', 'sort', 'pageSize'].forEach(function (name) {
                    var field = searchForm.querySelector('[name="' + name + '"]');
                    if (!field) {
                        return;
                    }

                    if (!params.has(name) && !field.value && filterState[name]) {
                        field.value = filterState[name];
                    }

                    function saveFilterState() {
                        filterState[name] = field.value || '';
                        writeJson(filterStateKey, filterState);
                    }

                    field.addEventListener('change', saveFilterState);
                    field.addEventListener('input', saveFilterState);
                });
            }

            var collapsed = readJson(treeStateKey, []);
            var collapsedSet = new Set(Array.isArray(collapsed) ? collapsed : []);

            function getRowById(categoryId) {
                return document.querySelector('tr[data-category-row][data-category-id="' + categoryId + '"]');
            }

            function hasCollapsedAncestor(row) {
                if (!row) {
                    return false;
                }

                var parentId = row.getAttribute('data-parent-id');
                while (parentId) {
                    if (collapsedSet.has(parentId)) {
                        return true;
                    }

                    var parentRow = getRowById(parentId);
                    if (!parentRow) {
                        break;
                    }
                    parentId = parentRow.getAttribute('data-parent-id');
                }

                return false;
            }

            function updateTreeUi() {
                document.querySelectorAll('tr[data-category-row]').forEach(function (row) {
                    row.style.display = hasCollapsedAncestor(row) ? 'none' : '';

                    var rowId = row.getAttribute('data-category-id');
                    var toggleIcon = row.querySelector('[data-toggle-icon]');
                    if (!toggleIcon) {
                        return;
                    }

                    toggleIcon.textContent = collapsedSet.has(rowId) ? '+' : '-';
                });

                writeJson(treeStateKey, Array.from(collapsedSet));
            }

            document.querySelectorAll('[data-category-toggle]').forEach(function (button) {
                button.addEventListener('click', function () {
                    var categoryId = button.getAttribute('data-category-toggle');
                    if (!categoryId) {
                        return;
                    }

                    if (collapsedSet.has(categoryId)) {
                        collapsedSet.delete(categoryId);
                    } else {
                        collapsedSet.add(categoryId);
                    }

                    updateTreeUi();
                });
            });

            var expandAllButton = document.querySelector('[data-tree-expand-all]');
            if (expandAllButton) {
                expandAllButton.addEventListener('click', function () {
                    collapsedSet.clear();
                    updateTreeUi();
                });
            }

            var collapseAllButton = document.querySelector('[data-tree-collapse-all]');
            if (collapseAllButton) {
                collapseAllButton.addEventListener('click', function () {
                    document.querySelectorAll('tr[data-category-row][data-has-children="true"]').forEach(function (row) {
                        var rowId = row.getAttribute('data-category-id');
                        if (rowId) {
                            collapsedSet.add(rowId);
                        }
                    });
                    updateTreeUi();
                });
            }

            updateTreeUi();

            var attributeUpdateId = document.getElementById('attribute-update-id');
            var attributeUpdateName = document.getElementById('attribute-update-selected');
            var attributeUpdateCode = document.getElementById('AttributeUpdateForm_Code');
            var attributeUpdateDisplayName = document.getElementById('AttributeUpdateForm_Name');
            var attributeUpdateDataType = document.getElementById('AttributeUpdateForm_DataType');
            var attributeUpdateScope = document.getElementById('AttributeUpdateForm_Scope');
            var attributeUpdateDisplayOrder = document.getElementById('AttributeUpdateForm_DisplayOrder');
            var attributeUpdateIsRequired = document.getElementById('AttributeUpdateForm_IsRequired');
            var attributeUpdateIsVariant = document.getElementById('AttributeUpdateForm_IsVariant');
            var attributeUpdateIsActive = document.getElementById('AttributeUpdateForm_IsActive');

            document.querySelectorAll('.attribute-edit-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    if (attributeUpdateId) attributeUpdateId.value = button.getAttribute('data-attribute-id') || '';
                    if (attributeUpdateName) attributeUpdateName.value = button.getAttribute('data-attribute-name') || '';
                    if (attributeUpdateCode) attributeUpdateCode.value = button.getAttribute('data-attribute-code') || '';
                    if (attributeUpdateDisplayName) attributeUpdateDisplayName.value = button.getAttribute('data-attribute-name') || '';
                    if (attributeUpdateDataType) attributeUpdateDataType.value = button.getAttribute('data-attribute-datatype') || '';
                    if (attributeUpdateScope) attributeUpdateScope.value = button.getAttribute('data-attribute-scope') || '';
                    if (window.jQuery) {
                        if (attributeUpdateDataType) window.jQuery(attributeUpdateDataType).trigger('change');
                        if (attributeUpdateScope) window.jQuery(attributeUpdateScope).trigger('change');
                    }
                    if (attributeUpdateDisplayOrder) attributeUpdateDisplayOrder.value = button.getAttribute('data-attribute-display-order') || '0';
                    if (attributeUpdateIsRequired) attributeUpdateIsRequired.checked = (button.getAttribute('data-attribute-is-required') || '').toLowerCase() === 'true';
                    if (attributeUpdateIsVariant) attributeUpdateIsVariant.checked = (button.getAttribute('data-attribute-is-variant') || '').toLowerCase() === 'true';
                    if (attributeUpdateIsActive) attributeUpdateIsActive.value = (button.getAttribute('data-attribute-isactive') || '').toLowerCase() === 'true' ? 'true' : 'false';

                    var attributeTab = document.querySelector('#category-tabs .nav-link[href="#attribute-tab"]');
                    if (attributeTab && window.jQuery) {
                        window.jQuery(attributeTab).tab('show');
                    }
                    var attributeListTab = document.querySelector('#attribute-section-tabs .nav-link[href="#attribute-section-bank"]');
                    if (attributeListTab && window.jQuery) {
                        window.jQuery(attributeListTab).tab('show');
                    }
                    var editPanel = document.getElementById('attribute-edit-panel');
                    if (editPanel) {
                        editPanel.style.display = '';
                    }
                    var form = document.getElementById('attribute-update-form');
                    if (form) {
                        form.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                });
            });

            function setOptionsMessage(row, message, isError) {
                var box = row ? row.querySelector('[data-options-message]') : null;
                if (!box) {
                    return;
                }

                box.className = 'attribute-options-message small mb-2 ' + (isError ? 'text-danger' : 'text-success');
                box.textContent = message || '';
            }

            function escapeHtml(value) {
                return (value || '').replace(/[&<>"']/g, function (char) {
                    return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[char];
                });
            }

            function optionRowsHtml(options) {
                if (!options || !options.length) {
                    return '<tr><td colspan="5">آپشنی ثبت نشده است.</td></tr>';
                }

                return options
                    .slice()
                    .sort(function (a, b) {
                        return (a.displayOrder || 0) - (b.displayOrder || 0)
                            || (a.optionName || '').localeCompare(b.optionName || '');
                    })
                    .map(function (option) {
                        var id = escapeHtml(option.id || option.Id || '');
                        var name = escapeHtml(option.optionName || option.OptionName || '');
                        var value = escapeHtml(option.optionValue || option.OptionValue || '');
                        var order = option.displayOrder || option.DisplayOrder || 0;
                        var isActive = option.isActive !== undefined ? option.isActive : option.IsActive;
                        return '<tr>'
                            + '<td><span class="text-monospace">' + value + '</span></td>'
                            + '<td>' + name + '</td>'
                            + '<td>' + order + '</td>'
                            + '<td>' + (isActive ? 'فعال' : 'غیرفعال') + '</td>'
                            + '<td class="text-nowrap">'
                            + '<button type="button" class="btn btn-outline-secondary btn-xs option-edit-btn" data-option-id="' + id + '" data-option-name="' + name + '" data-option-value="' + value + '" data-display-order="' + order + '"' + (canUpdateOptions ? '' : ' disabled') + '>ادیت</button> '
                            + '<button type="button" class="btn btn-outline-danger btn-xs ajax-option-delete-btn" data-option-id="' + id + '"' + (canDeleteOptions ? '' : ' disabled') + '>حذف</button>'
                            + '</td>'
                            + '</tr>';
                    })
                    .join('');
            }

            function renderOptions(row, options) {
                var tbody = row ? row.querySelector('[data-options-tbody]') : null;
                if (!tbody) {
                    return;
                }

                tbody.innerHTML = optionRowsHtml(options || []);
            }

            function getJson(response) {
                return response.json().catch(function () {
                    return { isSuccess: false, errorMessage: 'پاسخ سرور قابل خواندن نیست.' };
                });
            }

            function loadOptions(row, attributeId) {
                if (!row || !attributeId) {
                    return Promise.resolve();
                }

                setOptionsMessage(row, 'در حال بارگذاری...', false);
                return fetch(optionEndpoints.list + '?attributeId=' + encodeURIComponent(attributeId), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(getJson)
                    .then(function (payload) {
                        if (!payload.isSuccess) {
                            setOptionsMessage(row, payload.errorMessage || 'بارگذاری لیست آپشن‌ها انجام نشد.', true);
                            return;
                        }

                        renderOptions(row, payload.items || []);
                        setOptionsMessage(row, '', false);
                    })
                    .catch(function () {
                        setOptionsMessage(row, 'ارتباط با سرور برقرار نشد.', true);
                    });
            }

            function submitOptionForm(form, url, row, successCallback) {
                var submitButtons = form.querySelectorAll('button[type="submit"]');
                submitButtons.forEach(function (button) { button.setAttribute('disabled', 'disabled'); });
                setOptionsMessage(row, 'در حال ثبت...', false);

                return fetch(url, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(getJson)
                    .then(function (payload) {
                        if (!payload.isSuccess) {
                            setOptionsMessage(row, payload.errorMessage || 'عملیات انجام نشد.', true);
                            return;
                        }

                        renderOptions(row, payload.items || []);
                        setOptionsMessage(row, payload.message || 'عملیات انجام شد.', false);
                        if (typeof successCallback === 'function') {
                            successCallback();
                        }
                    })
                    .catch(function () {
                        setOptionsMessage(row, 'ارتباط با سرور برقرار نشد.', true);
                    })
                    .finally(function () {
                        submitButtons.forEach(function (button) { button.removeAttribute('disabled'); });
                    });
            }

            document.addEventListener('click', function (event) {
                var editButton = event.target.closest('.option-edit-btn');
                if (editButton) {
                    var row = editButton.closest('.attribute-options-row');
                    var inlineForm = row ? row.querySelector('.option-inline-edit-form') : null;
                    if (!inlineForm) {
                        return;
                    }

                    var idField = inlineForm.querySelector('[data-option-update-id]');
                    var nameField = inlineForm.querySelector('[data-option-update-name]');
                    var valueField = inlineForm.querySelector('[data-option-update-value]');
                    var orderField = inlineForm.querySelector('[data-option-update-order]');
                    if (idField) idField.value = editButton.getAttribute('data-option-id') || '';
                    if (nameField) nameField.value = editButton.getAttribute('data-option-name') || '';
                    if (valueField) valueField.value = editButton.getAttribute('data-option-value') || '';
                    if (orderField) orderField.value = editButton.getAttribute('data-display-order') || '0';
                    inlineForm.style.display = '';
                    inlineForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }

                var deleteButton = event.target.closest('.ajax-option-delete-btn');
                if (deleteButton) {
                    var optionsRow = deleteButton.closest('.attribute-options-row');
                    var attributeId = optionsRow ? optionsRow.getAttribute('data-options-for') || '' : '';
                    var optionId = deleteButton.getAttribute('data-option-id') || '';
                    var tokenField = optionsRow ? optionsRow.querySelector('input[name="__RequestVerificationToken"]') : null;
                    if (!attributeId || !optionId || !tokenField) {
                        return;
                    }
                    if (!window.confirm('این آپشن حذف شود؟')) {
                        return;
                    }

                    var data = new FormData();
                    data.append('__RequestVerificationToken', tokenField.value);
                    data.append('attributeId', attributeId);
                    data.append('optionId', optionId);
                    setOptionsMessage(optionsRow, 'در حال حذف...', false);
                    fetch(optionEndpoints.delete, {
                        method: 'POST',
                        body: data,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                        .then(getJson)
                        .then(function (payload) {
                            if (!payload.isSuccess) {
                                setOptionsMessage(optionsRow, payload.errorMessage || 'حذف آپشن انجام نشد.', true);
                                return;
                            }
                            renderOptions(optionsRow, payload.items || []);
                            setOptionsMessage(optionsRow, payload.message || 'آپشن حذف شد.', false);
                        })
                        .catch(function () {
                            setOptionsMessage(optionsRow, 'ارتباط با سرور برقرار نشد.', true);
                        });
                }
            });

            document.querySelectorAll('[data-option-add-form]').forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    event.preventDefault();
                    var row = form.closest('.attribute-options-row');
                    submitOptionForm(form, optionEndpoints.add, row, function () {
                        form.reset();
                    });
                });
            });

            document.querySelectorAll('[data-option-update-form]').forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    event.preventDefault();
                    var row = form.closest('.attribute-options-row');
                    submitOptionForm(form, optionEndpoints.update, row, function () {
                        form.style.display = 'none';
                        form.reset();
                    });
                });
            });

            document.querySelectorAll('[data-option-delete-form]').forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    event.preventDefault();
                    var row = form.closest('.attribute-options-row');
                    var attributeId = row ? row.getAttribute('data-options-for') || '' : '';
                    var optionIdField = form.querySelector('input[name="optionId"]');
                    if (!attributeId || !optionIdField || !window.confirm('این آپشن حذف شود؟')) {
                        return;
                    }

                    var data = new FormData(form);
                    data.set('attributeId', attributeId);
                    data.set('optionId', optionIdField.value || '');
                    fetch(optionEndpoints.delete, {
                        method: 'POST',
                        body: data,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                        .then(getJson)
                        .then(function (payload) {
                            if (!payload.isSuccess) {
                                setOptionsMessage(row, payload.errorMessage || 'حذف آپشن انجام نشد.', true);
                                return;
                            }
                            renderOptions(row, payload.items || []);
                            setOptionsMessage(row, payload.message || 'آپشن حذف شد.', false);
                        })
                        .catch(function () {
                            setOptionsMessage(row, 'ارتباط با سرور برقرار نشد.', true);
                        });
                });
            });

            document.querySelectorAll('.attribute-options-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    var attributeId = button.getAttribute('data-attribute-id') || '';
                    var row = document.querySelector('.attribute-options-row[data-options-for="' + attributeId + '"]');
                    if (!row) {
                        return;
                    }

                    var isVisible = row.style.display !== 'none';
                    document.querySelectorAll('.attribute-options-row').forEach(function (optionsRow) {
                        optionsRow.style.display = 'none';
                    });
                    row.style.display = isVisible ? 'none' : '';
                    if (!isVisible) {
                        loadOptions(row, attributeId).then(function () {
                            row.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        });
                    }
                });
            });

            var attributeListSearch = document.getElementById('attribute-list-search');
            if (attributeListSearch) {
                attributeListSearch.addEventListener('input', function () {
                    var value = (attributeListSearch.value || '').toLowerCase();
                    document.querySelectorAll('[data-attribute-list-row]').forEach(function (row) {
                        var haystack = (row.getAttribute('data-attribute-search') || '').toLowerCase();
                        var visible = !value || haystack.indexOf(value) >= 0;
                        row.style.display = visible ? '' : 'none';
                        var optionsButton = row.querySelector('.attribute-options-btn');
                        var attributeId = optionsButton ? optionsButton.getAttribute('data-attribute-id') || '' : '';
                        var optionsRow = attributeId ? document.querySelector('.attribute-options-row[data-options-for="' + attributeId + '"]') : null;
                        if (optionsRow && !visible) {
                            optionsRow.style.display = 'none';
                        }
                    });
                });
            }

            var ruleSectionEditTab = document.querySelector('#rule-section-tabs .nav-link[href="#rule-section-edit"]');
            var ruleInlineEditCard = document.getElementById('rule-inline-edit-card');
            var ruleInlineEditCancel = document.getElementById('rule-inline-edit-cancel');
            var ruleEditSelect = document.getElementById('RuleForm_AttributeId');
            var ruleEditDisplayOrder = document.getElementById('RuleForm_DisplayOrder');
            var ruleEditRequired = document.getElementById('RuleForm_IsRequired');
            var ruleEditVariant = document.getElementById('RuleForm_IsVariant');
            var ruleEditOverridden = document.getElementById('RuleForm_IsOverridden');
            var ruleEditActive = document.getElementById('RuleForm_IsActive');
            var ruleEditCategoryId = document.getElementById('RuleForm_CategoryId');

            function applyRuleOptionToEditForm() {
                if (!ruleEditSelect) {
                    return;
                }

                var selected = ruleEditSelect.options[ruleEditSelect.selectedIndex];
                if (!selected) {
                    return;
                }

                if (ruleEditDisplayOrder) ruleEditDisplayOrder.value = selected.getAttribute('data-rule-display-order') || '0';
                if (ruleEditRequired) ruleEditRequired.checked = (selected.getAttribute('data-rule-required') || '').toLowerCase() === 'true';
                if (ruleEditVariant) ruleEditVariant.checked = (selected.getAttribute('data-rule-variant') || '').toLowerCase() === 'true';
                if (ruleEditOverridden) ruleEditOverridden.checked = (selected.getAttribute('data-rule-overridden') || '').toLowerCase() === 'true';
                if (ruleEditActive) ruleEditActive.checked = (selected.getAttribute('data-rule-active') || '').toLowerCase() === 'true';
            }

            if (ruleEditSelect) {
                ruleEditSelect.addEventListener('change', applyRuleOptionToEditForm);
                applyRuleOptionToEditForm();
            }

            function openRuleInlineEdit(button) {
                if (!button) {
                    return;
                }

                localStorage.setItem(ruleSectionTabKey, '#rule-section-edit');
                if (ruleSectionEditTab && window.jQuery) {
                    window.jQuery(ruleSectionEditTab).tab('show');
                }

                if (ruleInlineEditCard) {
                    ruleInlineEditCard.style.display = '';
                }

                if (ruleEditCategoryId) {
                    ruleEditCategoryId.value = button.getAttribute('data-rule-category-id') || '@Model.SelectedCategoryId';
                }
                if (ruleEditSelect) {
                    ruleEditSelect.value = button.getAttribute('data-rule-attribute-id') || '';
                }
                if (ruleEditDisplayOrder) {
                    ruleEditDisplayOrder.value = button.getAttribute('data-rule-display-order') || '0';
                }
                if (ruleEditRequired) {
                    ruleEditRequired.checked = (button.getAttribute('data-rule-required') || '').toLowerCase() === 'true';
                }
                if (ruleEditVariant) {
                    ruleEditVariant.checked = (button.getAttribute('data-rule-variant') || '').toLowerCase() === 'true';
                }
                if (ruleEditOverridden) {
                    ruleEditOverridden.checked = (button.getAttribute('data-rule-overridden') || '').toLowerCase() === 'true';
                }
                if (ruleEditActive) {
                    ruleEditActive.checked = (button.getAttribute('data-rule-active') || '').toLowerCase() === 'true';
                }

                if (ruleEditSelect) {
                    ruleEditSelect.dispatchEvent(new Event('change'));
                    ruleEditSelect.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            }

            function closeRuleInlineEdit() {
                if (!ruleInlineEditCard) {
                    return;
                }

                ruleInlineEditCard.style.display = 'none';
                if (ruleEditSelect) {
                    ruleEditSelect.selectedIndex = 0;
                    ruleEditSelect.dispatchEvent(new Event('change'));
                }
            }

            document.querySelectorAll('.rule-inline-edit-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    openRuleInlineEdit(button);
                });
            });

            if (ruleInlineEditCancel) {
                ruleInlineEditCancel.addEventListener('click', closeRuleInlineEdit);
            }

            var assignAttributeToCategoryForm = document.getElementById('assign-attribute-to-category-form');
            if (assignAttributeToCategoryForm) {
                assignAttributeToCategoryForm.addEventListener('submit', function () {
                    localStorage.setItem(ruleSectionTabKey, '#rule-section-edit');
                });
            }

            var updateCategoryAttributeRuleForm = document.getElementById('update-category-attribute-rule-form');
            if (updateCategoryAttributeRuleForm) {
                updateCategoryAttributeRuleForm.addEventListener('submit', function () {
                    localStorage.setItem(ruleSectionTabKey, '#rule-section-edit');
                });
            }

            document.querySelectorAll('form[action$="RemoveCategoryAttributeRule"], form[action$="ActivateCategoryAttributeRule"], form[action$="DeactivateCategoryAttributeRule"]').forEach(function (form) {
                form.addEventListener('submit', function () {
                    localStorage.setItem(ruleSectionTabKey, '#rule-section-list');
                });
            });

            document.querySelectorAll('form[data-loading-form]').forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (form.id && watchedFormIds.indexOf(form.id) >= 0) {
                        saveFormDraft(form);
                        localStorage.setItem(submittedFormKey, getFormDraftKey(form));
                    }

                    var submitButtons = form.querySelectorAll('button[type="submit"]');
                    submitButtons.forEach(function (button) {
                        button.setAttribute('disabled', 'disabled');
                    });
                });
            });

            watchedForms.forEach(function (form) {
                form.querySelectorAll('input, textarea, select').forEach(function (field) {
                    field.addEventListener('change', function () {
                        saveFormDraft(form);
                    });
                    field.addEventListener('input', function () {
                        saveFormDraft(form);
                    });
                });
            });

            document.querySelectorAll('form[data-dirty-watch]').forEach(function (form) {
                form.querySelectorAll('input, textarea, select').forEach(function (field) {
                    field.addEventListener('change', function () {
                        form.dataset.isDirty = 'true';
                        dirtyForms.add(form);
                    });
                    field.addEventListener('input', function () {
                        form.dataset.isDirty = 'true';
                        dirtyForms.add(form);
                    });
                });

                form.addEventListener('submit', function () {
                    form.dataset.isDirty = 'false';
                    dirtyForms.delete(form);
                });
            });

            window.addEventListener('beforeunload', function (event) {
                var hasDirty = Array.from(dirtyForms).some(function (form) {
                    return form.dataset.isDirty === 'true';
                });

                if (!hasDirty) {
                    return;
                }

                event.preventDefault();
                event.returnValue = '';
            });
        })();
    </script>
}



