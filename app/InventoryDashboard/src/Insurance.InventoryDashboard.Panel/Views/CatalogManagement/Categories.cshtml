                                                                        <span>@category.Name</span>
                                                                        <span class="badge badge-pill badge-light ml-1">@levelLabel</span>
                                                                        @if (childCount > 0)
                                                                        {
                                                                            <span class="badge badge-pill badge-outline-primary ml-1">@childCount @UiText["catalog.categories.childCountSuffix"]</span>
                                                                        }
                                                                    </span>
                                                                </td>
                                                                <td>
                                                                    <span class="badge badge-pill @(category.IsActive ? "badge-primary" : "badge-secondary")">
                                                                        @(category.IsActive ? UiText["common.active"] : UiText["common.inactive"])
                                                                    </span>
                                                                </td>
                                                                <td><span class="small text-muted">@GetCategoryPathById(category.Id)</span></td>
