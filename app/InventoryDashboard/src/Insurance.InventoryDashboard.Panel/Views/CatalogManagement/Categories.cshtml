                                                                    <button type="submit" class="btn btn-outline-danger btn-xs" data-confirm-title="حذف ویژگی" data-confirm="این ویژگی حذف شود؟" @(Can("Catalog.AttributeDefinition.Delete", "AttributeDefinition.Delete") ? null : "disabled")>حذف</button>
                                                                </form>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
