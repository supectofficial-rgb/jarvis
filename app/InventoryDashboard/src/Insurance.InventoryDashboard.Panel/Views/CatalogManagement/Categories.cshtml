                                                                    <input type="hidden" name="attributeId" value="@attr.Id" />
                                                                    <button type="submit" class="btn btn-outline-success btn-xs" @(Can("Catalog.AttributeDefinition.Activate", "AttributeDefinition.Activate") ? null : "disabled")>فعال</button>
                                                                </form>
                                                                <form asp-action="DeactivateAttributeDefinition" method="post" class="d-inline" data-loading-form>
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                                                    <input type="hidden" name="attributeId" value="@attr.Id" />
                                                                    <button type="submit" class="btn btn-outline-warning btn-xs" @(Can("Catalog.AttributeDefinition.Deactivate", "AttributeDefinition.Deactivate") ? null : "disabled")>غیرفعال</button>
                                                                </form>
                                                                <form asp-action="DeleteAttributeDefinition" method="post" class="d-inline" data-loading-form>
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
