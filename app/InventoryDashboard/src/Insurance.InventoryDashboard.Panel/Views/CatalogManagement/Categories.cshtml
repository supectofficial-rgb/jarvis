                                                <label class="custom-control-label" asp-for="AssignForm.IsOverridden">بازنویسی‌شده</label>
                                            </div>
                                            <div class="custom-control custom-checkbox mt-2 mb-3">
                                                <input asp-for="AssignForm.IsActive" class="custom-control-input" />
                                                <label class="custom-control-label" asp-for="AssignForm.IsActive">فعال</label>
                                            </div>
                                            <button class="btn btn-success" type="submit" @(Can("Catalog.Category.Rule.Assign", "CategoryAttributeRule.Assign", "CategoryAttributeRule.Create") ? null : "disabled")>ثبت انتساب</button>
                                        </form>
                                    </div>
                                </div>

                                <div class="card">
                                    <div class="card-body">
                                        <h5 class="card-title">ویرایش قانون</h5>
                                        <form asp-action="UpdateCategoryAttributeRule" method="post" id="update-category-attribute-rule-form" data-loading-form data-dirty-watch>
                                            @Html.AntiForgeryToken()
                                            <input asp-for="RuleForm.CategoryId" type="hidden" value="@Model.SelectedCategoryId" />
                                            <div class="form-group">
                                                <label>ویژگی</label>
                                                <select asp-for="RuleForm.AttributeId" class="form-control js-search-select" data-placeholder="انتخاب ویژگی قانون">
                                                    @foreach (var rule in Model.CategoryAttributeRules.Where(x => !x.IsInherited))
                                                    {
                                                        <option value="@rule.AttributeId">@rule.AttributeName</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group"><label>ترتیب نمایش</label><input asp-for="RuleForm.DisplayOrder" type="number" min="0" class="form-control" /></div>
                                            <div class="custom-control custom-checkbox"><input asp-for="RuleForm.IsRequired" class="custom-control-input" /><label class="custom-control-label" asp-for="RuleForm.IsRequired">الزامی</label></div>
                                            <div class="custom-control custom-checkbox mt-2"><input asp-for="RuleForm.IsVariant" class="custom-control-input" /><label class="custom-control-label" asp-for="RuleForm.IsVariant">سطح واریانت</label></div>
                                            <div class="custom-control custom-checkbox mt-2"><input asp-for="RuleForm.IsOverridden" class="custom-control-input" /><label class="custom-control-label" asp-for="RuleForm.IsOverridden">بازنویسی‌شده</label></div>
                                            <div class="custom-control custom-checkbox mt-2"><input asp-for="RuleForm.IsActive" class="custom-control-input" /><label class="custom-control-label" asp-for="RuleForm.IsActive">فعال</label></div>
                                            <button class="btn btn-outline-primary mt-3" type="submit" @(Can("Catalog.Category.Rule.Update", "CategoryAttributeRule.Update") ? null : "disabled")>به‌روزرسانی قانون</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                            </div>

                            <div class="tab-pane" id="rule-section-list" role="tabpanel">
                        <div class="row">
                            <div class="col-12 mb-4">
                                <div class="card">
                                    <div class="card-body">
                                        <h5 class="card-title">قوانین دسته‌بندی</h5>
                                        <div class="table-responsive">
                                            <table class="table table-sm table-striped">
                                                <thead>
                                                    <tr>
                                                        <th>ویژگی</th>
                                                        <th>الزامی</th>
                                                        <th>سطح واریانت</th>
                                                        <th>ترتیب</th>
                                                        <th>بازنویسی‌شده</th>
                                                        <th>فعال</th>
                                                        <th>منبع</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var rule in Model.CategoryAttributeRules)
                                                    {
                                                        <tr>
                                                            <td>@rule.AttributeName <span class="text-muted small">(@rule.DataType)</span></td>
                                                            <td>@(rule.RuleIsRequired ? "بله" : "خیر")</td>
                                                            <td>@(rule.RuleIsVariant ? "بله" : "خیر")</td>
                                                            <td>@rule.RuleDisplayOrder</td>
                                                            <td>@(rule.RuleIsOverridden ? "بله" : "خیر")</td>
                                                            <td>@(rule.RuleIsActive ? "فعال" : "غیرفعال")</td>
                                                            <td>@(rule.IsInherited ? $"ارث‌رسیده از {rule.SourceCategoryName}" : "مستقیم")</td>
                                                            <td class="text-nowrap">
                                                                @if (!rule.IsInherited)
                                                                {
                                                                    <button type="button"
                                                                            class="btn btn-outline-secondary btn-xs rule-modal-edit-btn"
                                                                            data-rule-category-id="@Model.SelectedCategoryId"
                                                                            data-rule-attribute-id="@rule.AttributeId"
                                                                            data-rule-attribute-name="@rule.AttributeName"
                                                                            data-rule-display-order="@rule.RuleDisplayOrder"
                                                                            data-rule-required="@(rule.RuleIsRequired ? "true" : "false")"
                                                                            data-rule-variant="@(rule.RuleIsVariant ? "true" : "false")"
                                                                            data-rule-overridden="@(rule.RuleIsOverridden ? "true" : "false")"
                                                                            data-rule-active="@(rule.RuleIsActive ? "true" : "false")"
                                                                            data-toggle="modal"
                                                                            data-target="#ruleEditModal"
                                                                            @(Can("Catalog.Category.Rule.Update", "CategoryAttributeRule.Update") ? null : "disabled")>
                                                                        ویرایش
                                                                    </button>
                                                                    <form asp-action="ActivateCategoryAttributeRule" method="post" class="d-inline" data-loading-form>
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                                                        <input type="hidden" name="attributeId" value="@rule.AttributeId" />
                                                                        <button class="btn btn-outline-success btn-xs" type="submit" @(Can("Catalog.Category.Rule.Activate", "CategoryAttributeRule.Activate") ? null : "disabled")>فعال</button>
                                                                    </form>
                                                                    <form asp-action="DeactivateCategoryAttributeRule" method="post" class="d-inline" data-loading-form>
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                                                        <input type="hidden" name="attributeId" value="@rule.AttributeId" />
                                                                        <button class="btn btn-outline-warning btn-xs" type="submit" @(Can("Catalog.Category.Rule.Deactivate", "CategoryAttributeRule.Deactivate") ? null : "disabled")>غیرفعال</button>
                                                                    </form>
                                                                    <form asp-action="RemoveCategoryAttributeRule" method="post" class="d-inline" data-loading-form>
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                                                        <input type="hidden" name="attributeId" value="@rule.AttributeId" />
                                                                        <button class="btn btn-outline-danger btn-xs" type="submit" data-confirm-title="حذف قانون" data-confirm="این قانون دسته‌بندی حذف شود؟" @(Can("Catalog.Category.Rule.Remove", "CategoryAttributeRule.Remove", "CategoryAttributeRule.Delete") ? null : "disabled")>حذف</button>
                                                                    </form>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<div class="modal fade" id="ruleEditModal" tabindex="-1" role="dialog" aria-labelledby="ruleEditModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="ruleEditModalLabel">ویرایش قانون ویژگی</h5>
                <button type="button" class="close p-0" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form asp-action="UpdateCategoryAttributeRule" method="post" id="rule-modal-form" data-loading-form data-dirty-watch>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CategoryId" id="rule-modal-category-id" value="@Model.SelectedCategoryId" />
                    <input type="hidden" name="AttributeId" id="rule-modal-attribute-id" />
                    <div class="form-group">
                        <label>ویژگی</label>
                        <input type="text" id="rule-modal-attribute-name" class="form-control" readonly />
                    </div>
                    <div class="form-group">
                        <label>ترتیب نمایش</label>
                        <input type="number" name="DisplayOrder" id="rule-modal-display-order" min="0" class="form-control" />
                    </div>
                    <div class="custom-control custom-checkbox">
                        <input type="checkbox" name="IsRequired" id="rule-modal-required" class="custom-control-input" />
                        <label class="custom-control-label" for="rule-modal-required">الزامی</label>
                    </div>
                    <div class="custom-control custom-checkbox mt-2">
                        <input type="checkbox" name="IsVariant" id="rule-modal-variant" class="custom-control-input" />
                        <label class="custom-control-label" for="rule-modal-variant">سطح واریانت</label>
                    </div>
                    <div class="custom-control custom-checkbox mt-2">
                        <input type="checkbox" name="IsOverridden" id="rule-modal-overridden" class="custom-control-input" />
                        <label class="custom-control-label" for="rule-modal-overridden">بازنویسی‌شده</label>
                    </div>
                    <div class="custom-control custom-checkbox mt-2">
                        <input type="checkbox" name="IsActive" id="rule-modal-active" class="custom-control-input" />
