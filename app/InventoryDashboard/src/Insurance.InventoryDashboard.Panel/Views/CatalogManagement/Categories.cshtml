                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                        .then(getJson)
                        .then(function (payload) {
                            if (!payload.isSuccess) {
                                setOptionsMessage(row, payload.errorMessage || categoryTexts.optionDeleteFailed, true);
                                return;
                            }
                            renderOptions(row, payload.items || []);
                            setOptionsMessage(row, payload.message || categoryTexts.optionDeleteSucceeded, false);
                        })
                        .catch(function () {
                            setOptionsMessage(row, categoryTexts.optionServerUnavailable, true);
                        });
                });
            });

            document.querySelectorAll('.attribute-options-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    var attributeId = button.getAttribute('data-attribute-id') || '';
                    var row = document.querySelector('.attribute-options-row[data-options-for="' + attributeId + '"]');
                    if (!row) {
