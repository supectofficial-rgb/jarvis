                    var form = event.target.closest('form');
                    if (!form) {
                        return;
                    }

                    event.preventDefault();
                    localStorage.setItem(ruleSectionTabKey, '#rule-section-list');
                    submitRuleListForm(form);
                });
            }

            if (formulaListScope) {
                formulaListScope.addEventListener('submit', function (event) {
