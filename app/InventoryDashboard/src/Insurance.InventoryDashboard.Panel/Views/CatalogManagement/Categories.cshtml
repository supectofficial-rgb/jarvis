@using System
@using System.Linq
@using System.Text.Json
@model Insurance.InventoryDashboard.Panel.Models.CategoryManagementPageViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = UiText["catalog.categories.title"];
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;
    var isEditMode = !string.IsNullOrWhiteSpace(Model.CategoryForm.CategoryId);

    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x =>
        string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));
    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    var parentLookup = Model.FlatCategories
        .GroupBy(x => x.Id, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);
    var childrenLookup = Model.FlatCategories
        .GroupBy(x => x.ParentCategoryId ?? string.Empty, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(x => x.Key, x => x.Select(c => c.Id).ToList(), StringComparer.OrdinalIgnoreCase);

    bool HasChildren(string categoryId) => childrenLookup.TryGetValue(categoryId ?? string.Empty, out var children) && children.Count > 0;

    int GetDepth(Insurance.InventoryDashboard.Panel.Models.CategoryNodeModel category)
    {
        var depth = 0;
        var currentParentId = category.ParentCategoryId;
        var guard = 0;
        while (!string.IsNullOrWhiteSpace(currentParentId) &&
               guard < 1024 &&
               parentLookup.TryGetValue(currentParentId, out var parent))
        {
            depth++;
            currentParentId = parent.ParentCategoryId;
            guard++;
        }

        return depth;
    }

    string GetCategoryPathById(string? categoryId)
    {
        if (string.IsNullOrWhiteSpace(categoryId) || !parentLookup.TryGetValue(categoryId, out var current))
        {
            return "-";
        }

        var parts = new List<string>();
        var guard = 0;
        while (current is not null && guard < 1024)
        {
            parts.Add(current.Name);
            if (string.IsNullOrWhiteSpace(current.ParentCategoryId) || !parentLookup.TryGetValue(current.ParentCategoryId, out current))
            {
                break;
            }
            guard++;
        }

        parts.Reverse();
        return string.Join(" / ", parts);
    }

    string? ResolveMediaUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return null;
        }

        var trimmed = url.Trim();
        if (Uri.TryCreate(trimmed, UriKind.Absolute, out _))
        {
            return trimmed;
        }

        var configuredBaseUrl = Configuration["FileService:BaseUrl"]?.TrimEnd('/');
        var requestHost = Context?.Request?.Host.Host;
        var requestScheme = Context?.Request?.Scheme ?? "http";
        var configuredBaseIsLocalOnly =
            Uri.TryCreate(configuredBaseUrl, UriKind.Absolute, out var configuredUri) &&
            (string.Equals(configuredUri.Host, "localhost", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(configuredUri.Host, "127.0.0.1", StringComparison.OrdinalIgnoreCase)) &&
            !string.IsNullOrWhiteSpace(requestHost) &&
            !string.Equals(requestHost, "localhost", StringComparison.OrdinalIgnoreCase) &&
            !string.Equals(requestHost, "127.0.0.1", StringComparison.OrdinalIgnoreCase);
        var baseUrl = !string.IsNullOrWhiteSpace(configuredBaseUrl) && !configuredBaseIsLocalOnly
            ? configuredBaseUrl
            : (!string.IsNullOrWhiteSpace(requestHost) ? $"{requestScheme}://{requestHost}:8080" : null);

        return string.IsNullOrWhiteSpace(baseUrl)
            ? trimmed
            : $"{baseUrl}/{trimmed.TrimStart('/')}";
    }

    var hasRestrictedActions = !Can("Catalog.Category.Create", "Catalog.Category.Update", "Category.Create", "Category.Update")
        || !Can("Catalog.Category.Move", "Category.Move")
        || !Can("Catalog.Category.Activate", "Category.Activate")
        || !Can("Catalog.Category.Deactivate", "Category.Deactivate")
        || !Can("Catalog.Category.Delete", "Category.Delete")
        || !Can("Catalog.AttributeDefinition.Update", "AttributeDefinition.Update")
        || !Can("Catalog.AttributeOption.Update", "AttributeOption.Update")
        || !Can("Catalog.Category.Rule.Update", "CategoryAttributeRule.Update")
        || !Can("Catalog.Category.Formula.Manage", "Inventory.CategoryVariantNameFormula.Manage");
    var hasCatalogSuccess = TempData.ContainsKey("CatalogSuccess");
    var selectedCategoryPath = GetCategoryPathById(Model.SelectedCategoryId);
    var selectedCategory = Model.FlatCategories.FirstOrDefault(x => string.Equals(x.Id, Model.SelectedCategoryId, StringComparison.OrdinalIgnoreCase));
    var selectedCategoryChildrenCount = selectedCategory is null
        ? 0
        : Model.FlatCategories.Count(x => string.Equals(x.ParentCategoryId, selectedCategory.Id, StringComparison.OrdinalIgnoreCase));
    var activeSurface = Model.ActiveItem?.ItemId ?? "categories";
    var showCategories = string.Equals(activeSurface, "categories", StringComparison.OrdinalIgnoreCase);
    var showAttributes = string.Equals(activeSurface, "attributes", StringComparison.OrdinalIgnoreCase);
    var showRules = string.Equals(activeSurface, "category_attribute_rules", StringComparison.OrdinalIgnoreCase);
    var showFormulas = string.Equals(activeSurface, "variant_name_formulas", StringComparison.OrdinalIgnoreCase);
    var localRules = Model.CategoryAttributeRules.Where(x => !x.IsInherited).ToList();
    var localFormulas = Model.CategoryVariantNameFormulas.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name).ToList();
    var formulaAttributeSource = Model.CategoryAttributes.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name).ToList();
    var categoryFormPreviewUrl = ResolveMediaUrl(Model.CategoryForm.ImageThumbnailUrl ?? Model.CategoryForm.ImageUrl);
}

<style>
    #category-section-tabs a[href="#category-section-details"],
    #category-section-details,
    #move-category-card,
    #category-list-scope [data-bulk-form],
    #category-list-scope table th:first-child,
    #category-list-scope table td:first-child,
    #rule-tab > .card.mb-4:first-of-type {
        display: none;
    }
    .category-list-image {
        width: 48px;
        height: 48px;
        border-radius: .75rem;
        overflow: hidden;
        background: #f2f4f7;
        border: 1px solid #e2e6ea;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #9aa3ad;
        font-size: 1.25rem;
    }
    .category-list-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
</style>

<main id="categories-page"
      class="catalog-page"
      data-selected-category-id="@Model.SelectedCategoryId"
      data-catalog-success="@hasCatalogSuccess.ToString().ToLowerInvariant()">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h1>@UiText["catalog.categories.title"]</h1>
                <p class="text-muted">@UiText["catalog.categories.description"]</p>
                <div class="mb-3">
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.categories.primaryGoal"]</span>
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.categories.secondaryOperations"]</span>
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.categories.totalCount"] @Model.FlatCategories.Count</span>
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.categories.filteredCount"] @Model.FilteredFlatCategories.Count</span>
                    @if (!string.IsNullOrWhiteSpace(Model.SelectedCategoryId))
                    {
                        <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.categories.selectedPath"] @selectedCategoryPath</span>
                    }
                </div>
                <p class="small text-muted mb-3">
                    @UiText["catalog.categories.quickGuide"]
                </p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) || TempData["CatalogError"] is string)
        {
            <div class="row">
                <div class="col-12">
                    <div class="alert alert-warning mb-3">
                        @(TempData["CatalogError"] as string ?? Model.ErrorMessage)
                    </div>
                </div>
            </div>
        }

        @if (TempData["CatalogSuccess"] is string successMessage)
        {
            <div class="row">
                <div class="col-12">
                    <div class="alert alert-success mb-3">@successMessage</div>
                </div>
            </div>
        }

        @await Html.PartialAsync("~/Views/Shared/_CatalogPermissionNotice.cshtml", hasRestrictedActions)

        <div class="row">
            <div class="col-12">
                <ul class="nav nav-tabs separator-tabs mb-4 d-none" role="tablist" id="category-tabs">
                    <li class="nav-item"><a class="nav-link @(showCategories ? "active" : null)" data-toggle="tab" href="#category-tab" role="tab">@UiText["catalog.categories.tabs.categories"]</a></li>
                    <li class="nav-item"><a class="nav-link @(showAttributes ? "active" : null)" data-toggle="tab" href="#attribute-tab" role="tab">@UiText["catalog.categories.tabs.attributesAndOptions"]</a></li>
                    <li class="nav-item"><a class="nav-link @(showRules ? "active" : null)" data-toggle="tab" href="#rule-tab" role="tab">@UiText["catalog.categories.tabs.rules"]</a></li>
                    <li class="nav-item"><a class="nav-link @(showFormulas ? "active" : null)" data-toggle="tab" href="#formula-tab" role="tab">@UiText["catalog.categories.tabs.formulas"]</a></li>
                </ul>

                <div class="tab-content">
                    @if (showCategories)
                    {
                    <div class="tab-pane @(showCategories ? "show active" : null)" id="category-tab" role="tabpanel">
                        <ul class="nav nav-tabs separator-tabs mb-4" role="tablist" id="category-section-tabs">
                            <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#category-section-edit" role="tab">@UiText["catalog.categories.sections.edit"]</a></li>
                            <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#category-section-list" role="tab">@UiText["catalog.categories.sections.list"]</a></li>
                            <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#category-section-details" role="tab">@UiText["common.details"]</a></li>
                        </ul>
                        <div class="tab-content">
                            <div class="tab-pane show active" id="category-section-edit" role="tabpanel">
                        <div class="row">
                            <div class="col-12 mb-4">
                                <div class="card mb-4">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <h5 class="card-title mb-0">@(isEditMode ? UiText["catalog.categories.editTitle"] : UiText["catalog.categories.createTitle"])</h5>
                                            @if (isEditMode)
                                            {
                                                <a asp-action="Categories" asp-route-createNew="true" asp-route-clearCatalogMessage="true" class="btn btn-outline-secondary btn-xs">@UiText["common.createNew"]</a>
                                            }
                                        </div>

                                        <form asp-action="SaveCategory" method="post" id="category-upsert-form" data-loading-form data-dirty-watch>
                                            @Html.AntiForgeryToken()
                                            <input asp-for="CategoryForm.CategoryId" type="hidden" />
                                            <input asp-for="CategoryForm.ImageFileKey" type="hidden" />
                                            <input asp-for="CategoryForm.ImageUrl" type="hidden" />
                                            <input asp-for="CategoryForm.ImageThumbnailUrl" type="hidden" />
                                            <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                                            <div class="form-group">
                                                <label>@UiText["catalog.categories.code"]</label>
                                                <input asp-for="CategoryForm.Code" class="form-control" required maxlength="64" />
                                            </div>

                                            <div class="form-group">
                                                <label>@UiText["catalog.categories.name"]</label>
                                                <input asp-for="CategoryForm.Name" class="form-control" required />
                                            </div>

                                            <div class="form-group">
                                                <label>@UiText["catalog.categories.displayOrder"]</label>
                                                <input asp-for="CategoryForm.DisplayOrder" class="form-control" type="number" min="0" />
                                            </div>

                                            <div class="form-group">
                                                <label>@UiText["catalog.categories.parentCategory"]</label>
                                                <select asp-for="CategoryForm.ParentCategoryId" class="form-control js-search-select" data-placeholder='@UiText["catalog.categories.searchParent"]'>
                                                    <option value="">@UiText["catalog.categories.noParent"]</option>
                                                    @foreach (var category in Model.FlatCategories.Where(x => x.Id != Model.CategoryForm.CategoryId))
                                                    {
                                                        <option value="@category.Id">@category.Name</option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="form-group" data-media-uploader data-policy="category-image" data-base-url="@Configuration["FileService:BaseUrl"]">
                                                <div class="font-weight-bold mb-2">@UiText["category.image"]</div>
                                                <label>@UiText["category.image"]</label>
                                                <div class="border rounded p-3 bg-light">
                                                    <input type="file" class="form-control-file mb-2" accept=".jpg,.jpeg,.png,.webp" data-media-file />
                                                    <div class="progress mb-2 d-none" style="height:8px;" data-media-progress-wrap>
                                                        <div class="progress-bar" style="width:0%;" data-media-progress></div>
                                                    </div>
                                                    <div class="small text-muted mb-2" data-media-status>@UiText["media.imageHelp"]</div>
                                                    <button type="button" class="btn btn-outline-danger btn-xs d-none" data-media-remove>@UiText["media.removeImage"]</button>
                                                    <div class="mt-3 @(string.IsNullOrWhiteSpace(categoryFormPreviewUrl) ? "d-none" : null)" data-media-preview-wrap>
                                                        <img src="@categoryFormPreviewUrl" alt="preview" class="img-fluid rounded border" style="max-height:180px;" data-media-preview />
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="mt-3">
                                                <button class="btn btn-primary" type="submit" @((isEditMode ? Can("Inventory.Category.Update", "Catalog.Category.Update", "Category.Update") : Can("Inventory.Category.Create", "Catalog.Category.Create", "Category.Create")) ? null : "disabled")>
                                                    @(isEditMode ? UiText["catalog.categories.updateButton"] : UiText["catalog.categories.createTitle"])
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                @if (isEditMode && !string.IsNullOrWhiteSpace(Model.SelectedCategoryId))
                                {
                                    <div class="card" id="move-category-card">
                                        <div class="card-body">
                                            <h5 class="card-title">@UiText["catalog.categories.moveTitle"]</h5>
                                            <form asp-action="MoveCategory" method="post" id="move-category-form" data-loading-form data-dirty-watch>
                                                @Html.AntiForgeryToken()
                                                <input asp-for="MoveCategoryForm.CategoryId" type="hidden" value="@Model.SelectedCategoryId" />
                                                <div class="form-group">
                                                    <label>@UiText["catalog.categories.newParent"]</label>
                                                    <select asp-for="MoveCategoryForm.ParentCategoryId" class="form-control js-search-select" data-placeholder='@UiText["catalog.categories.selectNewParent"]'>
                                                        <option value="">@UiText["catalog.categories.noParent"]</option>
                                                        @foreach (var category in Model.FlatCategories.Where(x => x.Id != Model.SelectedCategoryId))
                                                        {
                                                            <option value="@category.Id">@category.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="mt-3">
                                                    <button type="submit" class="btn btn-outline-primary" @(Can("Catalog.Category.Move", "Category.Move") ? null : "disabled")>@UiText["catalog.categories.moveButton"]</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                            </div>

                            <div class="tab-pane" id="category-section-list" role="tabpanel">
                        <div class="row">
                            <div class="col-12 mb-4">
                                <div class="card">
                                    <div class="card-body" id="category-list-scope">
                                        <h5 class="card-title mb-3">@UiText["catalog.categories.sections.list"]</h5>

                                        <form method="get" asp-action="Categories" class="row mb-3" id="category-search-form" data-state-form>
                                            <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                            <div class="col-md-6 mb-2">
                                                <label class="text-muted small">@UiText["common.search"]</label>
                                                <input name="searchTerm" value="@Model.CategorySearchTerm" class="form-control" data-filter-label='@UiText["common.search"]' placeholder='@UiText["catalog.categories.searchPlaceholder"]' />
                                            </div>
                                            <div class="col-md-2 mb-2">
                                                <label class="text-muted small">@UiText["common.status"]</label>
                                                <select name="statusFilter" class="form-control" data-filter-label='@UiText["catalog.categories.filters.status"]'>
                                                    <option value="">@UiText["catalog.categories.all"]</option>
                                                    <option value="active" selected="@(string.Equals(Model.CategoryStatusFilter, "active", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["common.active"]</option>
                                                    <option value="inactive" selected="@(string.Equals(Model.CategoryStatusFilter, "inactive", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["common.inactive"]</option>
                                                </select>
                                            </div>
                                            <div class="col-md-2 mb-2">
                                                <label class="text-muted small">@UiText["catalog.categories.sort"]</label>
                                                <select name="sort" class="form-control" data-filter-label='@UiText["catalog.categories.filters.sort"]'>
                                                    <option value="">@UiText["catalog.categories.sortOptions.nameAsc"]</option>
                                                    <option value="name_desc" selected="@(string.Equals(Model.CategorySort, "name_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["catalog.categories.sortOptions.nameDesc"]</option>
                                                    <option value="code_asc" selected="@(string.Equals(Model.CategorySort, "code_asc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["catalog.categories.sortOptions.codeAsc"]</option>
                                                    <option value="code_desc" selected="@(string.Equals(Model.CategorySort, "code_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["catalog.categories.sortOptions.codeDesc"]</option>
                                                    <option value="displayorder_asc" selected="@(string.Equals(Model.CategorySort, "displayorder_asc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["catalog.categories.sortOptions.displayOrderAsc"]</option>
                                                    <option value="displayorder_desc" selected="@(string.Equals(Model.CategorySort, "displayorder_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["catalog.categories.sortOptions.displayOrderDesc"]</option>
                                                    <option value="status_asc" selected="@(string.Equals(Model.CategorySort, "status_asc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["catalog.categories.sortOptions.statusActiveFirst"]</option>
                                                    <option value="status_desc" selected="@(string.Equals(Model.CategorySort, "status_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["catalog.categories.sortOptions.statusInactiveFirst"]</option>
                                                </select>
                                            </div>
                                            <div class="col-md-1 mb-2">
                                                <label class="text-muted small">@UiText["common.count"]</label>
                                                <select name="pageSize" class="form-control" data-filter-label='@UiText["catalog.categories.filters.pageSize"]'>
                                                    @foreach (var size in Model.CategoryPageSizeOptions)
                                                    {
                                                        <option value="@size" selected="@(size == Model.CategoryPageSize ? "selected" : null)">@size</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-md-1 mb-2 d-flex align-items-end">
                                                <button type="submit" class="btn btn-primary btn-block">@UiText["common.apply"]</button>
                                            </div>
                                        </form>

                                        <div class="d-flex align-items-center justify-content-between flex-wrap mb-2">
                                            <div class="btn-group btn-group-sm mb-2">
                                                <button type="button" class="btn btn-outline-secondary" data-tree-expand-all>@UiText["catalog.categories.expandAll"]</button>
                                                <button type="button" class="btn btn-outline-secondary" data-tree-collapse-all>@UiText["catalog.categories.collapseAll"]</button>
                                            </div>
                                            <span class="small text-muted mb-2">@UiText["catalog.categories.bulkHelp"]</span>
                                        </div>

                                        <form asp-action="ApplyCategoryBulkAction"
                                              method="post"
                                              class="form-inline mb-3"
                                              data-loading-form
                                              data-bulk-form
                                              data-bulk-scope="#category-list-scope">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="selectedIds" data-bulk-target />
                                            <input type="hidden" name="bulkAction" data-bulk-action-input />
                                            <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                            <input type="hidden" name="searchTerm" value="@Model.CategorySearchTerm" />
                                            <input type="hidden" name="statusFilter" value="@Model.CategoryStatusFilter" />
                                            <input type="hidden" name="sort" value="@Model.CategorySort" />
                                            <input type="hidden" name="page" value="@Model.CategoryPage" />
                                            <input type="hidden" name="pageSize" value="@Model.CategoryPageSize" />
                                            <div class="small text-muted mr-2 mb-2">
                                                @UiText["catalog.categories.selectedCount"] <span data-bulk-count>0</span>
                                            </div>
                                            <div class="btn-group btn-group-sm mb-2">
                                                <button type="submit"
                                                        class="btn btn-outline-success btn-xs"
                                                        data-bulk-action="activate"
                                                        data-bulk-permission="@(Can("Catalog.Category.Activate", "Category.Activate") ? "allowed" : "denied")"
                                                        data-confirm-title="@UiText["catalog.categories.bulkActivateTitle"]"
                                                        data-confirm="@UiText["catalog.categories.bulkActivateConfirm"]"
                                                        disabled
                                                        @(Can("Catalog.Category.Activate", "Category.Activate") ? null : "disabled")>
                                                    @UiText["catalog.categories.bulkActivateButton"]
                                                </button>
                                                <button type="submit"
                                                        class="btn btn-outline-warning btn-xs"
                                                        data-bulk-action="deactivate"
                                                        data-bulk-permission="@(Can("Catalog.Category.Deactivate", "Category.Deactivate") ? "allowed" : "denied")"
                                                        data-confirm-title="@UiText["catalog.categories.bulkDeactivateTitle"]"
                                                        data-confirm="@UiText["catalog.categories.bulkDeactivateConfirm"]"
                                                        disabled
                                                        @(Can("Catalog.Category.Deactivate", "Category.Deactivate") ? null : "disabled")>
                                                    @UiText["catalog.categories.bulkDeactivateButton"]
                                                </button>
                                                <button type="submit"
                                                        class="btn btn-outline-danger btn-xs"
                                                        data-bulk-action="delete"
                                                        data-bulk-permission="@(Can("Catalog.Category.Delete", "Category.Delete") ? "allowed" : "denied")"
                                                        data-confirm-title="@UiText["catalog.categories.bulkDeleteTitle"]"
                                                        data-confirm="@UiText["catalog.categories.bulkDeleteConfirm"]"
                                                        disabled
                                                        @(Can("Catalog.Category.Delete", "Category.Delete") ? null : "disabled")>
                                                    @UiText["catalog.categories.bulkDeleteButton"]
                                                </button>
                                            </div>
                                        </form>

                                        <div class="table-responsive">
                                            <table class="table table-sm table-striped">
                                                <thead>
                                                    <tr>
                                                        <th>
                                                            <input type="checkbox" data-bulk-toggle aria-label='@UiText["catalog.categories.selectAll"]' />
                                                        </th>
                                                        <th>@UiText["category.image"]</th>
                                                        <th>@UiText["common.code"]</th>
                                                        <th>@UiText["common.name"]</th>
                                                        <th>@UiText["common.status"]</th>
                                                        <th>@UiText["catalog.categories.path"]</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @if (Model.FilteredFlatCategories.Count == 0)
                                                    {
                                                        <tr>
                                                            <td colspan="7">
                                                                <div class="alert alert-light my-2">
                                                                    <h6>@UiText["catalog.categories.noRecordFound"]</h6>
                                                                    <p class="mb-0 text-muted">@UiText["catalog.categories.noRecordFoundHelp"]</p>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var category in Model.FilteredFlatCategories)
                                                        {
                                                            var parentName = Model.FlatCategories.FirstOrDefault(x => x.Id == category.ParentCategoryId)?.Name;
                                                            var depth = GetDepth(category);
                                                            var levelLabel = string.Format(UiText["catalog.categories.levelLabelFormat"], depth + 1);
                                                            var hasChildren = HasChildren(category.Id);
                                                            var childCount = Model.FlatCategories.Count(x => string.Equals(x.ParentCategoryId, category.Id, StringComparison.OrdinalIgnoreCase));
