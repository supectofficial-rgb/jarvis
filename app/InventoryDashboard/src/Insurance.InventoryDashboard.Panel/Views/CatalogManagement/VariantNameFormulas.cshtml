                var separator = getSeparatorValue(createSeparatorField);

                var normalized = String(attributeId).toLowerCase();
                var existingIndex = createState.parts.findIndex(function (part) {
                    return String(part.attributeId || '').toLowerCase() === normalized;
                });

                if (createState.editingPartIndex >= 0) {
                    if (existingIndex >= 0 && existingIndex !== createState.editingPartIndex) {
                        return;
