@using System
@using System.Linq
@using System.Text.Json
@model Insurance.InventoryDashboard.Panel.Models.CategoryManagementPageViewModel
@{
    ViewData["Title"] = UiText["catalog.categories.title"];
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x =>
        string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));
    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    var parentLookup = Model.FlatCategories
        .GroupBy(x => x.Id, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);

    string GetCategoryPathById(string? categoryId)
    {
        if (string.IsNullOrWhiteSpace(categoryId) || !parentLookup.TryGetValue(categoryId, out var current))
        {
            return "-";
        }

        var parts = new List<string>();
        var guard = 0;
        while (current is not null && guard < 1024)
        {
            parts.Add(current.Name);
            if (string.IsNullOrWhiteSpace(current.ParentCategoryId) || !parentLookup.TryGetValue(current.ParentCategoryId, out current))
            {
                break;
            }
            guard++;
        }

        parts.Reverse();
        return string.Join(" / ", parts);
    }

    var hasRestrictedActions = !Can("Catalog.Category.Create", "Catalog.Category.Update", "Category.Create", "Category.Update")
        || !Can("Catalog.Category.Move", "Category.Move")
        || !Can("Catalog.Category.Activate", "Category.Activate")
        || !Can("Catalog.Category.Deactivate", "Category.Deactivate")
        || !Can("Catalog.Category.Delete", "Category.Delete")
        || !Can("Catalog.AttributeDefinition.Update", "AttributeDefinition.Update")
        || !Can("Catalog.AttributeOption.Update", "AttributeOption.Update")
        || !Can("Catalog.Category.Rule.Update", "CategoryAttributeRule.Update")
        || !Can("Catalog.Category.Formula.Manage", "Inventory.CategoryVariantNameFormula.Manage");
    var hasCatalogSuccess = TempData.ContainsKey("CatalogSuccess");
    var selectedCategoryPath = GetCategoryPathById(Model.SelectedCategoryId);
    var localFormulas = Model.CategoryVariantNameFormulas.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name).ToList();
    var formulaAttributeSource = Model.CategoryAttributes.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name).ToList();
}

<style>
    .category-list-image {
        width: 48px;
        height: 48px;
        border-radius: .75rem;
        overflow: hidden;
        background: #f2f4f7;
        border: 1px solid #e2e6ea;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #9aa3ad;
        font-size: 1.25rem;
    }

    .category-list-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
</style>

<main id="categories-page"
      class="catalog-page"
      data-selected-category-id="@Model.SelectedCategoryId"
      data-catalog-success="@hasCatalogSuccess.ToString().ToLowerInvariant()">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h1>@UiText["catalog.categories.title"]</h1>
                <p class="text-muted">@UiText["catalog.categories.description"]</p>
                <div class="mb-3">
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.categories.primaryGoal"]</span>
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.categories.secondaryOperations"]</span>
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.categories.totalCount"] @Model.FlatCategories.Count</span>
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.categories.filteredCount"] @Model.FilteredFlatCategories.Count</span>
                    @if (!string.IsNullOrWhiteSpace(Model.SelectedCategoryId))
                    {
                        <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.categories.selectedPath"] @selectedCategoryPath</span>
                    }
                </div>
                <p class="small text-muted mb-3">
                    @UiText["catalog.categories.quickGuide"]
                </p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) || TempData["CatalogError"] is string)
        {
            <div class="row">
                <div class="col-12">
                    <div class="alert alert-warning mb-3">
                        @(TempData["CatalogError"] as string ?? Model.ErrorMessage)
                    </div>
                </div>
            </div>
        }

        @if (TempData["CatalogSuccess"] is string successMessage)
        {
            <div class="row">
                <div class="col-12">
                    <div class="alert alert-success mb-3">@successMessage</div>
                </div>
            </div>
        }

        @await Html.PartialAsync("~/Views/Shared/_CatalogPermissionNotice.cshtml", hasRestrictedActions)

        <div class="row">
            <div class="col-12">
                <div id="formula-tab">
                    <ul class="nav nav-tabs separator-tabs mb-4" role="tablist" id="formula-section-tabs">
                        <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#formula-section-create" role="tab">@UiText["catalog.categories.sections.edit"]</a></li>
                        <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#formula-section-list" role="tab">@UiText["catalog.categories.formulaList"]</a></li>
                    </ul>
                    <div class="tab-content">
                        <div class="tab-pane show active" id="formula-section-create" role="tabpanel">
                            <div class="row">
                                <div class="col-12 mb-4">
                                    <div class="card">
                                        <div class="card-body">
                            <h5 class="card-title mb-3" id="formula-create-title">@UiText["catalog.categories.variantFormulaCreate"]</h5>
                            <p class="text-muted small mb-3">@UiText["catalog.categories.formulas.partsHelp"]</p>
                            <form asp-action="CreateVariantNameFormula"
                                  method="post"
                                  id="variant-name-formula-create-form"
                                  data-loading-form
                                  data-dirty-watch
                                  data-create-action-url="@Url.Action("CreateVariantNameFormula")"
                                  data-update-action-url="@Url.Action("UpdateVariantNameFormula")">
                                @Html.AntiForgeryToken()
                                                <div asp-validation-summary="All" class="text-danger small mb-2"></div>
                                                <input id="VariantNameFormulaForm_Create_FormulaId" name="VariantNameFormulaForm.FormulaId" type="hidden" value="" />
                                                <input id="VariantNameFormulaForm_Create_PartsJson" name="VariantNameFormulaForm.PartsJson" type="hidden" value="[]" />

                                                <div class="form-group">
                                                    <label>@UiText["catalog.categories.rules.category"]</label>
                                                    <select asp-for="VariantNameFormulaForm.CategoryId" id="VariantNameFormulaForm_Create_CategoryId" class="form-control js-search-select" data-placeholder='@UiText["catalog.categories.formulas.selectCategory"]' required>
                                                        <option value="">@UiText["catalog.categories.formulas.selectCategory"]</option>
                                                        @foreach (var category in Model.LeafCategories)
                                                        {
                                                            <option value="@category.Id" selected="@(category.Id == Model.SelectedCategoryId ? "selected" : null)">@category.Name</option>
                                                        }
                                                    </select>
                                                </div>

                                                <div class="form-group">
                                                    <label>@UiText["catalog.categories.formulas.name"]</label>
                                                    <input asp-for="VariantNameFormulaForm.Name" id="VariantNameFormulaForm_Create_Name" class="form-control" required maxlength="120" />
                                                </div>

                                                <div class="form-row">
                                                    <div class="form-group col-md-6">
                                                        <label>@UiText["catalog.categories.formulas.separator"]</label>
                                                        <select asp-for="VariantNameFormulaForm.Separator" id="VariantNameFormulaForm_Create_Separator" class="form-control">
                                                            <option value="-">@UiText["catalog.categories.formulas.separator.dash"]</option>
                                                            <option value=" ">@UiText["catalog.categories.formulas.separator.space"]</option>
                                                            <option value="__none">@UiText["catalog.categories.formulas.separator.none"]</option>
                                                        </select>
                                                    </div>
                                                    <div class="form-group col-md-3">
                                                        <label>@UiText["catalog.categories.displayOrder"]</label>
                                                        <input asp-for="VariantNameFormulaForm.DisplayOrder" id="VariantNameFormulaForm_Create_DisplayOrder" class="form-control" type="number" min="0" />
                                                    </div>
                                                    <div class="form-group col-md-3 d-flex align-items-end">
                                                        <div class="custom-control custom-checkbox">
                                                            <input asp-for="VariantNameFormulaForm.IsActive" class="custom-control-input" id="VariantNameFormulaForm_IsActive_Create" />
                                                            <label class="custom-control-label" for="VariantNameFormulaForm_IsActive_Create">@UiText["catalog.categories.rules.isActive"]</label>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="form-group">
                                                    <div class="custom-control custom-checkbox">
                                                        <input asp-for="VariantNameFormulaForm.IncludeCategoryName" class="custom-control-input" id="VariantNameFormulaForm_Create_IncludeCategoryName" />
                                                        <label class="custom-control-label" for="VariantNameFormulaForm_Create_IncludeCategoryName">@UiText["catalog.categories.formulas.includeCategoryName"]</label>
                                                    </div>
                                                </div>

                                                <div class="form-group mt-3">
                                                    <label>@UiText["catalog.categories.formulas.attributes"]</label>
                                                    <div class="input-group mb-2">
                                                        <select id="formula-create-attribute-picker" class="form-control js-search-select" data-placeholder='@UiText["catalog.categories.formulas.selectAttribute"]'>
                                                            <option value="">@UiText["catalog.categories.formulas.selectAttribute"]</option>
                                                            @foreach (var attr in formulaAttributeSource)
                                                            {
                                                                <option value="@attr.Id">@attr.Name (@attr.Code / @attr.Scope @((attr.IsInherited ? UiText["catalog.categories.formulas.inheritedSuffix"] : string.Empty)))</option>
                                                            }
                                                        </select>
                                                        <div class="input-group-append">
                                                            <button type="button" class="btn btn-outline-primary" id="formula-create-add-part-btn" @(formulaAttributeSource.Count == 0 ? "disabled" : null)>@UiText["catalog.categories.attributeOptions.add"]</button>
                                                        </div>
                                                    </div>
                                                    @if (formulaAttributeSource.Count == 0)
                                                    {
                                                        <small class="form-text text-warning">@UiText["catalog.categories.formulas.noAttributes"]</small>
                                                    }
                                                    <div id="formula-create-parts-empty" class="alert alert-light small mb-2">@UiText["catalog.categories.formulas.emptyParts"]</div>
                                                    <div id="formula-create-parts-list" class="list-group"></div>
                                                </div>

                                <div class="mt-3">
                                    <button class="btn btn-primary" type="submit" id="formula-create-submit-btn" @(Can("Catalog.Category.Formula.Manage", "Inventory.CategoryVariantNameFormula.Manage") ? null : "disabled")>@UiText["common.save"]</button>
                                </div>
                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane" id="formula-section-list" role="tabpanel">
                            <div class="row">
                                <div class="col-12 mb-4">
                                    <div class="card mb-4">
                                        <div class="card-body">
                                            <form asp-action="VariantNameFormulas" method="get" class="row align-items-end" id="formula-category-list-form">
                                                <div class="col-lg-8 col-md-8 mb-2">
                                                    <label class="text-muted small">@UiText["catalog.categories.rules.category"]</label>
                                                    <select name="categoryId" class="form-control js-search-select" data-placeholder='@UiText["catalog.categories.formulas.selectCategory"]' required>
                                                        <option value="">@UiText["catalog.categories.formulas.selectCategory"]</option>
                                                        @foreach (var category in Model.LeafCategories)
                                                        {
                                                            <option value="@category.Id" selected="@(category.Id == Model.SelectedCategoryId ? "selected" : null)">@category.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-lg-4 col-md-4 mb-2">
                                                    <button type="submit" class="btn btn-primary btn-block">@UiText["catalog.categories.formulas.loadList"]</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>

                                    <div class="card mb-4" id="formula-inline-edit-panel" style="display:none;">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <h5 class="card-title mb-0" id="formula-form-title">@UiText["catalog.categories.variantFormulaEdit"]</h5>
                                                <button type="button" class="btn btn-outline-secondary btn-xs" id="formula-edit-cancel">@UiText["catalog.categories.formulas.reset"]</button>
                                            </div>
                                            <form asp-action="UpdateVariantNameFormula" method="post" id="variant-name-formula-form" data-loading-form data-dirty-watch>
                                                @Html.AntiForgeryToken()
                                                <div asp-validation-summary="All" class="text-danger small mb-2"></div>
                                                <input asp-for="VariantNameFormulaForm.CategoryId" type="hidden" id="VariantNameFormulaForm_Inline_CategoryId" value="@Model.SelectedCategoryId" />
                                                <input asp-for="VariantNameFormulaForm.FormulaId" type="hidden" id="VariantNameFormulaForm_Inline_FormulaId" />
                                                <input asp-for="VariantNameFormulaForm.PartsJson" type="hidden" id="VariantNameFormulaForm_Inline_PartsJson" value="[]" />

                                                <div class="form-group">
                                                    <label>@UiText["catalog.categories.formulas.name"]</label>
                                                    <input asp-for="VariantNameFormulaForm.Name" class="form-control" id="VariantNameFormulaForm_Inline_Name" required maxlength="120" />
                                                </div>

                                                <div class="form-row">
                                                    <div class="form-group col-md-6">
                                                        <label>@UiText["catalog.categories.formulas.separator"]</label>
                                                        <select asp-for="VariantNameFormulaForm.Separator" class="form-control" id="VariantNameFormulaForm_Inline_Separator">
                                                            <option value="-">@UiText["catalog.categories.formulas.separator.dash"]</option>
                                                            <option value=" ">@UiText["catalog.categories.formulas.separator.space"]</option>
                                                            <option value="__none">@UiText["catalog.categories.formulas.separator.none"]</option>
                                                        </select>
                                                    </div>
                                                    <div class="form-group col-md-3">
                                                        <label>@UiText["catalog.categories.displayOrder"]</label>
                                                        <input asp-for="VariantNameFormulaForm.DisplayOrder" class="form-control" id="VariantNameFormulaForm_Inline_DisplayOrder" type="number" min="0" />
                                                    </div>
                                                    <div class="form-group col-md-3 d-flex align-items-end">
                                                        <div class="custom-control custom-checkbox">
                                                            <input asp-for="VariantNameFormulaForm.IsActive" class="custom-control-input" id="VariantNameFormulaForm_Inline_IsActive" />
                                                            <label class="custom-control-label" for="VariantNameFormulaForm_Inline_IsActive">@UiText["catalog.categories.rules.isActive"]</label>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="form-group">
                                                    <div class="custom-control custom-checkbox">
                                                        <input asp-for="VariantNameFormulaForm.IncludeCategoryName" class="custom-control-input" id="VariantNameFormulaForm_Inline_IncludeCategoryName" />
                                                        <label class="custom-control-label" for="VariantNameFormulaForm_Inline_IncludeCategoryName">@UiText["catalog.categories.formulas.includeCategoryName"]</label>
                                                    </div>
                                                </div>

                                                <div class="form-group">
                                                    <label>@UiText["catalog.categories.formulas.attributes"]</label>
                                                    <div class="input-group mb-2">
                                                        <select id="formula-attribute-picker" class="form-control js-search-select" data-placeholder='@UiText["catalog.categories.formulas.selectAttribute"]'>
                                                            <option value="">@UiText["catalog.categories.formulas.selectAttribute"]</option>
                                                            @foreach (var attr in formulaAttributeSource)
                                                            {
                                                                <option value="@attr.Id">@attr.Name (@attr.Code / @attr.Scope @((attr.IsInherited ? UiText["catalog.categories.formulas.inheritedSuffix"] : string.Empty)))</option>
                                                            }
                                                        </select>
                                                        <div class="input-group-append">
                                                            <button type="button" class="btn btn-outline-primary" id="formula-add-part-btn" @(formulaAttributeSource.Count == 0 ? "disabled" : null)>@UiText["catalog.categories.attributeOptions.add"]</button>
                                                        </div>
                                                    </div>
                                                    @if (formulaAttributeSource.Count == 0)
                                                    {
                                                        <small class="form-text text-warning">@UiText["catalog.categories.formulas.noAttributes"]</small>
                                                    }
                                                    <div id="formula-parts-empty" class="alert alert-light small mb-2">@UiText["catalog.categories.formulas.emptyParts"]</div>
                                                    <div id="formula-parts-list" class="list-group"></div>
                                                </div>

                                                <div class="mt-3 d-flex flex-wrap">
                                                    <button class="btn btn-primary mr-2 mb-2" type="submit" id="formula-submit-btn" @(Can("Catalog.Category.Formula.Manage", "Inventory.CategoryVariantNameFormula.Manage") ? null : "disabled")>@UiText["catalog.categories.formulas.update"]</button>
                                                    <button class="btn btn-outline-secondary mb-2" type="button" id="formula-reset-btn">@UiText["catalog.categories.formulas.reset"]</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>

                                    <div class="card">
                                        <div class="card-body" id="formula-list-scope">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <h5 class="card-title mb-0">@UiText["catalog.categories.variantFormulaList"]</h5>
                                                <span class="badge badge-pill badge-outline-primary">@localFormulas.Count</span>
                                            </div>
                                            <div class="table-responsive">
                                                <table class="table table-sm table-striped">
                                                    <thead>
                                                        <tr>
                                                            <th>@UiText["common.name"]</th>
                                                            <th>@UiText["catalog.categories.formulas.preview"]</th>
                                                            <th>@UiText["catalog.categories.displayOrder"]</th>
                                                            <th>@UiText["common.status"]</th>
                                                            <th></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @if (localFormulas.Count == 0)
                                                        {
                                                            <tr>
                                                                <td colspan="5">
                                                                    <div class="alert alert-light my-2">@UiText["catalog.categories.formulas.none"]</div>
                                                                </td>
                                                            </tr>
                                                        }
                                                        @foreach (var formula in localFormulas)
                                                        {
                                                            var formulaParts = formula.Parts.OrderBy(x => x.SortOrder).ThenBy(x => x.AttributeName).ToList();
                                                            <tr>
                                                                <td>
                                                                    <div class="font-weight-bold">@formula.Name</div>
                                                                    <div class="small text-muted">@formulaParts.Count @UiText["catalog.categories.formulas.attributeCountSuffix"]</div>
                                                                </td>
                                                                <td class="text-monospace">@(!string.IsNullOrWhiteSpace(formula.Preview) ? formula.Preview : "-")</td>
                                                                <td>@formula.DisplayOrder</td>
                                                                <td>
                                                                    <span class="badge badge-pill @(formula.IsActive ? "badge-success" : "badge-secondary")">
                                                                        @(formula.IsActive ? UiText["common.active"] : UiText["common.inactive"])
                                                                    </span>
                                                                </td>
                                                                <td class="text-nowrap">
                                                                    <button type="button"
                                                                            class="btn btn-outline-secondary btn-xs formula-edit-btn"
                                                                            data-formula-id="@formula.FormulaId"
                                                                            @(Can("Catalog.Category.Formula.Manage", "Inventory.CategoryVariantNameFormula.Manage") ? null : "disabled")>
                                                                        @UiText["common.edit"]
                                                                    </button>
                                                                    <form asp-action="DeleteVariantNameFormula" method="post" class="d-inline" data-loading-form>
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                                                        <input type="hidden" name="formulaId" value="@formula.FormulaId" />
                                                                        <button type="submit" class="btn btn-outline-danger btn-xs" data-confirm-title='@UiText["catalog.categories.formulas.deleteTitle"]' data-confirm='@UiText["catalog.categories.formulas.deleteConfirm"]' @(Can("Catalog.Category.Formula.Manage", "Inventory.CategoryVariantNameFormula.Manage") ? null : "disabled")>@UiText["common.delete"]</button>
                                                                    </form>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        (function () {
            function escapeHtml(value) {
                return (value || '')
                    .toString()
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function initSearchableSelects(scope) {
                if (!scope || !window.jQuery || !window.jQuery.fn || !window.jQuery.fn.select2) {
                    return;
                }

                var $ = window.jQuery;
                scope.querySelectorAll('select.js-search-select').forEach(function (select) {
                    if (select.dataset.select2Initialized === 'true') {
                        return;
                    }

                    $(select).select2({
                        theme: 'bootstrap',
                        dir: document.documentElement.getAttribute('dir') || 'rtl',
                        width: select.getAttribute('data-width') || '100%',
                        placeholder: select.getAttribute('data-placeholder') || '',
                        minimumResultsForSearch: select.hasAttribute('data-no-search') ? Infinity : 0
                    });

                    select.dataset.select2Initialized = 'true';
                });
            }

            var texts = {
                add: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.add"])),
                replace: @Html.Raw(JsonSerializer.Serialize(UiText["common.edit"])),
                remove: @Html.Raw(JsonSerializer.Serialize(UiText["common.delete"])),
                update: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.formulas.update"])),
                empty: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.formulas.emptyParts"])),
                inheritedSuffix: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.formulas.inheritedSuffix"])),
                separatorDash: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.formulas.separator.dash"])),
                separatorSpace: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.formulas.separator.space"])),
                separatorNone: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.formulas.separator.none"])),
                editTitle: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.variantFormulaEdit"]))
            };

        var formulas = @Html.Raw(JsonSerializer.Serialize(localFormulas.Select(functionFormula => new {
            formulaId = functionFormula.FormulaId,
            categoryId = functionFormula.CategoryId,
            categoryName = functionFormula.CategoryName,
            name = functionFormula.Name,
            separator = functionFormula.Separator,
            includeCategoryName = functionFormula.IncludeCategoryName,
            displayOrder = functionFormula.DisplayOrder,
            isActive = functionFormula.IsActive,
                parts = functionFormula.Parts
                    .OrderBy(x => x.SortOrder)
                    .ThenBy(x => x.AttributeName)
                    .Select(part => new {
                        attributeId = part.AttributeId,
                        separator = part.Separator,
                        attributeName = part.AttributeName,
                        attributeCode = part.AttributeCode,
                        sortOrder = part.SortOrder
                    })
                    .ToList()
            }).ToList()));

            var formulaAttributes = @Html.Raw(JsonSerializer.Serialize(formulaAttributeSource.Select(attribute => new {
                attributeId = attribute.Id,
                attributeName = attribute.Name,
                attributeCode = attribute.Code,
                displayOrder = attribute.DisplayOrder,
                isInherited = attribute.IsInherited
            }).ToList()));

            var createForm = document.getElementById('variant-name-formula-create-form');
            var createTitle = document.getElementById('formula-create-title');
            var createCategoryField = document.getElementById('VariantNameFormulaForm_Create_CategoryId');
        var createFormulaIdField = document.getElementById('VariantNameFormulaForm_Create_FormulaId');
        var createNameField = document.getElementById('VariantNameFormulaForm_Create_Name');
        var createPartsJsonField = document.getElementById('VariantNameFormulaForm_Create_PartsJson');
        var createAttributePicker = document.getElementById('formula-create-attribute-picker');
        var createSeparatorField = document.getElementById('VariantNameFormulaForm_Create_Separator');
        var createIncludeCategoryNameField = document.getElementById('VariantNameFormulaForm_Create_IncludeCategoryName');
        var createAddPartBtn = document.getElementById('formula-create-add-part-btn');
