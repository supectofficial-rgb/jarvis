                    setSeparatorValue(createSeparatorField, normalizeSeparatorValue(firstSeparator));
                }
                if (createIncludeCategoryNameField) {
                    createIncludeCategoryNameField.checked = !!formula.includeCategoryName;
                }

                createState.parts = (formula.parts || []).map(function (part) {
                    return clonePart(part);
