                var normalizedCategoryId = (categoryId || '').toString().trim();
                if (!normalizedCategoryId) {
                    return;
                }

                closeInlineEditor();

                var actionUrl = listFilterForm
                    ? (listFilterForm.getAttribute('action') || window.location.href)
                    : window.location.href;
                var nextUrl = new URL(actionUrl, window.location.origin);
                nextUrl.searchParams.set('categoryId', normalizedCategoryId);
                window.location.href = nextUrl.toString();
