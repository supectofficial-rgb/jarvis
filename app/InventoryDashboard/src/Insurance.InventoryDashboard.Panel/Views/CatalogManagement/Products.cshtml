                var result = collectAutoCreatePayload();
                var baseSku = getProductNumberPreview();
                var productName = (productNameField ? productNameField.value : '').trim();
                var combinations = buildVariantCombinations(result.dimensions);

                if (!baseSku || combinations.length === 0) {
                    autoVariantPreviewBody.innerHTML = '';
