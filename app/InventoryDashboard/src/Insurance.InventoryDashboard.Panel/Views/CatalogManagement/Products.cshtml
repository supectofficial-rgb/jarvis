                                + '<option value="true">' + @Html.Raw(JsonSerializer.Serialize(UiText["common.yes"])) + '</option>'
                                + '<option value="false">' + @Html.Raw(JsonSerializer.Serialize(UiText["common.no"])) + '</option>'
                                + '</select>';
                        } else {
                            inputHtml = '<input type="text" class="form-control js-auto-product-value" name="AutoProductValue_' + escapeHtml(attribute.attributeId || '') + '" placeholder="' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.attributeValuePlaceholder"])) + '" />';
                        }

                        return '<div class="form-group js-auto-product-attribute" data-attribute-id="' + escapeHtml(attribute.attributeId || '') + '" data-attribute-name="' + escapeHtml(attribute.name || '') + '" data-data-type="' + escapeHtml(attribute.dataType || '') + '" data-required="' + (attribute.isRequired ? 'true' : 'false') + '">'
                            + '<label>' + label + '</label>'
                            + inputHtml
                            + '<small class="form-text text-muted">' + escapeHtml(buildCreateAttributeOriginText(attribute, false)) + '</small>'
                            + '</div>';
                    }).join('');

                var variantSection = variantAttributes.length === 0
                    ? '<div class="text-muted small">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.noVariantBuilderAttributeDefined"])) + '</div>'
                    : variantAttributes.map(function (attribute) {
                        var options = Array.isArray(attribute.options) ? attribute.options : [];
                        return '<div class="form-group js-auto-variant-attribute" data-attribute-id="' + escapeHtml(attribute.attributeId || '') + '" data-attribute-name="' + escapeHtml(attribute.name || '') + '" data-data-type="' + escapeHtml(attribute.dataType || '') + '" data-display-order="' + escapeHtml(attribute.displayOrder || 0) + '" data-required="' + (attribute.isRequired ? 'true' : 'false') + '">'
                            + '<label>' + escapeHtml(attribute.name || '') + (attribute.isRequired ? ' *' : '') + '</label>'
                            + '<select multiple class="form-control js-search-select js-auto-variant-values" name="AutoVariantOptions_' + escapeHtml(attribute.attributeId || '') + '" data-no-search="true" data-placeholder="' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.selectMultipleOptions"])) + '">'
                            + options.map(function (option) {
                                return '<option value="' + escapeHtml(option.id || '') + '" data-option-name="' + escapeHtml(option.optionName || '') + '" data-option-value="' + escapeHtml(option.optionValue || '') + '" data-option-display-order="' + escapeHtml(option.displayOrder || 0) + '">'
                                    + escapeHtml(option.optionName || '') + ' (' + escapeHtml(option.optionValue || '') + ')</option>';
                            }).join('')
                            + '</select>'
                            + '<small class="form-text text-muted">' + escapeHtml(buildCreateAttributeOriginText(attribute, true)) + '</small>'
                            + '</div>';
                    }).join('');

                createDynamicSections.innerHTML = ''
                    + '<div class="card mb-3"><div class="card-body">'
                    + '<h6 class="card-title mb-3">@UiText["catalog.products.nonVariantAttributes"]</h6>'
                    + productSection
                    + '</div></div>'
                    + '<div class="card mb-3"><div class="card-body">'
                    + '<h6 class="card-title mb-3">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.variantBuilderAttributes"])) + '</h6>'
                    + variantSection
                    + '</div></div>'
                    + '<div class="card mb-3"><div class="card-body">'
                    + '<h6 class="card-title mb-2">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.generatedVariantPreview"])) + '</h6>'
                    + '<div id="auto-variant-preview-empty" class="text-muted small">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.generatedVariantPreviewHelp"])) + '</div>'
                    + '<div id="auto-variant-preview-container" class="table-responsive d-none">'
                    + '<table class="table table-sm table-striped mb-0"><thead><tr><th>#</th><th>' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.variantName"])) + '</th><th>SKU</th></tr></thead><tbody id="auto-variant-preview-body"></tbody></table>'
                    + '</div></div></div>';

                autoVariantPreviewContainer = document.getElementById('auto-variant-preview-container');
                autoVariantPreviewBody = document.getElementById('auto-variant-preview-body');
                autoVariantPreviewEmpty = document.getElementById('auto-variant-preview-empty');

                initSearchableSelects(createDynamicSections);
            }

            function bindAutoCreateInputEvents(scope) {
                if (!scope) {
                    return;
                }

                scope.querySelectorAll('.js-auto-product-value, .js-auto-variant-values').forEach(function (input) {
                    input.addEventListener('change', renderAutoVariantPreview);
                    input.addEventListener('input', renderAutoVariantPreview);
                });
            }

            function loadCreateAttributesForCategory(categoryId, options) {
                if (!productUpsertForm || !createDynamicSections) {
                    console.log('[Products][Attributes] form or dynamic section missing, skipping load.');
                    return;
                }

                var normalizedCategoryId = (categoryId || '').trim();
                console.log('[Products][Attributes] requested category business id:', normalizedCategoryId || '<empty>');
                var forceLoad = options && options.force === true;
                if (!forceLoad && normalizedCategoryId && lastCreateAttributesCategoryId.toLowerCase() === normalizedCategoryId.toLowerCase()) {
                    console.log('[Products][Attributes] duplicate category load skipped for:', normalizedCategoryId);
                    setCreateAttributeStatus(@Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.duplicateCategory"])), 'secondary');
                    return;
                }

                if (!normalizedCategoryId) {
                    console.log('[Products][Attributes] no category selected, clearing sections.');
                    if (pageElement) {
                        pageElement.setAttribute('data-selected-category-id', '');
                    }

                    lastCreateAttributesCategoryId = '';
                    setCreateAttributeStatus(@Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.noCategorySelected"])), 'warning');
                    setCreateAttributeFeedback('', 'warning');
                    renderCreateAttributeSections(null);
                    bindAutoCreateInputEvents(createDynamicSections);
                    renderAutoVariantPreview();
                    saveFormDraft(productUpsertForm);
                    return;
                }

                if (!isLeafCategory(normalizedCategoryId)) {
                    console.log('[Products][Attributes] selected category has children, attribute load canceled for:', normalizedCategoryId);
                    if (pageElement) {
                        pageElement.setAttribute('data-selected-category-id', '');
                    }

                    lastCreateAttributesCategoryId = '';
                    setCreateAttributeStatus(@Html.Raw(JsonSerializer.Serialize(UiText["product.attributes.loadAfterLeaf"])), 'warning');
                    setCreateAttributeFeedback('', 'warning');
                    renderCreateAttributeSections(null);
                    bindAutoCreateInputEvents(createDynamicSections);
                    renderAutoVariantPreview();
                    saveFormDraft(productUpsertForm);
                    return;
                }

                var currentRequestId = ++createAttributesRequestId;
                var currentDraft = captureFormDraft(productUpsertForm);
                lastCreateAttributesCategoryId = normalizedCategoryId;
                console.log('[Products][Attributes] dispatching attribute fetch for:', normalizedCategoryId, 'requestId:', currentRequestId);

                setCreateAttributeStatus(@Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.sendingRequest"])), 'warning');
                setCreateAttributeFeedback('', 'warning');
                createDynamicSections.innerHTML = '<div class="alert alert-light border">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.loadingCategoryAttributes"])) + '</div>';

                var url = new URL(createAttributesUrl || window.location.href, window.location.origin);
                url.searchParams.set('categoryId', normalizedCategoryId);

                fetch(url.toString(), {
                    method: 'GET',
                    credentials: 'same-origin',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(function (response) { return response.json(); })
                    .then(function (data) {
                        if (currentRequestId !== createAttributesRequestId) {
                            console.log('[Products][Attributes] stale response ignored for:', normalizedCategoryId, 'requestId:', currentRequestId);
                            return;
                        }

                        if (!data || data.isSuccess === false) {
                            console.log('[Products][Attributes] attribute fetch failed for:', normalizedCategoryId, 'response:', data);
                            createDynamicSections.innerHTML = '';
                            setCreateAttributeFeedback((data && data.errorMessage) || @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.loadCategoryAttributesFailed"])), 'danger');
                            renderCreateAttributeSections(null);
                            return;
                        }

                        console.log('[Products][Attributes] attribute fetch completed for:', normalizedCategoryId, 'response category:', data.categoryId || '<empty>');
                        setCreateAttributeStatus(@Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.loaded"])), 'success');
                        renderCreateAttributeSections(data);
                        applyFormDraft(productUpsertForm, currentDraft);
                        bindAutoCreateInputEvents(createDynamicSections);
                        if (pageElement) {
                            pageElement.setAttribute('data-selected-category-id', normalizedCategoryId);
                        }

                        if (data.errorMessage) {
                            setCreateAttributeFeedback(data.errorMessage, 'warning');
                        }

                        saveFormDraft(productUpsertForm);
                        renderAutoVariantPreview();
                    })
                    .catch(function () {
                        if (currentRequestId !== createAttributesRequestId) {
                            console.log('[Products][Attributes] stale error ignored for:', normalizedCategoryId, 'requestId:', currentRequestId);
                            return;
                        }

                        console.log('[Products][Attributes] attribute fetch threw error for:', normalizedCategoryId);
                        setCreateAttributeStatus(@Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.loadError"])), 'danger');
                        createDynamicSections.innerHTML = '';
                        setCreateAttributeFeedback(@Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.loadCategoryAttributesFailed"])), 'danger');
                        renderCreateAttributeSections(null);
                    });
            }

            function normalizeSkuSegment(rawValue) {
                var raw = (rawValue || '').toString().trim().toUpperCase();
                if (!raw) {
                    return '';
                }

                var normalized = raw.replace(/[^A-Z0-9_-]/g, '-');
                normalized = normalized.replace(/-{2,}/g, '-');
                normalized = normalized.replace(/^[-_]+|[-_]+$/g, '');
                return normalized;
            }

            function buildVariantCombinations(dimensions) {
                if (!Array.isArray(dimensions) || dimensions.length === 0) {
                    return [];
                }

                var combinations = [[]];
                dimensions.forEach(function (dimension) {
                    var next = [];
                    combinations.forEach(function (existing) {
                        (dimension.options || []).forEach(function (option) {
                            next.push(existing.concat([{
                                attributeId: dimension.attributeId,
                                attributeName: dimension.attributeName,
                                attributeDisplayOrder: dimension.attributeDisplayOrder || 0,
                                optionId: option.optionId,
                                optionName: option.optionName,
                                optionValue: option.optionValue,
                                optionDisplayOrder: option.optionDisplayOrder || 0
                            }]));
                        });
                    });
                    combinations = next;
                });

                return combinations;
            }

            function getProductNumberPreview() {
                var savedValue = normalizeSkuSegment(productBaseSkuField ? productBaseSkuField.value : '');
                if (savedValue) {
                    return savedValue;
                }

                if (!productCategoryField || productCategoryField.selectedIndex < 0) {
                    return 'PRD-AUTO';
                }

                var selectedOption = productCategoryField.options[productCategoryField.selectedIndex];
                var categoryCode = selectedOption ? (selectedOption.getAttribute('data-category-code') || selectedOption.textContent || '') : '';
                var prefix = normalizeSkuSegment(categoryCode);
                return prefix ? (prefix + '-AUTO') : 'PRD-AUTO';
