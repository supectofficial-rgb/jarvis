@using System
@using System.Linq
@using System.Text.Json
@model Insurance.InventoryDashboard.Panel.Models.ProductManagementPageViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = UiText["catalog.products.title"];
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var isEditMode = !string.IsNullOrWhiteSpace(Model.ProductForm.ProductId);
    var hasSelectedProduct = !string.IsNullOrWhiteSpace(Model.SelectedProductId);

    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x =>
        string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));
    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    var hasRestrictedActions = !Can("Catalog.Product.Create", "Catalog.Product.Update", "Product.Create", "Product.Update")
        || !Can("Catalog.Product.Activate", "Product.Activate")
        || !Can("Catalog.Product.Deactivate", "Product.Deactivate")
        || !Can("Catalog.Product.Delete", "Product.Delete")
        || !Can("Catalog.Product.ChangeCategory", "Product.ChangeCategory")
        || !Can("Catalog.ProductAttributeValue.Set", "ProductAttributeValue.Set")
        || !Can("Catalog.ProductAttributeValue.Remove", "ProductAttributeValue.Remove");
    var hasCatalogSuccess = TempData.ContainsKey("CatalogSuccess");

    // Flat category lookup remains shared between the card picker and the quick-search helper.
    var categoryLookup = Model.FlatCategories
        .GroupBy(x => x.Id, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);

    string GetCategoryPath(string? categoryId)
    {
        if (string.IsNullOrWhiteSpace(categoryId) || !categoryLookup.TryGetValue(categoryId, out var current))
        {
            return "-";
        }

        var parts = new List<string>();
        var guard = 0;
        while (current is not null && guard < 1024)
        {
            parts.Add(current.Name);
            if (string.IsNullOrWhiteSpace(current.ParentCategoryId) || !categoryLookup.TryGetValue(current.ParentCategoryId, out current))
            {
                break;
            }
            guard++;
        }
        parts.Reverse();
        return string.Join(" / ", parts);
    }

    var selectedCategoryPath = GetCategoryPath(Model.SelectedCategoryId);
    var selectedProductName = Model.SelectedProductDetails?.Name ?? Model.Products.FirstOrDefault(x => x.Id == Model.SelectedProductId)?.Name;
    var selectedValues = (Model.SelectedProductDetails?.Attributes ?? new List<Insurance.InventoryDashboard.Panel.Models.ProductAttributeValueModel>())
        .GroupBy(x => x.AttributeId, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(
            x => x.Key,
            x =>
            {
                var item = x.FirstOrDefault();
                return item is null ? string.Empty : (!string.IsNullOrWhiteSpace(item.OptionValue) ? item.OptionValue : item.Value) ?? string.Empty;
            },
            StringComparer.OrdinalIgnoreCase);
    var selectedAttributeValues = (Model.SelectedProductDetails?.Attributes ?? new List<Insurance.InventoryDashboard.Panel.Models.ProductAttributeValueModel>())
        .GroupBy(x => x.AttributeId, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);
    var selectedVariantOptionIds = Model.ProductVariantDetails
        .SelectMany(x => x.Attributes ?? new List<Insurance.InventoryDashboard.Panel.Models.VariantAttributeValueModel>())
        .Where(x => !string.IsNullOrWhiteSpace(x.OptionId))
        .GroupBy(x => x.AttributeId, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(
            x => x.Key,
            x => x.Select(v => v.OptionId!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToHashSet(StringComparer.OrdinalIgnoreCase),
            StringComparer.OrdinalIgnoreCase);
    var requiredProductAttributeCount = Model.EffectiveCategoryAttributes.Count(x => x.IsRequired);
    var completedRequiredProductAttributeCount = Model.EffectiveCategoryAttributes.Count(x =>
        x.IsRequired &&
        selectedValues.TryGetValue(x.AttributeId, out var value) &&
        !string.IsNullOrWhiteSpace(value));
    var productCompletionPercent = requiredProductAttributeCount == 0
        ? 100
        : (int)Math.Round((completedRequiredProductAttributeCount * 100.0) / requiredProductAttributeCount);
    var effectiveProductAttributeLookup = Model.EffectiveCategoryAttributes
        .GroupBy(x => x.AttributeId, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);

    bool IsProductScopeAttribute(Insurance.InventoryDashboard.Panel.Models.EffectiveAttributeViewModel attribute)
    {
        var scope = (attribute.Scope ?? string.Empty).Trim().ToLowerInvariant();
        if (scope is "product" or "both")
        {
            return true;
        }

        if (scope == "variant")
        {
            return false;
        }

        return !attribute.IsVariantLevel;
    }

    bool IsVariantScopeAttribute(Insurance.InventoryDashboard.Panel.Models.EffectiveAttributeViewModel attribute)
    {
        var scope = (attribute.Scope ?? string.Empty).Trim().ToLowerInvariant();
        if (scope is "variant" or "both")
        {
            return true;
        }

        if (scope == "product")
        {
            return false;
        }

        return attribute.IsVariantLevel;
    }

    string? ResolveMediaUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return null;
        }

        var trimmed = url.Trim();
        if (Uri.TryCreate(trimmed, UriKind.Absolute, out _))
        {
            return trimmed;
        }

        var configuredBaseUrl = Configuration["FileService:BaseUrl"]?.TrimEnd('/');
        var requestHost = Context?.Request?.Host.Host;
        var requestScheme = Context?.Request?.Scheme ?? "http";
        var configuredBaseIsLocalOnly =
            Uri.TryCreate(configuredBaseUrl, UriKind.Absolute, out var configuredUri) &&
            (string.Equals(configuredUri.Host, "localhost", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(configuredUri.Host, "127.0.0.1", StringComparison.OrdinalIgnoreCase)) &&
            !string.IsNullOrWhiteSpace(requestHost) &&
            !string.Equals(requestHost, "localhost", StringComparison.OrdinalIgnoreCase) &&
            !string.Equals(requestHost, "127.0.0.1", StringComparison.OrdinalIgnoreCase);
        var rootUrl = !string.IsNullOrWhiteSpace(requestHost) ? $"{requestScheme}://{requestHost}" : null;
        var baseUrl = !string.IsNullOrWhiteSpace(configuredBaseUrl) && !configuredBaseIsLocalOnly
            ? configuredBaseUrl
            : rootUrl;

        if (!string.IsNullOrWhiteSpace(baseUrl))
        {
            return $"{baseUrl}/{trimmed.TrimStart('/')}";
        }

        return trimmed.StartsWith("/", StringComparison.Ordinal)
            ? trimmed
            : $"/{trimmed.TrimStart('/')}";
    }

    var autoCreateProductAttributes = Model.EffectiveCategoryAttributes
        .Where(IsProductScopeAttribute)
        .OrderBy(x => x.DisplayOrder)
        .ThenBy(x => x.Name)
        .ToList();

    var autoCreateVariantBuilderAttributes = Model.EffectiveCategoryAttributes
        .Where(IsVariantScopeAttribute)
        .Where(x => x.IsVariantLevel)
        .OrderBy(x => x.DisplayOrder)
        .ThenBy(x => x.Name)
        .ToList();
    var categoryTreeUiNodes = Model.FlatCategories
        .Select(x => new
        {
            id = x.Id,
            parentId = x.ParentCategoryId,
            name = x.Name,
            code = x.Code,
            imageUrl = ResolveMediaUrl(x.ImageUrl),
            imageThumbnailUrl = ResolveMediaUrl(x.ImageThumbnailUrl)
        })
        .ToList();
    var productFormPreviewUrl = ResolveMediaUrl(Model.ProductForm.ImageThumbnailUrl ?? Model.ProductForm.ImageUrl);
}

<style>
    #product-management-tabs .nav-item:nth-child(3),
    #product-management-tabs .nav-item:nth-child(4),
    #product-tab-lifecycle,
    #product-tab-attributes,
    #product-list-scope [data-bulk-form],
    #product-list-scope table th:first-child,
    #product-list-scope table td:first-child,
    #product-list-scope .dropdown-toggle,
    #product-list-scope .dropdown-menu {
        display: none !important;
    }

    #product-list-tab-panel {
        display: none;
    }

    .product-category-tree-shell {
        border: 1px solid #d7dce1;
        border-radius: .75rem;
        background: #fff;
        padding: 1rem;
    }

    .product-category-level {
        border-top: 1px dashed #d7dce1;
        padding-top: 1rem;
        margin-top: 1rem;
    }

    .product-category-level:first-child {
        border-top: 0;
        padding-top: 0;
        margin-top: 0;
    }

    .product-category-level-title {
        font-size: .85rem;
        color: #6c757d;
        margin-bottom: .75rem;
    }

    .product-category-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 200px));
        gap: .75rem;
        justify-content: start;
    }

    .product-category-card {
        display: block;
        width: 100%;
        text-align: center;
        border: 1px solid #d7dce1;
        border-radius: .75rem;
        background: #fff;
        padding: 1rem .75rem;
        transition: all .2s ease;
        cursor: pointer;
    }

    .product-category-card:hover,
    .product-category-card:focus {
        border-color: #145388;
        box-shadow: 0 .25rem 1rem rgba(20, 83, 136, .12);
        outline: none;
    }

    .product-category-card.active {
        border-color: #145388;
        background: #145388;
        color: #fff;
        box-shadow: 0 .5rem 1.25rem rgba(20, 83, 136, .18);
    }

    .product-category-card-media {
        width: 100%;
        height: 92px;
        border-radius: .6rem;
        overflow: hidden;
        margin-bottom: .75rem;
        background: #f8f9fa;
    }

    .product-category-card-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .product-category-card-no-media .product-category-card-name {
        margin-top: .25rem;
    }

    .product-category-card-name {
        font-weight: 600;
        line-height: 1.4;
    }

    .product-category-card-code {
        display: block;
        font-size: .75rem;
        opacity: .75;
        margin-top: .25rem;
    }

    .product-category-selected-path {
        min-height: 2rem;
    }

</style>

<main id="products-page"
      class="catalog-page"
      data-selected-product-id="@Model.SelectedProductId"
      data-selected-category-id="@Model.SelectedCategoryId"
      data-create-attributes-url="@Url.Action("CreateAttributes", "ProductManagement")"
      data-catalog-success="@hasCatalogSuccess.ToString().ToLowerInvariant()">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h1>@UiText["catalog.products.title"]</h1>
                <p class="text-muted">@UiText["catalog.products.description"]</p>
                <div class="mb-3">
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.products.primaryGoal"]</span>
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.products.secondaryOperations"]</span>
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.products.totalCount"] @Model.ProductTotalCount</span>
                    @if (!string.IsNullOrWhiteSpace(Model.SelectedCategoryId))
                    {
                        <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.products.selectedCategoryPath"] @selectedCategoryPath</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(selectedProductName))
                    {
                        <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.products.selectedProduct"] @selectedProductName</span>
                    }
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.products.requiredCompletion"] @completedRequiredProductAttributeCount / @requiredProductAttributeCount</span>
                </div>
                <p class="small text-muted mb-3">
                    @UiText["catalog.products.quickGuide"]
                </p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) || TempData["CatalogError"] is string)
        {
            <div class="row">
                <div class="col-12">
                    <div class="alert alert-warning mb-3">
                        @(TempData["CatalogError"] as string ?? Model.ErrorMessage)
                    </div>
                </div>
            </div>
        }

        @if (TempData["CatalogSuccess"] is string successMessage)
        {
            <div class="row">
                <div class="col-12">
                    <div class="alert alert-success mb-3">@successMessage</div>
                </div>
            </div>
        }

        @if (TempData["CatalogNotice"] is string noticeMessage)
        {
            <div class="row">
                <div class="col-12">
                    <div class="alert alert-info mb-3">@noticeMessage</div>
                </div>
            </div>
        }

        @await Html.PartialAsync("~/Views/Shared/_CatalogPermissionNotice.cshtml", hasRestrictedActions)

        <div class="row mb-2">
            <div class="col-12">
                <div class="card">
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong>@UiText["catalog.products.completionStatus"]</strong>
                            <span class="badge badge-pill @(productCompletionPercent >= 100 ? "badge-primary" : productCompletionPercent >= 70 ? "badge-outline-primary" : "badge-danger")">
                                @productCompletionPercent%
                            </span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" role="progressbar" style="width:@productCompletionPercent%"></div>
                        </div>
                        <small class="text-muted d-block mt-2">
                            @UiText["catalog.products.completedRequiredFields"] @completedRequiredProductAttributeCount @UiText["catalog.products.outOf"] @requiredProductAttributeCount
                        </small>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.MissingRequiredProductAttributes.Count > 0)
        {
            <div class="row">
                <div class="col-12">
                    <div class="alert alert-danger mb-3">
                        @UiText["catalog.products.requiredAttributesIncomplete"]
                        @string.Join("، ", Model.MissingRequiredProductAttributes.Select(x => x.Name))
                    </div>
                </div>
            </div>
        }

        <div class="row">
            <div class="col-12 mb-4">
                <ul class="nav nav-tabs separator-tabs ml-0 mb-4" role="tablist" id="product-management-tabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-toggle="tab" href="#product-tab-main" role="tab">@UiText["catalog.products.tabs.form"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#product-tab-list" role="tab">@UiText["catalog.products.tabs.list"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#product-tab-attributes" role="tab">@UiText["catalog.products.tabs.attributes"]</a>
                    </li>
                </ul>
                <div class="tab-content">
                    @await Html.PartialAsync("~/Views/CatalogManagement/_ProductFormSection.cshtml", Model)
                    <div class="tab-pane fade" id="product-tab-list" role="tabpanel">
                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">@UiText["catalog.products.searchAndFilter"]</h5>
                                <form method="get" asp-action="Products" class="row" id="product-search-form" data-state-form>
                                    <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                    <div class="col-lg-10 col-md-9 mb-2">
                                        <label class="text-muted small">@UiText["catalog.products.searchLabel"]</label>
                                        <input name="searchTerm" value="@Model.ProductSearchTerm" class="form-control" data-filter-label='@UiText["common.search"]' placeholder='@UiText["catalog.products.searchPlaceholder"]' />
                                    </div>
                                    <div class="col-lg-2 col-md-3 mb-2 d-flex align-items-end">
                                        <button type="submit" class="btn btn-primary btn-block">@UiText["common.apply"]</button>
                                    </div>
                                </form>
                                <small class="text-muted d-block mt-2">@UiText["catalog.products.searchHelp"]</small>
                            </div>
                        </div>
                    </div>
                    @await Html.PartialAsync("~/Views/CatalogManagement/_ProductAttributesSection.cshtml", Model)
                </div>
            </div>

            @await Html.PartialAsync("~/Views/CatalogManagement/_ProductListSection.cshtml", Model)
        </div>
    </div>
</main>

@section Scripts {
    <script>
        (function () {
            var pageElement = document.getElementById('products-page');
            var searchForm = document.getElementById('product-search-form');
            var tabs = document.querySelectorAll('#product-management-tabs .nav-link');
            var productListTabPanel = document.getElementById('product-list-tab-panel');
            var productListTabPane = document.getElementById('product-tab-list');
            var tabKey = 'catalog-products-active-tab-v1';
            var stateKey = 'catalog-products-state-v2';
            var draftStateKey = 'catalog-products-form-drafts-v1';
            var submittedFormKey = 'catalog-products-last-submitted-form-v1';
            var dirtyForms = new Set();
            var watchedFormIds = ['product-upsert-form', 'product-category-change-form'];
            var watchedForms = watchedFormIds
                .map(function (formId) { return document.getElementById(formId); })
                .filter(function (form) { return form instanceof HTMLFormElement; });
            var productUpsertForm = document.getElementById('product-upsert-form');
            var productCategoryField = document.getElementById('ProductForm_CategoryId');
            var categoryTreeLevels = document.getElementById('product-category-tree-levels');
            var categoryPathBadge = document.getElementById('product-category-path-badge');
            var productNameField = document.getElementById('ProductForm_Name');
            var productBaseSkuField = document.getElementById('ProductForm_BaseSku');
            var autoPayloadField = document.getElementById('product-auto-variant-payload');
            var createAttributeFeedback = document.getElementById('product-create-attribute-feedback');
            var createDynamicSections = document.getElementById('product-create-dynamic-sections');
            var autoVariantPreviewContainer = document.getElementById('auto-variant-preview-container');
            var autoVariantPreviewBody = document.getElementById('auto-variant-preview-body');
            var autoVariantPreviewEmpty = document.getElementById('auto-variant-preview-empty');
            var createAttributeStatus = document.getElementById('product-create-attribute-status');
            var createAttributesUrl = pageElement ? (pageElement.getAttribute('data-create-attributes-url') || '') : '';
            var productListRequestId = 0;
            var createAttributesRequestId = 0;
            var lastCreateAttributesCategoryId = '';
            var isEditMode = !!(productUpsertForm && productUpsertForm.querySelector('[name="ProductForm.ProductId"]') && (productUpsertForm.querySelector('[name="ProductForm.ProductId"]').value || '').trim());
            var categoryTreeNodes = @Html.Raw(JsonSerializer.Serialize(categoryTreeUiNodes));
            var categoryNodeLookup = {};
            var categoryChildrenLookup = {};

            function readState() {
                try {
                    return JSON.parse(localStorage.getItem(stateKey) || '{}');
                } catch (e) {
                    return {};
                }
            }

            function writeState(nextState) {
                localStorage.setItem(stateKey, JSON.stringify(nextState));
            }

            function readDrafts() {
                try {
                    return JSON.parse(localStorage.getItem(draftStateKey) || '{}');
                } catch (e) {
                    return {};
                }
            }

            function writeDrafts(nextDrafts) {
                localStorage.setItem(draftStateKey, JSON.stringify(nextDrafts));
            }

            function captureFormDraft(form) {
                var values = {};
                form.querySelectorAll('input, textarea, select').forEach(function (field) {
                    if (!field.name || field.name === '__RequestVerificationToken') {
                        return;
                    }

                    if (field.type === 'checkbox') {
                        values[field.name] = { type: 'checkbox', value: field.checked };
                        return;
                    }

                    if (field.type === 'radio') {
                        if (!values[field.name]) {
                            values[field.name] = { type: 'radio', value: '' };
                        }
                        if (field.checked) {
                            values[field.name].value = field.value || '';
                        }
                        return;
                    }

                    if (field.tagName === 'SELECT' && field.multiple) {
                        values[field.name] = {
                            type: 'multi',
                            value: Array.from(field.selectedOptions || []).map(function (option) { return option.value || ''; })
                        };
                        return;
                    }

                    values[field.name] = { type: 'value', value: field.value || '' };
                });

                return values;
            }

            function applyFormDraft(form, values) {
                if (!values || typeof values !== 'object') {
                    return;
                }

                Object.keys(values).forEach(function (fieldName) {
                    var meta = values[fieldName];
                    if (!meta) {
                        return;
                    }

                    if (meta.type === 'radio') {
                        form.querySelectorAll('input[type="radio"][name="' + fieldName + '"]').forEach(function (radio) {
                            radio.checked = (radio.value || '') === (meta.value || '');
                        });
                        return;
                    }

                    var field = form.querySelector('[name="' + fieldName + '"]');
                    if (!field) {
                        return;
                    }

                    if (meta.type === 'multi') {
                        var selected = Array.isArray(meta.value) ? meta.value : [];
                        Array.from(field.options || []).forEach(function (option) {
                            option.selected = selected.indexOf(option.value) >= 0;
                        });
                        field.dispatchEvent(new Event('change', { bubbles: true }));
                        return;
                    }

                    if (meta.type === 'checkbox') {
                        field.checked = !!meta.value;
                        return;
                    }

                    field.value = meta.value || '';
                });
            }

            function saveFormDraft(form) {
                var drafts = readDrafts();
                drafts[form.id] = captureFormDraft(form);
                writeDrafts(drafts);
            }

            function getDraftProductId(values) {
                if (!values || !values['ProductForm.ProductId']) {
                    return '';
                }

                return (values['ProductForm.ProductId'].value || '').trim();
            }

            function shouldRestoreProductDraft(values) {
                if (@Model.IsProductCreateMode.ToString().ToLowerInvariant()) {
                    return false;
                }

                var currentProductId = pageElement ? (pageElement.getAttribute('data-selected-product-id') || '').trim() : '';
                var draftProductId = getDraftProductId(values);

                if (!currentProductId) {
                    return !draftProductId;
                }

                return !draftProductId || draftProductId === currentProductId;
            }

            function restoreFormDrafts() {
                var drafts = readDrafts();
                watchedForms.forEach(function (form) {
                    if (form.id === 'product-upsert-form' && !shouldRestoreProductDraft(drafts[form.id])) {
                        if (@Model.IsProductCreateMode.ToString().ToLowerInvariant()) {
                            form.reset();
                        }
                        return;
                    }

                    applyFormDraft(form, drafts[form.id]);
                });
            }

            function clearSubmittedDraftAfterSuccess() {
                if (!@hasCatalogSuccess.ToString().ToLowerInvariant()) {
                    return;
                }

                var submittedFormId = localStorage.getItem(submittedFormKey);
                if (!submittedFormId) {
                    return;
                }

                var drafts = readDrafts();
                if (drafts && drafts[submittedFormId]) {
                    delete drafts[submittedFormId];
                    writeDrafts(drafts);
                }

                localStorage.removeItem(submittedFormKey);
            }

            function readField(formElement, name) {
                var field = formElement ? formElement.querySelector('[name="' + name + '"]') : null;
                return field ? (field.value || '') : '';
            }

            function setFieldIfMissing(formElement, name, value) {
                if (!formElement || !value) {
                    return;
                }

                var field = formElement.querySelector('[name="' + name + '"]');
                if (!field) {
                    return;
                }

                var params = new URLSearchParams(window.location.search);
                if (params.has(name)) {
                    return;
                }

                if (!field.value) {
                    field.value = value;
                }
            }

            function savePageState(extra) {
                var current = readState();
                var next = {
                    selectedProductId: pageElement ? (pageElement.getAttribute('data-selected-product-id') || '') : '',
                    selectedCategoryId: pageElement ? (pageElement.getAttribute('data-selected-category-id') || '') : '',
                    filters: {
                        searchTerm: readField(searchForm, 'searchTerm'),
                        categoryFilterId: readField(searchForm, 'categoryFilterId'),
                        statusFilter: readField(searchForm, 'statusFilter'),
                        sort: readField(searchForm, 'sort'),
                        pageSize: readField(searchForm, 'pageSize')
                    },
                    draft: current.draft || {}
                };

                if (extra && typeof extra === 'object') {
                    next.draft = Object.assign({}, next.draft, extra);
                }

                writeState(next);
            }

            function restorePageState() {
                var state = readState();
                if (!state || !state.filters) {
                    return;
                }

                setFieldIfMissing(searchForm, 'searchTerm', state.filters.searchTerm);
                setFieldIfMissing(searchForm, 'categoryFilterId', state.filters.categoryFilterId);
                setFieldIfMissing(searchForm, 'statusFilter', state.filters.statusFilter);
                setFieldIfMissing(searchForm, 'sort', state.filters.sort);
                setFieldIfMissing(searchForm, 'pageSize', state.filters.pageSize);
            }

            function setProductListLoading(isLoading) {
                if (!productListTabPanel) {
                    return;
                }

                productListTabPanel.classList.toggle('opacity-50', !!isLoading);
                productListTabPanel.style.pointerEvents = isLoading ? 'none' : '';
            }

            function buildProductListUrl(pageUrl) {
                if (pageUrl) {
                    return pageUrl;
                }

                if (!searchForm) {
                    return window.location.href;
                }

                var url = new URL(searchForm.getAttribute('action') || window.location.pathname, window.location.origin);
                var formData = new FormData(searchForm);
                var params = new URLSearchParams(formData);

                params.forEach(function (value, key) {
                    url.searchParams.set(key, value);
                });

                url.hash = 'product-tab-list';
                return url.toString();
            }

            function refreshProductList(requestUrl) {
                if (!productListTabPanel || !requestUrl) {
                    return Promise.resolve();
                }

                var currentRequestId = ++productListRequestId;
                setProductListLoading(true);

                return fetch(requestUrl, {
                    method: 'GET',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                    .then(function (response) {
                        if (!response.ok) {
                            throw new Error('Request failed with status ' + response.status);
                        }

                        return response.text();
                    })
                    .then(function (html) {
                        if (currentRequestId !== productListRequestId) {
                            return;
                        }

                        var parser = new DOMParser();
                        var nextDocument = parser.parseFromString(html, 'text/html');
                        var nextPanel = nextDocument.getElementById('product-list-tab-panel');

                        if (!nextPanel) {
                            throw new Error('Product list panel not found in response.');
                        }

                        productListTabPanel.innerHTML = nextPanel.innerHTML;

                        if (window.history && window.history.replaceState) {
                            var nextUrl = new URL(requestUrl, window.location.origin);
                            nextUrl.hash = 'product-tab-list';
                            window.history.replaceState({}, '', nextUrl.toString());
                        }
                    })
                    .catch(function () {
                        window.location.href = requestUrl;
                    })
                    .finally(function () {
                        if (currentRequestId === productListRequestId) {
                            setProductListLoading(false);
                        }
                    });
            }

            function escapeHtml(value) {
                return (value || '')
                    .toString()
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function initializeCategoryTreeData() {
                categoryNodeLookup = {};
                categoryChildrenLookup = {};

                (Array.isArray(categoryTreeNodes) ? categoryTreeNodes : []).forEach(function (node) {
                    if (!node || !node.id) {
                        return;
                    }

                    var normalizedId = (node.id || '').trim();
                    var normalizedParentId = (node.parentId || '').trim();
                    categoryNodeLookup[normalizedId] = {
                        id: normalizedId,
                        parentId: normalizedParentId,
                        name: node.name || normalizedId,
                        code: node.code || '',
                        imageUrl: node.imageUrl || '',
                        imageThumbnailUrl: node.imageThumbnailUrl || ''
                    };
                });

                Object.keys(categoryNodeLookup).forEach(function (normalizedId) {
                    var node = categoryNodeLookup[normalizedId];
                    var normalizedParentId = node.parentId || '';
                    var key = normalizedParentId && categoryNodeLookup[normalizedParentId]
                        ? normalizedParentId
                        : '__root__';

                    if (!categoryChildrenLookup[key]) {
                        categoryChildrenLookup[key] = [];
                    }

                    categoryChildrenLookup[key].push(node);
                });

                Object.keys(categoryChildrenLookup).forEach(function (key) {
                    categoryChildrenLookup[key].sort(function (left, right) {
                        return (left.name || '').localeCompare(right.name || '', 'fa');
                    });
                });
            }

            function getCategoryChildren(parentId) {
                return categoryChildrenLookup[parentId || '__root__'] || [];
            }

            function isLeafCategory(categoryId) {
                return getCategoryChildren(categoryId).length === 0;
            }

            function buildCategoryPathIds(categoryId) {
                var normalizedCategoryId = (categoryId || '').trim();
                if (!normalizedCategoryId || !categoryNodeLookup[normalizedCategoryId]) {
                    return [];
                }

                var path = [];
                var current = categoryNodeLookup[normalizedCategoryId];
                var guard = 0;
                while (current && guard < 32) {
                    path.push(current.id);
                    current = current.parentId ? categoryNodeLookup[current.parentId] : null;
                    guard++;
                }

                path.reverse();
                return path;
            }

            function syncCategoryPathBadge(pathIds) {
                if (!categoryPathBadge) {
                    return;
                }

                var pathText = (pathIds || [])
                    .map(function (categoryId) {
                        return categoryNodeLookup[categoryId] ? categoryNodeLookup[categoryId].name : '';
                    })
                    .filter(function (name) { return !!name; })
                    .join(' / ');

                if (!pathText) {
                    categoryPathBadge.classList.add('d-none');
                    categoryPathBadge.textContent = '';
                    return;
                }

                categoryPathBadge.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.selectedPathBadge"])) + pathText;
                categoryPathBadge.classList.remove('d-none');
            }

            function persistSelectedProductCategory(categoryId, options) {
                if (!productCategoryField) {
                    return;
                }

                var normalizedCategoryId = (categoryId || '').trim();
                productCategoryField.value = normalizedCategoryId;

                if ((!options || options.syncWidget !== false) && window.jQuery && window.jQuery.fn && window.jQuery.fn.select2) {
                    window.jQuery(productCategoryField).val(normalizedCategoryId).trigger('change.select2');
                }
            }

            function clearSelectedProductCategory() {
                persistSelectedProductCategory('', { syncWidget: true });
                if (pageElement) {
                    pageElement.setAttribute('data-selected-category-id', '');
                }
                lastCreateAttributesCategoryId = '';
            }

            function handleQuickSearchCategorySelection(categoryId) {
                var normalizedCategoryId = (categoryId || '').trim();
                console.log('[Products][QuickSearch] category business id:', normalizedCategoryId || '<empty>');

                persistSelectedProductCategory(normalizedCategoryId, { syncWidget: true });
                syncCategoryTreeFromValue(normalizedCategoryId);
                console.log('[Products][QuickSearch] calling attributes for category:', normalizedCategoryId || '<empty>');
                loadCreateAttributesForCategory(normalizedCategoryId, { force: true });
            }

            function handleCategoryCardSelection(categoryId) {
                var normalizedCategoryId = (categoryId || '').trim();
                console.log('[Products][Card] category business id:', normalizedCategoryId || '<empty>');
                if (!normalizedCategoryId) {
                    console.log('[Products][Card] empty category id, stopping.');
                    return;
                }

                var nextPath = buildCategoryPathIds(normalizedCategoryId);
                renderCategoryTree(nextPath);
                console.log('[Products][Card] category tree rendered for:', normalizedCategoryId);

                if (isLeafCategory(normalizedCategoryId)) {
                    console.log('[Products][Card] no children found, calling attributes for:', normalizedCategoryId);
                    persistSelectedProductCategory(normalizedCategoryId, { syncWidget: true });
                    loadCreateAttributesForCategory(normalizedCategoryId, { force: true });
                    console.log('[Products][Card] attribute call dispatched for:', normalizedCategoryId);
                    return;
                }

                console.log('[Products][Card] has children, rendering child categories for:', normalizedCategoryId);
                clearSelectedProductCategory();
                console.log('[Products][Card] child category render completed for:', normalizedCategoryId);
            }

            function renderCategoryLevelCards(pathIds) {
                if (!categoryTreeLevels) {
                    return;
                }

                var levels = [];
                var currentParentId = '';

                while (true) {
                    var children = getCategoryChildren(currentParentId);
                    if (!children.length) {
                        break;
                    }

                    var levelIndex = levels.length;
                    levels.push({
                        level: levelIndex + 1,
                        parentId: currentParentId,
                        activeId: pathIds[levelIndex] || '',
                        items: children
                    });

                    var activeId = pathIds[levelIndex];
                    if (!activeId || !categoryNodeLookup[activeId] || isLeafCategory(activeId)) {
                        break;
                    }

                    currentParentId = activeId;
                }

                categoryTreeLevels.innerHTML = levels.map(function (level) {
                    return '<div class="product-category-level" data-level="' + level.level + '">'
                        + '<div class="product-category-level-title">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.categorySelectionStepPrefix"])) + ' ' + level.level + ' ' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.categorySelectionStepSuffix"])) + '</div>'
                        + '<div class="product-category-grid">'
                        + level.items.map(function (item) {
                            var isActive = level.activeId && level.activeId.toLowerCase() === item.id.toLowerCase();
                            var imageUrl = item.imageThumbnailUrl || item.imageUrl || '';
                            var mediaHtml = imageUrl
                                ? ('<span class="product-category-card-media"><img src="' + escapeHtml(imageUrl) + '" alt="' + escapeHtml(item.name) + '" /></span>')
                                : '';
                            return '<button type="button" class="product-category-card' + (isActive ? ' active' : '') + (!imageUrl ? ' product-category-card-no-media' : '') + '" data-category-card data-category-id="' + escapeHtml(item.id) + '">'
                                + mediaHtml
                                + '<span class="product-category-card-name">' + escapeHtml(item.name) + '</span>'
                                + '<span class="product-category-card-code">' + escapeHtml(item.code || @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.noCode"]))) + '</span>'
                                + '</button>';
                        }).join('')
                        + '</div>'
                        + '</div>';
                }).join('');

            }

            function renderCategoryTree(pathIds) {
                var effectivePath = Array.isArray(pathIds) ? pathIds.filter(function (item) { return !!item; }) : [];
                renderCategoryLevelCards(effectivePath);
                syncCategoryPathBadge(effectivePath);
            }

            function syncCategoryTreeFromValue(categoryId) {
                renderCategoryTree(buildCategoryPathIds(categoryId));
            }

            function initSearchableSelects(scope) {
                if (!scope || !window.jQuery || !window.jQuery.fn || !window.jQuery.fn.select2) {
                    return;
                }

                var $ = window.jQuery;
                scope.querySelectorAll('select.js-search-select').forEach(function (select) {
                    if (select.dataset.select2Initialized === 'true') {
                        return;
                    }

                    $(select).select2({
                        theme: 'bootstrap',
                        dir: document.documentElement.getAttribute('dir') || 'rtl',
                        width: select.getAttribute('data-width') || '100%',
                        placeholder: select.getAttribute('data-placeholder') || '',
                        minimumResultsForSearch: select.hasAttribute('data-no-search') ? Infinity : 0
                    });

                    select.dataset.select2Initialized = 'true';
                });
            }

            function setCreateAttributeFeedback(message, kind) {
                if (!createAttributeFeedback) {
                    return;
                }

                if (!message) {
                    createAttributeFeedback.innerHTML = '';
                    return;
                }

                var alertClass = kind === 'warning'
                    ? 'alert-warning'
                    : (kind === 'success' ? 'alert-success' : 'alert-danger');
                createAttributeFeedback.innerHTML = '<div class="alert ' + alertClass + ' mb-3">' + escapeHtml(message) + '</div>';
            }

            function setCreateAttributeStatus(message, kind) {
                if (!createAttributeStatus) {
                    return;
                }

                var badgeClass = kind === 'success'
                    ? 'badge-success'
                    : (kind === 'warning' ? 'badge-warning' : (kind === 'danger' ? 'badge-danger' : 'badge-secondary'));
                createAttributeStatus.className = 'badge ' + badgeClass + ' ml-2';
                createAttributeStatus.textContent = message || @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.unknownStatus"]));
            }

            function buildCreateAttributeOriginText(attribute, includeDisplayOrder) {
                var parts = [];
                if (includeDisplayOrder) {
                    parts.push(@Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.attributePriorityPrefix"])) + (attribute.displayOrder || 0));
                }

                parts.push(attribute.isInherited
                    ? (@Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.inheritedFromPrefix"])) + (attribute.sourceCategoryName || ''))
                    : @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.direct"]));
                parts.push(attribute.isRequired ? @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.required"])) : @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.optional"])));
                return parts.join(' - ');
            }

            function renderCreateAttributeSections(data) {
                if (!createDynamicSections) {
                    return;
                }

                var productAttributes = Array.isArray(data && data.productAttributes) ? data.productAttributes : [];
                var variantAttributes = Array.isArray(data && data.variantAttributes) ? data.variantAttributes : [];

                if (!data || !data.categoryId) {
                    createDynamicSections.innerHTML = '<div class="alert alert-warning">@UiText["catalog.products.selectCategoryForDynamicSections"]</div>';
                    autoVariantPreviewContainer = document.getElementById('auto-variant-preview-container');
                    autoVariantPreviewBody = document.getElementById('auto-variant-preview-body');
                    autoVariantPreviewEmpty = document.getElementById('auto-variant-preview-empty');
                    return;
                }

                var productSection = productAttributes.length === 0
                    ? '<div class="text-muted small">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.noProductAttributeDefined"])) + '</div>'
                    : productAttributes.map(function (attribute) {
                        var label = escapeHtml(attribute.name || '') + ' (' + escapeHtml(attribute.dataType || '') + ')' + (attribute.isRequired ? ' *' : '');
                        var inputHtml = '';
                        var options = Array.isArray(attribute.options) ? attribute.options : [];
                        var dataType = ((attribute.dataType || '') + '').trim().toLowerCase();

                        if (options.length > 0) {
                            inputHtml = '<select class="form-control js-search-select js-auto-product-value" data-option-input="true" name="AutoProductOption_' + escapeHtml(attribute.attributeId || '') + '" data-placeholder="' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.selectOption"])) + '">'
                                + '<option value="">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.selectValue"])) + '</option>'
                                + options.map(function (option) {
                                    return '<option value="' + escapeHtml(option.id || '') + '" data-option-name="' + escapeHtml(option.optionName || '') + '" data-option-value="' + escapeHtml(option.optionValue || '') + '">'
                                        + escapeHtml(option.optionName || '') + ' (' + escapeHtml(option.optionValue || '') + ')</option>';
                                }).join('')
                                + '</select>';
                        } else if (dataType === 'number') {
                            inputHtml = '<input type="number" step="any" class="form-control js-auto-product-value" name="AutoProductValue_' + escapeHtml(attribute.attributeId || '') + '" placeholder="' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.products.numericValue"])) + '" />';
                        } else if (dataType === 'date') {
                            inputHtml = '<input type="date" class="form-control js-auto-product-value" name="AutoProductValue_' + escapeHtml(attribute.attributeId || '') + '" />';
                        } else if (dataType === 'boolean') {
                            inputHtml = '<select class="form-control js-auto-product-value" name="AutoProductValue_' + escapeHtml(attribute.attributeId || '') + '">'
