            if (label) label.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["product.image"]));
            if (status) status.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["media.imageHelp"]));
            if (removeButton) removeButton.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["media.removeImage"]));

            function getUploadErrorMessage(xhr, fallbackMessage) {
                try {
                    var errorPayload = JSON.parse(xhr.responseText || '{}');
                    if (errorPayload && errorPayload.message) {
                        return errorPayload.message;
                    }
                } catch (e) {
                }

                return fallbackMessage;
            }

            function syncPreview() {
                var previewUrl = (thumbField.value || imageUrlField.value || '').trim();
                if (!previewUrl) {
                    previewWrap.classList.add('d-none');
                    removeButton.classList.add('d-none');
                    return;
                }
                preview.src = toMediaUrl(previewUrl);
                previewWrap.classList.remove('d-none');
                removeButton.classList.remove('d-none');
