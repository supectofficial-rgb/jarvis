        var item = Model.SellerLookup.FirstOrDefault(x => string.Equals(x.SellerBusinessKey, id, StringComparison.OrdinalIgnoreCase));
        return item is null ? id : $"{item.Code} - {item.Name}";
    }

    string LocationName(string id)
    {
        if (string.IsNullOrWhiteSpace(id))
        {
            return "-";
        }

        var item = Model.LocationLookup.FirstOrDefault(x => string.Equals(x.LocationBusinessKey, id, StringComparison.OrdinalIgnoreCase));
        return item is null ? id : item.LocationCode;
    }

    string QualityStatusName(string id)
    {
        if (string.IsNullOrWhiteSpace(id))
        {
            return "-";
        }

        var item = Model.QualityStatusLookup.FirstOrDefault(x => string.Equals(x.QualityStatusBusinessKey, id, StringComparison.OrdinalIgnoreCase));
        return item is null ? id : $"{item.Code} - {item.Name}";
    }

    string TransactionStatusClass(string? status) => status switch
    {
        "Draft" => "badge-outline-secondary",
        "Posted" => "badge-success",
        "Cancelled" => "badge-warning",
        "Reversed" => "badge-danger",
        _ => "badge-secondary"
    };
}

