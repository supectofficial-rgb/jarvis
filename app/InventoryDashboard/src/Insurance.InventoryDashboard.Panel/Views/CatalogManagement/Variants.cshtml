<div class="modal fade" id="variant-prices-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="variant-prices-modal-title">@UiText["catalog.variants.pricesTitle"]</h5>
                    <div class="small text-muted" id="variant-prices-modal-subtitle"></div>
                </div>
                <button type="button" class="close" data-dismiss="modal" aria-label='@UiText["catalog.variants.close"]'>
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="variant-prices-modal-body">
                <div class="alert alert-warning d-none" id="variant-prices-bulk-empty">یک یا چند مورد از موارد را انتخاب کنید</div>
                <div class="alert alert-danger d-none" id="variant-prices-modal-error"></div>
                <div class="alert alert-light" id="variant-prices-modal-summary"></div>

                <form asp-action="ApplyVariantPricing"
                      asp-controller="VariantManagement"
                      method="post"
                      id="variant-pricing-form"
                      data-ajax-submit="variant-pricing"
                      data-loading-form>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="SelectedVariantRefs" id="variant-pricing-selected-refs" />
                    <div id="variant-pricing-content">
                        <div class="border rounded bg-light p-3 mb-3">
                            <div class="form-row align-items-end">
                                <div class="form-group col-md-4 mb-2">
                                    <label>قیمت یکسان برای همه ردیف‌ها</label>
                                    <input name="ApplyToAllAmount" class="form-control" id="variant-pricing-fill-amount" type="number" min="0" step="0.01" value="@Model.BulkPricingForm.ApplyToAllAmount?.ToString()" />
                                </div>
                                <div class="form-group col-md-3 mb-2">
                                    <label class="d-none d-md-block">&nbsp;</label>
                                    <button type="button" class="btn btn-outline-primary btn-block" id="variant-pricing-fill-button">پر کردن همه</button>
                                </div>
                                <div class="form-group col-md-2 mb-2">
                                    <label>ارز</label>
                                    <input name="Currency" class="form-control" maxlength="8" value="@Model.BulkPricingForm.Currency" />
                                </div>
                                <div class="form-group col-md-2 mb-2">
                                    <label>حداقل مقدار</label>
                                    <input name="MinQty" class="form-control" type="number" min="1" step="0.01" value="@Model.BulkPricingForm.MinQty" />
                                </div>
                                <div class="form-group col-md-1 mb-2">
                                    <label>اولویت</label>
                                    <input name="Priority" class="form-control" type="number" value="@Model.BulkPricingForm.Priority" />
                                </div>
                            </div>
                            <small class="text-muted">اگر برای بعضی ردیف‌ها مقدار وارد نشود، همین مقدار استفاده می‌شود.</small>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0">
                                <thead>
                                    <tr>
                                        <th>@UiText["catalog.variants.priceType"]</th>
                                        <th>@UiText["catalog.variants.priceChannel"]</th>
                                        <th>@UiText["pricing.amount"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < priceMatrixItems.Count; i++)
                                    {
                                        var price = priceMatrixItems[i];
                                        <tr>
                                            <td>
                                                <input type="hidden" name="Prices[@i].PriceTypeRef" value="@price.PriceTypeRef" />
                                                @(priceTypeLookup.FirstOrDefault(x => x.PriceTypeBusinessKey == price.PriceTypeRef) is { } priceType
                                                    ? $"{priceType.Code} - {priceType.Name}"
                                                    : price.PriceTypeRef.ToString("D"))
                                            </td>
                                            <td>
                                                <input type="hidden" name="Prices[@i].PriceChannelRef" value="@price.PriceChannelRef" />
                                                @(priceChannelLookup.FirstOrDefault(x => x.PriceChannelBusinessKey == price.PriceChannelRef) is { } priceChannel
                                                    ? $"{priceChannel.Code} - {priceChannel.Name}"
                                                    : price.PriceChannelRef.ToString("D"))
                                            </td>
                                            <td>
                                                <input class="form-control form-control-sm js-price-amount"
                                                       name="Prices[@i].Amount"
                                                       data-price-matrix-key="@($"{price.PriceTypeRef:D}|{price.PriceChannelRef:D}")"
                                                       type="number"
                                                       min="0"
                                                       step="0.01"
                                                       value="" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="text-right mt-3">
                        <button type="submit" class="btn btn-primary">ثبت قیمت‌ها</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

