                var filterText = (bulkAddonSearchInput && bulkAddonSearchInput.value ? bulkAddonSearchInput.value : '').toLowerCase();
                bulkAddonSelectorList.innerHTML = '';

                Array.from(bulkAddonSelect.options || []).forEach(function (option) {
                    if (!option.value) {
