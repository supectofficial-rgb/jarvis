                                                </div>
                                            </form>
                                        </div>
                                        <hr class="my-4" />
                                        <div id="variant-media-library-modal-body">
                                            @await Html.PartialAsync("~/Views/Shared/_VariantMediaLibraryBody.cshtml", Model.SelectedVariantDetails)
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="variant-list-content"
                             class="table-responsive"
                             data-source-url='@Url.Action("VariantList", "VariantManagement")'
