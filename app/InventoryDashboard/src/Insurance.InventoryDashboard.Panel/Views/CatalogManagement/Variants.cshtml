            var bulkAddonSelectorList = document.getElementById('bulk-addon-selector-list');
            var bulkAddonApplyButton = document.getElementById('bulk-addon-apply-selection');
            var bulkAddonPills = document.getElementById('bulk-addon-selection-pills');
            var bulkAddonSummary = document.getElementById('bulk-addon-selection-summary');

            function readBulkAddonSelection() {
                var rawValue = bulkAddonSelectedIdsInput ? bulkAddonSelectedIdsInput.value : '';
                return rawValue ? rawValue.split(',').map(function (item) { return item.trim(); }).filter(Boolean) : [];
            }

            function renderBulkAddonSummary() {
                if (!bulkAddonPills || !bulkAddonSelect || !bulkAddonSummary) {
                    return;
