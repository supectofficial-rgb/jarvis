@using System
@using System.Linq
@using System.Text.Json
@model Insurance.InventoryDashboard.Panel.Models.VariantManagementPageViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = UiText["catalog.variants.title"];
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var isEditMode = !string.IsNullOrWhiteSpace(Model.VariantForm.VariantId);
    var hasSelectedProduct = !string.IsNullOrWhiteSpace(Model.SelectedProductId);
    var hasSelectedVariant = !string.IsNullOrWhiteSpace(Model.SelectedVariantId);
    var movementLocked = Model.SelectedVariantDetails?.InventoryMovementLocked ?? false;
    var attributeTypeOptions = Model.EffectiveProductAttributes
        .Select(x => x.DataType)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x)
        .ToList();

    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x =>
        string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));
    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    var hasRestrictedActions = !Can("Catalog.Variant.Create", "Catalog.Variant.Update", "ProductVariant.Create", "ProductVariant.Update")
        || !Can("Catalog.Variant.Activate", "ProductVariant.Activate")
        || !Can("Catalog.Variant.Deactivate", "ProductVariant.Deactivate")
        || !Can("Catalog.Variant.Delete", "ProductVariant.Delete")
        || !Can("Catalog.Variant.ChangeTrackingPolicy", "ProductVariant.ChangeTrackingPolicy")
        || !Can("Catalog.Variant.ChangeBaseUom", "ProductVariant.ChangeBaseUom")
        || !Can("Catalog.Variant.LockInventoryMovement", "ProductVariant.LockInventoryMovement")
        || !Can("Catalog.VariantAttributeValue.Set", "VariantAttributeValue.Set")
        || !Can("Catalog.VariantAttributeValue.Remove", "VariantAttributeValue.Remove");
    var hasCatalogSuccess = TempData.ContainsKey("CatalogSuccess");
    var selectedProduct = Model.Products.FirstOrDefault(x => string.Equals(x.Id, Model.SelectedProductId, StringComparison.OrdinalIgnoreCase));
    var selectedVariant = Model.Variants.FirstOrDefault(x => string.Equals(x.Id, Model.SelectedVariantId, StringComparison.OrdinalIgnoreCase));
    var selectedVariantName = selectedVariant?.Sku ?? Model.SelectedVariantDetails?.Sku;
    string? RelatedVariantProductId(string? variantId)
    {
        if (string.IsNullOrWhiteSpace(variantId))
        {
            return null;
        }

        return Model.RelatedVariantLookup.FirstOrDefault(x => string.Equals(x.Id, variantId, StringComparison.OrdinalIgnoreCase))?.ProductId;
    }
    var variantValues = (Model.SelectedVariantDetails?.Attributes ?? new List<Insurance.InventoryDashboard.Panel.Models.VariantAttributeValueModel>())
        .GroupBy(x => x.AttributeId, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(
            x => x.Key,
            x =>
            {
                var item = x.FirstOrDefault();
                return item is null ? string.Empty : (!string.IsNullOrWhiteSpace(item.OptionValue) ? item.OptionValue : item.Value) ?? string.Empty;
            },
            StringComparer.OrdinalIgnoreCase);
    var requiredVariantAttributeCount = Model.EffectiveProductAttributes.Count(x => x.IsRequired);
    var completedRequiredVariantAttributeCount = Model.EffectiveProductAttributes.Count(x =>
        x.IsRequired &&
        variantValues.TryGetValue(x.AttributeId, out var value) &&
        !string.IsNullOrWhiteSpace(value));
    var variantCompletionPercent = requiredVariantAttributeCount == 0
        ? 100
        : (int)Math.Round((completedRequiredVariantAttributeCount * 100.0) / requiredVariantAttributeCount);
    var effectiveVariantAttributeLookup = Model.EffectiveProductAttributes
        .GroupBy(x => x.AttributeId, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);
    var selectedAttributeOptionIds = (Model.VariantAttributeOptionFilterIds ?? string.Empty)
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);
    string WarehouseName(string id)
    {
        if (string.IsNullOrWhiteSpace(id))
        {
            return "-";
        }

        var item = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, id, StringComparison.OrdinalIgnoreCase));
        return item is null ? id : $"{item.Code} - {item.Name}";
    }

    string SellerName(string id)
    {
        if (string.IsNullOrWhiteSpace(id))
        {
            return "-";
        }

        var item = Model.SellerLookup.FirstOrDefault(x => string.Equals(x.SellerBusinessKey, id, StringComparison.OrdinalIgnoreCase));
        return item is null ? id : $"{item.Code} - {item.Name}";
    }

    string LocationName(string id)
    {
        if (string.IsNullOrWhiteSpace(id))
        {
            return "-";
        }

        var item = Model.LocationLookup.FirstOrDefault(x => string.Equals(x.LocationBusinessKey, id, StringComparison.OrdinalIgnoreCase));
        return item is null ? id : item.LocationCode;
    }

    string QualityStatusName(string id)
    {
        if (string.IsNullOrWhiteSpace(id))
        {
            return "-";
        }

        var item = Model.QualityStatusLookup.FirstOrDefault(x => string.Equals(x.QualityStatusBusinessKey, id, StringComparison.OrdinalIgnoreCase));
        return item is null ? id : $"{item.Code} - {item.Name}";
    }

    string TransactionStatusClass(string? status) => status switch
    {
        "Draft" => "badge-outline-secondary",
        "Posted" => "badge-success",
        "Cancelled" => "badge-warning",
        "Reversed" => "badge-danger",
        _ => "badge-secondary"
    };
}

<main id="variants-page"
      class="catalog-page"
      data-selected-product-id="@Model.SelectedProductId"
      data-selected-variant-id="@Model.SelectedVariantId"
      data-catalog-success="@hasCatalogSuccess.ToString().ToLowerInvariant()">
    <div class="container-fluid">
        <div class="row variant-page-heading">
            <div class="col-12">
                <h1>@UiText["catalog.variants.title"]</h1>
                <p class="text-muted">@UiText["catalog.variants.description"]</p>
                <div class="mb-3">
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.variants.primaryGoal"]</span>
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.variants.secondaryOperations"]</span>
                    @if (selectedProduct is not null)
                    {
                        <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.variants.selectedProduct"] @selectedProduct.Name</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(selectedVariantName))
                    {
                        <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.variants.selectedVariant"] @selectedVariantName</span>
                    }
                    <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.variants.requiredCompletion"] @completedRequiredVariantAttributeCount / @requiredVariantAttributeCount</span>
                    @if (movementLocked)
                    {
                        <span class="badge badge-pill badge-outline-primary mb-1">@UiText["catalog.variants.lockStatusActive"]</span>
                    }
                </div>
                <p class="small text-muted mb-3">
                    @UiText["catalog.variants.quickGuide"]
                </p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) || TempData["CatalogError"] is string)
        {
            <div class="row">
                <div class="col-12">
                    <div class="alert alert-warning mb-3">@(TempData["CatalogError"] as string ?? Model.ErrorMessage)</div>
                </div>
            </div>
        }

        @if (TempData["CatalogSuccess"] is string successMessage)
        {
            <div class="row"><div class="col-12"><div class="alert alert-success mb-3">@successMessage</div></div></div>
        }

        @if (TempData["CatalogNotice"] is string noticeMessage)
        {
            <div class="row"><div class="col-12"><div class="alert alert-info mb-3">@noticeMessage</div></div></div>
        }

        <div class="variant-permission-panel">
            @await Html.PartialAsync("~/Views/Shared/_CatalogPermissionNotice.cshtml", hasRestrictedActions)
        </div>

        <div class="row mb-2 variant-completion-panel">
            <div class="col-12">
                @if (Model.SelectedVariantDetails is not null)
                {
                    <div class="card mb-4">
                        <div class="card-body">
                            <div class="d-flex flex-wrap justify-content-between align-items-center mb-2">
                                <h5 class="card-title mb-1">@UiText["catalog.variants.currentStock"]</h5>
                                <div>
                                    <span class="badge badge-pill badge-outline-primary">@UiText["catalog.variants.totalStock"] @Model.VariantStockTotalQuantity</span>
                                    <span class="badge badge-pill badge-light">@UiText["catalog.variants.bucketCount"] @Model.VariantStockBucketCount</span>
                                </div>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm table-striped mb-0">
                                    <thead>
                                        <tr>
                                            <th>@UiText["catalog.variants.warehouse"]</th>
                                            <th>@UiText["catalog.variants.location"]</th>
                                            <th>@UiText["catalog.variants.seller"]</th>
                                            <th>@UiText["catalog.variants.quality"]</th>
                                            <th>@UiText["catalog.variants.lotBatch"]</th>
                                            <th>@UiText["catalog.variants.quantity"]</th>
                                            <th>@UiText["catalog.variants.lastUpdated"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.VariantStockDetails.Count == 0)
                                        {
                                            <tr>
                                                <td colspan="7" class="text-muted">@UiText["catalog.variants.noVisibleStock"]</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            foreach (var stock in Model.VariantStockDetails)
                                            {
                                                <tr>
                                                    <td>@WarehouseName(stock.WarehouseRef)</td>
                                                    <td>@LocationName(stock.LocationRef)</td>
                                                    <td>@SellerName(stock.SellerRef)</td>
                                                    <td>@QualityStatusName(stock.QualityStatusRef)</td>
                                                    <td>@(string.IsNullOrWhiteSpace(stock.LotBatchNo) ? "-" : stock.LotBatchNo)</td>
                                                    <td>@stock.QuantityOnHand</td>
                                                    <td>@stock.LastUpdatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }

                <div class="card">
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong>@UiText["catalog.variants.completionStatus"]</strong>
                            <span class="badge badge-pill @(variantCompletionPercent >= 100 ? "badge-primary" : variantCompletionPercent >= 70 ? "badge-outline-primary" : "badge-danger")">
                                @variantCompletionPercent%
                            </span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" role="progressbar" style="width:@variantCompletionPercent%"></div>
                        </div>
                        <small class="text-muted d-block mt-2">
                            @UiText["catalog.variants.completedRequiredFields"] @completedRequiredVariantAttributeCount @UiText["catalog.variants.outOf"] @requiredVariantAttributeCount
                        </small>
                    </div>
                    <div class="tab-pane fade" id="variant-tab-inventory-movements" role="tabpanel">
                        @if (hasSelectedProduct && hasSelectedVariant)
                        {
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
                                        <h5 class="card-title mb-1">@UiText["catalog.variants.inventoryMovements"]</h5>
                                        <span class="text-muted small">@Model.VariantInventoryTransactions.Count @UiText["catalog.variants.transactionCountSuffix"]</span>
                                    </div>
                                    <div class="table-responsive">
                                        <table class="table table-sm table-striped mb-0">
                                            <thead>
                                                <tr>
                                                    <th>@UiText["catalog.variants.transactionNo"]</th>
                                                    <th>@UiText["common.type"]</th>
                                                    <th>@UiText["common.status"]</th>
                                                    <th>@UiText["catalog.variants.warehouse"]</th>
                                                    <th>@UiText["catalog.variants.seller"]</th>
                                                    <th>@UiText["catalog.variants.occurredAt"]</th>
                                                    <th>@UiText["catalog.variants.postedAt"]</th>
                                                    <th>@UiText["catalog.variants.reason"]</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (Model.VariantInventoryTransactions.Count == 0)
                                                {
                                                    <tr>
                                                        <td colspan="8" class="text-muted">@UiText["catalog.variants.noInventoryMovements"]</td>
                                                    </tr>
                                                }
                                                else
                                                {
                                                    foreach (var tx in Model.VariantInventoryTransactions.OrderByDescending(x => x.OccurredAt))
                                                    {
                                                        <tr>
                                                            <td class="text-monospace">@tx.TransactionNo</td>
                                                            <td>@tx.TransactionType</td>
                                                            <td><span class="badge badge-pill @TransactionStatusClass(tx.Status)">@tx.Status</span></td>
                                                            <td>@WarehouseName(tx.WarehouseRef)</td>
                                                            <td>@SellerName(tx.SellerRef)</td>
                                                            <td>@tx.OccurredAt.ToString("yyyy/MM/dd HH:mm")</td>
                                                            <td>@(tx.PostedAt.HasValue ? tx.PostedAt.Value.ToString("yyyy/MM/dd HH:mm") : "-")</td>
                                                            <td>@(string.IsNullOrWhiteSpace(tx.ReasonCode) ? "-" : tx.ReasonCode)</td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="card">
                                <div class="card-body">
                                    <div class="alert alert-light mb-0">
                                        <h6>@UiText["catalog.variants.noVariantSelected"]</h6>
                                        <p class="mb-0 text-muted">@UiText["catalog.variants.noVariantSelectedInventoryHelp"]</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (Model.MissingRequiredVariantAttributes.Count > 0)
        {
            <div class="row variant-missing-panel">
                <div class="col-12">
                    <div class="alert alert-danger mb-3">
                        @UiText["catalog.variants.requiredAttributesIncomplete"]
                        @string.Join("، ", Model.MissingRequiredVariantAttributes.Select(x => x.Name))
                    </div>
                </div>
            </div>
        }

        @if (movementLocked)
        {
            <div class="row variant-lock-panel">
                <div class="col-12">
                    <div class="alert alert-secondary mb-3">
                        @UiText["catalog.variants.lockedMovementWarning"]
                    </div>
                </div>
            </div>
        }

        <div class="row mb-3">
            <div class="col-12 mb-2" id="variant-product-selector-card">
                <div class="card h-100">
                    <div class="card-body">
                        <h6 class="card-title">@UiText["catalog.variants.selectProductTitle"]</h6>
                        <form method="get" asp-action="Variants" id="variant-product-selector-form" data-state-form>
                            <div class="form-group mb-0">
                                <select name="productId" class="form-control js-search-select" data-placeholder='@UiText["catalog.variants.selectProduct"]' onchange="this.form.submit()">
                                    @foreach (var product in Model.Products)
                                    {
                                        <option value="@product.Id" selected="@(product.Id == Model.SelectedProductId ? "selected" : null)">@product.Name (@product.BaseSku)</option>
                                    }
                                </select>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-12 mb-2">
                <div class="card h-100">
                    <div class="card-body">
                        <h6 class="card-title mb-3">@UiText["catalog.variants.searchAndFilter"]</h6>
                        <form method="get" asp-action="Variants" class="row" id="variant-search-form" data-state-form>
                            <input type="hidden" name="attributeOptionIds" id="variant-attribute-option-ids" value="@Model.VariantAttributeOptionFilterIds" />
                            <div class="col-md-3 mb-2">
                                <label class="text-muted small">@UiText["catalog.variants.productSearchLabel"]</label>
                                <input name="searchTerm" value="@Model.VariantSearchTerm" class="form-control" data-filter-label='@UiText["common.search"]' placeholder='@UiText["catalog.variants.productSearchPlaceholder"]' />
                            </div>
                            <div class="col-md-3 mb-2">
                                <label class="text-muted small">@UiText["catalog.variants.categoryFilter"]</label>
                                <select name="categoryId" class="form-control js-search-select" data-placeholder='@UiText["catalog.variants.selectCategory"]'>
                                    <option value="">@UiText["catalog.variants.allCategories"]</option>
                                    @foreach (var category in Model.LeafCategories)
                                    {
                                        <option value="@category.Id" selected="@(string.Equals(Model.VariantCategoryFilterId, category.Id, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@category.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3 mb-2">
                                <label class="text-muted small">@UiText["catalog.variants.attributesFilter"]</label>
                                <select id="variant-attribute-options-filter" class="form-control js-search-select" multiple data-placeholder='@UiText["catalog.variants.selectOptions"]'>
                                    @foreach (var attr in Model.EffectiveProductAttributes.Where(x => x.Options.Count > 0).OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name))
                                    {
                                        <optgroup label="@attr.Name">
                                            @foreach (var option in attr.Options.OrderBy(x => x.DisplayOrder).ThenBy(x => x.OptionName))
                                            {
                                                <option value="@option.Id" selected="@(selectedAttributeOptionIds.Contains(option.Id) ? "selected" : null)">@option.OptionName (@option.OptionValue)</option>
                                            }
                                        </optgroup>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3 mb-2">
                                <label class="text-muted small">@UiText["catalog.variants.trackingPolicy"]</label>
                                <select name="trackingPolicy" class="form-control" data-filter-label='@UiText["catalog.variants.trackingPolicy"]'>
                                    <option value="">@UiText["catalog.variants.all"]</option>
                                    <option value="None" selected="@(Model.VariantTrackingFilter == "None" ? "selected" : null)">@UiText["catalog.variants.trackingNone"]</option>
                                    <option value="Batch" selected="@(Model.VariantTrackingFilter == "Batch" ? "selected" : null)">@UiText["catalog.variants.trackingBatch"]</option>
                                    <option value="Serial" selected="@(Model.VariantTrackingFilter == "Serial" ? "selected" : null)">@UiText["catalog.variants.trackingSerial"]</option>
                                </select>
                            </div>
                            <div class="col-md-2 mb-2">
                                <label class="text-muted small">@UiText["common.status"]</label>
                                <select name="statusFilter" class="form-control" data-filter-label='@UiText["common.status"]'>
                                    <option value="">@UiText["catalog.variants.none"]</option>
                                    <option value="active" selected="@(string.Equals(Model.VariantStatusFilter, "active", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["common.active"]</option>
                                    <option value="inactive" selected="@(string.Equals(Model.VariantStatusFilter, "inactive", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["common.inactive"]</option>
                                </select>
                            </div>
                            <div class="col-md-2 mb-2">
                                <label class="text-muted small">@UiText["catalog.variants.attributeType"]</label>
                                <select name="attributeTypeFilter" class="form-control js-search-select" data-filter-label='@UiText["catalog.variants.attributeType"]' data-no-search="true">
                                    <option value="">@UiText["catalog.variants.none"]</option>
                                    @foreach (var type in attributeTypeOptions)
                                    {
                                        <option value="@type" selected="@(string.Equals(Model.SelectedAttributeTypeFilter, type, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@type</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2 mb-2">
                                <label class="text-muted small">@UiText["catalog.variants.sort"]</label>
                                <select name="sort" class="form-control" data-filter-label='@UiText["catalog.variants.sort"]'>
                                    <option value="">@UiText["catalog.variants.sortSkuAsc"]</option>
                                    <option value="sku_desc" selected="@(string.Equals(Model.VariantSort, "sku_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["catalog.variants.sortSkuDesc"]</option>
                                    <option value="tracking_asc" selected="@(string.Equals(Model.VariantSort, "tracking_asc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["catalog.variants.sortTrackingAsc"]</option>
                                    <option value="tracking_desc" selected="@(string.Equals(Model.VariantSort, "tracking_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["catalog.variants.sortTrackingDesc"]</option>
                                    <option value="status_asc" selected="@(string.Equals(Model.VariantSort, "status_asc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["catalog.variants.sortStatusAsc"]</option>
                                    <option value="status_desc" selected="@(string.Equals(Model.VariantSort, "status_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["catalog.variants.sortStatusDesc"]</option>
                                </select>
                            </div>
                            <div class="col-md-1 mb-2">
                                <label class="text-muted small">@UiText["common.count"]</label>
                                <select name="pageSize" class="form-control" data-filter-label='@UiText["common.count"]'>
                                    @foreach (var size in Model.VariantPageSizeOptions)
                                    {
                                        <option value="@size" selected="@(size == Model.VariantPageSize ? "selected" : null)">@size</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-1 mb-2 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary btn-block">@UiText["common.apply"]</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12 mb-4">
                <ul class="nav nav-tabs separator-tabs ml-0 mb-4" role="tablist" id="variant-management-tabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-toggle="tab" href="#variant-tab-main" role="tab">@UiText["catalog.variants.tabs.form"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#variant-tab-actions" role="tab">@UiText["catalog.variants.tabs.domainActions"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#variant-tab-attributes" role="tab">@UiText["catalog.variants.tabs.attributes"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#variant-tab-conversions" role="tab">@UiText["catalog.variants.tabs.unitConversion"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#variant-tab-inventory-movements" role="tab">@UiText["catalog.variants.tabs.inventoryMovement"]</a>
                    </li>
                </ul>
                <div class="tab-content">
                    @await Html.PartialAsync("~/Views/CatalogManagement/_VariantMainSection.cshtml", Model)
                    @await Html.PartialAsync("~/Views/CatalogManagement/_VariantActionsSection.cshtml", Model)
                    @await Html.PartialAsync("~/Views/CatalogManagement/_VariantAttributesSection.cshtml", Model)
                    @await Html.PartialAsync("~/Views/CatalogManagement/_VariantConversionsSection.cshtml", Model)
                </div>
            </div>

            <div class="col-12 mb-4">
                <div class="card mb-4">
                    <div class="card-body" id="variant-list-scope">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="card-title mb-0">@UiText["catalog.variants.listTitle"]</h5>
                            <span class="text-muted small">@Model.VariantTotalCount @UiText["catalog.variants.recordCountSuffix"]</span>
                        </div>
                        <form asp-action="ApplyVariantBulkAction"
                              method="post"
                              class="form-inline mb-3"
                              data-loading-form
                              data-bulk-form
                              data-bulk-scope="#variant-list-scope">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="selectedIds" data-bulk-target />
                            <input type="hidden" name="bulkAction" data-bulk-action-input />
                            <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                            <input type="hidden" name="searchTerm" value="@Model.VariantSearchTerm" />
                            <input type="hidden" name="trackingPolicy" value="@Model.VariantTrackingFilter" />
                            <input type="hidden" name="statusFilter" value="@Model.VariantStatusFilter" />
                            <input type="hidden" name="attributeTypeFilter" value="@Model.SelectedAttributeTypeFilter" />
                            <input type="hidden" name="sort" value="@Model.VariantSort" />
                            <input type="hidden" name="page" value="@Model.VariantPage" />
                            <input type="hidden" name="pageSize" value="@Model.VariantPageSize" />
                            <div class="small text-muted mr-2 mb-2">
                                @UiText["catalog.variants.selectedCount"] <span data-bulk-count>0</span>
                            </div>
                            <div class="btn-group btn-group-sm mb-2">
                                <button type="submit"
                                        class="btn btn-outline-success btn-xs"
                                        data-bulk-action="activate"
                                        data-bulk-permission="@(Can("Catalog.Variant.Activate", "ProductVariant.Activate") ? "allowed" : "denied")"
                                        data-confirm-title="@UiText["catalog.variants.bulkActivateTitle"]"
                                        data-confirm="@UiText["catalog.variants.bulkActivateConfirm"]"
                                        disabled
                                        @(Can("Catalog.Variant.Activate", "ProductVariant.Activate") ? null : "disabled")>
                                    @UiText["catalog.variants.bulkActivateButton"]
                                </button>
                                <button type="submit"
                                        class="btn btn-outline-warning btn-xs"
                                        data-bulk-action="deactivate"
                                        data-bulk-permission="@(Can("Catalog.Variant.Deactivate", "ProductVariant.Deactivate") ? "allowed" : "denied")"
                                        data-confirm-title="@UiText["catalog.variants.bulkDeactivateTitle"]"
                                        data-confirm="@UiText["catalog.variants.bulkDeactivateConfirm"]"
                                        disabled
                                        @(Can("Catalog.Variant.Deactivate", "ProductVariant.Deactivate") ? null : "disabled")>
                                    @UiText["catalog.variants.bulkDeactivateButton"]
                                </button>
                                <button type="submit"
                                        class="btn btn-outline-danger btn-xs"
                                        data-bulk-action="delete"
                                        data-bulk-permission="@(Can("Catalog.Variant.Delete", "ProductVariant.Delete") ? "allowed" : "denied")"
                                        data-confirm-title="@UiText["catalog.variants.bulkDeleteTitle"]"
                                        data-confirm="@UiText["catalog.variants.bulkDeleteConfirm"]"
                                        disabled
                                        @(Can("Catalog.Variant.Delete", "ProductVariant.Delete") ? null : "disabled")>
                                    @UiText["catalog.variants.bulkDeleteButton"]
                                </button>
                            </div>
                        </form>
                        <form asp-action="BulkAssignVariantAddOn"
                              method="post"
                              class="border rounded p-3 mb-3 bg-light"
                              data-loading-form
                              data-bulk-form
                              data-bulk-scope="#variant-list-scope">
                            @Html.AntiForgeryToken()
                            <input asp-for="BulkVariantAddOnForm.ProductId" type="hidden" value="@Model.SelectedProductId" />
                            <input asp-for="BulkVariantAddOnForm.SelectedVariantIds" type="hidden" data-bulk-target />
                            <input asp-for="BulkVariantAddOnForm.SelectedAddOnVariantIds" type="hidden" id="bulk-addon-selected-ids" />
                            <input asp-for="BulkVariantAddOnForm.AddOnVariantId" type="hidden" id="bulk-addon-primary-id" />
                            <input type="hidden" data-bulk-action-input />
                            <div class="d-flex flex-wrap justify-content-between align-items-center mb-2">
                                <div>
                                    <strong>@UiText["catalog.variants.bulkAddonTitle"]</strong>
                                    <div class="small text-muted">@UiText["catalog.variants.bulkAddonHelp"]</div>
                                </div>
                                <span class="badge badge-pill badge-outline-primary">@UiText["catalog.variants.selectedLabel"] <span data-bulk-count>0</span></span>
                            </div>
                            <div class="form-row align-items-end">
                                <div class="col-md-9 mb-2">
                                    <label>@UiText["catalog.variants.addonVariant"]</label>
                                    <select asp-for="BulkVariantAddOnForm.AddOnVariantId"
                                            class="form-control js-search-select"
                                            data-placeholder='@UiText["catalog.variants.selectAddon"]'>
                                        <option value="">@UiText["catalog.variants.selectVariantOption"]</option>
                                        @foreach (var variant in Model.RelatedVariantLookup)
                                        {
                                            <option value="@variant.Id">@variant.Sku @(string.IsNullOrWhiteSpace(variant.Barcode) ? string.Empty : $" - {variant.Barcode}")</option>
                                        }
                                    </select>
                                    <button type="button"
                                            class="btn btn-outline-secondary btn-block text-left mt-2"
                                            data-toggle="modal"
                                            data-target="#bulk-addon-selector-modal">
                                        @UiText["catalog.variants.selectMultipleAddons"]
                                    </button>
                                    <div class="small text-muted mt-2">@UiText["catalog.variants.multiAddonSearchHelp"]</div>
                                    <div class="border rounded bg-white p-2 mt-2" id="bulk-addon-selection-summary">
                                        <span class="text-muted small" data-empty-text>@UiText["catalog.variants.noAddonSelectedYet"]</span>
                                        <div class="d-flex flex-wrap" id="bulk-addon-selection-pills"></div>
                                    </div>
                                </div>
                                <div class="col-md-3 mb-2">
                                    <button type="submit"
                                            class="btn btn-outline-primary btn-block"
                                            data-bulk-action="assign-addon"
                                            data-bulk-permission="allowed">
                                        @UiText["catalog.variants.registerForSelections"]
                                    </button>
                                </div>
                            </div>
                        </form>
                        <form asp-action="BulkAssignVariantImages"
                              method="post"
                              class="border rounded p-3 mb-3 bg-light"
                              data-loading-form
                              data-bulk-form
                              data-bulk-scope="#variant-list-scope">
                            @Html.AntiForgeryToken()
                            <input asp-for="BulkVariantImageForm.ProductId" type="hidden" value="@Model.SelectedProductId" />
                            <input asp-for="BulkVariantImageForm.SelectedVariantIds" type="hidden" data-bulk-target />
                            <input asp-for="BulkVariantImageForm.ImagesJson" type="hidden" />
                            <div class="d-flex flex-wrap justify-content-between align-items-center mb-2">
                                <div>
                                    <strong>@UiText["catalog.variants.bulkMediaTitle"]</strong>
                                    <div class="small text-muted">@UiText["catalog.variants.bulkMediaHelp"]</div>
                                </div>
                                <span class="badge badge-pill badge-outline-primary">@UiText["catalog.variants.selectedLabel"] <span data-bulk-count>0</span></span>
                            </div>
                            <div data-media-manager
                                 data-policy="variant-gallery"
                                 data-base-url="@Configuration["FileService:BaseUrl"]"
                                 data-input-name="BulkVariantImageForm.ImagesJson">
                                <input type="file" class="form-control-file mb-2" accept=".jpg,.jpeg,.png,.webp,.mp4,.webm,.mov,.m4v" data-media-file multiple />
                                <div class="progress mb-2 d-none" style="height:8px;" data-media-progress-wrap>
                                    <div class="progress-bar" style="width:0%;" data-media-progress></div>
                                </div>
                                <div class="small text-muted mb-2" data-media-status>@UiText["variant.media.bulkHelp"]</div>
                                <div class="row" data-media-items></div>
                                <div class="alert alert-light mb-3" data-media-empty>@UiText["variant.media.bulkEmpty"]</div>
                            </div>
                            <div class="text-right">
                                <button type="submit"
                                        class="btn btn-outline-primary"
                                        data-bulk-action="assign-media"
                                        data-bulk-permission="allowed">
                                    @UiText["catalog.variants.registerMediaForSelections"]
                                </button>
                            </div>
                        </form>
                        <div class="table-responsive">
                            <table class="table table-sm table-striped">
                                <thead>
                                    <tr>
                                        <th><input type="checkbox" data-bulk-toggle aria-label='@UiText["catalog.variants.selectAll"]' /></th>
                                        <th>SKU</th>
                                        <th>@UiText["catalog.variants.barcode"]</th>
                                        <th>@UiText["catalog.variants.baseUom"]</th>
                                        <th>@UiText["catalog.variants.trackingPolicy"]</th>
                                        <th>@UiText["common.status"]</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Variants.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="7">
                                                <div class="alert alert-light my-2">
                                                    <h6>@UiText["catalog.variants.noVariantsFound"]</h6>
                                                    <p class="mb-0 text-muted">@UiText["catalog.variants.reviewFiltersOrCreate"]</p>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var variant in Model.Variants)
                                        {
                                            <tr>
                                                <td><input type="checkbox" data-bulk-row value="@variant.Id" aria-label='@string.Format(UiText["catalog.variants.rowRequiredFormat"], variant.Sku)' /></td>
                                                <td><span class="text-monospace">@variant.Sku</span></td>
                                                <td>@(string.IsNullOrWhiteSpace(variant.Barcode) ? "-" : $"#{variant.Barcode}")</td>
                                                <td>@variant.BaseUom</td>
                                                <td>@variant.TrackingPolicy</td>
                                                <td>
                                                    <span class="badge badge-pill @(variant.IsActive ? "badge-primary" : "badge-secondary")">
                                                        @(variant.IsActive ? UiText["common.active"] : UiText["common.inactive"])
                                                    </span>
                                                    @if (variant.InventoryMovementLocked)
                                                    {
                                                        <span class="badge badge-warning ml-1">@UiText["catalog.variants.locked"]</span>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm">
                                                        <button type="button" class="btn btn-outline-info btn-xs js-variant-detail"
                                                                data-detail-url="@Url.Action("VariantStocks", "VariantManagement", new { variantId = variant.Id })"
                                                                data-detail-title="@UiText["catalog.variants.inventoryAndWarehouses"]">
                                                            @UiText["catalog.variants.warehousesButton"]
                                                        </button>
                                                        <button type="button" class="btn btn-outline-info btn-xs js-variant-detail"
                                                                data-detail-url="@Url.Action("VariantPrices", "VariantManagement", new { variantId = variant.Id })"
                                                                data-detail-title="@UiText["catalog.variants.pricesTitle"]">
                                                            @UiText["catalog.variants.pricesButton"]
                                                        </button>
                                                        <button type="button" class="btn btn-outline-info btn-xs js-variant-detail"
                                                                data-detail-url="@Url.Action("VariantDocuments", "VariantManagement", new { variantId = variant.Id })"
                                                                data-detail-title="@UiText["catalog.variants.documentsAndTransactions"]">
                                                            @UiText["catalog.variants.documentsButton"]
                                                        </button>
                                                        <button type="button" class="btn btn-outline-secondary btn-xs dropdown-toggle dropdown-toggle-split" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                            <span class="sr-only">@UiText["common.operations"]</span>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right">
                                                            <form asp-action="ActivateVariant" method="post" class="px-3 py-1" data-loading-form>
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                                                                <input type="hidden" name="variantId" value="@variant.Id" />
                                                                <button type="submit" class="btn btn-link p-0" @(Can("Catalog.Variant.Activate", "ProductVariant.Activate") ? null : "disabled")>@UiText["catalog.variants.activateButton"]</button>
                                                            </form>
                                                            <form asp-action="DeactivateVariant" method="post" class="px-3 py-1" data-loading-form>
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                                                                <input type="hidden" name="variantId" value="@variant.Id" />
                                                                <button type="submit" class="btn btn-link p-0" @(Can("Catalog.Variant.Deactivate", "ProductVariant.Deactivate") ? null : "disabled")>@UiText["catalog.variants.deactivateButton"]</button>
                                                            </form>
                                                            <form asp-action="LockVariantInventoryMovement" method="post" class="px-3 py-1" data-loading-form>
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                                                                <input type="hidden" name="variantId" value="@variant.Id" />
                                                                <button type="submit"
                                                                        class="btn btn-link p-0"
                                                                        data-confirm-title="@UiText["catalog.variants.lockMovementTitle"]"
                                                                        data-confirm="@UiText["catalog.variants.lockListConfirm"]"
                                                                        @(Can("Catalog.Variant.LockInventoryMovement", "ProductVariant.LockInventoryMovement") ? null : "disabled")>
                                                                    @UiText["catalog.variants.lockButtonShort"]
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (Model.VariantTotalPages > 1)
                        {
                            <nav class="mt-3">
                                <ul class="pagination pagination-sm mb-0">
                                    @for (var i = 1; i <= Model.VariantTotalPages; i++)
                                    {
                                        <li class="page-item @(i == Model.VariantPage ? "active" : null)">
                                            <a class="page-link"
                                               asp-action="Variants"
                                               asp-route-productId="@Model.SelectedProductId"
                                               asp-route-variantId="@Model.SelectedVariantId"
                                               asp-route-searchTerm="@Model.VariantSearchTerm"
                                               asp-route-trackingPolicy="@Model.VariantTrackingFilter"
                                               asp-route-statusFilter="@Model.VariantStatusFilter"
                                               asp-route-attributeTypeFilter="@Model.SelectedAttributeTypeFilter"
                                               asp-route-sort="@Model.VariantSort"
                                               asp-route-page="@i"
                                               asp-route-pageSize="@Model.VariantPageSize">@i</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    </div>
                </div>

                <div class="card mb-4" id="variant-details-card">
                    <div class="card-body">
                        <h5 class="card-title">@UiText["catalog.variants.detailsTitle"]</h5>
                        @if (Model.SelectedVariantDetails is null)
                        {
                            <div class="alert alert-light mb-0">
                                <h6>@UiText["catalog.variants.noVariantSelected"]</h6>
                                <p class="mb-0 text-muted">@UiText["catalog.variants.selectVariantForDetails"]</p>
                            </div>
                        }
                        else
                        {
                            <p class="mb-1"><strong>SKU:</strong> <span class="text-monospace">@Model.SelectedVariantDetails.Sku</span></p>
                            <p class="mb-1"><strong>@UiText["catalog.variants.barcode"]:</strong> @(string.IsNullOrWhiteSpace(Model.SelectedVariantDetails.Barcode) ? "-" : Model.SelectedVariantDetails.Barcode)</p>
                            <p class="mb-1"><strong>@UiText["catalog.variants.baseUom"]:</strong> @Model.SelectedVariantDetails.BaseUom</p>
                            <p class="mb-1"><strong>@UiText["catalog.variants.trackingPolicy"]:</strong> @Model.SelectedVariantDetails.TrackingPolicy</p>
                            <p class="mb-3">
                                <strong>@UiText["catalog.variants.lockMovementTitle"]:</strong>
                                <span class="badge badge-pill @(Model.SelectedVariantDetails.InventoryMovementLocked ? "badge-warning" : "badge-primary")">
                                    @(Model.SelectedVariantDetails.InventoryMovementLocked ? UiText["common.active"] : UiText["common.inactive"])
                                </span>
                            </p>
                            <h6>@UiText["catalog.variants.savedAttributeValues"]</h6>
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead><tr><th>@UiText["catalog.variants.attribute"]</th><th>@UiText["catalog.variants.value"]</th><th>@UiText["catalog.variants.metadata"]</th><th></th></tr></thead>
                                    <tbody>
                                        @foreach (var attr in Model.SelectedVariantDetails.Attributes)
                                        {
                                            effectiveVariantAttributeLookup.TryGetValue(attr.AttributeId, out var attrMeta);
                                            var currentValue = !string.IsNullOrWhiteSpace(attr.OptionValue)
                                                ? attr.OptionValue
                                                : attr.Value;
                                            var optionDisplayName = !string.IsNullOrWhiteSpace(attr.OptionValue) && attrMeta is not null
                                                ? attrMeta.Options.FirstOrDefault(o => string.Equals(o.OptionValue, attr.OptionValue, StringComparison.OrdinalIgnoreCase))?.OptionName
                                                : null;
                                            var displayValue = !string.IsNullOrWhiteSpace(optionDisplayName)
                                                ? optionDisplayName
                                                : currentValue;
                                            <tr>
                                                <td>@(attr.AttributeName ?? attr.AttributeId)</td>
                                                <td>@(string.IsNullOrWhiteSpace(displayValue) ? "-" : displayValue)</td>
                                                <td>
                                                    @if (attrMeta is not null)
                                                    {
                                                        <span class="badge badge-pill @(attrMeta.IsRequired ? "badge-danger" : "badge-light")">@(attrMeta.IsRequired ? UiText["catalog.variants.required"] : UiText["catalog.variants.optional"])</span>
                                                        <span class="badge badge-pill @(attrMeta.IsInherited ? "badge-outline-primary" : "badge-outline-secondary")">@(attrMeta.IsInherited ? UiText["catalog.variants.inherited"] : UiText["catalog.variants.direct"])</span>
                                                    }
                                                </td>
                                                <td>
                                                    <button type="button"
                                                            class="btn btn-outline-secondary btn-xs variant-attribute-edit-btn"
                                                            data-attribute-id="@attr.AttributeId"
                                                            data-current-value="@currentValue"
                                                            @(Can("Catalog.VariantAttributeValue.Set", "VariantAttributeValue.Set") ? null : "disabled")>
                                                        @UiText["common.edit"]
                                                    </button>
                                                    <form asp-action="RemoveVariantAttributeValue" method="post" class="d-inline" data-loading-form>
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                                                        <input type="hidden" name="variantId" value="@Model.SelectedVariantDetails.Id" />
                                                        <input type="hidden" name="attributeId" value="@attr.AttributeId" />
                                                        <button type="submit" class="btn btn-outline-danger btn-xs" data-confirm-title="@UiText["catalog.variants.deleteAttributeValueTitle"]" data-confirm="@UiText["catalog.variants.deleteAttributeValueConfirm"]" @(Can("Catalog.VariantAttributeValue.Remove", "VariantAttributeValue.Remove") ? null : "disabled")>@UiText["common.delete"]</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>

                <div class="card mb-4" id="variant-media-library-card">
                    <div class="card-body">
                        <h5 class="card-title">@UiText["catalog.variants.variantMediaTitle"]</h5>
                        @if (Model.SelectedVariantDetails is null)
                        {
                            <div class="alert alert-light mb-0">
                                <h6>@UiText["catalog.variants.noVariantSelected"]</h6>
                                <p class="mb-0 text-muted">@UiText["catalog.variants.selectVariantForMedia"]</p>
                            </div>
                        }
                        else if (Model.SelectedVariantDetails.Images.Count == 0)
                        {
                            <div class="alert alert-light mb-0">
                                @UiText["catalog.variants.noMediaRegistered"]
                            </div>
                        }
                        else
                        {
                            <div class="row">
                                @foreach (var media in Model.SelectedVariantDetails.Images.OrderBy(x => x.DisplayOrder))
                                {
                                    var isVideo = !string.IsNullOrWhiteSpace(media.ContentType) && media.ContentType.StartsWith("video/", StringComparison.OrdinalIgnoreCase);
                                    <div class="col-lg-4 col-md-6 mb-3">
                                        <div class="card h-100">
                                            <div class="card-body">
                                                @if (isVideo)
                                                {
                                                    <video src="@media.OriginalUrl" class="w-100 rounded border mb-2" style="max-height:200px;" controls preload="metadata"></video>
                                                }
                                                else
                                                {
                                                    <img src="@media.ThumbnailUrl" alt="@media.OriginalFileName" class="img-fluid rounded border mb-2" style="max-height:200px;" />
                                                }
                                                <div class="small text-muted mb-2">@media.OriginalFileName</div>
                                                <div class="mb-2">
                                                    <span class="badge badge-pill badge-outline-primary">@UiText["catalog.variants.displayOrder"] @media.DisplayOrder</span>
                                                    @if (media.IsPrimary)
                                                    {
                                                        <span class="badge badge-pill badge-primary">@UiText["catalog.variants.primary"]</span>
                                                    }
                                                    <span class="badge badge-pill badge-light">@(isVideo ? UiText["catalog.variants.video"] : UiText["catalog.variants.image"])</span>
                                                </div>
                                                <div class="btn-group btn-group-sm">
                                                    <a href="@media.OriginalUrl" target="_blank" rel="noopener" class="btn btn-outline-info btn-xs">@UiText["catalog.variants.view"]</a>
                                                    <form asp-action="RemoveVariantImage" method="post" class="d-inline" data-loading-form>
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                                                        <input type="hidden" name="variantId" value="@Model.SelectedVariantDetails.Id" />
                                                        <input type="hidden" name="fileKey" value="@media.FileKey" />
                                                        <button type="submit" class="btn btn-outline-danger btn-xs">@UiText["catalog.variants.removeRelation"]</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="card" id="variant-uom-conversions-card">
                    <div class="card-body">
                        <h5 class="card-title">@UiText["catalog.variants.conversionListTitle"]</h5>
                        <div class="table-responsive">
                            <table class="table table-sm table-striped">
                                <thead><tr><th>@UiText["catalog.variants.fromUnit"]</th><th>@UiText["catalog.variants.toUnit"]</th><th>@UiText["catalog.variants.conversionFactor"]</th><th>@UiText["catalog.variants.roundingMode"]</th><th>@UiText["catalog.variants.basePath"]</th><th></th></tr></thead>
                                <tbody>
                                    @if (Model.VariantUomConversions.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="6">
                                                <div class="alert alert-light my-2">
                                                    <h6>@UiText["catalog.variants.noConversionPath"]</h6>
                                                    <p class="mb-0 text-muted">@UiText["catalog.variants.noConversionPathHelp"]</p>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var conversion in Model.VariantUomConversions)
                                        {
                                            var from = Model.UnitOfMeasures.FirstOrDefault(x => string.Equals(x.Id, conversion.FromUomRef, StringComparison.OrdinalIgnoreCase));
                                            var to = Model.UnitOfMeasures.FirstOrDefault(x => string.Equals(x.Id, conversion.ToUomRef, StringComparison.OrdinalIgnoreCase));
                                            <tr>
                                                <td>@(from is null ? conversion.FromUomRef : $"{from.Code} - {from.Name}")</td>
                                                <td>@(to is null ? conversion.ToUomRef : $"{to.Code} - {to.Name}")</td>
                                                <td>@conversion.Factor</td>
                                                <td>@conversion.RoundingMode</td>
                                                <td>@(conversion.IsBasePath ? UiText["common.yes"] : UiText["common.no"])</td>
                                                <td>
                                                    <button type="button"
                                                            class="btn btn-outline-secondary btn-xs conversion-edit-btn"
                                                            data-from-uom="@conversion.FromUomRef"
                                                            data-to-uom="@conversion.ToUomRef"
                                                            data-factor="@conversion.Factor"
                                                            data-rounding="@conversion.RoundingMode"
                                                            data-is-base-path="@(conversion.IsBasePath ? "true" : "false")"
                                                            @(Can("Catalog.VariantUomConversion.Upsert", "ProductVariantUomConversion.Upsert") ? null : "disabled")>
                                                        @UiText["common.edit"]
                                                    </button>
                                                    <form asp-action="RemoveVariantUomConversion" method="post" class="d-inline" data-loading-form>
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                                                        <input type="hidden" name="variantId" value="@Model.SelectedVariantId" />
                                                        <input type="hidden" name="fromUomRef" value="@conversion.FromUomRef" />
                                                        <input type="hidden" name="toUomRef" value="@conversion.ToUomRef" />
                                                        <button type="submit" class="btn btn-outline-danger btn-xs" data-confirm-title="@UiText["catalog.variants.deleteConversionTitle"]" data-confirm="@UiText["catalog.variants.deleteConversionConfirm"]" @(Can("Catalog.VariantUomConversion.Remove", "ProductVariantUomConversion.Remove") ? null : "disabled")>@UiText["common.delete"]</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 mb-4">
                <div class="card mb-4" id="variant-assembly-card">
                    <div class="card-body">
                        <h5 class="card-title mb-2">@UiText["catalog.variants.assemblyTitle"]</h5>
                        @if (hasSelectedProduct && hasSelectedVariant)
                        {
                            <p class="text-muted small">@UiText["catalog.variants.assemblyHelp"]</p>
                            <form asp-action="ExecuteVariantAssembly" method="post" id="variant-assembly-form" class="mb-0" data-loading-form data-dirty-watch>
                                @Html.AntiForgeryToken()
                                <input asp-for="VariantAssemblyOperationForm.ProductId" type="hidden" value="@Model.SelectedProductId" />
                                <input asp-for="VariantAssemblyOperationForm.VariantId" type="hidden" value="@Model.SelectedVariantId" />
                                <div class="form-row">
                                    <div class="col-md-3 mb-2">
                                        <label>@UiText["catalog.variants.operationType"]</label>
                                        <select asp-for="VariantAssemblyOperationForm.OperationType" class="form-control js-search-select" data-no-search="true">
                                            <option value="Assemble">@UiText["catalog.variants.assemble"]</option>
                                            <option value="Disassemble">@UiText["catalog.variants.disassemble"]</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3 mb-2">
                                        <label>@UiText["catalog.variants.finalQuantity"]</label>
                                        <input asp-for="VariantAssemblyOperationForm.Quantity" type="number" min="0.000001" step="0.000001" class="form-control" />
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <label>@UiText["catalog.variants.reasonDescription"]</label>
                                        <input asp-for="VariantAssemblyOperationForm.ReasonCode" class="form-control" placeholder="@UiText["catalog.variants.optional"]" />
                                    </div>
                                    <div class="col-md-2 mb-2 d-flex align-items-end">
                                        <button class="btn btn-primary btn-block" type="submit">@UiText["catalog.variants.submitOperation"]</button>
                                    </div>
                                </div>
                            </form>
                        }
                        else
                        {
                            <div class="alert alert-light mb-0"><h6>@UiText["catalog.variants.noVariantSelected"]</h6><p class="mb-0 text-muted">@UiText["catalog.variants.selectVariantForAssembly"]</p></div>
                        }
                    </div>
                </div>

                <div class="card mb-4" id="variant-components-card">
                    <div class="card-body">
                        <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
                            <div>
                                <h5 class="card-title mb-1">@UiText["catalog.variants.componentsTitle"]</h5>
                                <p class="text-muted small mb-0">@UiText["catalog.variants.componentsHelp"]</p>
                            </div>
                            @if (hasSelectedProduct && hasSelectedVariant)
                            {
                                <button class="btn btn-outline-primary btn-sm" type="button" data-toggle="collapse" data-target="#variant-component-editor" aria-expanded="false" aria-controls="variant-component-editor">@UiText["catalog.variants.addOrEditComponent"]</button>
                            }
                        </div>
                        @if (hasSelectedProduct && hasSelectedVariant)
                        {
                            <p class="text-muted small">@UiText["catalog.variants.componentsTableHelp"]</p>
                            <div class="collapse mb-4" id="variant-component-editor">
                            <form asp-action="UpsertVariantComponent" method="post" id="variant-component-form" data-loading-form data-dirty-watch>
                                @Html.AntiForgeryToken()
                                <input asp-for="VariantComponentForm.ProductId" type="hidden" value="@Model.SelectedProductId" />
                                <input asp-for="VariantComponentForm.VariantId" type="hidden" value="@Model.SelectedVariantId" />
                                <input asp-for="VariantComponentForm.ComponentId" type="hidden" />
                                <div class="form-row">
                                    <div class="col-md-8 mb-2">
                                        <label>@UiText["catalog.variants.componentVariant"]</label>
                                        <select asp-for="VariantComponentForm.ComponentVariantId" class="form-control js-search-select" data-placeholder='@UiText["catalog.variants.selectVariant"]'>
                                            <option value="">@UiText["catalog.variants.selectVariant"]</option>
                                            @foreach (var variant in Model.RelatedVariantLookup)
                                            {
                                                <option value="@variant.Id">@variant.Sku @(string.IsNullOrWhiteSpace(variant.Barcode) ? string.Empty : $" - {variant.Barcode}")</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <label>@UiText["common.count"]</label>
                                        <input asp-for="VariantComponentForm.Quantity" type="number" min="0.000001" step="0.000001" class="form-control" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="col-md-6 mb-2">
                                        <label>@UiText["catalog.variants.componentWarehouse"]</label>
                                        <select asp-for="VariantComponentForm.WarehouseId" class="form-control" id="VariantComponentForm_WarehouseId">
                                            <option value="">@UiText["catalog.variants.selectWarehouse"]</option>
                                            @foreach (var warehouse in Model.WarehouseLookup.OrderBy(x => x.Code))
                                            {
                                                <option value="@warehouse.WarehouseBusinessKey">@warehouse.Code - @warehouse.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <label>@UiText["catalog.variants.componentLocation"]</label>
                                        <select asp-for="VariantComponentForm.LocationId" class="form-control" id="VariantComponentForm_LocationId">
                                            <option value="">@UiText["catalog.variants.selectLocation"]</option>
                                            @foreach (var location in Model.LocationLookup.OrderBy(x => x.LocationCode))
                                            {
                                                <option value="@location.LocationBusinessKey" data-warehouse-id="@location.WarehouseRef">@location.LocationCode (@location.LocationType)</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <button class="btn btn-outline-primary btn-sm" type="submit">@UiText["catalog.variants.saveComponent"]</button>
                            </form>
                            </div>
                            <h6>@UiText["catalog.variants.savedMedia"]</h6>
                            @if (Model.SelectedVariantDetails!.Images.Count == 0)
                            {
                                <div class="alert alert-light">
                                    @UiText["catalog.variants.noMediaRegistered"]
                                </div>
                            }
                            else
                            {
                                <div class="row mb-4">
                                    @foreach (var media in Model.SelectedVariantDetails.Images.OrderBy(x => x.DisplayOrder))
                                    {
                                        var isVideo = !string.IsNullOrWhiteSpace(media.ContentType) && media.ContentType.StartsWith("video/", StringComparison.OrdinalIgnoreCase);
                                        <div class="col-lg-4 col-md-6 mb-3">
                                            <div class="card h-100">
                                                <div class="card-body">
                                                    @if (isVideo)
                                                    {
                                                        <video src="@media.OriginalUrl" class="w-100 rounded border mb-2" style="max-height:200px;" controls preload="metadata"></video>
                                                    }
                                                    else
                                                    {
                                                        <img src="@media.ThumbnailUrl" alt="@media.OriginalFileName" class="img-fluid rounded border mb-2" style="max-height:200px;" />
                                                    }
                                                    <div class="small text-muted mb-2">@media.OriginalFileName</div>
                                                    <div class="mb-2">
                                                        <span class="badge badge-pill badge-outline-primary">@UiText["catalog.variants.displayOrder"] @media.DisplayOrder</span>
                                                        @if (media.IsPrimary)
                                                        {
                                                            <span class="badge badge-pill badge-primary">@UiText["catalog.variants.primary"]</span>
                                                        }
                                                        <span class="badge badge-pill badge-light">@(isVideo ? UiText["catalog.variants.video"] : UiText["catalog.variants.image"])</span>
                                                    </div>
                                                    <div class="btn-group btn-group-sm">
                                                        <a href="@media.OriginalUrl" target="_blank" rel="noopener" class="btn btn-outline-info btn-xs">@UiText["catalog.variants.view"]</a>
                                                        <form asp-action="RemoveVariantImage" method="post" class="d-inline" data-loading-form>
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                                                            <input type="hidden" name="variantId" value="@Model.SelectedVariantDetails.Id" />
                                                            <input type="hidden" name="fileKey" value="@media.FileKey" />
                                                            <button type="submit" class="btn btn-outline-danger btn-xs">@UiText["catalog.variants.removeRelation"]</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            <div class="table-responsive">
                                <table class="table table-sm table-striped">
                                    <thead><tr><th>SKU</th><th>@UiText["catalog.variants.barcode"]</th><th>@UiText["common.count"]</th><th>@UiText["catalog.variants.warehouse"]</th><th>@UiText["catalog.variants.location"]</th><th></th></tr></thead>
                                    <tbody>
                                        @if (Model.VariantComponents.Count == 0)
                                        {
                                            <tr><td colspan="6" class="text-muted">@UiText["catalog.variants.noComponentRegistered"]</td></tr>
                                        }
                                        else
                                        {
                                            foreach (var component in Model.VariantComponents)
                                            {
                                                <tr>
                                                    <td class="text-monospace">@component.ComponentSku</td>
                                                    <td>@(string.IsNullOrWhiteSpace(component.ComponentBarcode) ? "-" : component.ComponentBarcode)</td>
                                                    <td>@component.Quantity</td>
                                                    <td>@(string.IsNullOrWhiteSpace(component.WarehouseCode) ? "-" : component.WarehouseCode)</td>
                                                    <td>@(string.IsNullOrWhiteSpace(component.LocationCode) ? "-" : component.LocationCode)</td>
                                                    <td>
                                                        @{
                                                            var componentProductId = RelatedVariantProductId(component.ComponentVariantId);
                                                        }
                                                        <div class="btn-group btn-group-sm">
                                                            @if (!string.IsNullOrWhiteSpace(componentProductId))
                                                            {
                                                                <a class="btn btn-outline-info btn-xs" asp-action="Variants" asp-route-productId="@componentProductId" asp-route-variantId="@component.ComponentVariantId">@UiText["catalog.variants.view"]</a>
                                                            }
                                                            <button type="button" class="btn btn-outline-secondary btn-xs js-component-edit" data-component-id="@component.ComponentId" data-component-variant-id="@component.ComponentVariantId" data-component-warehouse-id="@component.WarehouseId" data-component-location-id="@component.LocationId" data-component-quantity="@component.Quantity">@UiText["common.edit"]</button>
                                                            <form asp-action="RemoveVariantComponent" method="post" class="d-inline" data-loading-form>
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                                                                <input type="hidden" name="variantId" value="@Model.SelectedVariantId" />
                                                                <input type="hidden" name="componentId" value="@component.ComponentId" />
                                                                <input type="hidden" name="componentVariantId" value="@component.ComponentVariantId" />
                                                                <button type="submit" class="btn btn-outline-danger btn-xs">@UiText["common.delete"]</button>
                                                            </form>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-light mb-0"><h6>@UiText["catalog.variants.noVariantSelected"]</h6><p class="mb-0 text-muted">@UiText["catalog.variants.selectVariantSimple"]</p></div>
                        }
                    </div>

                <div class="card mb-4" id="variant-addons-card">
                    <div class="card-body">
                        <h5 class="card-title mb-1">@UiText["catalog.variants.addonListTitle"]</h5>
                        @if (hasSelectedProduct && hasSelectedVariant)
                        {
                            <p class="text-muted small">@UiText["catalog.variants.addonListHelp"]</p>
                            <div class="table-responsive">
                                <table class="table table-sm table-striped">
                                    <thead><tr><th>SKU</th><th>@UiText["catalog.variants.barcode"]</th><th></th></tr></thead>
                                    <tbody>
                                        @if (Model.VariantAddOns.Count == 0)
                                        {
                                            <tr><td colspan="3" class="text-muted">@UiText["catalog.variants.noAddonRegistered"]</td></tr>
                                        }
                                        else
                                        {
                                            foreach (var addOn in Model.VariantAddOns)
                                            {
                                                <tr>
                                                    <td class="text-monospace">@addOn.AddOnSku</td>
                                                    <td>@(string.IsNullOrWhiteSpace(addOn.AddOnBarcode) ? "-" : addOn.AddOnBarcode)</td>
                                                    <td>
                                                        @{
                                                            var addOnProductId = RelatedVariantProductId(addOn.AddOnVariantId);
                                                        }
                                                        <div class="btn-group btn-group-sm">
                                                            @if (!string.IsNullOrWhiteSpace(addOnProductId))
                                                            {
                                                                <a class="btn btn-outline-info btn-xs" asp-action="Variants" asp-route-productId="@addOnProductId" asp-route-variantId="@addOn.AddOnVariantId">@UiText["catalog.variants.view"]</a>
                                                            }
                                                            <form asp-action="RemoveVariantAddOn" method="post" class="d-inline" data-loading-form>
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                                                                <input type="hidden" name="variantId" value="@Model.SelectedVariantId" />
                                                                <input type="hidden" name="addOnVariantId" value="@addOn.AddOnVariantId" />
                                                                <button type="submit" class="btn btn-outline-danger btn-xs">@UiText["common.delete"]</button>
                                                            </form>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-light mb-0"><h6>@UiText["catalog.variants.noVariantSelected"]</h6><p class="mb-0 text-muted">@UiText["catalog.variants.selectVariantSimple"]</p></div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<div class="modal fade" id="variant-detail-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="variant-detail-modal-title">@UiText["catalog.variants.detailsTitle"]</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label='@UiText["catalog.variants.close"]'>
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="variant-detail-modal-body" class="table-responsive small text-muted">@UiText["catalog.variants.loading"]</div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="bulk-addon-selector-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@UiText["catalog.variants.selectAddon"]</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label='@UiText["catalog.variants.close"]'>
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="search" class="form-control mb-3" id="bulk-addon-search" placeholder="@UiText["catalog.variants.searchSkuOrBarcode"]" />
                <div class="small text-muted mb-2">@UiText["catalog.variants.multiAddonSelectHelp"]</div>
                <div class="list-group" id="bulk-addon-selector-list" style="max-height:420px; overflow:auto;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">@UiText["catalog.variants.close"]</button>
                <button type="button" class="btn btn-primary" id="bulk-addon-apply-selection">@UiText["catalog.variants.applySelection"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var pageElement = document.getElementById('variants-page');
            var productSelectorForm = document.getElementById('variant-product-selector-form');
            var searchForm = document.getElementById('variant-search-form');
            var attributeOptionsFilter = document.getElementById('variant-attribute-options-filter');
            var attributeOptionIdsInput = document.getElementById('variant-attribute-option-ids');
            var detailModal = $('#variant-detail-modal');
            var detailModalTitle = document.getElementById('variant-detail-modal-title');
            var detailModalBody = document.getElementById('variant-detail-modal-body');
            var tabs = document.querySelectorAll('#variant-management-tabs .nav-link');
            var tabKey = 'catalog-variants-active-tab-v1';
            var stateKey = 'catalog-variants-state-v2';
            var draftStateKey = 'catalog-variants-form-drafts-v1';
            var submittedFormKey = 'catalog-variants-last-submitted-form-v1';
            var dirtyForms = new Set();
            var watchedFormIds = [
                'variant-upsert-form',
                'variant-tracking-policy-form',
                'variant-base-uom-form',
                'variant-uom-conversion-form',
                'variant-component-form',
                'variant-assembly-form'
            ];
            var watchedForms = watchedFormIds
                .map(function (formId) { return document.getElementById(formId); })
                .filter(function (form) { return form instanceof HTMLFormElement; });

            if (searchForm && attributeOptionsFilter && attributeOptionIdsInput) {
                searchForm.addEventListener('submit', function () {
                    attributeOptionIdsInput.value = Array.from(attributeOptionsFilter.selectedOptions || [])
                        .map(function (option) { return option.value || ''; })
                        .filter(Boolean)
                        .join(',');
                });
            }

            function renderDetailTable(items) {
                if (!Array.isArray(items) || items.length === 0) {
                    return '<div class="text-muted>' + @JsonSerializer.Serialize(UiText["catalog.variants.noDisplayData"]) + '</div>';
                }

                var keys = Object.keys(items[0] || {});
                var head = keys.map(function (key) { return '<th>' + key + '</th>'; }).join('');
                var rows = items.map(function (item) {
                    return '<tr>' + keys.map(function (key) {
                        var value = item[key];
                        return '<td>' + (value === null || value === undefined || value === '' ? '-' : String(value)) + '</td>';
                    }).join('') + '</tr>';
                }).join('');

                return '<table class="table table-sm table-striped mb-0"><thead><tr>' + head + '</tr></thead><tbody>' + rows + '</tbody></table>';
            }

            document.querySelectorAll('.js-variant-detail').forEach(function (button) {
                button.addEventListener('click', function () {
                    var url = button.getAttribute('data-detail-url');
                    if (!url || !detailModalBody) {
                        return;
                    }

                    if (detailModalTitle) {
                        detailModalTitle.textContent = button.getAttribute('data-detail-title') || @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.detailsTitle"]));
                    }
                    detailModalBody.innerHTML = '<div class="text-muted>' + @JsonSerializer.Serialize(UiText["catalog.variants.loading"]) + '</div>';
                    detailModal.modal('show');

                    fetch(url, { headers: { 'Accept': 'application/json' } })
                        .then(function (response) { return response.json(); })
                        .then(function (payload) {
                            if (payload && payload.error) {
                                detailModalBody.innerHTML = '<div class="text-danger">' + payload.error + '</div>';
                                return;
                            }

                            detailModalBody.innerHTML = renderDetailTable(payload);
                        })
                        .catch(function () {
                            detailModalBody.innerHTML = '<div class="text-danger>' + @JsonSerializer.Serialize(UiText["catalog.variants.loadInfoFailed"]) + '</div>';
                        });
                });
            });

            function readState() {
                try {
                    return JSON.parse(localStorage.getItem(stateKey) || '{}');
                } catch (e) {
                    return {};
                }
            }

            function writeState(nextState) {
                localStorage.setItem(stateKey, JSON.stringify(nextState));
            }

            function readDrafts() {
                try {
                    return JSON.parse(localStorage.getItem(draftStateKey) || '{}');
                } catch (e) {
                    return {};
                }
            }

            function writeDrafts(nextDrafts) {
                localStorage.setItem(draftStateKey, JSON.stringify(nextDrafts));
            }

            function captureFormDraft(form) {
                var values = {};
                form.querySelectorAll('input, textarea, select').forEach(function (field) {
                    if (!field.name || field.name === '__RequestVerificationToken') {
                        return;
                    }

                    if (field.type === 'checkbox') {
                        values[field.name] = { type: 'checkbox', value: field.checked };
                        return;
                    }

                    if (field.type === 'radio') {
                        if (!values[field.name]) {
                            values[field.name] = { type: 'radio', value: '' };
                        }
                        if (field.checked) {
                            values[field.name].value = field.value || '';
                        }
                        return;
                    }

                    values[field.name] = { type: 'value', value: field.value || '' };
                });

                return values;
            }

            function applyFormDraft(form, values) {
                if (!values || typeof values !== 'object') {
                    return;
                }

                Object.keys(values).forEach(function (fieldName) {
                    var meta = values[fieldName];
                    if (!meta) {
                        return;
                    }

                    if (meta.type === 'radio') {
                        form.querySelectorAll('input[type="radio"][name="' + fieldName + '"]').forEach(function (radio) {
                            radio.checked = (radio.value || '') === (meta.value || '');
                        });
                        return;
                    }

                    var field = form.querySelector('[name="' + fieldName + '"]');
                    if (!field) {
                        return;
                    }

                    if (meta.type === 'checkbox') {
                        field.checked = !!meta.value;
                        return;
                    }

                    field.value = meta.value || '';
                });
            }

            function saveFormDraft(form) {
                var drafts = readDrafts();
                drafts[form.id] = captureFormDraft(form);
                writeDrafts(drafts);
            }

            function restoreFormDrafts() {
                var drafts = readDrafts();
                watchedForms.forEach(function (form) {
                    applyFormDraft(form, drafts[form.id]);
                });
            }

            function clearSubmittedDraftAfterSuccess() {
                if (!@hasCatalogSuccess.ToString().ToLowerInvariant()) {
                    return;
                }

                var submittedFormId = localStorage.getItem(submittedFormKey);
                if (!submittedFormId) {
                    return;
                }

                var drafts = readDrafts();
                if (drafts && drafts[submittedFormId]) {
                    delete drafts[submittedFormId];
                    writeDrafts(drafts);
                }

                localStorage.removeItem(submittedFormKey);
            }

            function readField(formElement, name) {
                var field = formElement ? formElement.querySelector('[name="' + name + '"]') : null;
                return field ? (field.value || '') : '';
            }

            function setFieldIfMissing(formElement, name, value) {
                if (!formElement || !value) {
                    return;
                }

                var field = formElement.querySelector('[name="' + name + '"]');
                if (!field) {
                    return;
                }

                var params = new URLSearchParams(window.location.search);
                if (params.has(name)) {
                    return;
                }

                if (!field.value) {
                    field.value = value;
                }
            }

            function savePageState(extra) {
                var current = readState();
                var next = {
                    selectedProductId: pageElement ? (pageElement.getAttribute('data-selected-product-id') || '') : '',
                    selectedVariantId: pageElement ? (pageElement.getAttribute('data-selected-variant-id') || '') : '',
                    productSelector: {
                        productId: readField(productSelectorForm, 'productId')
                    },
                    filters: {
                        searchTerm: readField(searchForm, 'searchTerm'),
                        trackingPolicy: readField(searchForm, 'trackingPolicy'),
                        statusFilter: readField(searchForm, 'statusFilter'),
                        attributeTypeFilter: readField(searchForm, 'attributeTypeFilter'),
                        sort: readField(searchForm, 'sort'),
                        pageSize: readField(searchForm, 'pageSize')
                    },
                    draft: current.draft || {}
                };

                if (extra && typeof extra === 'object') {
                    next.draft = Object.assign({}, next.draft, extra);
                }

                writeState(next);
            }

            function restorePageState() {
                var state = readState();
                if (!state) {
                    return;
                }

                if (state.productSelector && state.productSelector.productId) {
                    setFieldIfMissing(productSelectorForm, 'productId', state.productSelector.productId);
                }
                if (state.filters) {
                    setFieldIfMissing(searchForm, 'searchTerm', state.filters.searchTerm);
                    setFieldIfMissing(searchForm, 'trackingPolicy', state.filters.trackingPolicy);
                    setFieldIfMissing(searchForm, 'statusFilter', state.filters.statusFilter);
                    setFieldIfMissing(searchForm, 'attributeTypeFilter', state.filters.attributeTypeFilter);
                    setFieldIfMissing(searchForm, 'sort', state.filters.sort);
                    setFieldIfMissing(searchForm, 'pageSize', state.filters.pageSize);
                }
            }

            function showTabByHref(href) {
                if (!href) {
                    return;
                }

                var target = document.querySelector('#variant-management-tabs .nav-link[href="' + href + '"]');
                if (target && window.jQuery) {
                    window.jQuery(target).tab('show');
                }
            }

