                </button>
                <button type="button" class="close" data-dismiss="modal" aria-label='@UiText["catalog.variants.close"]'>
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning d-none" id="variant-tags-bulk-empty">یک یا چند مورد از موارد را انتخاب کنید</div>
                <div class="alert alert-light" id="variant-tags-modal-summary"></div>
                <div id="variant-tags-create-card" class="card mb-3 d-none">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong>ایجاد برچسب جدید</strong>
                            <button type="button" class="btn btn-link btn-sm p-0" id="variant-tags-create-cancel">بستن</button>
                        </div>
                        <form asp-action="UpsertVariantTag"
                              method="post"
                              id="variant-tag-create-form"
                              data-ajax-submit="variant-tags"
                              data-loading-form>
                            @Html.AntiForgeryToken()
                            <input name="VariantTagForm.ProductId" type="hidden" value="@Model.SelectedProductId" />
                            <input name="VariantTagForm.VariantId" type="hidden" value="" />
                            <input name="VariantTagForm.TagId" type="hidden" value="" />
                            <input name="VariantTagForm.TagColor" type="hidden" value="" />
                            <div class="form-group">
                                <label>نام برچسب</label>
                                <input name="VariantTagForm.TagName" class="form-control" placeholder="مثلا ویژه یا تخفیف" />
                            </div>
                            <button type="submit" class="btn btn-primary">تایید</button>
                        </form>
                    </div>
                </div>

                <div id="variant-tags-bulk-form-wrapper">
                    <form asp-action="BulkAssignVariantTags"
                          method="post"
                          class="mb-3"
                          id="variant-tags-bulk-form"
                          data-ajax-submit="bulk-tags"
                          data-loading-form>
                        @Html.AntiForgeryToken()
                        <input asp-for="BulkVariantTagForm.ProductId" type="hidden" value="@Model.SelectedProductId" />
                        <input asp-for="BulkVariantTagForm.SelectedVariantIds" type="hidden" id="bulk-tags-selected-ids" />
                        <div class="form-group">
                            <label>برچسب‌ها</label>
                            <select id="bulk-variant-tag-lookup"
                                    class="form-control js-search-select"
                                    multiple
                                    data-placeholder="از لیست برچسب‌های سیستم انتخاب کنید"></select>
                            <input asp-for="BulkVariantTagForm.TagNames" type="hidden" />
                            <div class="small text-muted mt-2">این فیلد از برچسب‌های ثبت‌شده در سیستم تغذیه می‌شود.</div>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block">ثبت گروهی برچسب</button>
                    </form>
                </div>

                <div id="variant-tags-single-form-wrapper">
                    <form asp-action="UpsertVariantTag"
                          method="post"
                          id="variant-tag-form"
                          data-ajax-submit="variant-tags"
                          data-loading-form>
                        @Html.AntiForgeryToken()
                        <input asp-for="VariantTagForm.ProductId" type="hidden" value="@Model.SelectedProductId" />
                        <input asp-for="VariantTagForm.VariantId" type="hidden" />
                        <input asp-for="VariantTagForm.TagId" type="hidden" />
                        <div class="form-row">
                            <div class="col-md-8 mb-2">
                                <label>نام برچسب</label>
                                <select id="single-variant-tag-lookup"
                                        class="form-control js-search-select"
                                        data-placeholder="از لیست برچسب‌های سیستم انتخاب کنید"></select>
                                <input asp-for="VariantTagForm.TagName" type="hidden" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label>رنگ برچسب</label>
                            <input asp-for="VariantTagForm.TagColor" class="form-control" placeholder="#ffcc00" />
                        </div>
                        <button type="submit" class="btn btn-outline-primary btn-block">ثبت برچسب</button>
                    </form>
                </div>

                <div id="variant-tags-current-wrapper">
                    <hr />
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>برچسب‌های فعلی</strong>
                        <span class="text-muted small" id="variant-tags-count">0</span>
                    </div>
                    <div id="variant-tags-list" class="d-flex flex-wrap"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var pageElement = document.getElementById('variants-page');
            var productSelectorForm = document.getElementById('variant-product-selector-form');
            var searchForm = document.getElementById('variant-search-form');
            var attributeOptionsFilter = document.getElementById('variant-attribute-options-filter');
            var attributeOptionIdsInput = document.getElementById('variant-attribute-option-ids');
            var detailModal = $('#variant-detail-modal');
            var detailModalTitle = document.getElementById('variant-detail-modal-title');
            var detailModalBody = document.getElementById('variant-detail-modal-body');
            var tagsModal = $('#variant-tags-modal');
            var tagsModalTitle = document.getElementById('variant-tags-modal-title');
            var tagsModalSummary = document.getElementById('variant-tags-modal-summary');
            var tagsBulkForm = document.getElementById('variant-tags-bulk-form');
            var tagsSingleForm = document.getElementById('variant-tag-form');
            var tagsSingleVariantId = document.getElementById('VariantTagForm_VariantId');
            var tagsSingleTagId = document.getElementById('VariantTagForm_TagId');
            var tagsSingleTagName = document.getElementById('VariantTagForm_TagName');
            var tagsSingleTagColor = document.getElementById('VariantTagForm_TagColor');
            var tagsCreateToggle = document.getElementById('variant-tags-create-toggle');
            var tagsCreateCard = document.getElementById('variant-tags-create-card');
            var tagsCreateCancel = document.getElementById('variant-tags-create-cancel');
            var tagsCreateForm = document.getElementById('variant-tag-create-form');
            var tagsCreateProductId = tagsCreateForm ? tagsCreateForm.querySelector('[name="VariantTagForm.ProductId"]') : null;
            var tagsCreateVariantId = tagsCreateForm ? tagsCreateForm.querySelector('[name="VariantTagForm.VariantId"]') : null;
            var tagsCreateTagId = tagsCreateForm ? tagsCreateForm.querySelector('[name="VariantTagForm.TagId"]') : null;
            var tagsCreateTagName = tagsCreateForm ? tagsCreateForm.querySelector('[name="VariantTagForm.TagName"]') : null;
            var tagsCreateTagColor = tagsCreateForm ? tagsCreateForm.querySelector('[name="VariantTagForm.TagColor"]') : null;
            var bulkMediaForm = document.getElementById('variant-bulk-media-form');
            var addonVariantInput = document.getElementById('VariantAddOnForm_AddOnVariantId');
            var bulkTagLookupSelect = document.getElementById('bulk-variant-tag-lookup');
            var singleTagLookupSelect = document.getElementById('single-variant-tag-lookup');
            var pendingCreatedTagName = '';
            var tagsList = document.getElementById('variant-tags-list');
            var tagsCount = document.getElementById('variant-tags-count');
            var tagsBulkEmpty = document.getElementById('variant-tags-bulk-empty');
            var bulkTagsSelectedIdsInput = document.getElementById('bulk-tags-selected-ids');
            var tagsBulkWrapper = document.getElementById('variant-tags-bulk-form-wrapper');
            var tagsSingleWrapper = document.getElementById('variant-tags-single-form-wrapper');
            var tagsCurrentWrapper = document.getElementById('variant-tags-current-wrapper');
            var bulkSelectionWarning = document.getElementById('variant-bulk-selection-warning');
            var componentListContainer = document.getElementById('variant-components-list-container');
            var addonListContainer = document.getElementById('variant-addons-list-container');
            var componentModalBody = document.getElementById('variant-components-modal-body');
            var mediaModalBody = document.getElementById('variant-media-library-modal-body');
            var tagsModalBody = document.getElementById('variant-tags-modal-body');
            var tagLookupUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("VariantTagLookup", "VariantManagement") ?? string.Empty));
            var tagLookupItems = [];
            var tagLookupPromise = null;
            var tagLookupTake = 200;
            var noDisplayDataText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.noDisplayData"]));
            var loadingText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.loading"]));
            var loadInfoFailedText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.loadInfoFailed"]));
            var selectOptionText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.selectOption"]));
            var inventoryAndWarehousesTitleText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.inventoryAndWarehouses"]));
            var pricesTitleText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.pricesTitle"]));
            var variantMediaTitleText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.variantMediaTitle"]));
            var warehouseText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.warehouse"]));
            var quantityText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.quantity"]));
            var bucketCountText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.bucketCount"]));
            var sellerText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.seller"]));
            var priceTypeText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.priceType"]));
            var priceChannelText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.priceChannel"]));
            var amountText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.amount"]));
            var currencyText = @Html.Raw(JsonSerializer.Serialize(UiText["pricing.currency"]));
            var minQuantityText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.minQuantity"]));
            var priorityText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.priority"]));
            var effectiveFromText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.effectiveFrom"]));
            var effectiveToText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.effectiveTo"]));
            var statusText = @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.status"]));
            var activeText = @Html.Raw(JsonSerializer.Serialize(UiText["common.active"]));
            var inactiveText = @Html.Raw(JsonSerializer.Serialize(UiText["common.inactive"]));
            var stateKey = 'catalog-variants-state-v2';
            var draftStateKey = 'catalog-variants-form-drafts-v1';
            var submittedFormKey = 'catalog-variants-last-submitted-form-v1';
            var dirtyForms = new Set();
            var watchedFormIds = [
                'variant-upsert-form',
                'variant-tracking-policy-form',
                'variant-base-uom-form',
                'variant-component-form'
            ];
            var watchedForms = watchedFormIds
                .map(function (formId) { return document.getElementById(formId); })
                .filter(function (form) { return form instanceof HTMLFormElement; });

            if (searchForm && attributeOptionsFilter && attributeOptionIdsInput) {
                searchForm.addEventListener('submit', function () {
                    attributeOptionIdsInput.value = Array.from(attributeOptionsFilter.selectedOptions || [])
                        .map(function (option) { return option.value || ''; })
                        .filter(Boolean)
                        .join(',');
                });
            }

            function escapeHtml(value) {
                return (value === null || value === undefined ? '' : String(value))
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function formatDateTime(value) {
                if (!value) {
                    return '-';
                }

                var date = new Date(value);
                if (isNaN(date.getTime())) {
                    return String(value);
                }

                return date.toLocaleString('fa-IR');
            }

            function renderWarehouseDetails(items) {
                if (!Array.isArray(items) || items.length === 0) {
                    return '<div class="alert alert-light mb-0">' + noDisplayDataText + '</div>';
                }

                var head = '<th>' + warehouseText + '</th><th>' + quantityText + '</th><th>' + bucketCountText + '</th>';
                var rows = items.map(function (item) {
                    var locations = Array.isArray(item.locations) ? item.locations : [];
                    return '<tr>' +
                        '<td>' + escapeHtml(item.warehouseLabel || item.warehouseCode || item.warehouseRef || '-') + '</td>' +
                        '<td>' + escapeHtml(item.quantityOnHand === null || item.quantityOnHand === undefined ? '-' : item.quantityOnHand) + '</td>' +
                        '<td>' + escapeHtml(item.bucketCount === null || item.bucketCount === undefined ? locations.length : item.bucketCount) + '</td>' +
                    '</tr>';
                }).join('');

                return '<table class="table table-sm table-striped mb-0"><thead><tr>' + head + '</tr></thead><tbody>' + rows + '</tbody></table>';
            }

            function renderPriceDetails(items) {
                if (!Array.isArray(items) || items.length === 0) {
                    return '<div class="alert alert-light mb-0">' + noDisplayDataText + '</div>';
                }

                var head = [
                    sellerText,
                    priceTypeText,
                    priceChannelText,
                    amountText,
                    currencyText,
                    minQuantityText,
                    priorityText,
                    effectiveFromText,
                    effectiveToText,
                    statusText
                ].map(function (title) { return '<th>' + title + '</th>'; }).join('');

                var rows = items.map(function (item) {
                    var isActive = item && item.isActive;
                    return '<tr>' +
                        '<td>' + escapeHtml(item.sellerLabel || item.sellerRef || '-') + '</td>' +
                        '<td>' + escapeHtml(item.priceTypeLabel || item.priceTypeRef || '-') + '</td>' +
                        '<td>' + escapeHtml(item.priceChannelLabel || item.priceChannelRef || '-') + '</td>' +
                        '<td>' + escapeHtml(item.amount === null || item.amount === undefined ? '-' : item.amount) + '</td>' +
                        '<td>' + escapeHtml(item.currency || '-') + '</td>' +
                        '<td>' + escapeHtml(item.minQty === null || item.minQty === undefined ? '-' : item.minQty) + '</td>' +
                        '<td>' + escapeHtml(item.priority === null || item.priority === undefined ? '-' : item.priority) + '</td>' +
                        '<td>' + escapeHtml(formatDateTime(item.effectiveFrom)) + '</td>' +
                        '<td>' + escapeHtml(formatDateTime(item.effectiveTo)) + '</td>' +
                        '<td><span class="badge badge-pill ' + (isActive ? 'badge-success' : 'badge-secondary') + '">' + (isActive ? activeText : inactiveText) + '</span></td>' +
                    '</tr>';
                }).join('');

                return '<table class="table table-sm table-striped mb-0"><thead><tr>' + head + '</tr></thead><tbody>' + rows + '</tbody></table>';
            }

            function openVariantDataModal(modal, titleElement, bodyElement, url, renderer, titleText) {
                if (!modal || !bodyElement || !url) {
                    return;
                }

                if (titleElement && titleText) {
                    titleElement.textContent = titleText;
                }

                bodyElement.innerHTML = '<div class="text-muted">' + loadingText + '</div>';
                modal.modal('show');

                fetch(url, { headers: { 'Accept': 'application/json' } })
                    .then(function (response) { return response.json(); })
                    .then(function (payload) {
                        if (payload && payload.error) {
                            bodyElement.innerHTML = '<div class="text-danger">' + escapeHtml(payload.error) + '</div>';
                            return;
                        }

                        var items = payload && Array.isArray(payload.items) ? payload.items : [];
                        bodyElement.innerHTML = renderer(items);
                    })
                    .catch(function () {
                        bodyElement.innerHTML = '<div class="text-danger">' + loadInfoFailedText + '</div>';
                    });
            }

            function fetchPageFragment(url, selector) {
                return fetch(url, { headers: { 'Accept': 'text/html' } })
                    .then(function (response) { return response.text(); })
                    .then(function (html) {
                        var parser = new DOMParser();
                        var doc = parser.parseFromString(html, 'text/html');
                        var fragment = doc.querySelector(selector);
                        return fragment ? fragment.innerHTML : '';
                    });
            }

            function replaceFragment(selector, html) {
                var target = document.querySelector(selector);
                if (target) {
                    target.innerHTML = html || '';
                }
            }

            function openVariantFragmentModal(modal, titleElement, bodyElement, url, fragmentSelector, titleText) {
                if (!modal || !bodyElement || !url || !fragmentSelector) {
                    return Promise.resolve();
                }

                if (titleElement && titleText) {
                    titleElement.textContent = titleText;
                }

                bodyElement.setAttribute('data-source-url', url);
                bodyElement.setAttribute('data-source-selector', fragmentSelector);
                bodyElement.innerHTML = '<div class="text-muted">' + loadingText + '</div>';
                modal.modal('show');

                return fetchPageFragment(url, fragmentSelector)
                    .then(function (html) {
                        bodyElement.innerHTML = html || '<div class="text-danger">' + loadInfoFailedText + '</div>';
                    })
                    .catch(function () {
                        bodyElement.innerHTML = '<div class="text-danger">' + loadInfoFailedText + '</div>';
                    });
            }

            function openVariantHtmlModal(modal, titleElement, bodyElement, url, titleText) {
                if (!modal || !bodyElement || !url) {
                    return Promise.resolve();
                }

                if (titleElement && titleText) {
                    titleElement.textContent = titleText;
                }

                bodyElement.setAttribute('data-source-url', url);
                bodyElement.removeAttribute('data-source-selector');
                bodyElement.innerHTML = '<div class="text-muted">' + loadingText + '</div>';
                modal.modal('show');

                return fetch(url, { headers: { 'Accept': 'text/html' } })
                    .then(function (response) { return response.text(); })
                    .then(function (html) {
                        bodyElement.innerHTML = html || '<div class="text-danger">' + loadInfoFailedText + '</div>';
                    })
                    .catch(function () {
                        bodyElement.innerHTML = '<div class="text-danger">' + loadInfoFailedText + '</div>';
                    });
            }

            function refreshFragmentBody(bodyElement) {
                if (!bodyElement) {
                    return Promise.resolve();
                }

                var url = bodyElement.getAttribute('data-source-url') || '';
                var selector = bodyElement.getAttribute('data-source-selector') || '';
                if (!url) {
                    return Promise.resolve();
                }

                if (!selector) {
                    bodyElement.innerHTML = '<div class="text-muted">' + loadingText + '</div>';
                    return fetch(url, { headers: { 'Accept': 'text/html' } })
                        .then(function (response) { return response.text(); })
                        .then(function (html) {
                            bodyElement.innerHTML = html || '<div class="text-danger">' + loadInfoFailedText + '</div>';
                        })
                        .catch(function () {
                            bodyElement.innerHTML = '<div class="text-danger">' + loadInfoFailedText + '</div>';
                        });
                }

                return fetchPageFragment(url, selector).then(function (html) {
                    bodyElement.innerHTML = html || bodyElement.innerHTML;
                });
            }

            function refreshMediaLibrary() {
                return refreshFragmentBody(mediaModalBody);
            }

            function refreshAddonList() {
                return refreshFragmentBody(addonListContainer);
            }

            function clearAddonSelection() {
                if (addonVariantInput && window.jQuery && window.jQuery.fn && window.jQuery.fn.select2) {
                    window.jQuery(addonVariantInput).val(null).trigger('change');
                } else if (addonVariantInput) {
                    addonVariantInput.value = '';
                }
            }

            function clearBulkAddonSelection() {
                if (bulkAddonSelect && window.jQuery && window.jQuery.fn && window.jQuery.fn.select2) {
                    window.jQuery(bulkAddonSelect).val(null).trigger('change');
                } else if (bulkAddonSelect) {
                    bulkAddonSelect.value = '';
                }
            }

            function refreshComponentList() {
                return refreshFragmentBody(componentModalBody);
            }

            document.querySelectorAll('.js-variant-stock-details').forEach(function (button) {
                button.addEventListener('click', function () {
                    openVariantDataModal(
                        $('#variant-stock-modal'),
                        document.getElementById('variant-stock-modal-title'),
                        document.getElementById('variant-stock-modal-body'),
                        button.getAttribute('data-stock-url') || '',
                        renderWarehouseDetails,
                        button.getAttribute('data-detail-title') || inventoryAndWarehousesTitleText);
                });
            });

            document.querySelectorAll('.js-variant-prices-details').forEach(function (button) {
                button.addEventListener('click', function () {
                    openVariantDataModal(
                        $('#variant-prices-modal'),
                        document.getElementById('variant-prices-modal-title'),
                        document.getElementById('variant-prices-modal-body'),
                        button.getAttribute('data-prices-url') || '',
                        renderPriceDetails,
                        button.getAttribute('data-detail-title') || pricesTitleText);
                });
            });

            document.addEventListener('click', function (event) {
                var mediaButton = event.target.closest ? event.target.closest('.js-variant-media-details') : null;
                if (mediaButton) {
                    event.preventDefault();
                    openVariantHtmlModal(
                        $('#variant-media-library-modal'),
                        document.getElementById('variant-media-library-modal-title'),
                        document.getElementById('variant-media-library-modal-body'),
                        mediaButton.getAttribute('data-variant-url') || '',
                        mediaButton.getAttribute('data-detail-title') || variantMediaTitleText);
                    return;
                }

                var addonButton = event.target.closest ? event.target.closest('.js-variant-addon-details') : null;
                if (addonButton) {
                    event.preventDefault();
                    openVariantFragmentModal(
                        $('#variant-addons-modal'),
                        document.getElementById('variant-addons-modal').querySelector('.modal-title'),
                        document.getElementById('variant-addons-list-container'),
                        addonButton.getAttribute('data-variant-url') || '',
                        '#variant-addons-list-container',
                        addonButton.getAttribute('data-detail-title') || '');
                    return;
                }

                var componentButton = event.target.closest ? event.target.closest('.js-variant-components-details') : null;
                if (componentButton) {
                    event.preventDefault();
                    openVariantFragmentModal(
                        $('#variant-components-modal'),
                        document.getElementById('variant-components-modal').querySelector('.modal-title'),
                        document.getElementById('variant-components-modal-body'),
                        componentButton.getAttribute('data-variant-url') || '',
                        '#variant-components-modal-body',
                        componentButton.getAttribute('data-detail-title') || '');
                    return;
                }

                var tagButton = event.target.closest ? event.target.closest('.js-variant-tags') : null;
                if (tagButton) {
                    event.preventDefault();
                    var variantId = tagButton.getAttribute('data-variant-id') || '';
                    var label = tagButton.getAttribute('data-variant-label') || '';
                    if (tagsModal) {
                        tagsModal.attr('data-tag-mode', 'single');
                        tagsModal.attr('data-variant-id', variantId);
                        tagsModal.attr('data-variant-label', label);
                        tagsModal.attr('data-bulk-has-selection', 'false');
                    }

                    ensureTagLookupOptions().then(function () {
                        loadVariantTagsForModal(variantId, 'single', label);
                        if (tagsModal && tagsModal.modal) {
                            tagsModal.modal('show');
                        }
                    });
                }
            });

            function readState() {
                try {
                    return JSON.parse(localStorage.getItem(stateKey) || '{}');
                } catch (e) {
                    return {};
                }
            }

            function writeState(nextState) {
                localStorage.setItem(stateKey, JSON.stringify(nextState));
            }

            function readDrafts() {
                try {
                    return JSON.parse(localStorage.getItem(draftStateKey) || '{}');
                } catch (e) {
                    return {};
                }
            }

            function writeDrafts(nextDrafts) {
                localStorage.setItem(draftStateKey, JSON.stringify(nextDrafts));
            }

            function captureFormDraft(form) {
                var values = {};
                form.querySelectorAll('input, textarea, select').forEach(function (field) {
                    if (!field.name || field.name === '__RequestVerificationToken') {
                        return;
                    }

                    if (field.type === 'checkbox') {
                        values[field.name] = { type: 'checkbox', value: field.checked };
                        return;
                    }

                    if (field.type === 'radio') {
                        if (!values[field.name]) {
                            values[field.name] = { type: 'radio', value: '' };
                        }
                        if (field.checked) {
                            values[field.name].value = field.value || '';
                        }
                        return;
                    }

                    values[field.name] = { type: 'value', value: field.value || '' };
                });

                return values;
            }

            function applyFormDraft(form, values) {
                if (!values || typeof values !== 'object') {
                    return;
                }

                Object.keys(values).forEach(function (fieldName) {
                    var meta = values[fieldName];
                    if (!meta) {
                        return;
                    }

                    if (meta.type === 'radio') {
                        form.querySelectorAll('input[type="radio"][name="' + fieldName + '"]').forEach(function (radio) {
                            radio.checked = (radio.value || '') === (meta.value || '');
                        });
                        return;
                    }

                    var field = form.querySelector('[name="' + fieldName + '"]');
                    if (!field) {
                        return;
                    }

                    if (meta.type === 'checkbox') {
                        field.checked = !!meta.value;
                        return;
                    }

                    field.value = meta.value || '';
                });
            }

            function saveFormDraft(form) {
                var drafts = readDrafts();
                drafts[form.id] = captureFormDraft(form);
                writeDrafts(drafts);
            }

            function restoreFormDrafts() {
                var drafts = readDrafts();
                watchedForms.forEach(function (form) {
                    applyFormDraft(form, drafts[form.id]);
                });
            }

            function clearSubmittedDraftAfterSuccess() {
                if (!@hasCatalogSuccess.ToString().ToLowerInvariant()) {
                    return;
                }

                var submittedFormId = localStorage.getItem(submittedFormKey);
                if (!submittedFormId) {
                    return;
                }

                var drafts = readDrafts();
                if (drafts && drafts[submittedFormId]) {
                    delete drafts[submittedFormId];
                    writeDrafts(drafts);
                }

                localStorage.removeItem(submittedFormKey);
            }

            function readField(formElement, name) {
                var field = formElement ? formElement.querySelector('[name="' + name + '"]') : null;
                return field ? (field.value || '') : '';
            }

            function setFieldIfMissing(formElement, name, value) {
                if (!formElement || !value) {
                    return;
                }

                var field = formElement.querySelector('[name="' + name + '"]');
                if (!field) {
                    return;
                }

                var params = new URLSearchParams(window.location.search);
                if (params.has(name)) {
                    return;
                }

                if (!field.value) {
                    field.value = value;
                }
            }

