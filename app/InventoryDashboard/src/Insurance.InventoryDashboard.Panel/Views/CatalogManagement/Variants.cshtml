            }

            function createMediaManager(root) {
                var baseUrl = (root.getAttribute('data-base-url') || '').replace(/\/$/, '');
                var policy = (root.getAttribute('data-policy') || '').trim();
                var inputName = root.getAttribute('data-input-name') || '';
                var fileInput = root.querySelector('[data-media-file]');
                var progressWrap = root.querySelector('[data-media-progress-wrap]');
                var progressBar = root.querySelector('[data-media-progress]');
                var status = root.querySelector('[data-media-status]');
                var itemsWrap = root.querySelector('[data-media-items]');
                var emptyState = root.querySelector('[data-media-empty]');
                var form = root.closest('form');
                var hiddenInput = null;
                if (inputName) {
                    hiddenInput = root.querySelector('[name="' + inputName + '"]') || (form ? form.querySelector('[name="' + inputName + '"]') : null);
                }

                if (!baseUrl || !policy || !fileInput || !itemsWrap) {
                    if (status) {
                        status.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["variant.media.fileServiceUnavailable"]));
                    }
                    return;
                }

                var state = {
                    items: normalizeItems(parseJson(hiddenInput ? hiddenInput.value : '[]'))
                };

                function sync() {
                    state.items = normalizeItems(state.items);
                    if (hiddenInput) {
                        hiddenInput.value = JSON.stringify(state.items);
                        hiddenInput.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                    if (emptyState) {
                        emptyState.classList.toggle('d-none', state.items.length > 0);
                    }
                }

                function render() {
                    itemsWrap.innerHTML = state.items.map(function (item, index) {
                        var previewHtml = isVideoItem(item)
                            ? '<video src="' + escapeHtml(resolveUrl(baseUrl, item.originalUrl)) + '" class="w-100 rounded border mb-2" style="max-height:180px;" controls preload="metadata"></video>'
                            : '<img src="' + escapeHtml(resolveUrl(baseUrl, item.thumbnailUrl || item.originalUrl)) + '" alt="' + escapeHtml(item.originalFileName) + '" class="img-fluid rounded border mb-2" style="max-height:180px;" />';

                        return '' +
                            '<div class="col-lg-4 col-md-6 mb-3" data-media-index="' + index + '">' +
                                '<div class="card h-100"><div class="card-body">' +
                                    previewHtml +
                                    '<div class="small text-muted mb-2">' + escapeHtml(item.originalFileName) + '</div>' +
                                    '<div class="mb-2">' +
                                        '<span class="badge badge-pill badge-outline-primary">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.displayOrder"])) + ' ' + item.displayOrder + '</span> ' +
                                        (item.isPrimary ? '<span class="badge badge-pill badge-primary">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.primary"])) + '</span> ' : '') +
                                        '<span class="badge badge-pill badge-light">' + (isVideoItem(item) ? @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.video"])) : @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.image"]))) + '</span>' +
                                    '</div>' +
                                    '<div class="btn-group btn-group-sm flex-wrap">' +
                                        '<button type="button" class="btn btn-outline-secondary btn-xs" data-media-action="move-up">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.moveUp"])) + '</button>' +
                                        '<button type="button" class="btn btn-outline-secondary btn-xs" data-media-action="move-down">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.moveDown"])) + '</button>' +
                                        '<button type="button" class="btn btn-outline-primary btn-xs" data-media-action="make-primary">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.primary"])) + '</button>' +
                                        '<button type="button" class="btn btn-outline-danger btn-xs" data-media-action="remove">' + @Html.Raw(JsonSerializer.Serialize(UiText["common.delete"])) + '</button>' +
                                    '</div>' +
                                '</div></div>' +
                            '</div>';
                    }).join('');

                    sync();
                }

                function setStatus(message) {
                    if (status) {
                        status.textContent = message;
                    }
                }

                function getUploadErrorMessage(xhr, fallbackMessage) {
                    try {
                        var payload = JSON.parse(xhr.responseText || '{}');
                        if (payload && payload.message) {
                            return payload.message;
                        }
                    } catch (e) {
                    }

                    return fallbackMessage;
                }

                function uploadFile(file) {
                    return new Promise(function (resolve, reject) {
                        var xhr = new XMLHttpRequest();
                        var formData = new FormData();
                        formData.append('file', file);
                        xhr.open('POST', baseUrl + '/api/FileService/files/upload?policy=' + encodeURIComponent(policy));

                        if (progressWrap) {
                            progressWrap.classList.remove('d-none');
                        }

                        xhr.upload.addEventListener('progress', function (event) {
                            if (!event.lengthComputable || !progressBar) {
                                return;
                            }

                            progressBar.style.width = Math.round((event.loaded / event.total) * 100) + '%';
                        });

                        xhr.onload = function () {
                            if (progressWrap) {
                                progressWrap.classList.add('d-none');
                            }
                            if (progressBar) {
                                progressBar.style.width = '0%';
                            }

                            if (xhr.status < 200 || xhr.status >= 300) {
                                reject(new Error(getUploadErrorMessage(xhr, @Html.Raw(JsonSerializer.Serialize(UiText["variant.media.uploadFailed"])))));
                                return;
                            }

                            try {
                                resolve(JSON.parse(xhr.responseText));
                            } catch (e) {
                                reject(e);
                            }
                        };

                        xhr.onerror = function () {
                            if (progressWrap) {
                                progressWrap.classList.add('d-none');
                            }
                            if (progressBar) {
                                progressBar.style.width = '0%';
                            }
                            reject(new Error(@Html.Raw(JsonSerializer.Serialize(UiText["variant.media.fileServiceUnavailable"]))));
                        };

                        xhr.send(formData);
                    });
                }

                async function handleUpload(files) {
                    var list = Array.prototype.slice.call(files || []);
                    if (list.length === 0) {
                        return;
                    }

                    for (var i = 0; i < list.length; i++) {
                        var file = list[i];
                        setStatus(@Html.Raw(JsonSerializer.Serialize(UiText["variant.media.uploadingPrefix"])) + file.name);

                        try {
                            var result = await uploadFile(file);
                            state.items.push({
                                fileKey: result.fileKey || '',
                                originalFileName: result.originalFileName || file.name,
                                contentType: result.contentType || file.type || '',
                                originalUrl: result.url || '',
                                thumbnailUrl: result.thumbnailUrl || result.url || '',
                                displayOrder: state.items.length,
                                isPrimary: state.items.length === 0
                            });
                            render();
                            setStatus((result.originalFileName || file.name) + ' ' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.uploaded"])));
                        } catch (e) {
                            setStatus((e && e.message) ? e.message : @Html.Raw(JsonSerializer.Serialize(UiText["variant.media.uploadFailed"])));
                            break;
                        }
                    }

                    fileInput.value = '';
                }

                fileInput.addEventListener('change', function () {
                    handleUpload(fileInput.files);
                });

                root.addEventListener('click', function (event) {
                    var actionButton = event.target.closest('[data-media-action]');
                    if (!actionButton) {
                        return;
                    }

                    var host = actionButton.closest('[data-media-index]');
                    if (!host) {
                        return;
                    }

                    var index = parseInt(host.getAttribute('data-media-index') || '-1', 10);
                    if (index < 0 || index >= state.items.length) {
                        return;
                    }

                    var action = actionButton.getAttribute('data-media-action');
                    if (action === 'remove') {
                        var removedPrimary = !!state.items[index].isPrimary;
                        state.items.splice(index, 1);
                        if (removedPrimary && state.items.length > 0) {
                            state.items[0].isPrimary = true;
                        }
                    } else if (action === 'make-primary') {
                        state.items.forEach(function (item, itemIndex) {
                            item.isPrimary = itemIndex === index;
                        });
                    } else if (action === 'move-up' && index > 0) {
                        var current = state.items[index];
                        state.items[index] = state.items[index - 1];
                        state.items[index - 1] = current;
                    } else if (action === 'move-down' && index < state.items.length - 1) {
                        var next = state.items[index];
                        state.items[index] = state.items[index + 1];
                        state.items[index + 1] = next;
                    }

                    render();
                });

                render();
            }

            document.querySelectorAll('[data-media-manager]').forEach(createMediaManager);
        })();
    </script>
}
