                    setBulkModalState(target, hasSelection);
                    showModal(target);
                }, true);
            });

            $('#variant-bulk-addon-modal').on('show.bs.modal', function () {
                var currentMode = addonModal && addonModal.attr ? (addonModal.attr('data-addon-mode') || 'bulk') : 'bulk';
                var currentVariantId = addonModal && addonModal.attr ? (addonModal.attr('data-variant-id') || '') : '';
                var hasSelection = currentMode === 'single' ? true : getSelectedVariantCount() > 0;
                if (addonModal && addonModal.attr) {
                    addonModal.attr('data-addon-mode', currentMode);
                }
                setBulkModalState('#variant-bulk-addon-modal', hasSelection);
                if (bulkAddonSelect && window.jQuery && window.jQuery.fn && window.jQuery.fn.select2) {
                    window.jQuery(bulkAddonSelect).val(null).trigger('change');
                }
                updateAddonSubmitState();
            });

            $('#variant-bulk-media-modal').on('show.bs.modal', function () {
                var hasSelection = getSelectedVariantCount() > 0;
                if (mediaModal && mediaModal.attr) {
                    mediaModal.attr('data-media-mode', 'bulk');
                }
                setBulkModalState('#variant-bulk-media-modal', hasSelection);
            });

            updateBulkModalTriggers();

            if (variantListContainer) {
                variantListContainer.addEventListener('change', function (event) {
                    var target = event.target;
                    if (!target || !(target instanceof HTMLInputElement)) {
                        return;
                    }

                    if (!target.matches('input[type="checkbox"][data-bulk-row], input[type="checkbox"][data-bulk-toggle]')) {
                        return;
                    }

                    updateBulkModalTriggers();
                });
            }

            [searchForm, productSelectorForm].forEach(function (formElement) {
                if (!formElement) {
                    return;
                }

                formElement.querySelectorAll('input, select').forEach(function (field) {
                    field.addEventListener('change', function () {
                        savePageState();
                    });
                    field.addEventListener('input', function () {
                        savePageState();
                    });
                });
            });

            document.addEventListener('submit', function (event) {
                var ajaxForm = event.target.closest ? event.target.closest('form[data-ajax-submit]') : null;
                if (!ajaxForm) {
                    return;
                }

                    event.preventDefault();
                    savePageState();
                    if (ajaxForm === tagsBulkForm) {
                        syncBulkTagIdsField();
                    }
                    if (ajaxForm === tagsSingleForm) {
                        syncSingleTagIdField();
                    }
                    if (ajaxForm === tagsCreateForm) {
                        var pendingTagNameInput = tagsCreateForm ? tagsCreateForm.querySelector('input[name="TagDefinitionForm.TagName"]') : null;
                        pendingCreatedTagName = pendingTagNameInput ? (pendingTagNameInput.value || '').trim() : '';
                    }

                var submitButtons = ajaxForm.querySelectorAll('button[type="submit"]');
                var mode = ajaxForm.getAttribute('data-ajax-submit') || '';

                if (mode === 'bulk-addon') {
                    var selectedAddOnId = bulkAddonSelect
                        ? ((window.jQuery && window.jQuery.fn && window.jQuery.fn.select2)
                            ? (window.jQuery(bulkAddonSelect).val() || '').toString().trim()
                            : (bulkAddonSelect.value || '').trim())
                        : '';
                    var selectedTagId = bulkAddonTagSelect
                        ? ((window.jQuery && window.jQuery.fn && window.jQuery.fn.select2)
                            ? (window.jQuery(bulkAddonTagSelect).val() || '').toString().trim()
                            : (bulkAddonTagSelect.value || '').trim())
                        : '';

                    if (!selectedAddOnId && !selectedTagId) {
                        alert('حداقل یکی از واریانت یا هشتگ را برای Add-on انتخاب کنید.');
                        return;
                    }

                    if (selectedAddOnId && selectedTagId) {
                        alert('فقط یکی از واریانت یا هشتگ را برای Add-on انتخاب کنید.');
                        return;
                    }
                }

                submitButtons.forEach(function (button) {
                    button.setAttribute('disabled', 'disabled');
                });

                fetch(ajaxForm.action, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'text/html'
                    },
                    body: new FormData(ajaxForm)
                })
                    .then(function (response) {
                        if (!response.ok) {
                            return response.text().then(function (text) {
                                throw new Error(text || loadInfoFailedText);
                            });
                        }

                        var mode = ajaxForm.getAttribute('data-ajax-submit') || '';
                        if (mode === 'bulk-media' || mode === 'bulk-addon') {
                            return response.json().then(function (payload) {
                                return {
                                    mode: mode,
                                    ok: response.ok,
                                    payload: payload || {}
                                };
                            });
                        }

                        if (mode === 'variant-tags' && ajaxForm === tagsCreateForm) {
                            return response.json().then(function (payload) {
                                return {
                                    mode: mode,
                                    payload: payload || {}
                                };
                            });
                        }

                        if (mode === 'variant-pricing') {
                            return response.json().then(function (payload) {
                                return {
                                    mode: mode,
                                    ok: response.ok,
                                    payload: payload || {}
                                };
                            });
                        }

                        return response.text().then(function (text) {
                            return {
                                mode: mode,
                                text: text
                            };
                        });
                    })
                    .then(function (result) {
                        var mode = result && result.mode ? result.mode : (ajaxForm.getAttribute('data-ajax-submit') || '');
                        if (mode === 'variant-components') {
                            return refreshComponentList().then(function () {
                                if (componentStockPanel) {
                                    componentStockPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
                                }
                            });
                        }

                        if (mode === 'variant-media-remove') {
                            return refreshMediaLibrary();
                        }

                        if (mode === 'variant-addons') {
                            return refreshAddonList().then(function () {
                                clearAddonSelection();
                            });
                        }

                        if (mode === 'variant-tags') {
                            if (ajaxForm === tagsCreateForm) {
                                var payload = result && result.payload ? result.payload : {};
                                pendingCreatedTagId = (payload && payload.tagId) ? payload.tagId : '';
                                return reloadTagLookupOptions(pendingCreatedTagId).then(function () {
                                    var currentMode = tagsModal ? (tagsModal.attr('data-tag-mode') || 'single') : 'single';
                                    if (currentMode === 'single' && pendingCreatedTagId && singleTagLookupSelect && window.jQuery && window.jQuery.fn && window.jQuery.fn.select2) {
                                        window.jQuery(singleTagLookupSelect).val(pendingCreatedTagId).trigger('change');
                                    }
                                    pendingCreatedTagName = '';
                                    pendingCreatedTagId = '';
                                    var currentVariantId = tagsSingleVariantId && tagsSingleVariantId.value ? tagsSingleVariantId.value : '';
                                    return loadVariantTagsForModal(currentVariantId, currentMode, tagsModalTitle ? tagsModalTitle.textContent : '');
                                });
                            }

                            return reloadTagLookupOptions().then(function () {
                                var currentMode = tagsModal ? (tagsModal.attr('data-tag-mode') || 'single') : 'single';
                                var currentVariantId = tagsSingleVariantId && tagsSingleVariantId.value ? tagsSingleVariantId.value : '';
                                return loadVariantTagsForModal(currentVariantId, currentMode, tagsModalTitle ? tagsModalTitle.textContent : '');
                            });
                        }

                        if (mode === 'bulk-media') {
                            if (bulkMediaForm) {
                                var mediaStatus = bulkMediaForm.querySelector('[data-media-status]');
                                if (mediaStatus) {
                                    var payload = result && result.payload ? result.payload : {};
                                    mediaStatus.textContent = payload.message || mediaStatus.textContent;
                                }
                            }
                            return Promise.resolve();
                        }

                        if (mode === 'bulk-addon') {
                            var addonPayload = result && result.payload ? result.payload : {};
                            var addonMode = addonModal ? (addonModal.attr('data-addon-mode') || 'bulk') : 'bulk';
                            var currentAddonVariantId = addonModal ? (addonModal.attr('data-variant-id') || '') : '';
                            var currentAddonLabel = addonModal ? (addonModal.attr('data-variant-label') || '') : '';
                            var currentAddonProductId = addonModal ? (addonModal.attr('data-product-id') || getSelectedProductId() || '') : getSelectedProductId();
                            if (!result.ok || !addonPayload.isSuccess) {
                                throw new Error(addonPayload.error || addonPayload.message || loadInfoFailedText);
                            }

                            if (addonMode === 'single') {
                                return loadVariantAddOnsForModal(
                                    currentAddonVariantId,
                                    'single',
                                    currentAddonLabel,
                                    currentAddonProductId
                                ).then(function () {
                                    clearAddonSelection();
                                    updateAddonSubmitState();
                                });
                            }

                            return refreshAddonList().then(function () {
                                clearBulkAddonSelection();
                                updateAddonSubmitState();
                            });
                        }

                        if (mode === 'bulk-tags') {
                            if (tagsModal) {
                                tagsModal.modal('hide');
                            }
                            return Promise.resolve();
                        }

                        if (mode === 'variant-pricing') {
                            var pricingPayload = result && result.payload ? result.payload : {};
                            if (!result.ok || !pricingPayload.isSuccess) {
                                throw new Error(pricingPayload.error || pricingPayload.message || loadInfoFailedText);
                            }

                            if (pricingModalSummary) {
                                pricingModalSummary.classList.remove('d-none');
                                pricingModalSummary.textContent = pricingPayload.message || 'قیمت‌ها با موفقیت ثبت شد.';
                            }

                            if (pricingModalError) {
                                pricingModalError.classList.add('d-none');
                                pricingModalError.textContent = '';
                            }

                            if (pricingFillAmountInput) {
                                pricingFillAmountInput.value = '';
                            }

                            return Promise.resolve();
                        }

                        return Promise.resolve();
                    })
                    .catch(function (error) {
                        alert((error && error.message) ? error.message : loadInfoFailedText);
                    })
                    .finally(function () {
                        submitButtons.forEach(function (button) {
                            button.removeAttribute('disabled');
                        });
                    });
            }, true);

            document.querySelectorAll('form[data-loading-form]').forEach(function (formElement) {
                if (formElement.hasAttribute('data-ajax-submit')) {
                    return;
                }

                formElement.addEventListener('submit', function (event) {
                    savePageState();
                    if (formElement.id && watchedFormIds.indexOf(formElement.id) >= 0) {
                        saveFormDraft(formElement);
                        localStorage.setItem(submittedFormKey, formElement.id);
                    }
                    formElement.querySelectorAll('button[type="submit"]').forEach(function (button) { button.setAttribute('disabled', 'disabled'); });
                });
            });

            if (false && bulkMediaForm) {
                bulkMediaForm.addEventListener('submit', function (event) {
                    event.preventDefault();
                    savePageState();

                    var submitButtons = bulkMediaForm.querySelectorAll('button[type="submit"]');
                    submitButtons.forEach(function (button) {
                        button.setAttribute('disabled', 'disabled');
                    });

                    var body = new FormData(bulkMediaForm);
                    fetch(bulkMediaForm.action, {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'Accept': 'application/json'
                        },
                        body: body
                    })
                        .then(function (response) {
                            return response.json().then(function (payload) {
                                return { ok: response.ok, payload: payload };
                            });
                        })
                        .then(function (result) {
                            if (!result.ok || !result.payload || !result.payload.isSuccess) {
                                var errorMessage = (result.payload && (result.payload.error || result.payload.message)) ? (result.payload.error || result.payload.message) : loadInfoFailedText;
                                alert(errorMessage);
                                return;
                            }

                            if (bulkMediaForm) {
                                var statusElement = bulkMediaForm.querySelector('[data-media-status]');
                                if (statusElement) {
                                    statusElement.textContent = result.payload.message || statusElement.textContent;
                                }
                            }
                        })
                        .catch(function () {
                            alert(loadInfoFailedText);
                        })
                        .finally(function () {
                            submitButtons.forEach(function (button) {
                                button.removeAttribute('disabled');
                            });
                        });
                });
            }

            watchedForms.forEach(function (formElement) {
                formElement.querySelectorAll('input, textarea, select').forEach(function (field) {
                    field.addEventListener('change', function () {
                        saveFormDraft(formElement);
                    });
                    field.addEventListener('input', function () {
                        saveFormDraft(formElement);
                    });
                });
            });

            document.querySelectorAll('form[data-dirty-watch]').forEach(function (formElement) {
                formElement.querySelectorAll('input, textarea, select').forEach(function (field) {
                    field.addEventListener('change', function () {
                        formElement.dataset.isDirty = 'true';
                        dirtyForms.add(formElement);
                    });
                    field.addEventListener('input', function () {
                        formElement.dataset.isDirty = 'true';
                        dirtyForms.add(formElement);
                    });
                });

                formElement.addEventListener('submit', function () {
                    formElement.dataset.isDirty = 'false';
                    dirtyForms.delete(formElement);
                });
            });

            window.addEventListener('beforeunload', function (event) {
                var hasDirty = Array.from(dirtyForms).some(function (formElement) {
                    return formElement.dataset.isDirty === 'true';
                });

                if (!hasDirty) {
                    return;
                }

                event.preventDefault();
                event.returnValue = '';
            });
        })();
    </script>
    <script>
        (function () {
            function parseJson(value) {
                if (!value) {
                    return [];
                }

                try {
                    var parsed = JSON.parse(value);
                    return Array.isArray(parsed) ? parsed : [];
                } catch (e) {
                    return [];
                }
            }

            function escapeHtml(value) {
                return String(value || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function resolveUrl(baseUrl, path) {
                if (!path) {
                    return '';
                }

                return /^https?:\/\//i.test(path) ? path : baseUrl + path;
            }

            function isVideoItem(item) {
                var contentType = (item && item.contentType) || '';
                return contentType.toLowerCase().indexOf('video/') === 0;
            }

            function normalizeItems(items) {
                var normalized = (items || [])
                    .filter(function (item) { return item && item.fileKey; })
                    .map(function (item, index) {
                        return {
                            fileKey: item.fileKey,
                            originalFileName: item.originalFileName || item.fileKey,
                            contentType: item.contentType || '',
                            originalUrl: item.originalUrl || item.url || '',
                            thumbnailUrl: item.thumbnailUrl || item.originalUrl || item.url || '',
                            displayOrder: typeof item.displayOrder === 'number' ? item.displayOrder : index,
                            isPrimary: !!item.isPrimary
                        };
                    })
                    .sort(function (left, right) { return left.displayOrder - right.displayOrder; });

                if (normalized.length > 0 && !normalized.some(function (item) { return item.isPrimary; })) {
                    normalized[0].isPrimary = true;
                }

                normalized.forEach(function (item, index) {
                    item.displayOrder = index;
                });

                return normalized;
            }

            function createMediaManager(root) {
                var baseUrl = (root.getAttribute('data-base-url') || '').replace(/\/$/, '');
                var policy = (root.getAttribute('data-policy') || '').trim();
                var inputName = root.getAttribute('data-input-name') || '';
                var fileInput = root.querySelector('[data-media-file]');
                var progressWrap = root.querySelector('[data-media-progress-wrap]');
                var progressBar = root.querySelector('[data-media-progress]');
                var status = root.querySelector('[data-media-status]');
                var itemsWrap = root.querySelector('[data-media-items]');
                var emptyState = root.querySelector('[data-media-empty]');
                var form = root.closest('form');
                var hiddenInput = null;
                if (inputName) {
                    hiddenInput = root.querySelector('[name="' + inputName + '"]') || (form ? form.querySelector('[name="' + inputName + '"]') : null);
                }

                if (!baseUrl || !policy || !fileInput || !itemsWrap) {
                    if (status) {
                        status.textContent = @Html.Raw(JsonSerializer.Serialize(UiText["variant.media.fileServiceUnavailable"]));
                    }
                    return;
                }

                var state = {
                    items: normalizeItems(parseJson(hiddenInput ? hiddenInput.value : '[]'))
                };

                function sync() {
                    state.items = normalizeItems(state.items);
                    if (hiddenInput) {
                        hiddenInput.value = JSON.stringify(state.items);
                        hiddenInput.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                    if (emptyState) {
                        emptyState.classList.toggle('d-none', state.items.length > 0);
                    }
                }

                function render() {
                    itemsWrap.innerHTML = state.items.map(function (item, index) {
                        var previewHtml = isVideoItem(item)
                            ? '<video src="' + escapeHtml(resolveUrl(baseUrl, item.originalUrl)) + '" class="w-100 rounded border mb-2" style="max-height:180px;" controls preload="metadata"></video>'
                            : '<img src="' + escapeHtml(resolveUrl(baseUrl, item.thumbnailUrl || item.originalUrl)) + '" alt="' + escapeHtml(item.originalFileName) + '" class="img-fluid rounded border mb-2" style="max-height:180px;" />';

                        return '' +
                            '<div class="col-lg-4 col-md-6 mb-3" data-media-index="' + index + '">' +
                                '<div class="card h-100"><div class="card-body">' +
                                    previewHtml +
                                    '<div class="small text-muted mb-2">' + escapeHtml(item.originalFileName) + '</div>' +
                                    '<div class="mb-2">' +
                                        '<span class="badge badge-pill badge-outline-primary">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.displayOrder"])) + ' ' + item.displayOrder + '</span> ' +
                                        (item.isPrimary ? '<span class="badge badge-pill badge-primary">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.primary"])) + '</span> ' : '') +
                                        '<span class="badge badge-pill badge-light">' + (isVideoItem(item) ? @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.video"])) : @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.image"]))) + '</span>' +
                                    '</div>' +
                                    '<div class="btn-group btn-group-sm flex-wrap">' +
                                        '<button type="button" class="btn btn-outline-secondary btn-xs" data-media-action="move-up">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.moveUp"])) + '</button>' +
                                        '<button type="button" class="btn btn-outline-secondary btn-xs" data-media-action="move-down">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.moveDown"])) + '</button>' +
                                        '<button type="button" class="btn btn-outline-primary btn-xs" data-media-action="make-primary">' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.primary"])) + '</button>' +
                                        '<button type="button" class="btn btn-outline-danger btn-xs" data-media-action="remove">' + @Html.Raw(JsonSerializer.Serialize(UiText["common.delete"])) + '</button>' +
                                    '</div>' +
                                '</div></div>' +
                            '</div>';
                    }).join('');

                    sync();
                }

                function setStatus(message) {
                    if (status) {
                        status.textContent = message;
                    }
                }

                function getUploadErrorMessage(xhr, fallbackMessage) {
                    try {
                        var payload = JSON.parse(xhr.responseText || '{}');
                        if (payload && payload.message) {
                            return payload.message;
                        }
                    } catch (e) {
                    }

                    return fallbackMessage;
                }

                function uploadFile(file) {
                    return new Promise(function (resolve, reject) {
                        var xhr = new XMLHttpRequest();
                        var formData = new FormData();
                        formData.append('file', file);
                        xhr.open('POST', baseUrl + '/api/FileService/files/upload?policy=' + encodeURIComponent(policy));

                        if (progressWrap) {
                            progressWrap.classList.remove('d-none');
                        }

                        xhr.upload.addEventListener('progress', function (event) {
                            if (!event.lengthComputable || !progressBar) {
                                return;
                            }

                            progressBar.style.width = Math.round((event.loaded / event.total) * 100) + '%';
                        });

                        xhr.onload = function () {
                            if (progressWrap) {
                                progressWrap.classList.add('d-none');
                            }
                            if (progressBar) {
                                progressBar.style.width = '0%';
                            }

                            if (xhr.status < 200 || xhr.status >= 300) {
                                reject(new Error(getUploadErrorMessage(xhr, @Html.Raw(JsonSerializer.Serialize(UiText["variant.media.uploadFailed"])))));
                                return;
                            }

                            try {
                                resolve(JSON.parse(xhr.responseText));
                            } catch (e) {
                                reject(e);
                            }
                        };

                        xhr.onerror = function () {
                            if (progressWrap) {
                                progressWrap.classList.add('d-none');
                            }
                            if (progressBar) {
                                progressBar.style.width = '0%';
                            }
                            reject(new Error(@Html.Raw(JsonSerializer.Serialize(UiText["variant.media.fileServiceUnavailable"]))));
                        };

                        xhr.send(formData);
                    });
                }

                async function handleUpload(files) {
                    var list = Array.prototype.slice.call(files || []);
                    if (list.length === 0) {
                        return;
                    }

                    for (var i = 0; i < list.length; i++) {
                        var file = list[i];
                        setStatus(@Html.Raw(JsonSerializer.Serialize(UiText["variant.media.uploadingPrefix"])) + file.name);

                        try {
                            var result = await uploadFile(file);
                            state.items.push({
                                fileKey: result.fileKey || '',
                                originalFileName: result.originalFileName || file.name,
                                contentType: result.contentType || file.type || '',
                                originalUrl: result.url || '',
                                thumbnailUrl: result.thumbnailUrl || result.url || '',
                                displayOrder: state.items.length,
                                isPrimary: state.items.length === 0
                            });
                            render();
                            setStatus((result.originalFileName || file.name) + ' ' + @Html.Raw(JsonSerializer.Serialize(UiText["catalog.variants.uploaded"])));
                        } catch (e) {
                            setStatus((e && e.message) ? e.message : @Html.Raw(JsonSerializer.Serialize(UiText["variant.media.uploadFailed"])));
                            break;
                        }
                    }

                    fileInput.value = '';
                }

                fileInput.addEventListener('change', function () {
                    handleUpload(fileInput.files);
                });

                root.addEventListener('click', function (event) {
                    var actionButton = event.target.closest('[data-media-action]');
                    if (!actionButton) {
                        return;
                    }

                    var host = actionButton.closest('[data-media-index]');
                    if (!host) {
                        return;
                    }

                    var index = parseInt(host.getAttribute('data-media-index') || '-1', 10);
                    if (index < 0 || index >= state.items.length) {
                        return;
                    }

                    var action = actionButton.getAttribute('data-media-action');
                    if (action === 'remove') {
                        var removedPrimary = !!state.items[index].isPrimary;
                        state.items.splice(index, 1);
                        if (removedPrimary && state.items.length > 0) {
                            state.items[0].isPrimary = true;
                        }
                    } else if (action === 'make-primary') {
                        state.items.forEach(function (item, itemIndex) {
                            item.isPrimary = itemIndex === index;
                        });
                    } else if (action === 'move-up' && index > 0) {
                        var current = state.items[index];
                        state.items[index] = state.items[index - 1];
                        state.items[index - 1] = current;
                    } else if (action === 'move-down' && index < state.items.length - 1) {
                        var next = state.items[index];
                        state.items[index] = state.items[index + 1];
                        state.items[index + 1] = next;
                    }

                    render();
                });

                render();
            }

            document.querySelectorAll('[data-media-manager]').forEach(createMediaManager);
        })();
    </script>
}
