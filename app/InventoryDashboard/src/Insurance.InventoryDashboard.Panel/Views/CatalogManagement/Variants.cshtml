            if (bulkAddonApplyButton) {
                bulkAddonApplyButton.addEventListener('click', function () {
                    if (!bulkAddonSelectorList || !bulkAddonSelectedIdsInput || !bulkAddonPrimaryInput || !bulkAddonSelect) {
