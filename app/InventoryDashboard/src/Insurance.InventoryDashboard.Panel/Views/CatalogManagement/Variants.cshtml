                return rawValue ? rawValue.split(',').map(function (item) { return item.trim(); }).filter(Boolean) : [];
            }

            function renderBulkAddonSummary() {
                if (!bulkAddonPills || !bulkAddonSelect || !bulkAddonSummary) {
                    return;
                }

                var selectedIds = readBulkAddonSelection();
                bulkAddonPills.innerHTML = '';
                var emptyText = bulkAddonSummary.querySelector('[data-empty-text]');
                if (emptyText) {
                    emptyText.classList.toggle('d-none', selectedIds.length > 0);
