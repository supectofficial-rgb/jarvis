            var bulkAddonSelect = document.getElementById('BulkVariantAddOnForm_AddOnVariantId');
            var bulkAddonPrimaryInput = document.getElementById('bulk-addon-primary-id');
            var bulkAddonSelectedIdsInput = document.getElementById('bulk-addon-selected-ids');
