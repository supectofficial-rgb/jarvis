                             data-selected-variant-id="@Model.SelectedVariantId"
                             data-search-term="@Model.VariantSearchTerm"
                             data-tracking-policy="@Model.VariantTrackingFilter"
                             data-status-filter="@Model.VariantStatusFilter"
                             data-attribute-type-filter="@Model.SelectedAttributeTypeFilter"
                             data-sort="@Model.VariantSort"
                             data-page="@Model.VariantPage"
                             data-page-size="@Model.VariantPageSize">
                            <div class="alert alert-light mb-0">@UiText["catalog.variants.loading"]</div>
                        </div>
                    </div>
                </div>

</main>

