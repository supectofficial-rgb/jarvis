                        ? 'برچسب‌ها برای واریانت‌های انتخاب‌شده ثبت می‌شوند.'
                        : 'برچسب‌های ثبت‌شده‌ی همین واریانت را می‌بینی و می‌توانی اضافه/حذف کنی.';
                }

                if (tagsSingleVariantId) {
                    tagsSingleVariantId.value = mode === 'bulk' ? '' : variantId;
                }

                if (mode === 'bulk') {
                    if (bulkTagsSelectedIdsInput) {
                        bulkTagsSelectedIdsInput.value = variantId || '';
                    }
                    if (bulkTagLookupSelect && window.jQuery && window.jQuery.fn && window.jQuery.fn.select2) {
                        window.jQuery(bulkTagLookupSelect).val(null).trigger('change');
                    }
                    syncBulkTagIdsField();
                    renderTagList([], mode);
                    return;
                }

                if (!variantId) {
                    if (singleTagLookupSelect && window.jQuery && window.jQuery.fn && window.jQuery.fn.select2) {
                        window.jQuery(singleTagLookupSelect).val(null).trigger('change');
                    }
                    if (tagsSingleTagId) {
                        tagsSingleTagId.value = '';
                    }
                    renderTagList([], mode);
                    return;
                }

                if (tagsCreateToggle) {
                    tagsCreateToggle.classList.remove('d-none');
                }
                if (tagsCreateCard) {
                    tagsCreateCard.classList.add('d-none');
                }
                resetTagCreateForm();

                var url = @Html.Raw(JsonSerializer.Serialize(Url.Action("VariantTags", "VariantManagement") ?? string.Empty)) + '?variantId=' + encodeURIComponent(variantId);
                fetch(url, { headers: { 'Accept': 'application/json' } })
                    .then(function (response) { return response.json(); })
                    .then(function (payload) {
                        if (payload && payload.error) {
                            renderTagList([], mode);
                            if (tagsModalSummary) {
                                tagsModalSummary.textContent = payload.error;
                            }
                            return;
                        }

                        renderTagList(payload || [], mode);
                    })
                .catch(function () {
                    renderTagList([], mode);
                });
            }

            function removeVariantTagAjax(tag) {
