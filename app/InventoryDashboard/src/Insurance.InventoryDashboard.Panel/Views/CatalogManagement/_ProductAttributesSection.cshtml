@using System
@using System.Linq
@using System.Text.Json
@model Insurance.InventoryDashboard.Panel.Models.ProductManagementPageViewModel
@{
    var hasSelectedProduct = !string.IsNullOrWhiteSpace(Model.SelectedProductId);
    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x =>
        string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));
    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }
}
<div class="tab-pane fade" id="product-tab-attributes" role="tabpanel">
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">@UiText["catalog.products.effectiveCategoryAttributes"]</h5>
            @foreach (var group in Model.CategoryAttributeGroups)
            {
                <div class="mb-3 pb-2 border-bottom">
                    <div class="d-flex align-items-center mb-2">
                        <strong class="mr-2">@group.CategoryName</strong>
                        <span class="badge badge-pill @(group.IsCurrentCategory ? "badge-outline-secondary" : "badge-outline-primary")">
                            @(group.IsCurrentCategory ? UiText["catalog.products.direct"] : UiText["catalog.products.inherited"])
                        </span>
                    </div>
                    <ul class="list-unstyled mb-0 small">
                        @foreach (var attr in group.Attributes)
                        {
                            <li class="mb-1">
                                <strong>@attr.Name</strong>
                                <span class="text-muted">(@attr.DataType / @attr.Scope) - @(attr.IsRequired ? UiText["catalog.products.required"] : UiText["catalog.products.optional"])</span>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>

    @if (hasSelectedProduct)
    {
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@UiText["catalog.products.setProductAttribute"]</h5>
                <form asp-action="SetProductAttributeValue" method="post" id="product-attribute-form" data-loading-form data-dirty-watch>
                    @Html.AntiForgeryToken()
                    <input asp-for="ProductAttributeForm.ProductId" type="hidden" value="@Model.SelectedProductId" />
                    <input asp-for="ProductAttributeForm.CategoryId" type="hidden" value="@Model.SelectedCategoryId" />
                    <div class="form-group">
                        <label>@UiText["catalog.products.attribute"]</label>
                        <select asp-for="ProductAttributeForm.AttributeId" class="form-control js-search-select" id="product-attribute-select" data-placeholder='@UiText["catalog.products.selectAttribute"]' required>
                            <option value="">@UiText["catalog.products.selectAttribute"]</option>
                            @foreach (var attr in Model.EffectiveCategoryAttributes)
                            {
                                var optionsJson = JsonSerializer.Serialize(attr.Options.Select(o => new { name = o.OptionName, value = o.OptionValue }));
                                <option value="@attr.AttributeId"
                                        data-type="@attr.DataType"
                                        data-required="@(attr.IsRequired ? "true" : "false")"
                                        data-options='@optionsJson'>
                                    @attr.Name (@attr.DataType / @attr.Scope)
                                    @(attr.IsRequired ? $" - {UiText["catalog.products.required"]}" : $" - {UiText["catalog.products.optional"]}")
                                    @(attr.IsInherited ? $" - {UiText["catalog.products.inheritedFromPrefix"]}{attr.SourceCategoryName}" : $" - {UiText["catalog.products.direct"]}")
                                </option>
                            }
                        </select>
                    </div>
                    <div class="form-group" id="product-value-text-group"><label>@UiText["catalog.products.value"]</label><input type="text" class="form-control" id="product-value-text" /></div>
                    <div class="form-group d-none" id="product-value-number-group"><label>@UiText["catalog.products.numericValue"]</label><input type="number" step="any" class="form-control" id="product-value-number" /></div>
                    <div class="form-group d-none" id="product-value-date-group"><label>@UiText["catalog.products.date"]</label><input type="date" class="form-control" id="product-value-date" /></div>
                    <div class="form-group d-none" id="product-value-boolean-group">
                        <label class="d-block">@UiText["catalog.products.booleanValue"]</label>
                        <div class="custom-control custom-switch mb-2">
                            <input type="checkbox" class="custom-control-input" id="product-value-boolean">
                            <label class="custom-control-label" for="product-value-boolean">@UiText["catalog.products.booleanValueToggle"]</label>
                        </div>
                        <button type="button" class="btn btn-outline-secondary btn-xs" id="product-value-boolean-clear">@UiText["catalog.products.clearValue"]</button>
                    </div>
                    <div class="form-group d-none" id="product-value-option-group"><label>@UiText["catalog.products.option"]</label><select class="form-control js-search-select" id="product-value-option" data-no-search="true"></select></div>
                    <input asp-for="ProductAttributeForm.Value" type="hidden" id="product-value-hidden" />
                    <div class="mt-3">
                        <button class="btn btn-outline-primary" type="submit" @(Can("Catalog.ProductAttributeValue.Set", "ProductAttributeValue.Set") ? null : "disabled")>@UiText["catalog.products.submitValue"]</button>
                    </div>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="alert alert-light mb-0">
                    <h6>@UiText["catalog.products.noProductSelected"]</h6>
                    <p class="mb-0 text-muted">@UiText["catalog.products.noProductSelectedAttributeHelp"]</p>
                </div>
            </div>
        </div>
    }
</div>
