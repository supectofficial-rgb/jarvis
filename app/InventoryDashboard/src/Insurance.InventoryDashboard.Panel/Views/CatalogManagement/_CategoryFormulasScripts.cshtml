@using System.Linq
@using System.Text.Json
@model Insurance.InventoryDashboard.Panel.Models.CategoryManagementPageViewModel
@{
    var localFormulas = Model.CategoryVariantNameFormulas.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name).ToList();
    var formulaAttributeSource = Model.CategoryAttributes.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name).ToList();
}
<script>
    (function () {
        function escapeHtml(value) {
            return (value || '')
                .toString()
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function initSearchableSelects(scope) {
            if (!scope || !window.jQuery || !window.jQuery.fn || !window.jQuery.fn.select2) {
                return;
            }

            var $ = window.jQuery;
            scope.querySelectorAll('select.js-search-select').forEach(function (select) {
                if (select.dataset.select2Initialized === 'true') {
                    return;
                }

                $(select).select2({
                    theme: 'bootstrap',
                    dir: document.documentElement.getAttribute('dir') || 'rtl',
                    width: select.getAttribute('data-width') || '100%',
                    placeholder: select.getAttribute('data-placeholder') || '',
                    minimumResultsForSearch: select.hasAttribute('data-no-search') ? Infinity : 0
                });

                select.dataset.select2Initialized = 'true';
            });
        }

        var texts = {
            add: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.attributeOptions.add"])),
            replace: @Html.Raw(JsonSerializer.Serialize(UiText["common.edit"])),
            remove: @Html.Raw(JsonSerializer.Serialize(UiText["common.delete"])),
            update: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.formulas.update"])),
            empty: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.formulas.emptyParts"])),
            inheritedSuffix: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.formulas.inheritedSuffix"])),
            separatorDash: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.formulas.separator.dash"])),
            separatorSpace: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.formulas.separator.space"])),
            separatorNone: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.formulas.separator.none"])),
            editTitle: @Html.Raw(JsonSerializer.Serialize(UiText["catalog.categories.variantFormulaEdit"]))
        };

        var formulas = @Html.Raw(JsonSerializer.Serialize(localFormulas.Select(functionFormula => new {
            formulaId = functionFormula.FormulaId,
            categoryId = functionFormula.CategoryId,
            categoryName = functionFormula.CategoryName,
            name = functionFormula.Name,
            separator = functionFormula.Separator,
            includeCategoryName = functionFormula.IncludeCategoryName,
            displayOrder = functionFormula.DisplayOrder,
            isActive = functionFormula.IsActive,
                parts = functionFormula.Parts
                    .OrderBy(x => x.SortOrder)
                    .ThenBy(x => x.AttributeName)
                    .Select(part => new {
                        attributeId = part.AttributeId,
                        separator = part.Separator,
                        attributeName = part.AttributeName,
                        attributeCode = part.AttributeCode,
                        sortOrder = part.SortOrder
                    })
                    .ToList()
        }).ToList()));

        var formulaAttributes = @Html.Raw(JsonSerializer.Serialize(formulaAttributeSource.Select(attribute => new {
            attributeId = attribute.Id,
            attributeName = attribute.Name,
            attributeCode = attribute.Code,
            displayOrder = attribute.DisplayOrder,
            isInherited = attribute.IsInherited
        }).ToList()));

        var createForm = document.getElementById('variant-name-formula-create-form');
        var createTitle = document.getElementById('formula-create-title');
        var createCategoryField = document.getElementById('VariantNameFormulaForm_Create_CategoryId');
        var createFormulaIdField = document.getElementById('VariantNameFormulaForm_Create_FormulaId');
        var createNameField = document.getElementById('VariantNameFormulaForm_Create_Name');
        var createPartsJsonField = document.getElementById('VariantNameFormulaForm_Create_PartsJson');
        var createAttributePicker = document.getElementById('formula-create-attribute-picker');
        var createSeparatorField = document.getElementById('VariantNameFormulaForm_Create_Separator');
        var createIncludeCategoryNameField = document.getElementById('VariantNameFormulaForm_Create_IncludeCategoryName');
        var createAddPartBtn = document.getElementById('formula-create-add-part-btn');
        var createPartsList = document.getElementById('formula-create-parts-list');
        var createPartsEmpty = document.getElementById('formula-create-parts-empty');
        var createSubmitBtn = document.getElementById('formula-create-submit-btn');
        var createDefaultTitle = createTitle ? createTitle.textContent : '';
        var createDefaultSubmitLabel = createSubmitBtn ? createSubmitBtn.textContent : '';
        var createCreateActionUrl = createForm ? (createForm.getAttribute('data-create-action-url') || createForm.getAttribute('action') || '') : '';
        var createUpdateActionUrl = createForm ? (createForm.getAttribute('data-update-action-url') || createCreateActionUrl) : '';

        var listFilterForm = document.getElementById('formula-category-list-form');
        var listCategoryField = listFilterForm ? listFilterForm.querySelector('select[name="categoryId"]') : null;

        var inlinePanel = document.getElementById('formula-inline-edit-panel');
        var inlineForm = document.getElementById('variant-name-formula-form');
        var inlineTitle = document.getElementById('formula-form-title');
        var inlineCancelBtn = document.getElementById('formula-edit-cancel');
        var inlineSubmitBtn = document.getElementById('formula-submit-btn');
        var inlineResetBtn = document.getElementById('formula-reset-btn');
        var inlineFormulaIdField = document.getElementById('VariantNameFormulaForm_Inline_FormulaId');
        var inlineCategoryField = document.getElementById('VariantNameFormulaForm_Inline_CategoryId');
        var inlineNameField = document.getElementById('VariantNameFormulaForm_Inline_Name');
        var inlineSeparatorField = document.getElementById('VariantNameFormulaForm_Inline_Separator');
        var inlineIncludeCategoryNameField = document.getElementById('VariantNameFormulaForm_Inline_IncludeCategoryName');
        var inlineDisplayOrderField = document.getElementById('VariantNameFormulaForm_Inline_DisplayOrder');
        var inlineIsActiveField = document.getElementById('VariantNameFormulaForm_Inline_IsActive');
        var inlinePartsJsonField = document.getElementById('VariantNameFormulaForm_Inline_PartsJson');
        var attributePicker = document.getElementById('formula-attribute-picker');
        var addPartBtn = document.getElementById('formula-add-part-btn');
        var partsList = document.getElementById('formula-parts-list');
        var partsEmpty = document.getElementById('formula-parts-empty');
        var listTabLink = document.querySelector('#formula-section-tabs .nav-link[href="#formula-section-list"]');

        var state = {
            parts: [],
            editingPartIndex: -1
        };
            var createState = {
                parts: [],
                editingPartIndex: -1,
                editingFormulaId: ''
            };
            var isFormulaEditorHydrating = false;

        function normalizeSeparatorValue(separator) {
            if (separator === '__none') {
                return '';
            }

            return separator == null ? ' ' : separator;
        }

        function getSeparatorValue(field) {
            if (!field) {
                return ' ';
            }

            var value = field.value;
            return normalizeSeparatorValue(value);
        }

        function setSeparatorValue(field, value) {
            if (!field) {
                return;
            }

            field.value = value === '' ? '__none' : (value || ' ');
            if (window.jQuery) {
                window.jQuery(field).val(field.value).trigger('change');
            }
        }

        function clonePart(part) {
            return {
                attributeId: part ? part.attributeId || '' : '',
                separator: part ? normalizeSeparatorValue(part.separator) : ' '
            };
        }

        function serializeParts(parts) {
            return (parts || []).map(function (part, index) {
                return {
                    attributeId: part.attributeId,
                    separator: normalizeSeparatorValue(part.separator),
                    sortOrder: index + 1
                };
            });
        }

        function getFormulaById(formulaId) {
            if (!formulaId) {
                return null;
            }

            var normalized = String(formulaId).toLowerCase();
            for (var i = 0; i < formulas.length; i += 1) {
                if (String(formulas[i].formulaId || '').toLowerCase() === normalized) {
                    return formulas[i];
                }
            }

            return null;
        }

        function getAttributeById(attributeId) {
            if (!attributeId) {
                return null;
            }

            var normalized = String(attributeId).toLowerCase();
            for (var i = 0; i < formulaAttributes.length; i += 1) {
                if (String(formulaAttributes[i].attributeId || '').toLowerCase() === normalized) {
                    return formulaAttributes[i];
                }
            }

            return null;
        }

        function getPickerValue() {
            if (!attributePicker) {
                return '';
            }

            if (window.jQuery) {
                var jqValue = window.jQuery(attributePicker).val();
                if (Array.isArray(jqValue)) {
                    return jqValue.length > 0 ? (jqValue[0] || '') : '';
                }
                if (jqValue) {
                    return jqValue;
                }
            }

            return attributePicker.value || '';
        }

        function setPickerValue(value) {
            if (!attributePicker) {
                return;
            }

            attributePicker.value = value || '';
            if (window.jQuery) {
                window.jQuery(attributePicker).val(value || '').trigger('change');
            }
        }

        function syncInlinePartsJson() {
            if (inlinePartsJsonField) {
                inlinePartsJsonField.value = JSON.stringify(serializeParts(state.parts));
            }
        }

        function updateInlineButtons() {
            if (inlineSubmitBtn) {
                inlineSubmitBtn.disabled = !inlineFormulaIdField || !inlineFormulaIdField.value;
            }

            if (addPartBtn) {
                addPartBtn.textContent = state.editingPartIndex >= 0 ? texts.replace : texts.add;
            }
        }

        function clearPartEditing() {
            state.editingPartIndex = -1;
            setPickerValue('');
            updateInlineButtons();
        }

        function getSeparatorLabel(separator) {
            if (separator === '') {
                return texts.separatorNone;
            }

            if (separator === ' ') {
                return texts.separatorSpace;
            }

            if (separator === '-') {
                return texts.separatorDash;
            }

            return separator;
        }

        function renderParts() {
            if (!partsList || !partsEmpty) {
                return;
            }

            partsList.innerHTML = '';

            if (!state.parts.length) {
                partsEmpty.style.display = '';
                partsEmpty.classList.remove('alert-warning');
                partsEmpty.classList.add('alert-light');
                partsEmpty.textContent = texts.empty;
                syncInlinePartsJson();
                updateInlineButtons();
                return;
            }

            partsEmpty.style.display = 'none';

            state.parts.forEach(function (part, index) {
                var attribute = getAttributeById(part.attributeId);
                var item = document.createElement('div');
                item.className = 'list-group-item';
                item.innerHTML = ''
                    + '<div class="d-flex justify-content-between align-items-center flex-wrap">'
                    + '<div class="pr-2 mb-2 mb-md-0">'
                    + '<div class="font-weight-bold">' + escapeHtml(attribute ? attribute.attributeName : part.attributeId) + '</div>'
                    + '<div class="small text-muted">'
                    + escapeHtml(attribute ? attribute.attributeCode : '')
                    + (attribute && attribute.isInherited ? escapeHtml(texts.inheritedSuffix) : '')
                    + '</div>'
                    + '<div class="small text-muted">'
                    + escapeHtml(getSeparatorLabel(part.separator))
                    + '</div>'
                    + '</div>'
                    + '<div class="btn-group btn-group-sm" role="group">'
                    + '<button type="button" class="btn btn-outline-secondary formula-part-action" data-formula-action="up" data-formula-index="' + index + '"' + (index === 0 ? ' disabled' : '') + '>&uarr;</button>'
                    + '<button type="button" class="btn btn-outline-secondary formula-part-action" data-formula-action="down" data-formula-index="' + index + '"' + (index === state.parts.length - 1 ? ' disabled' : '') + '>&darr;</button>'
                    + '<button type="button" class="btn btn-outline-secondary formula-part-action" data-formula-action="edit" data-formula-index="' + index + '">' + escapeHtml(texts.replace) + '</button>'
                    + '<button type="button" class="btn btn-outline-danger formula-part-action" data-formula-action="remove" data-formula-index="' + index + '">' + escapeHtml(texts.remove) + '</button>'
                    + '</div>'
                    + '</div>';
                partsList.appendChild(item);
            });

            syncInlinePartsJson();
            updateInlineButtons();
        }

        function openInlineEditor(formula) {
            if (!formula || !inlinePanel || !inlineForm) {
                return;
            }

            if (window.jQuery && listTabLink) {
                window.jQuery(listTabLink).tab('show');
            }

            inlinePanel.style.display = '';
            if (inlineTitle) {
                inlineTitle.textContent = texts.editTitle;
            }

            if (inlineFormulaIdField) {
                inlineFormulaIdField.value = formula.formulaId || '';
            }
            if (inlineCategoryField) {
                inlineCategoryField.value = formula.categoryId || (listCategoryField ? listCategoryField.value : '') || '@Model.SelectedCategoryId';
            }
            if (inlineNameField) {
                inlineNameField.value = formula.name || '';
            }
            if (inlineSeparatorField) {
                var firstSeparator = (formula.parts && formula.parts.length > 0 && formula.parts[0].separator != null)
                    ? formula.parts[0].separator
                    : formula.separator;
                setSeparatorValue(inlineSeparatorField, normalizeSeparatorValue(firstSeparator));
            }
            if (inlineIncludeCategoryNameField) {
                inlineIncludeCategoryNameField.checked = !!formula.includeCategoryName;
            }
            if (inlineDisplayOrderField) {
                inlineDisplayOrderField.value = formula.displayOrder != null ? formula.displayOrder : 0;
            }
            if (inlineIsActiveField) {
                inlineIsActiveField.checked = !!formula.isActive;
            }

            state.parts = (formula.parts || []).map(function (part) {
                return clonePart(part);
            });

            clearPartEditing();
            renderParts();
            inlinePanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function closeInlineEditor() {
            if (!inlineForm || !inlinePanel) {
                return;
            }

            inlineForm.reset();
            if (inlineFormulaIdField) {
                inlineFormulaIdField.value = '';
            }
            if (inlineCategoryField) {
                inlineCategoryField.value = (listCategoryField ? listCategoryField.value : '') || '@Model.SelectedCategoryId';
            }
            if (inlinePartsJsonField) {
                inlinePartsJsonField.value = '[]';
            }

            state.parts = [];
            clearPartEditing();
            renderParts();
            inlinePanel.style.display = 'none';
        }

        function setCreateEditorMode(isEditMode) {
            if (createTitle) {
                createTitle.textContent = isEditMode ? texts.editTitle : createDefaultTitle;
            }

            if (createSubmitBtn) {
                createSubmitBtn.textContent = isEditMode ? texts.update : createDefaultSubmitLabel;
            }

            if (createForm) {
                createForm.setAttribute('action', isEditMode ? createUpdateActionUrl : createCreateActionUrl);
            }
        }

        function openCreateEditor(formula) {
            if (!formula || !createForm) {
                return;
            }

            isFormulaEditorHydrating = true;
            var createTab = document.querySelector('#formula-section-tabs .nav-link[href="#formula-section-create"]');
            if (window.jQuery && createTab) {
                window.jQuery(createTab).tab('show');
            }

            createState.editingFormulaId = formula.formulaId || '';
            if (createFormulaIdField) {
                createFormulaIdField.value = formula.formulaId || '';
            }
            if (createNameField) {
                createNameField.value = formula.name || '';
            }
            if (createCategoryField) {
                createCategoryField.value = formula.categoryId || (listCategoryField ? listCategoryField.value : '') || '@Model.SelectedCategoryId';
                if (window.jQuery) {
                    window.jQuery(createCategoryField).val(createCategoryField.value || '').trigger('change');
                }
            }
            if (createSeparatorField) {
                var firstSeparator = (formula.parts && formula.parts.length > 0 && formula.parts[0].separator != null)
                    ? formula.parts[0].separator
                    : formula.separator;
                setSeparatorValue(createSeparatorField, normalizeSeparatorValue(firstSeparator));
            }
            if (createIncludeCategoryNameField) {
                createIncludeCategoryNameField.checked = !!formula.includeCategoryName;
            }

            createState.parts = (formula.parts || []).map(function (part) {
                return clonePart(part);
            });
            createState.editingPartIndex = -1;
            setCreateEditorMode(true);
            clearCreatePartEditing();
            renderCreateParts();
            isFormulaEditorHydrating = false;
            createForm.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function resetCreateEditor() {
            createState.editingFormulaId = '';
            if (createFormulaIdField) {
                createFormulaIdField.value = '';
            }
            if (createNameField) {
                createNameField.value = '';
            }
            if (createSeparatorField) {
                setSeparatorValue(createSeparatorField, ' ');
            }
            if (createIncludeCategoryNameField) {
                createIncludeCategoryNameField.checked = true;
            }
            if (createPartsJsonField) {
                createPartsJsonField.value = '[]';
            }
            createState.parts = [];
            createState.editingPartIndex = -1;
            clearCreatePartEditing();
            renderCreateParts();
            setCreateEditorMode(false);
        }

        function addOrReplacePart() {
            var attributeId = getPickerValue();
            if (!attributeId) {
                return;
            }
            var separator = getSeparatorValue(inlineSeparatorField);

            var normalized = String(attributeId).toLowerCase();
            var existingIndex = state.parts.findIndex(function (part) {
                return String(part.attributeId || '').toLowerCase() === normalized;
            });

            if (state.editingPartIndex >= 0) {
                if (existingIndex >= 0 && existingIndex !== state.editingPartIndex) {
                    return;
                }
                state.parts[state.editingPartIndex] = {
                    attributeId: attributeId,
                    separator: separator
                };
            } else {
                if (existingIndex >= 0) {
                    return;
                }
                state.parts.push({
                    attributeId: attributeId,
                    separator: separator
                });
            }

            clearPartEditing();
            renderParts();
        }

        function removePart(index) {
            if (index < 0 || index >= state.parts.length) {
                return;
            }

            state.parts.splice(index, 1);
            if (state.editingPartIndex === index) {
                clearPartEditing();
            } else if (state.editingPartIndex > index) {
                state.editingPartIndex -= 1;
            }
            renderParts();
        }

        function movePart(index, delta) {
            var nextIndex = index + delta;
            if (index < 0 || nextIndex < 0 || nextIndex >= state.parts.length) {
                return;
            }

            var temp = state.parts[index];
            state.parts[index] = state.parts[nextIndex];
            state.parts[nextIndex] = temp;

            if (state.editingPartIndex === index) {
                state.editingPartIndex = nextIndex;
            } else if (state.editingPartIndex === nextIndex) {
                state.editingPartIndex = index;
            }

            renderParts();
        }

        function startPartEdit(index) {
            if (index < 0 || index >= state.parts.length) {
                return;
            }

            state.editingPartIndex = index;
            setPickerValue(state.parts[index].attributeId);
            setSeparatorValue(inlineSeparatorField, normalizeSeparatorValue(state.parts[index].separator));
            updateInlineButtons();
            if (attributePicker) {
                attributePicker.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }

        function syncCreateParts() {
            if (createPartsJsonField) {
                createPartsJsonField.value = JSON.stringify(serializeParts(createState.parts));
            }
        }

        function getCreatePickerValue() {
            if (!createAttributePicker) {
                return '';
            }

            if (window.jQuery) {
                var jqValue = window.jQuery(createAttributePicker).val();
                if (Array.isArray(jqValue)) {
                    return jqValue.length > 0 ? (jqValue[0] || '') : '';
                }
                if (jqValue) {
                    return jqValue;
                }
            }

            return createAttributePicker.value || '';
        }

        function setCreatePickerValue(value) {
            if (!createAttributePicker) {
                return;
            }

            createAttributePicker.value = value || '';
            if (window.jQuery) {
                window.jQuery(createAttributePicker).val(value || '').trigger('change');
            }
        }

        function updateCreateButtons() {
            if (createAddPartBtn) {
                createAddPartBtn.textContent = createState.editingPartIndex >= 0 ? texts.replace : texts.add;
            }
        }

        function clearCreatePartEditing() {
            createState.editingPartIndex = -1;
            setCreatePickerValue('');
            updateCreateButtons();
        }

        function renderCreateParts() {
            if (!createPartsList || !createPartsEmpty) {
                syncCreateParts();
                return;
            }

            createPartsList.innerHTML = '';

            if (!createState.parts.length) {
                createPartsEmpty.style.display = '';
                createPartsEmpty.classList.remove('alert-warning');
                createPartsEmpty.classList.add('alert-light');
                createPartsEmpty.textContent = texts.empty;
                syncCreateParts();
                updateCreateButtons();
                return;
            }

            createPartsEmpty.style.display = 'none';

            createState.parts.forEach(function (part, index) {
                var attribute = getAttributeById(part.attributeId);
                var item = document.createElement('div');
                item.className = 'list-group-item';
                item.innerHTML = ''
                    + '<div class="d-flex justify-content-between align-items-center flex-wrap">'
                    + '<div class="pr-2 mb-2 mb-md-0">'
                    + '<div class="font-weight-bold">' + escapeHtml(attribute ? attribute.attributeName : part.attributeId) + '</div>'
                    + '<div class="small text-muted">'
                    + escapeHtml(attribute ? attribute.attributeCode : '')
                    + (attribute && attribute.isInherited ? escapeHtml(texts.inheritedSuffix) : '')
                    + '</div>'
                    + '<div class="small text-muted">'
                    + escapeHtml(getSeparatorLabel(part.separator))
                    + '</div>'
                    + '</div>'
                    + '<div class="btn-group btn-group-sm" role="group">'
                    + '<button type="button" class="btn btn-outline-secondary formula-create-part-action" data-formula-action="up" data-formula-index="' + index + '"' + (index === 0 ? ' disabled' : '') + '>&uarr;</button>'
                    + '<button type="button" class="btn btn-outline-secondary formula-create-part-action" data-formula-action="down" data-formula-index="' + index + '"' + (index === createState.parts.length - 1 ? ' disabled' : '') + '>&darr;</button>'
                    + '<button type="button" class="btn btn-outline-secondary formula-create-part-action" data-formula-action="edit" data-formula-index="' + index + '">' + escapeHtml(texts.replace) + '</button>'
                    + '<button type="button" class="btn btn-outline-danger formula-create-part-action" data-formula-action="remove" data-formula-index="' + index + '">' + escapeHtml(texts.remove) + '</button>'
                    + '</div>'
                    + '</div>';
                createPartsList.appendChild(item);
            });

            syncCreateParts();
            updateCreateButtons();
        }

        function addOrReplaceCreatePart() {
            var attributeId = getCreatePickerValue();
            if (!attributeId) {
                return;
            }
            var separator = getSeparatorValue(createSeparatorField);

            var normalized = String(attributeId).toLowerCase();
            var existingIndex = createState.parts.findIndex(function (part) {
                return String(part.attributeId || '').toLowerCase() === normalized;
            });

            if (createState.editingPartIndex >= 0) {
                if (existingIndex >= 0 && existingIndex !== createState.editingPartIndex) {
                    return;
                }
                createState.parts[createState.editingPartIndex] = {
                    attributeId: attributeId,
                    separator: separator
                };
            } else {
                if (existingIndex >= 0) {
                    return;
                }
                createState.parts.push({
                    attributeId: attributeId,
                    separator: separator
                });
            }

            clearCreatePartEditing();
            renderCreateParts();
        }

        function moveCreatePart(index, delta) {
            var nextIndex = index + delta;
            if (index < 0 || nextIndex < 0 || nextIndex >= createState.parts.length) {
                return;
            }

            var temp = createState.parts[index];
            createState.parts[index] = createState.parts[nextIndex];
            createState.parts[nextIndex] = temp;

            if (createState.editingPartIndex === index) {
                createState.editingPartIndex = nextIndex;
            } else if (createState.editingPartIndex === nextIndex) {
                createState.editingPartIndex = index;
            }

            renderCreateParts();
        }

        function startCreatePartEdit(index) {
            if (index < 0 || index >= createState.parts.length) {
                return;
            }

            createState.editingPartIndex = index;
            setCreatePickerValue(createState.parts[index].attributeId);
            setSeparatorValue(createSeparatorField, normalizeSeparatorValue(createState.parts[index].separator));
            updateCreateButtons();
            if (createAttributePicker) {
                createAttributePicker.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }

        function removeCreatePart(index) {
            if (index < 0 || index >= createState.parts.length) {
                return;
            }

            createState.parts.splice(index, 1);
            if (createState.editingPartIndex === index) {
                clearCreatePartEditing();
            } else if (createState.editingPartIndex > index) {
                createState.editingPartIndex -= 1;
            }
            renderCreateParts();
        }

        function syncCategorySelections(sourceValue) {
            if (isFormulaEditorHydrating) {
                return;
            }

            if (createCategoryField && sourceValue && createCategoryField.value !== sourceValue) {
                createCategoryField.value = sourceValue;
                if (window.jQuery) {
                    window.jQuery(createCategoryField).val(sourceValue).trigger('change');
                }
            }

            if (listCategoryField && sourceValue && listCategoryField.value !== sourceValue) {
                listCategoryField.value = sourceValue;
                if (window.jQuery) {
                    window.jQuery(listCategoryField).val(sourceValue).trigger('change');
                }
            }

            if (inlineCategoryField && !inlineFormulaIdField.value) {
                inlineCategoryField.value = sourceValue || '@Model.SelectedCategoryId';
            }
        }

        initSearchableSelects(document);
        syncCreateParts();
        renderCreateParts();
        renderParts();
        updateInlineButtons();

        if (createForm) {
            createForm.addEventListener('submit', syncCreateParts);
        }

        if (createAddPartBtn) {
            createAddPartBtn.addEventListener('click', addOrReplaceCreatePart);
        }

        if (listFilterForm) {
            listFilterForm.addEventListener('submit', function () {
                closeInlineEditor();
            });
        }

        if (createCategoryField) {
            createCategoryField.addEventListener('change', function () {
                syncCategorySelections(createCategoryField.value || '');
            });
            if (window.jQuery) {
                window.jQuery(createCategoryField).on('select2:select select2:clear', function () {
                    syncCategorySelections(window.jQuery(createCategoryField).val() || '');
                });
            }
        }

        if (listCategoryField) {
            listCategoryField.addEventListener('change', function () {
                if (!inlineFormulaIdField.value) {
                    inlineCategoryField.value = listCategoryField.value || '@Model.SelectedCategoryId';
                }
            });
        }

        if (addPartBtn) {
            addPartBtn.addEventListener('click', addOrReplacePart);
        }

        if (inlineResetBtn) {
            inlineResetBtn.addEventListener('click', clearPartEditing);
        }

        if (inlineCancelBtn) {
            inlineCancelBtn.addEventListener('click', closeInlineEditor);
        }

        document.addEventListener('click', function (event) {
            var formulaEditButton = event.target.closest('.formula-edit-btn');
            if (formulaEditButton) {
                var formulaToEdit = getFormulaById(formulaEditButton.getAttribute('data-formula-id') || '');
                if (formulaToEdit) {
                    openCreateEditor(formulaToEdit);
                }
                return;
            }

            var formulaPartManageButton = event.target.closest('.formula-part-manage-btn');
            if (formulaPartManageButton) {
                var hostFormula = getFormulaById(formulaPartManageButton.getAttribute('data-formula-id') || '');
                var hostPartIndex = parseInt(formulaPartManageButton.getAttribute('data-formula-part-index') || '-1', 10);
                if (hostFormula) {
                    openInlineEditor(hostFormula);
                    startPartEdit(hostPartIndex);
                }
                return;
            }

            var formulaPartRemoveButton = event.target.closest('.formula-part-remove-btn');
            if (formulaPartRemoveButton) {
                var removeFormula = getFormulaById(formulaPartRemoveButton.getAttribute('data-formula-id') || '');
                var removePartIndex = parseInt(formulaPartRemoveButton.getAttribute('data-formula-part-index') || '-1', 10);
                if (removeFormula) {
                    openInlineEditor(removeFormula);
                    removePart(removePartIndex);
                }
                return;
            }

            var partActionButton = event.target.closest('.formula-part-action');
            if (partActionButton) {
                var action = partActionButton.getAttribute('data-formula-action') || '';
                var index = parseInt(partActionButton.getAttribute('data-formula-index') || '-1', 10);

                if (action === 'up') {
                    movePart(index, -1);
                } else if (action === 'down') {
                    movePart(index, 1);
                } else if (action === 'edit') {
                    startPartEdit(index);
                } else if (action === 'remove') {
                    removePart(index);
                }
                return;
            }

            var createPartActionButton = event.target.closest('.formula-create-part-action');
            if (!createPartActionButton) {
                return;
            }

            var createAction = createPartActionButton.getAttribute('data-formula-action') || '';
            var createIndex = parseInt(createPartActionButton.getAttribute('data-formula-index') || '-1', 10);

            if (createAction === 'up') {
                moveCreatePart(createIndex, -1);
            } else if (createAction === 'down') {
                moveCreatePart(createIndex, 1);
            } else if (createAction === 'edit') {
                startCreatePartEdit(createIndex);
            } else if (createAction === 'remove') {
                removeCreatePart(createIndex);
            }
        }, true);

        if (inlineForm) {
            inlineForm.addEventListener('submit', function () {
                syncInlinePartsJson();
            });
        }
    })();
</script>
