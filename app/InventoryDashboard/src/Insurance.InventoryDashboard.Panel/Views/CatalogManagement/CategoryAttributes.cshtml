@model Insurance.InventoryDashboard.Panel.Models.CategoryManagementPageViewModel
@{
    ViewData["Title"] = UiText["catalog.categories.title"];
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;
}

@await Html.PartialAsync(
    "~/Views/CatalogManagement/_CategoryPageShell.cshtml",
    Model,
    new ViewDataDictionary(ViewData)
    {
        ["SectionPartial"] = "~/Views/CatalogManagement/_CategoryRulesSection.cshtml"
    })

@section Scripts {
    @await Html.PartialAsync("~/Views/CatalogManagement/_CategoryRulesScripts.cshtml", Model)
}
