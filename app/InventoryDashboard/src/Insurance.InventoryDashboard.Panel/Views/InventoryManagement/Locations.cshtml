@using System
@using System.Linq
@using System.Text.Json
@model Insurance.InventoryDashboard.Panel.Models.WarehouseManagementPageViewModel
@{
    ViewData["Title"] = "لوکیشن‌ها";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x => string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) || string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));
    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    var isLocationEditMode = !string.IsNullOrWhiteSpace(Model.LocationForm.LocationId);
    var activeTab = string.Equals(Model.LocationTab, "create", StringComparison.OrdinalIgnoreCase) || isLocationEditMode ? "create" : "list";
    var selectedWarehouseName = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, Model.SelectedWarehouseId, StringComparison.OrdinalIgnoreCase))?.Name;
    var locationTypeOptions = new[] { "Bulk", "Pick", "Return", "Damage", "Quarantine" };
    var locationListUrl = Url.Action("LocationList", "InventoryManagement") ?? string.Empty;
    var warehouseStructuresUrl = Url.Action("WarehouseStructures", "InventoryManagement") ?? string.Empty;
    var warehouseLabelMap = Model.WarehouseLookup
        .OrderBy(x => x.Code)
        .ToDictionary(x => x.WarehouseBusinessKey, x => $"{x.Code} - {x.Name}", StringComparer.OrdinalIgnoreCase);
    var canEditLocation = Can("Inventory.Location.Update", "Location.Update");
    var canActivateLocation = Can("Inventory.Location.Activate", "Location.Activate");
    var canDeactivateLocation = Can("Inventory.Location.Deactivate", "Location.Deactivate");
    var canDeleteLocation = Can("Inventory.Location.Delete", "Location.Delete");

    string WarehouseName(string? warehouseId)
    {
        if (string.IsNullOrWhiteSpace(warehouseId))
        {
            return "-";
        }

        var warehouse = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, warehouseId, StringComparison.OrdinalIgnoreCase));
        return warehouse is null ? warehouseId : $"{warehouse.Code} - {warehouse.Name}";
    }
}

<main id="inventory-management-root" class="catalog-page">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="mb-4 d-flex justify-content-between align-items-start flex-wrap">
                    <div>
                        <h1>لوکیشن‌ها</h1>
                        <p class="text-muted">@UiText["inventory.warehouses.description"]</p>
                        <div>
                            <span class="badge badge-pill badge-outline-primary mb-1">@UiText["inventory.warehouses.summary.filteredLocationCount"] <span data-location-total-count>@Model.LocationTotalCount</span></span>
                            @if (!string.IsNullOrWhiteSpace(selectedWarehouseName))
                            {
                                <span class="badge badge-pill badge-outline-secondary mb-1" data-location-selected-warehouse data-location-selected-prefix="@UiText["inventory.warehouses.summary.selectedWarehouse"]">@UiText["inventory.warehouses.summary.selectedWarehouse"] @selectedWarehouseName</span>
                            }
                        </div>
                    </div>
                    <div>
                        <a asp-action="Warehouses" class="btn btn-outline-secondary">صفحه انبارها</a>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-warning">@Model.ErrorMessage</div>
                }
                @if (TempData.ContainsKey("CatalogError"))
                {
                    <div class="alert alert-danger">@TempData["CatalogError"]</div>
                }
                @if (TempData.ContainsKey("CatalogSuccess"))
                {
                    <div class="alert alert-success">@TempData["CatalogSuccess"]</div>
                }
            </div>
        </div>

        <div class="row">
            <div class="col-12 mb-4">
                <ul class="nav nav-tabs separator-tabs ml-0 mb-4" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link @(activeTab == "create" ? "active" : null)" data-toggle="tab" href="#location-tab-create" role="tab">تولید</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(activeTab == "list" ? "active" : null)" data-toggle="tab" href="#location-tab-list" role="tab">لیست</a>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade @(activeTab == "create" ? "show active" : null)" id="location-tab-create" role="tabpanel">
                        <div class="card mb-4">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="card-title mb-0">@(isLocationEditMode ? UiText["inventory.warehouses.editLocation"] : UiText["inventory.warehouses.createLocationTitle"])</h5>
                                    @if (!string.IsNullOrWhiteSpace(Model.SelectedWarehouseId))
                                    {
                                        <a asp-action="Locations" asp-route-warehouseId="@Model.SelectedWarehouseId" asp-route-tab="create" class="btn btn-outline-secondary btn-xs">جدید</a>
                                    }
                                </div>
                                <form asp-action="SaveLocation" method="post" data-loading-form data-dirty-watch data-ajax-target="#inventory-management-root">
                                    @Html.AntiForgeryToken()
                                    <input asp-for="LocationForm.LocationId" type="hidden" />
                                    <div asp-validation-summary="All" class="text-danger small mb-2"></div>
                                    <div class="form-group">
                                        <label>@UiText["inventory.warehouses.warehouse"]</label>
                                        <select asp-for="LocationForm.WarehouseId"
                                                class="form-control js-search-select"
                                                data-placeholder="@UiText["inventory.warehouses.selectWarehouse"]"
                                                data-warehouse-structure-select
                                                required>
                                            <option value="">@UiText["inventory.warehouses.selectWarehouse"]</option>
                                            @foreach (var warehouse in Model.WarehouseLookup.OrderBy(x => x.Code))
                                            {
                                                <option value="@warehouse.WarehouseBusinessKey">@warehouse.Code - @warehouse.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label>@UiText["inventory.warehouses.locationCode"]</label>
                                        <input asp-for="LocationForm.LocationCode" class="form-control text-monospace" required maxlength="80" placeholder="@UiText["inventory.warehouses.exampleLocation"]" />
                                    </div>
                                    <div class="form-group">
                                        <label>@UiText["inventory.warehouses.locationType"]</label>
                                        <select asp-for="LocationForm.LocationType" class="form-control js-search-select" data-no-search="true">
                                            <option value="Bulk">Bulk</option>
                                            <option value="Pick">Pick</option>
                                            <option value="Return">Return</option>
                                            <option value="Damage">Damage</option>
                                            <option value="Quarantine">Quarantine</option>
                                        </select>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group col-md-3">
                                            <label>@UiText["inventory.warehouses.aisle"]</label>
                                            <input asp-for="LocationForm.Aisle" class="form-control" maxlength="40" />
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label>@UiText["inventory.warehouses.rack"]</label>
                                            <input asp-for="LocationForm.Rack" class="form-control" maxlength="40" />
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label>@UiText["inventory.warehouses.shelf"]</label>
                                            <input asp-for="LocationForm.Shelf" class="form-control" maxlength="40" />
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label>@UiText["inventory.warehouses.bin"]</label>
                                            <input asp-for="LocationForm.Bin" class="form-control" maxlength="40" />
                                        </div>
                                    </div>
                                    @if (isLocationEditMode)
                                    {
                                        <div class="custom-control custom-checkbox mt-2">
                                            <input asp-for="LocationForm.IsActive" class="custom-control-input" />
                                            <label class="custom-control-label" asp-for="LocationForm.IsActive">@UiText["inventory.warehouses.locationActiveToggle"]</label>
                                        </div>
                                    }
                                    <button class="btn btn-primary mt-3" type="submit" @(Can("Inventory.Location.Create", "Inventory.Location.Update", "Location.Create", "Location.Update") ? null : "disabled")>
                                        @(isLocationEditMode ? UiText["inventory.warehouses.updateLocation"] : UiText["inventory.warehouses.createLocationTitle"])
                                    </button>
                                </form>

                                <div class="border-top mt-4 pt-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div>
                                            <h5 class="card-title mb-0">ساختار انبار</h5>
                                            <div class="text-muted small">درخت ساختار انتخاب‌شده اینجا لود می‌شود و بعد از تغییر انبار به‌روز می‌شود.</div>
                                        </div>
                                        <button type="button" class="btn btn-outline-secondary btn-xs" data-warehouse-structure-refresh>رفرش</button>
                                    </div>
                                    <div id="warehouse-structure-panel" class="p-0">
                                        @if (string.IsNullOrWhiteSpace(Model.SelectedWarehouseId))
                                        {
                                            <div class="alert alert-light mb-0">ابتدا یک انبار انتخاب کنید تا ساختار آن نمایش داده شود.</div>
                                        }
                                        else
                                        {
                                            <div class="text-muted">در حال بارگذاری...</div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade @(activeTab == "list" ? "show active" : null)" id="location-tab-list" role="tabpanel">
                        <div class="card mb-4">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="card-title mb-0">لیست لوکیشن‌ها</h5>
                                    <span class="text-muted small"><span data-location-total-count>@Model.LocationTotalCount</span> رکورد</span>
                                </div>

                        @if (string.IsNullOrWhiteSpace(Model.SelectedWarehouseId))
                        {
                            <div class="alert alert-info" data-location-warehouse-empty-state>
                                ابتدا یک انبار انتخاب کنید تا لیست لوکیشن‌های همان انبار نمایش داده شود.
                            </div>
                        }

                                <div class="mb-3" data-location-list-alert hidden></div>

                                <form asp-action="LocationList" method="get" class="form-row mb-3" data-location-list-form data-location-list-url="@locationListUrl">
                                    <input type="hidden" name="tab" value="list" />
                                    <input type="hidden" name="locationPage" value="@Model.LocationPage" data-location-page-input />
                                    <div class="form-group col-md-3">
                                        <label>انبار</label>
                                        <select name="warehouseId" class="form-control js-search-select" data-location-warehouse-select>
                                            <option value="">همه انبارها</option>
                                            @foreach (var warehouse in Model.WarehouseLookup.OrderBy(x => x.Code))
                                            {
                                                if (warehouse.WarehouseBusinessKey == Model.SelectedWarehouseId)
                                                {
                                                    <option value="@warehouse.WarehouseBusinessKey" selected="selected">@warehouse.Code - @warehouse.Name</option>
                                                }
                                                else
                                                {
                                                    <option value="@warehouse.WarehouseBusinessKey">@warehouse.Code - @warehouse.Name</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group col-md-2">
                                        <label>کد لوکیشن</label>
                                        <input name="locationCode" value="@Model.LocationCodeFilter" class="form-control" />
                                    </div>
                                    <div class="form-group col-md-2">
                                        <label>نوع</label>
                                        <select name="locationTypes" class="form-control js-search-select" multiple data-placeholder="انتخاب چند نوع">
                                            @foreach (var locationType in locationTypeOptions)
                                            {
                                                if (Model.LocationTypesFilter.Any(x => string.Equals(x, locationType, StringComparison.OrdinalIgnoreCase)))
                                                {
                                                    <option value="@locationType" selected="selected">@locationType</option>
                                                }
                                                else
                                                {
                                                    <option value="@locationType">@locationType</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group col-md-2">
                                        <label>راهرو</label>
                                        <input name="locationAisle" value="@Model.LocationAisleFilter" class="form-control" />
                                    </div>
                                    <div class="form-group col-md-2">
                                        <label>رک</label>
                                        <input name="locationRack" value="@Model.LocationRackFilter" class="form-control" />
                                    </div>
                                    <div class="form-group col-md-2">
                                        <label>طبقه</label>
                                        <input name="locationShelf" value="@Model.LocationShelfFilter" class="form-control" />
                                    </div>
                                    <div class="form-group col-md-2">
                                        <label>باکس</label>
                                        <input name="locationBin" value="@Model.LocationBinFilter" class="form-control" />
                                    </div>
                                    <div class="form-group col-md-2">
                                        <label>وضعیت</label>
                                        <select name="locationStatus" class="form-control">
                                            <option value="">همه</option>
                                            @if (Model.LocationStatusFilter == "active")
                                            {
                                                <option value="active" selected="selected">فعال</option>
                                            }
                                            else
                                            {
                                                <option value="active">فعال</option>
                                            }
                                            @if (Model.LocationStatusFilter == "inactive")
                                            {
                                                <option value="inactive" selected="selected">غیرفعال</option>
                                            }
                                            else
                                            {
                                                <option value="inactive">غیرفعال</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group col-md-1">
                                        <label>تعداد</label>
                                        <select name="locationPageSize" class="form-control" data-location-page-size>
                                            @foreach (var size in Model.PageSizeOptions)
                                            {
                                                @if (Model.LocationPageSize == size)
                                                {
                                                    <option value="@size" selected="selected">@size</option>
                                                }
                                                else
                                                {
                                                    <option value="@size">@size</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group col-md-2 d-flex align-items-end">
                                        <button class="btn btn-outline-primary btn-block" type="submit">اعمال</button>
                                    </div>
                                </form>

                                <div class="table-responsive">
                                    <table class="table table-sm table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th>کد</th>
                                                <th>انبار</th>
                                                <th>نوع</th>
                                                <th>راهرو/رک/طبقه/باکس</th>
                                                <th>وضعیت</th>
                                                <th class="text-right">عملیات</th>
                                            </tr>
                                        </thead>
                                        <tbody data-location-list-body>
                                            @if (Model.Locations.Count == 0)
                                            {
                                                <tr>
                                                    <td colspan="6" class="text-center text-muted">لوکیشنی پیدا نشد.</td>
                                                </tr>
                                            }
                                            else
                                            {
                                                foreach (var location in Model.Locations)
                                                {
                                                    <tr>
                                                        <td><span class="text-monospace">@location.LocationCode</span></td>
                                                        <td>@WarehouseName(location.WarehouseRef)</td>
                                                        <td>@location.LocationType</td>
                                                        <td>@($"{location.Aisle ?? "-"} / {location.Rack ?? "-"} / {location.Shelf ?? "-"} / {location.Bin ?? "-"}")</td>
                                                        <td>
                                                            <span class="badge badge-pill @(location.IsActive ? "badge-primary" : "badge-secondary")">
                                                                @(location.IsActive ? "فعال" : "غیرفعال")
                                                            </span>
                                                        </td>
                                                        <td class="text-right">
                                                            <a class="btn btn-outline-primary btn-xs" asp-action="Locations" asp-route-warehouseId="@location.WarehouseRef" asp-route-locationId="@location.LocationBusinessKey" asp-route-locationTypes="@Model.LocationTypesFilter" asp-route-locationCode="@Model.LocationCodeFilter" asp-route-locationAisle="@Model.LocationAisleFilter" asp-route-locationRack="@Model.LocationRackFilter" asp-route-locationShelf="@Model.LocationShelfFilter" asp-route-locationBin="@Model.LocationBinFilter" asp-route-locationStatus="@Model.LocationStatusFilter" asp-route-tab="create">ویرایش</a>
                                                            <form asp-action="ActivateLocation" method="post" class="d-inline inventory-status-action" data-loading-form data-location-action-form>
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="warehouseId" value="@location.WarehouseRef" />
                                                                <input type="hidden" name="locationId" value="@location.LocationBusinessKey" />
                                                                <input type="hidden" name="locationCode" value="@Model.LocationCodeFilter" />
                                                                @foreach (var locationType in Model.LocationTypesFilter)
                                                                {
                                                                    <input type="hidden" name="locationTypes" value="@locationType" />
                                                                }
                                                                <input type="hidden" name="locationAisle" value="@Model.LocationAisleFilter" />
                                                                <input type="hidden" name="locationRack" value="@Model.LocationRackFilter" />
                                                                <input type="hidden" name="locationShelf" value="@Model.LocationShelfFilter" />
                                                                <input type="hidden" name="locationBin" value="@Model.LocationBinFilter" />
                                                                <input type="hidden" name="locationStatus" value="@Model.LocationStatusFilter" />
                                                                <button class="btn btn-outline-success btn-xs" type="submit" @(Can("Inventory.Location.Activate", "Location.Activate") ? null : "disabled")>فعال</button>
                                                            </form>
                                                            <form asp-action="DeactivateLocation" method="post" class="d-inline inventory-status-action" data-loading-form data-location-action-form>
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="warehouseId" value="@location.WarehouseRef" />
                                                                <input type="hidden" name="locationId" value="@location.LocationBusinessKey" />
                                                                <input type="hidden" name="locationCode" value="@Model.LocationCodeFilter" />
                                                                @foreach (var locationType in Model.LocationTypesFilter)
                                                                {
                                                                    <input type="hidden" name="locationTypes" value="@locationType" />
                                                                }
                                                                <input type="hidden" name="locationAisle" value="@Model.LocationAisleFilter" />
                                                                <input type="hidden" name="locationRack" value="@Model.LocationRackFilter" />
                                                                <input type="hidden" name="locationShelf" value="@Model.LocationShelfFilter" />
                                                                <input type="hidden" name="locationBin" value="@Model.LocationBinFilter" />
                                                                <input type="hidden" name="locationStatus" value="@Model.LocationStatusFilter" />
                                                                <button class="btn btn-outline-warning btn-xs" type="submit" @(Can("Inventory.Location.Deactivate", "Location.Deactivate") ? null : "disabled")>غیرفعال</button>
                                                            </form>
                                                            <form asp-action="DeleteLocation" method="post" class="d-inline" data-loading-form data-location-action-form>
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="warehouseId" value="@location.WarehouseRef" />
                                                                <input type="hidden" name="locationId" value="@location.LocationBusinessKey" />
                                                                <input type="hidden" name="locationCode" value="@Model.LocationCodeFilter" />
                                                                @foreach (var locationType in Model.LocationTypesFilter)
                                                                {
                                                                    <input type="hidden" name="locationTypes" value="@locationType" />
                                                                }
                                                                <input type="hidden" name="locationAisle" value="@Model.LocationAisleFilter" />
                                                                <input type="hidden" name="locationRack" value="@Model.LocationRackFilter" />
                                                                <input type="hidden" name="locationShelf" value="@Model.LocationShelfFilter" />
                                                                <input type="hidden" name="locationBin" value="@Model.LocationBinFilter" />
                                                                <input type="hidden" name="locationStatus" value="@Model.LocationStatusFilter" />
                                                                <button class="btn btn-outline-danger btn-xs" type="submit" data-confirm-title="حذف لوکیشن" data-confirm="این لوکیشن حذف شود؟" @(Can("Inventory.Location.Delete", "Location.Delete") ? null : "disabled")>حذف</button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>

                                <nav class="mt-3" data-location-pagination @(Model.LocationTotalPages > 1 ? null : "hidden")>
                                    @if (Model.LocationTotalPages > 1)
                                    {
                                        <ul class="pagination pagination-sm mb-0">
                                            @for (var i = 1; i <= Model.LocationTotalPages; i++)
                                            {
                                                <li class="page-item @(i == Model.LocationPage ? "active" : null)">
                                                    <a class="page-link"
                                                       asp-action="LocationList"
                                                       data-location-page-link
                                                       asp-route-warehouseId="@Model.SelectedWarehouseId"
                                                       asp-route-warehouseCode="@Model.WarehouseCodeFilter"
                                                       asp-route-warehouseName="@Model.WarehouseNameFilter"
                                                       asp-route-warehouseStatus="@Model.WarehouseStatusFilter"
                                                       asp-route-locationCode="@Model.LocationCodeFilter"
                                                       asp-route-locationTypes="@Model.LocationTypesFilter"
                                                       asp-route-locationAisle="@Model.LocationAisleFilter"
                                                       asp-route-locationRack="@Model.LocationRackFilter"
                                                       asp-route-locationShelf="@Model.LocationShelfFilter"
                                                       asp-route-locationBin="@Model.LocationBinFilter"
                                                       asp-route-locationStatus="@Model.LocationStatusFilter"
                                                       asp-route-tab="list"
                                                       asp-route-warehousePage="@Model.WarehousePage"
                                                       asp-route-warehousePageSize="@Model.WarehousePageSize"
                                                       asp-route-locationPage="@i"
                                                       asp-route-locationPageSize="@Model.LocationPageSize">@i</a>
                                                </li>
                                            }
                                        </ul>
                                    }
                                </nav>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        (function () {
            var locationsPageUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("Locations", "InventoryManagement") ?? string.Empty));
            var locationListUrl = @Html.Raw(JsonSerializer.Serialize(locationListUrl));
            var warehouseLabelMap = @Html.Raw(JsonSerializer.Serialize(warehouseLabelMap));
            var canEditLocation = @Html.Raw(JsonSerializer.Serialize(canEditLocation));
            var canActivateLocation = @Html.Raw(JsonSerializer.Serialize(canActivateLocation));
            var canDeactivateLocation = @Html.Raw(JsonSerializer.Serialize(canDeactivateLocation));
            var canDeleteLocation = @Html.Raw(JsonSerializer.Serialize(canDeleteLocation));
            var actionUrls = {
                activate: @Html.Raw(JsonSerializer.Serialize(Url.Action("ActivateLocation", "InventoryManagement") ?? string.Empty)),
                deactivate: @Html.Raw(JsonSerializer.Serialize(Url.Action("DeactivateLocation", "InventoryManagement") ?? string.Empty)),
                delete: @Html.Raw(JsonSerializer.Serialize(Url.Action("DeleteLocation", "InventoryManagement") ?? string.Empty))
            };

            var listForm = document.querySelector('[data-location-list-form]');
            var listBody = document.querySelector('[data-location-list-body]');
            var pagination = document.querySelector('[data-location-pagination]');
            var totalCountEl = document.querySelector('[data-location-total-count]');
            var selectedWarehouseBadge = document.querySelector('[data-location-selected-warehouse]');
            var emptyStateAlert = document.querySelector('[data-location-warehouse-empty-state]');
            var alertBox = document.querySelector('[data-location-list-alert]');
            var pageInput = document.querySelector('[data-location-page-input]');
            var structurePanel = document.getElementById('warehouse-structure-panel');
            var structureSelect = document.querySelector('[data-warehouse-structure-select]');
            var structureRefreshButton = document.querySelector('[data-warehouse-structure-refresh]');

            if (!listForm || !listBody || !pagination) {
                return;
            }

            function refreshStructureWidgets(root) {
                if (!window.appUi || !root) {
                    return;
                }

                if (typeof window.appUi.initSearchableSelects === 'function') {
                    window.appUi.initSearchableSelects(root);
                }

                if (typeof window.appUi.initAutoSubmit === 'function') {
                    window.appUi.initAutoSubmit(root);
                }
            }

            async function loadStructurePanel(url) {
                if (!url || !structurePanel) {
                    return;
                }

                structurePanel.innerHTML = '<div class="text-muted">در حال بارگذاری...</div>';

                var response = await fetch(url, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'text/html'
                    }
                });

                var html = await response.text();
                var doc = new DOMParser().parseFromString(html, 'text/html');
                var nextPanel = doc.querySelector('#warehouse-structure-panel');
                if (!nextPanel) {
                    throw new Error('بارگذاری ساختار انبار با خطا مواجه شد.');
                }

                structurePanel.innerHTML = nextPanel.innerHTML;
                refreshStructureWidgets(structurePanel);
            }

            function getSelectedStructureUrl() {
                var warehouseId = structureSelect ? structureSelect.value : '';
                if (!warehouseId) {
                    return '';
                }

                return @Html.Raw(JsonSerializer.Serialize(warehouseStructuresUrl)) + '?warehouseId=' + encodeURIComponent(warehouseId);
            }

            function refreshStructurePanel() {
                return loadStructurePanel(getSelectedStructureUrl());
            }

            function escapeHtml(value) {
                return String(value ?? '').replace(/[&<>"']/g, function (character) {
                    switch (character) {
                        case '&': return '&amp;';
                        case '<': return '&lt;';
                        case '>': return '&gt;';
                        case '"': return '&quot;';
                        case '\'': return '&#39;';
                        default: return character;
                    }
                });
            }

            function escapeAttr(value) {
                return escapeHtml(value).replace(/`/g, '&#96;');
            }

            function getWarehouseLabel(warehouseId) {
                if (!warehouseId) {
                    return '-';
                }

                return warehouseLabelMap[warehouseId] || warehouseId;
            }

            function getCurrentWarehouseId() {
                var select = listForm.querySelector('[data-location-warehouse-select]');
                return select ? select.value : '';
            }

            function getCurrentFilters() {
                var data = new FormData(listForm);
                data.set('tab', 'list');
                return data;
            }

            function setAlert(message, type) {
                if (!alertBox) {
                    return;
                }

                if (!message) {
                    alertBox.hidden = true;
                    alertBox.innerHTML = '';
                    return;
                }

                var alertType = type || 'info';
                alertBox.hidden = false;
                alertBox.innerHTML = '<div class="alert alert-' + alertType + ' mb-0">' + escapeHtml(message) + '</div>';
            }

            function buildEditUrl(item) {
                var url = new URL(locationsPageUrl, window.location.origin);
                var filters = getCurrentFilters();
                filters.forEach(function (value, key) {
                    if (key !== 'locationPage' && key !== 'locationId' && key !== 'tab') {
                        url.searchParams.append(key, value);
                    }
                });
                url.searchParams.set('warehouseId', item.warehouseRef || '');
                url.searchParams.set('locationId', item.locationBusinessKey || '');
                url.searchParams.set('tab', 'create');
                return url.pathname + url.search;
            }

            function buildActionButton(label, action, kind, item, extraClass, disabled) {
                var state = disabled ? ' disabled' : '';
                return '<button type="button" class="btn ' + extraClass + ' btn-xs" data-location-action-button data-location-action="' + action + '" data-location-id="' + escapeAttr(item.locationBusinessKey) + '" data-location-warehouse-id="' + escapeAttr(item.warehouseRef) + '"' + state + '>' + escapeHtml(label) + '</button>';
            }

            function renderRow(item) {
                var statusClass = item.isActive ? 'badge-primary' : 'badge-secondary';
                var statusText = item.isActive ? 'فعال' : 'غیرفعال';
                var editUrl = buildEditUrl(item);
                var actionButtons = [];

                if (canEditLocation) {
                    actionButtons.push('<a class="btn btn-outline-primary btn-xs" href="' + escapeAttr(editUrl) + '">ویرایش</a>');
                }
                if (canActivateLocation) {
                    actionButtons.push(buildActionButton('فعال', 'activate', 'success', item, 'btn-outline-success', false));
                }
                if (canDeactivateLocation) {
                    actionButtons.push(buildActionButton('غیرفعال', 'deactivate', 'warning', item, 'btn-outline-warning', false));
                }
                if (canDeleteLocation) {
                    actionButtons.push(buildActionButton('حذف', 'delete', 'danger', item, 'btn-outline-danger', false));
                }

                return '<tr>' +
                    '<td><span class="text-monospace">' + escapeHtml(item.locationCode || '-') + '</span></td>' +
                    '<td>' + escapeHtml(getWarehouseLabel(item.warehouseRef)) + '</td>' +
                    '<td>' + escapeHtml(item.locationType || '-') + '</td>' +
                    '<td>' + escapeHtml((item.aisle || '-') + ' / ' + (item.rack || '-') + ' / ' + (item.shelf || '-') + ' / ' + (item.bin || '-')) + '</td>' +
                    '<td><span class="badge badge-pill ' + statusClass + '">' + statusText + '</span></td>' +
                    '<td class="text-right">' + actionButtons.join(' ') + '</td>' +
                    '</tr>';
            }

            function renderRows(items) {
                if (!items || !items.length) {
                    return '<tr><td colspan="6" class="text-center text-muted">لوکیشنی پیدا نشد.</td></tr>';
                }

                return items.map(renderRow).join('');
            }

            function renderPagination(response) {
                var totalPages = response && response.totalPages ? response.totalPages : 1;
                var currentPage = response && response.page ? response.page : 1;

                if (totalPages <= 1) {
                    pagination.hidden = true;
                    pagination.innerHTML = '';
                    return;
                }

                var html = ['<ul class="pagination pagination-sm mb-0">'];
                for (var i = 1; i <= totalPages; i++) {
                    html.push('<li class="page-item' + (i === currentPage ? ' active' : '') + '">');
                    html.push('<a class="page-link" href="#" data-location-page-link data-location-page="' + i + '">' + i + '</a>');
                    html.push('</li>');
                }
                html.push('</ul>');
                pagination.innerHTML = html.join('');
                pagination.hidden = false;
            }

            function syncHeader(response) {
                if (totalCountEl) {
                    totalCountEl.textContent = response && response.totalCount != null ? response.totalCount : 0;
                }

                var selectedWarehouseId = response && response.selectedWarehouseId ? response.selectedWarehouseId : getCurrentWarehouseId();
                if (emptyStateAlert) {
                    emptyStateAlert.hidden = !!selectedWarehouseId;
                }
                if (selectedWarehouseBadge) {
                    var prefix = selectedWarehouseBadge.getAttribute('data-location-selected-prefix') || '';
                    var selectedWarehouseName = response && response.selectedWarehouseName ? response.selectedWarehouseName : getWarehouseLabel(selectedWarehouseId);

                    if (selectedWarehouseId && selectedWarehouseName && selectedWarehouseName !== selectedWarehouseId) {
                        selectedWarehouseBadge.hidden = false;
                        selectedWarehouseBadge.textContent = prefix + ' ' + selectedWarehouseName;
                    } else if (selectedWarehouseId) {
                        selectedWarehouseBadge.hidden = false;
                        selectedWarehouseBadge.textContent = prefix + ' ' + selectedWarehouseName;
                    } else {
                        selectedWarehouseBadge.hidden = true;
                    }
                }
            }

            async function loadLocationList(page) {
                var data = getCurrentFilters();
                data.set('locationPage', String(page || 1));

                if (pageInput) {
                    pageInput.value = String(page || 1);
                }

                setAlert('');
                var query = new URLSearchParams(data).toString();

                var response = await fetch(locationListUrl + '?' + query, {
                    method: 'GET',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    cache: 'no-store',
                });

                if (!response.ok) {
                    var errorPayload = null;
                    try {
                        errorPayload = await response.json();
                    } catch (error) {
                        errorPayload = null;
                    }

                    throw new Error((errorPayload && errorPayload.errorMessage) || 'خطا در بارگذاری لیست لوکیشن‌ها.');
                }

                var payload = await response.json();
                listBody.innerHTML = renderRows(payload.items || []);
                renderPagination(payload);
                syncHeader(payload);
            }

            async function submitLocationAction(url, warehouseId, locationId) {
                var token = document.querySelector('input[name="__RequestVerificationToken"]');
                var formData = new FormData();
                if (token) {
                    formData.append('__RequestVerificationToken', token.value);
                }
                formData.append('warehouseId', warehouseId || '');
                formData.append('locationId', locationId || '');

                var response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    body: formData
                });

                var payload = null;
                try {
                    payload = await response.json();
                } catch (error) {
                    payload = null;
                }

                if (!response.ok || !payload || payload.isSuccess === false) {
                    throw new Error((payload && payload.errorMessage) || 'عملیات با خطا مواجه شد.');
                }

                await loadLocationList(pageInput ? Number(pageInput.value || '1') : 1);
            }

            document.addEventListener('submit', function (event) {
                var form = event.target;
                if (!(form instanceof HTMLFormElement)) {
                    return;
                }

                if (form.matches('form[data-location-action-form]')) {
                    event.preventDefault();
                    var submitter = event.submitter || document.activeElement;
                    var confirmText = submitter && submitter.getAttribute ? submitter.getAttribute('data-confirm') : null;
                    if (confirmText && !window.confirm(confirmText)) {
                        return;
                    }

                    var actionUrl = form.getAttribute('action') || '';
                    var formData = new FormData(form);
                    fetch(actionUrl, {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'Accept': 'application/json'
                        },
                        body: formData
                    }).then(function (response) {
                        return response.json().then(function (payload) {
                            if (!response.ok || !payload || payload.isSuccess === false) {
                                throw new Error((payload && payload.errorMessage) || 'عملیات با خطا مواجه شد.');
                            }

                            return loadLocationList(pageInput ? Number(pageInput.value || '1') : 1);
                        });
                    }).catch(function (error) {
                        setAlert(error.message || 'عملیات با خطا مواجه شد.', 'danger');
                    });
                    return;
                }

                if (form !== listForm) {
                    return;
                }

                event.preventDefault();
                loadLocationList(1).catch(function (error) {
                    setAlert(error.message || 'خطا در بارگذاری لیست لوکیشن‌ها.', 'danger');
                });
            }, true);

            document.addEventListener('click', function (event) {
                var pageLink = event.target && event.target.closest ? event.target.closest('[data-location-page-link]') : null;
                if (pageLink) {
                    event.preventDefault();
                    var page = Number(pageLink.getAttribute('data-location-page') || '1');
                    loadLocationList(page).catch(function (error) {
                        setAlert(error.message || 'خطا در بارگذاری لیست لوکیشن‌ها.', 'danger');
                    });
                    return;
                }

                var actionButton = event.target && event.target.closest ? event.target.closest('[data-location-action-button]') : null;
                if (actionButton) {
                    event.preventDefault();
                    var action = actionButton.getAttribute('data-location-action') || '';
                    var warehouseId = actionButton.getAttribute('data-location-warehouse-id') || '';
                    var locationId = actionButton.getAttribute('data-location-id') || '';
                    var actionUrl = actionUrls[action];

                    if (!actionUrl) {
                        return;
                    }

                    submitLocationAction(actionUrl, warehouseId, locationId).catch(function (error) {
                        setAlert(error.message || 'عملیات با خطا مواجه شد.', 'danger');
                    });
                }
            }, true);

            if (structureSelect) {
                structureSelect.addEventListener('change', function () {
                    refreshStructurePanel().catch(function (error) {
                        if (structurePanel) {
                            structurePanel.innerHTML = '<div class="alert alert-danger mb-0">' + escapeHtml(error.message || 'بارگذاری ساختار انبار با خطا مواجه شد.') + '</div>';
                        }
                    });
                });
            }

            if (structureRefreshButton) {
                structureRefreshButton.addEventListener('click', function (event) {
                    event.preventDefault();
                    refreshStructurePanel().catch(function (error) {
                        if (structurePanel) {
                            structurePanel.innerHTML = '<div class="alert alert-danger mb-0">' + escapeHtml(error.message || 'بارگذاری ساختار انبار با خطا مواجه شد.') + '</div>';
                        }
                    });
                });
            }

            if (structurePanel && structureSelect && structureSelect.value) {
                refreshStructurePanel().catch(function () {
                    // Keep the initial placeholder if the first load fails.
                });
            }
        })();
    </script>
}
