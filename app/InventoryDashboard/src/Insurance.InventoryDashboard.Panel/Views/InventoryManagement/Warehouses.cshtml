@using System
@using System.Linq
@model Insurance.InventoryDashboard.Panel.Models.WarehouseManagementPageViewModel
@{
    ViewData["Title"] = UiText["inventory.warehouses.title"];
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x => string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) || string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));
    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    var isWarehouseEditMode = !string.IsNullOrWhiteSpace(Model.WarehouseForm.WarehouseId);
    var isLocationEditMode = !string.IsNullOrWhiteSpace(Model.LocationForm.LocationId);
    var activeSurface = Model.ActiveItem?.ItemId ?? "warehouses";
    var showLocations = string.Equals(activeSurface, "locations", StringComparison.OrdinalIgnoreCase);
    var showWarehouses = !showLocations;
    var selectedWarehouseName = Model.SelectedWarehouseDetails?.Name
        ?? Model.Warehouses.FirstOrDefault(x => x.WarehouseBusinessKey == Model.SelectedWarehouseId)?.Name;
    string WarehouseName(string? warehouseId)
    {
        if (string.IsNullOrWhiteSpace(warehouseId))
        {
            return "-";
        }

        var warehouse = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, warehouseId, StringComparison.OrdinalIgnoreCase));
        return warehouse is null ? warehouseId : $"{warehouse.Code} - {warehouse.Name}";
    }
}

<style>
    .inventory-section-tabs .nav-link {
        cursor: pointer;
    }

    .inventory-status-action {
        display: none !important;
    }
</style>

<main id="inventory-management-root" class="catalog-page">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="mb-4">
                    <h1>@UiText["inventory.warehouses.title"]</h1>
                    <p class="text-muted">@UiText["inventory.warehouses.description"]</p>
                    <div>
                        <span class="badge badge-pill badge-outline-primary mb-1">@UiText["inventory.warehouses.summary.warehouseCount"] @Model.WarehouseTotalCount</span>
                        <span class="badge badge-pill badge-outline-primary mb-1">@UiText["inventory.warehouses.summary.filteredLocationCount"] @Model.LocationTotalCount</span>
                        @if (!string.IsNullOrWhiteSpace(selectedWarehouseName))
                        {
                            <span class="badge badge-pill badge-outline-secondary mb-1">@UiText["inventory.warehouses.summary.selectedWarehouse"] @selectedWarehouseName</span>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-warning">@Model.ErrorMessage</div>
                }
                @if (TempData.ContainsKey("CatalogError"))
                {
                    <div class="alert alert-danger">@TempData["CatalogError"]</div>
                }
                @if (TempData.ContainsKey("CatalogSuccess"))
                {
                    <div class="alert alert-success">@TempData["CatalogSuccess"]</div>
                }
            </div>
        </div>

        <div class="row">
            <div class="col-12 mb-4">
                <ul class="nav nav-tabs separator-tabs ml-0 mb-4 d-none" role="tablist" id="warehouse-management-tabs">
                    <li class="nav-item">
                        <a class="nav-link @(showWarehouses ? "active" : null)" data-toggle="tab" href="#warehouse-tab-form" role="tab">@UiText["inventory.warehouses.tabs.warehouseForm"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(showLocations ? "active" : null)" data-toggle="tab" href="#warehouse-tab-location" role="tab">@UiText["inventory.warehouses.tabs.locationForm"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#warehouse-tab-details" role="tab">@UiText["inventory.warehouses.tabs.details"]</a>
                    </li>
                </ul>

                <div class="tab-content">
                    @if (showWarehouses)
                    {
                    <div class="tab-pane fade @(showWarehouses ? "show active" : null)" id="warehouse-tab-form" role="tabpanel">
                        <ul class="nav nav-tabs separator-tabs ml-0 mb-4 inventory-section-tabs" role="tablist" data-section-tabs>
                            <li class="nav-item">
                                <a class="nav-link active" data-section-target="#warehouse-section-create">@UiText["inventory.warehouses.createWarehouse"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" data-section-target="#warehouse-section-search">@UiText["inventory.warehouses.searchWarehouses"]</a>
                            </li>
                        </ul>
                        <div class="card mb-4 inventory-section-pane" id="warehouse-section-create">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="card-title mb-0">@(isWarehouseEditMode ? UiText["inventory.warehouses.editWarehouse"] : UiText["inventory.warehouses.createWarehouseTitle"])</h5>
                                    @if (isWarehouseEditMode)
                                    {
                                        <a asp-action="Warehouses" class="btn btn-outline-secondary btn-xs" data-ajax-target="#inventory-management-root">@UiText["common.createNew"]</a>
                                    }
                                </div>
                                <form asp-action="SaveWarehouse" method="post" data-loading-form data-dirty-watch data-ajax-target="#inventory-management-root">
                                    @Html.AntiForgeryToken()
                                    <input asp-for="WarehouseForm.WarehouseId" type="hidden" />
                                    <div asp-validation-summary="All" class="text-danger small mb-2"></div>
                                    <div class="form-group">
                                        <label>@UiText["inventory.warehouses.code"]</label>
                                        <input asp-for="WarehouseForm.Code" class="form-control text-monospace" required maxlength="50" placeholder="@UiText["inventory.warehouses.exampleMain"]" />
                                    </div>
                                    <div class="form-group">
                                        <label>@UiText["inventory.warehouses.name"]</label>
                                        <input asp-for="WarehouseForm.Name" class="form-control" required maxlength="160" />
                                    </div>
                                    @if (isWarehouseEditMode)
                                    {
                                        <div class="custom-control custom-checkbox mt-2">
                                            <input asp-for="WarehouseForm.IsActive" class="custom-control-input" />
                                        <label class="custom-control-label" asp-for="WarehouseForm.IsActive">@UiText["inventory.warehouses.activeToggle"]</label>
                                    </div>
                                    }
                                    <button class="btn btn-primary mt-3" type="submit" @(Can("Inventory.Warehouse.Create", "Inventory.Warehouse.Update", "Warehouse.Create", "Warehouse.Update") ? null : "disabled")>
                                        @(isWarehouseEditMode ? UiText["inventory.warehouses.updateWarehouse"] : UiText["inventory.warehouses.createWarehouseTitle"])
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    }

                    @if (showLocations)
                    {
                    <div class="tab-pane fade @(showLocations ? "show active" : null)" id="warehouse-tab-location" role="tabpanel">
                        <ul class="nav nav-tabs separator-tabs ml-0 mb-4 inventory-section-tabs" role="tablist" data-section-tabs>
                            <li class="nav-item">
                                <a class="nav-link active" data-section-target="#location-section-create">@UiText["inventory.warehouses.createLocation"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" data-section-target="#location-section-search">@UiText["inventory.warehouses.searchLocations"]</a>
                            </li>
                        </ul>
                        <div class="card mb-4 inventory-section-pane" id="location-section-create">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="card-title mb-0">@(isLocationEditMode ? UiText["inventory.warehouses.editLocation"] : UiText["inventory.warehouses.createLocationTitle"])</h5>
                                    @if (!string.IsNullOrWhiteSpace(Model.SelectedWarehouseId))
                                    {
                                        <a asp-action="Locations" asp-route-warehouseId="@Model.SelectedWarehouseId" class="btn btn-outline-secondary btn-xs" data-ajax-target="#inventory-management-root">@UiText["inventory.warehouses.createLocationNew"]</a>
                                    }
                                </div>
                                <form asp-action="SaveLocation" method="post" data-loading-form data-dirty-watch data-ajax-target="#inventory-management-root">
                                    @Html.AntiForgeryToken()
                                    <input asp-for="LocationForm.LocationId" type="hidden" />
                                    <div asp-validation-summary="All" class="text-danger small mb-2"></div>
                                    <div class="form-group">
                                        <label>@UiText["inventory.warehouses.warehouse"]</label>
                                        <select asp-for="LocationForm.WarehouseId" class="form-control js-search-select" data-placeholder="@UiText["inventory.warehouses.selectWarehouse"]" required>
                                            <option value="">@UiText["inventory.warehouses.selectWarehouse"]</option>
                                            @foreach (var warehouse in Model.WarehouseLookup.OrderBy(x => x.Code))
                                            {
                                                <option value="@warehouse.WarehouseBusinessKey">@warehouse.Code - @warehouse.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label>@UiText["inventory.warehouses.locationCode"]</label>
                                        <input asp-for="LocationForm.LocationCode" class="form-control text-monospace" required maxlength="80" placeholder="@UiText["inventory.warehouses.exampleLocation"]" />
                                    </div>
                                    <div class="form-group">
                                        <label>@UiText["inventory.warehouses.locationType"]</label>
                                        <select asp-for="LocationForm.LocationType" class="form-control js-search-select" data-no-search="true">
                                            <option value="Bulk">Bulk</option>
                                            <option value="Pick">Pick</option>
                                            <option value="Return">Return</option>
                                            <option value="Damage">Damage</option>
                                            <option value="Quarantine">Quarantine</option>
                                        </select>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group col-md-3">
                                            <label>@UiText["inventory.warehouses.aisle"]</label>
                                            <input asp-for="LocationForm.Aisle" class="form-control" maxlength="40" />
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label>@UiText["inventory.warehouses.rack"]</label>
                                            <input asp-for="LocationForm.Rack" class="form-control" maxlength="40" />
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label>@UiText["inventory.warehouses.shelf"]</label>
                                            <input asp-for="LocationForm.Shelf" class="form-control" maxlength="40" />
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label>@UiText["inventory.warehouses.bin"]</label>
                                            <input asp-for="LocationForm.Bin" class="form-control" maxlength="40" />
                                        </div>
                                    </div>
                                    @if (isLocationEditMode)
                                    {
                                        <div class="custom-control custom-checkbox mt-2">
                                            <input asp-for="LocationForm.IsActive" class="custom-control-input" />
                                        <label class="custom-control-label" asp-for="LocationForm.IsActive">@UiText["inventory.warehouses.locationActiveToggle"]</label>
                                    </div>
                                    }
                                    <button class="btn btn-primary mt-3" type="submit" @(Can("Inventory.Location.Create", "Inventory.Location.Update", "Location.Create", "Location.Update") ? null : "disabled")>
                                        @(isLocationEditMode ? UiText["inventory.warehouses.updateLocation"] : UiText["inventory.warehouses.createLocationTitle"])
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    }

                    @if (showWarehouses)
                    {
                    <div class="tab-pane fade" id="warehouse-tab-details" role="tabpanel">
                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title">@UiText["inventory.warehouses.detailsTitle"]</h5>
                                @if (Model.SelectedWarehouseDetails is null)
                                {
                                    <div class="alert alert-light mb-0">@UiText["inventory.warehouses.noWarehouseSelected"]</div>
                                }
                                else
                                {
                                    <p class="mb-1"><strong>کد:</strong> <span class="text-monospace">@Model.SelectedWarehouseDetails.Code</span></p>
                                    <p class="mb-1"><strong>نام:</strong> @Model.SelectedWarehouseDetails.Name</p>
                                    <p class="mb-3">
                                        <strong>@UiText["common.status"]:</strong>
                                        <span class="badge badge-pill @(Model.SelectedWarehouseDetails.IsActive ? "badge-primary" : "badge-secondary")">
                                            @(Model.SelectedWarehouseDetails.IsActive ? UiText["common.active"] : UiText["common.inactive"])
                                        </span>
                                    </p>
                                    <h6 class="mb-2">@UiText["inventory.warehouses.thisWarehouseLocations"]</h6>
                                    @if (Model.SelectedWarehouseDetails.Locations.Count == 0)
                                    {
                                        <div class="text-muted small">@UiText["inventory.warehouses.noLocationsForWarehouse"]</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-sm table-striped mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>کد</th>
                                                        <th>نوع</th>
                                                        <th>راهرو/رک/طبقه/باکس</th>
                                                        <th>وضعیت</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var location in Model.SelectedWarehouseDetails.Locations)
                                                    {
                                                        <tr>
                                                            <td><span class="text-monospace">@location.LocationCode</span></td>
                                                            <td>@location.LocationType</td>
                                                            <td>@($"{location.Aisle ?? "-"} / {location.Rack ?? "-"} / {location.Shelf ?? "-"} / {location.Bin ?? "-"}")</td>
                                                            <td>
                                                                <span class="badge badge-pill @(location.IsActive ? "badge-primary" : "badge-secondary")">
                                                                    @(location.IsActive ? "فعال" : "غیرفعال")
                                                                </span>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                    }
                </div>
            </div>

            @if (showWarehouses)
            {
            <div class="col-12 mb-4 inventory-section-pane d-none @(showWarehouses ? null : "d-none")" id="warehouse-section-search">
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="card-title mb-0">لیست انبارها</h5>
                            <span class="text-muted small">@Model.WarehouseTotalCount رکورد</span>
                        </div>
                        <form asp-action="Warehouses" method="get" class="form-row mb-3" data-ajax-target="#inventory-management-root">
                            <input type="hidden" name="warehouseId" value="@Model.SelectedWarehouseId" />
                            <div class="form-group col-md-3">
                                <label>کد</label>
                                <input name="warehouseCode" value="@Model.WarehouseCodeFilter" class="form-control" />
                            </div>
                            <div class="form-group col-md-3">
                                <label>نام</label>
                                <input name="warehouseName" value="@Model.WarehouseNameFilter" class="form-control" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>وضعیت</label>
                                <select name="warehouseStatus" class="form-control">
                                    <option value="">همه</option>
                                    @if (Model.WarehouseStatusFilter == "active")
                                    {
                                        <option value="active" selected="selected">فعال</option>
                                    }
                                    else
                                    {
                                        <option value="active">فعال</option>
                                    }
                                    @if (Model.WarehouseStatusFilter == "inactive")
                                    {
                                        <option value="inactive" selected="selected">غیرفعال</option>
                                    }
                                    else
                                    {
                                        <option value="inactive">غیرفعال</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group col-md-2">
                                <label>تعداد</label>
                                <select name="warehousePageSize" class="form-control">
                                    @foreach (var size in Model.PageSizeOptions)
                                    {
                                        @if (Model.WarehousePageSize == size)
                                        {
                                            <option value="@size" selected="selected">@size</option>
                                        }
                                        else
                                        {
                                            <option value="@size">@size</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="form-group col-md-2 d-flex align-items-end">
                                <button class="btn btn-outline-primary btn-block" type="submit">اعمال</button>
                            </div>
                        </form>
                        <div class="table-responsive">
                            <table class="table table-sm table-striped mb-0">
                                <thead>
                                    <tr>
                                        <th>کد</th>
                                        <th>نام</th>
                                        <th>وضعیت</th>
                                        <th class="text-right">عملیات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Warehouses.Count == 0)
                                    {
                                        <tr><td colspan="4" class="text-center text-muted">انباری پیدا نشد.</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var warehouse in Model.Warehouses)
                                        {
                                            <tr>
                                                <td><span class="text-monospace">@warehouse.Code</span></td>
                                                <td>@warehouse.Name</td>
                                                <td>
                                                    <span class="badge badge-pill @(warehouse.IsActive ? "badge-primary" : "badge-secondary")">
                                                        @(warehouse.IsActive ? "فعال" : "غیرفعال")
                                                    </span>
                                                </td>
                                                <td class="text-right">
                                                    <a class="btn btn-outline-primary btn-xs" asp-action="Warehouses" asp-route-warehouseId="@warehouse.WarehouseBusinessKey" data-ajax-target="#inventory-management-root">ویرایش</a>
                                                    <form asp-action="ActivateWarehouse" method="post" class="d-inline inventory-status-action" data-loading-form data-ajax-target="#inventory-management-root">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="warehouseId" value="@warehouse.WarehouseBusinessKey" />
                                                        <button class="btn btn-outline-success btn-xs" type="submit" @(Can("Inventory.Warehouse.Activate", "Warehouse.Activate") ? null : "disabled")>فعال</button>
                                                    </form>
                                                    <form asp-action="DeactivateWarehouse" method="post" class="d-inline inventory-status-action" data-loading-form data-ajax-target="#inventory-management-root">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="warehouseId" value="@warehouse.WarehouseBusinessKey" />
                                                        <button class="btn btn-outline-warning btn-xs" type="submit" @(Can("Inventory.Warehouse.Deactivate", "Warehouse.Deactivate") ? null : "disabled")>غیرفعال</button>
                                                    </form>
                                                    <form asp-action="DeleteWarehouse" method="post" class="d-inline" data-loading-form data-ajax-target="#inventory-management-root">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="warehouseId" value="@warehouse.WarehouseBusinessKey" />
                                                        <button class="btn btn-outline-danger btn-xs" type="submit" data-confirm-title="حذف انبار" data-confirm="این انبار حذف شود؟" @(Can("Inventory.Warehouse.Delete", "Warehouse.Delete") ? null : "disabled")>حذف</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (Model.WarehouseTotalPages > 1)
                        {
                            <nav class="mt-3">
                                <ul class="pagination pagination-sm mb-0">
                                    @for (var i = 1; i <= Model.WarehouseTotalPages; i++)
                                    {
                                        <li class="page-item @(i == Model.WarehousePage ? "active" : null)">
                                            <a class="page-link"
                                               asp-action="Warehouses"
                                               data-ajax-target="#inventory-management-root"
                                               asp-route-warehouseId="@Model.SelectedWarehouseId"
                                               asp-route-warehouseCode="@Model.WarehouseCodeFilter"
                                               asp-route-warehouseName="@Model.WarehouseNameFilter"
                                               asp-route-warehouseStatus="@Model.WarehouseStatusFilter"
                                               asp-route-locationCode="@Model.LocationCodeFilter"
                                               asp-route-locationType="@Model.LocationTypeFilter"
                                               asp-route-locationAisle="@Model.LocationAisleFilter"
                                               asp-route-locationRack="@Model.LocationRackFilter"
                                               asp-route-locationShelf="@Model.LocationShelfFilter"
                                               asp-route-locationBin="@Model.LocationBinFilter"
                                               asp-route-locationStatus="@Model.LocationStatusFilter"
                                               asp-route-warehousePage="@i"
                                               asp-route-warehousePageSize="@Model.WarehousePageSize"
                                               asp-route-locationPage="@Model.LocationPage"
                                               asp-route-locationPageSize="@Model.LocationPageSize">@i</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    </div>
                </div>
            </div>
            }

            @if (showLocations)
            {
            <div class="col-12 mb-4 inventory-section-pane d-none @(showLocations ? null : "d-none")" id="location-section-search">
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="card-title mb-0">لیست لوکیشن‌ها</h5>
                            <span class="text-muted small">@Model.LocationTotalCount رکورد</span>
                        </div>
                        <form asp-action="Locations" method="get" class="form-row mb-3" data-ajax-target="#inventory-management-root">
                            <div class="form-group col-md-3">
                                <label>انبار</label>
                                <select name="warehouseId" class="form-control js-search-select">
                                    <option value="">همه انبارها</option>
                                    @foreach (var warehouse in Model.WarehouseLookup.OrderBy(x => x.Code))
                                    {
                                        @if (warehouse.WarehouseBusinessKey == Model.SelectedWarehouseId)
                                        {
                                            <option value="@warehouse.WarehouseBusinessKey" selected="selected">@warehouse.Code - @warehouse.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@warehouse.WarehouseBusinessKey">@warehouse.Code - @warehouse.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="form-group col-md-2">
                                <label>کد لوکیشن</label>
                                <input name="locationCode" value="@Model.LocationCodeFilter" class="form-control" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>نوع</label>
                                <input name="locationType" value="@Model.LocationTypeFilter" class="form-control" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>راهرو</label>
                                <input name="locationAisle" value="@Model.LocationAisleFilter" class="form-control" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>رک</label>
                                <input name="locationRack" value="@Model.LocationRackFilter" class="form-control" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>طبقه</label>
                                <input name="locationShelf" value="@Model.LocationShelfFilter" class="form-control" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>باکس</label>
                                <input name="locationBin" value="@Model.LocationBinFilter" class="form-control" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>وضعیت</label>
                                <select name="locationStatus" class="form-control">
                                    <option value="">همه</option>
                                    @if (Model.LocationStatusFilter == "active")
                                    {
                                        <option value="active" selected="selected">فعال</option>
                                    }
                                    else
                                    {
                                        <option value="active">فعال</option>
                                    }
                                    @if (Model.LocationStatusFilter == "inactive")
                                    {
                                        <option value="inactive" selected="selected">غیرفعال</option>
                                    }
                                    else
                                    {
                                        <option value="inactive">غیرفعال</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group col-md-1">
                                <label>تعداد</label>
                                <select name="locationPageSize" class="form-control">
                                    @foreach (var size in Model.PageSizeOptions)
                                    {
                                        @if (Model.LocationPageSize == size)
                                        {
                                            <option value="@size" selected="selected">@size</option>
                                        }
                                        else
                                        {
                                            <option value="@size">@size</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="form-group col-md-2 d-flex align-items-end">
                                <button class="btn btn-outline-primary btn-block" type="submit">اعمال</button>
                            </div>
                        </form>
                        <div class="table-responsive">
                            <table class="table table-sm table-striped mb-0">
                                <thead>
                                    <tr>
                                        <th>کد</th>
                                        <th>انبار</th>
                                        <th>نوع</th>
                                        <th>راهرو/رک/طبقه/باکس</th>
                                        <th>وضعیت</th>
                                        <th class="text-right">عملیات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Locations.Count == 0)
                                    {
                                        <tr><td colspan="6" class="text-center text-muted">لوکیشنی پیدا نشد.</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var location in Model.Locations)
                                        {
                                            <tr>
                                                <td><span class="text-monospace">@location.LocationCode</span></td>
                                                <td>@WarehouseName(location.WarehouseRef)</td>
                                                <td>@location.LocationType</td>
                                                <td>@($"{location.Aisle ?? "-"} / {location.Rack ?? "-"} / {location.Shelf ?? "-"} / {location.Bin ?? "-"}")</td>
                                                <td>
                                                    <span class="badge badge-pill @(location.IsActive ? "badge-primary" : "badge-secondary")">
                                                        @(location.IsActive ? "فعال" : "غیرفعال")
                                                    </span>
                                                </td>
                                                <td class="text-right">
                                                    <a class="btn btn-outline-primary btn-xs" asp-action="Locations" asp-route-warehouseId="@location.WarehouseRef" asp-route-locationId="@location.LocationBusinessKey" data-ajax-target="#inventory-management-root">ویرایش</a>
                                                    <form asp-action="ActivateLocation" method="post" class="d-inline inventory-status-action" data-loading-form data-ajax-target="#inventory-management-root">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="warehouseId" value="@location.WarehouseRef" />
                                                        <input type="hidden" name="locationId" value="@location.LocationBusinessKey" />
                                                        <button class="btn btn-outline-success btn-xs" type="submit" @(Can("Inventory.Location.Activate", "Location.Activate") ? null : "disabled")>فعال</button>
                                                    </form>
                                                    <form asp-action="DeactivateLocation" method="post" class="d-inline inventory-status-action" data-loading-form data-ajax-target="#inventory-management-root">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="warehouseId" value="@location.WarehouseRef" />
                                                        <input type="hidden" name="locationId" value="@location.LocationBusinessKey" />
                                                        <button class="btn btn-outline-warning btn-xs" type="submit" @(Can("Inventory.Location.Deactivate", "Location.Deactivate") ? null : "disabled")>غیرفعال</button>
                                                    </form>
                                                    <form asp-action="DeleteLocation" method="post" class="d-inline" data-loading-form data-ajax-target="#inventory-management-root">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="warehouseId" value="@location.WarehouseRef" />
                                                        <input type="hidden" name="locationId" value="@location.LocationBusinessKey" />
                                                        <button class="btn btn-outline-danger btn-xs" type="submit" data-confirm-title="حذف لوکیشن" data-confirm="این لوکیشن حذف شود؟" @(Can("Inventory.Location.Delete", "Location.Delete") ? null : "disabled")>حذف</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (Model.LocationTotalPages > 1)
                        {
                            <nav class="mt-3">
                                <ul class="pagination pagination-sm mb-0">
                                    @for (var i = 1; i <= Model.LocationTotalPages; i++)
                                    {
                                        <li class="page-item @(i == Model.LocationPage ? "active" : null)">
                                            <a class="page-link"
                                               asp-action="Locations"
                                               data-ajax-target="#inventory-management-root"
                                               asp-route-warehouseId="@Model.SelectedWarehouseId"
                                               asp-route-warehouseCode="@Model.WarehouseCodeFilter"
                                               asp-route-warehouseName="@Model.WarehouseNameFilter"
                                               asp-route-warehouseStatus="@Model.WarehouseStatusFilter"
                                               asp-route-locationCode="@Model.LocationCodeFilter"
                                               asp-route-locationType="@Model.LocationTypeFilter"
                                               asp-route-locationAisle="@Model.LocationAisleFilter"
                                               asp-route-locationRack="@Model.LocationRackFilter"
                                               asp-route-locationShelf="@Model.LocationShelfFilter"
                                               asp-route-locationBin="@Model.LocationBinFilter"
                                               asp-route-locationStatus="@Model.LocationStatusFilter"
                                               asp-route-warehousePage="@Model.WarehousePage"
                                               asp-route-warehousePageSize="@Model.WarehousePageSize"
                                               asp-route-locationPage="@i"
                                               asp-route-locationPageSize="@Model.LocationPageSize">@i</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    </div>
                </div>
            </div>
            }
        </div>
    </div>
</main>

