        <div class="tab-pane fade @(showListTab ? "show active" : null)" id="document-list-pane" role="tabpanel" aria-labelledby="document-list-tab">
            <div class="row">
                <div class="col-12 mb-4">
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="card-title mb-0">@UiText["inventory.documents.list.title"]</h5>
                        <span class="text-muted small" id="receipt-document-list-count">@Model.DocumentTotalCount @UiText["inventory.documents.list.countSuffix"]</span>
                        </div>
                        <form asp-action="@documentAction" asp-controller="InventoryManagement" method="get" class="form-row mb-3" id="receipt-document-list-form" data-loading-form data-ajax-target="#documents-page-root" data-ajax-preserve-url="true" data-document-search-filters data-location-lookup-url="@Url.Action("SearchDocumentWarehouseLocationsLookup", "InventoryManagement")">
                            <input type="hidden" name="documentId" value="@Model.SelectedDocumentId" />
                            <input type="hidden" name="documentType" value="@currentDocumentType" />
                        @await Html.PartialAsync("_DocumentListSearchFilters", Model)
                        </form>

                        <div class="table-responsive">
                            <table class="table table-sm table-striped mb-0">
                                <thead>
                                    <tr>
                                        <th>@UiText["inventory.documents.list.number"]</th>
                                        <th>@UiText["inventory.documents.list.type"]</th>
                                        <th>@UiText["inventory.documents.list.date"]</th>
                                        <th>@UiText["inventory.documents.list.status"]</th>
                                        <th class="text-right">@UiText["inventory.documents.list.actions"]</th>
                                    </tr>
                                </thead>
                                <tbody id="receipt-document-list-body">
                                    @if (Model.Documents.Count == 0)
                                    {
                                        <tr><td colspan="5" class="text-center text-muted">@UiText["inventory.documents.action.noDocumentSelected"]</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var document in Model.Documents)
                                        {
                                            var canEditDocument = string.Equals(document.Status, "Draft", StringComparison.OrdinalIgnoreCase);
                                            var canDeleteDocument = string.Equals(document.Status, "Draft", StringComparison.OrdinalIgnoreCase);
                                            var canActDocument = !string.Equals(document.Status, "Posted", StringComparison.OrdinalIgnoreCase);
                                            <tr>
                                                <td><span class="text-monospace">@document.DocumentNo</span></td>
                                                <td>@TypeLabel(document.DocumentType)</td>
                                                <td>@document.OccurredAt.ToString("yyyy/MM/dd HH:mm")</td>
                                                <td><span class="badge badge-pill @StatusClass(document.Status)">@StatusLabel(document.Status)</span></td>
                                                <td class="text-right">
                                                    <button type="button" class="btn btn-outline-primary btn-xs js-receipt-document-details mr-1" data-document-id="@document.DocumentBusinessKey" data-document-no="@document.DocumentNo">@UiText["inventory.documents.action.details"]</button>
                                                    @if (canEditDocument)
                                                    {
                                                        <a class="btn btn-outline-secondary btn-xs mr-1"
                                                           asp-action="@documentAction"
                                                           asp-controller="InventoryManagement"
                                                           asp-route-documentId="@document.DocumentBusinessKey"
                                                           asp-route-documentType="@document.DocumentType"
                                                           asp-route-tab="create"
                                                           asp-route-variantId="@Model.VariantFilter"
                                                           asp-route-warehouseId="@Model.WarehouseFilter"
                                                           asp-route-locationId="@Model.LocationFilter"
                                                           asp-route-page="@Model.DocumentPage"
                                                           asp-route-pageSize="@Model.DocumentPageSize"
                                                           asp-route-documentNo="@Model.DocumentNoFilter"
                                                           asp-route-status="@Model.DocumentStatusFilter"
                                                           asp-route-occurredFrom="@Model.OccurredFromFilter"
                                                           asp-route-occurredTo="@Model.OccurredToFilter"
                                                           data-ajax-target="#documents-page-root">@UiText["inventory.documents.action.editDocument"]</a>
                                                    }
                                                    @if (canDeleteDocument)
                                                    {
                                                        <button type="button"
                                                                class="btn btn-outline-danger btn-xs mr-1 js-receipt-document-delete"
                                                                data-document-id="@document.DocumentBusinessKey"
                                                                data-document-no="@document.DocumentNo">@UiText["inventory.documents.action.deleteDocument"]</button>
                                                    }
                                                    <button type="button"
                                                            class="btn btn-outline-info btn-xs js-receipt-document-action"
                                                            data-document-id="@document.DocumentBusinessKey"
                                                            data-document-no="@document.DocumentNo"
                                                            data-document-status="@document.Status"
                                                            @(canActDocument ? null : "disabled")>@UiText["inventory.documents.action.changeStatus"]</button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-3" id="receipt-document-list-pagination-wrapper">
                        @if (Model.DocumentTotalPages > 1)
                        {
                            <nav id="receipt-document-list-pagination">
                                <ul class="pagination pagination-sm mb-0">
                                    @for (var i = 1; i <= Model.DocumentTotalPages; i++)
                                    {
                                        <li class="page-item @(i == Model.DocumentPage ? "active" : null)">
                                            <a class="page-link"
                                               asp-action="@documentAction"
                                               asp-controller="InventoryManagement"
                                               asp-route-documentId="@Model.SelectedDocumentId"
                                               asp-route-documentNo="@Model.DocumentNoFilter"
                                               asp-route-documentType="@Model.DocumentTypeFilter"
                                               asp-route-status="@Model.DocumentStatusFilter"
                                               asp-route-variantId="@Model.VariantFilter"
                                               asp-route-warehouseId="@Model.WarehouseFilter"
                                               asp-route-locationId="@Model.LocationFilter"
                                               asp-route-occurredFrom="@Model.OccurredFromFilter"
                                               asp-route-occurredTo="@Model.OccurredToFilter"
                                               asp-route-page="@i"
                                               asp-route-pageSize="@Model.DocumentPageSize"
                                               data-ajax-target="#documents-page-root">@i</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 mb-4 d-none">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">جزئیات سند</h5>
                        @if (Model.SelectedDocumentDetails is null)
                        {
                            <div class="alert alert-light mb-0">سندی برای نمایش انتخاب نشده است.</div>
                        }
                        else
                        {
                            var selectedDocumentType = Model.SelectedDocumentDetails.DocumentType;
                            var showQualityColumn = string.Equals(selectedDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase)
                                || string.Equals(selectedDocumentType, "Conversion", StringComparison.OrdinalIgnoreCase);
                            var canEditLines = string.Equals(Model.SelectedDocumentDetails.Status, "Draft", StringComparison.OrdinalIgnoreCase);

                            <p class="mb-1"><strong>شماره:</strong> <span class="text-monospace">@Model.SelectedDocumentDetails.DocumentNo</span></p>
                            <p class="mb-1"><strong>نوع:</strong> @TypeLabel(Model.SelectedDocumentDetails.DocumentType)</p>
                            <p class="mb-1"><strong>وضعیت:</strong> <span class="badge badge-pill @StatusClass(Model.SelectedDocumentDetails.Status)">@StatusLabel(Model.SelectedDocumentDetails.Status)</span></p>
                            <p class="mb-1"><strong>تاریخ وقوع:</strong> @Model.SelectedDocumentDetails.OccurredAt.ToString("yyyy/MM/dd HH:mm")</p>
                            <p class="mb-1"><strong>مرجع:</strong> @(string.IsNullOrWhiteSpace(Model.SelectedDocumentDetails.ReferenceType) ? "-" : $"{Model.SelectedDocumentDetails.ReferenceType} / {Model.SelectedDocumentDetails.ReferenceBusinessId}")</p>
                            <p class="mb-1"><strong>@UiText["inventory.documents.externalReferenceNo"]:</strong> @(string.IsNullOrWhiteSpace(Model.SelectedDocumentDetails.ExternalReferenceNo) ? "-" : Model.SelectedDocumentDetails.ExternalReferenceNo)</p>
                            <p class="mb-1"><strong>علت:</strong> @(string.IsNullOrWhiteSpace(Model.SelectedDocumentDetails.ReasonCode) ? "-" : Model.SelectedDocumentDetails.ReasonCode)</p>
                            <p class="mb-1"><strong>تاریخ تایید:</strong> @(Model.SelectedDocumentDetails.ApprovedAt?.ToString("yyyy/MM/dd HH:mm") ?? "-")</p>
                            <p class="mb-3"><strong>تاریخ پست:</strong> @(Model.SelectedDocumentDetails.PostedAt?.ToString("yyyy/MM/dd HH:mm") ?? "-")</p>

                            @if (canEditLines)
                            {
                                <div class="border-top pt-3 mt-3">
                                    <h6 class="mb-3">@(string.IsNullOrWhiteSpace(Model.LineForm.LineId) ? "افزودن آیتم سند" : "ویرایش آیتم سند")</h6>
                                    <form asp-action="SaveDocumentLine" asp-controller="InventoryManagement" method="post" class="mb-0" data-loading-form data-ajax-target="#documents-page-root">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" asp-for="LineForm.DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                        <input type="hidden" asp-for="LineForm.DocumentType" value="@selectedDocumentType" />
                                        <input type="hidden" asp-for="LineForm.LineId" value="@Model.LineForm.LineId" />
                                        <div class="form-row">
                                            <div class="form-group col-md-4">
                                                <label>واریانت</label>
                                                <select asp-for="LineForm.VariantId" class="form-control js-search-select" data-placeholder="جستجو با کد یا نام واریانت" required>
                                                    <option value="">انتخاب واریانت</option>
                                                    @foreach (var variant in Model.VariantLookup.OrderBy(x => x.Sku))
                                                    {
                                                        <option value="@variant.Id" selected="@(variant.Id == Model.LineForm.VariantId ? "selected" : null)">@VariantLabel(variant)</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group col-md-2">
                                                <label>تعداد</label>
                                                <input asp-for="LineForm.Qty" type="number" step="0.0001" min="0.0001" class="form-control" />
                                            </div>
                                            <div class="form-group col-md-3 line-source">
                                                <label>لوکیشن مبدا</label>
                                                <select asp-for="LineForm.SourceLocationRef" class="form-control js-search-select" data-placeholder="انتخاب لوکیشن">
                                                    <option value="">انتخاب لوکیشن</option>
                                                    @foreach (var location in Model.LocationLookup.OrderBy(x => x.LocationCode))
                                                    {
                                                        <option value="@location.LocationBusinessKey" selected="@(location.LocationBusinessKey == Model.LineForm.SourceLocationRef ? "selected" : null)">@location.LocationCode (@location.LocationType)</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group col-md-3 line-destination">
                                                <label>لوکیشن مقصد</label>
                                                <select asp-for="LineForm.DestinationLocationRef" class="form-control js-search-select" data-placeholder="انتخاب لوکیشن">
                                                    <option value="">انتخاب لوکیشن</option>
                                                    @foreach (var location in Model.LocationLookup.OrderBy(x => x.LocationCode))
                                                    {
                                                        <option value="@location.LocationBusinessKey" selected="@(location.LocationBusinessKey == Model.LineForm.DestinationLocationRef ? "selected" : null)">@location.LocationCode (@location.LocationType)</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group col-md-2">
                                                <label>لات/بچ</label>
                                                <input asp-for="LineForm.LotBatchNo" class="form-control" />
                                            </div>
                                            @if (showQualityColumn)
                                            {
                                                @if (string.Equals(selectedDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <div class="form-group col-md-2 line-from-quality">
                                                        <label>کیفیت مبدأ</label>
                                                        <select asp-for="LineForm.FromQualityStatusRef" class="form-control js-search-select" data-placeholder="انتخاب کیفیت">
                                                            <option value="">انتخاب کیفیت</option>
                                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                                            {
                                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.FromQualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="form-group col-md-2 line-to-quality">
                                                        <label>کیفیت مقصد</label>
                                                        <select asp-for="LineForm.ToQualityStatusRef" class="form-control js-search-select" data-placeholder="انتخاب کیفیت">
                                                            <option value="">انتخاب کیفیت</option>
                                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                                            {
                                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.ToQualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="form-group col-md-2 line-quality">
                                                        <label>کیفیت</label>
                                                        <select asp-for="LineForm.QualityStatusRef" class="form-control js-search-select" data-placeholder="انتخاب کیفیت">
                                                            <option value="">انتخاب کیفیت</option>
                                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                                            {
                                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.QualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                }
                                            }
                                            <div class="form-group col-md-2 line-adjustment">
                                                    <label>@UiText["inventory.documents.line.adjustmentDirection"]</label>
                                                    <select asp-for="LineForm.AdjustmentDirection" class="form-control">
                                                    <option value="">@UiText["inventory.documents.line.selectOption"]</option>
                                                    <option value="Increase" selected="@(Model.LineForm.AdjustmentDirection == "Increase" ? "selected" : null)">@UiText["inventory.documents.line.increase"]</option>
                                                    <option value="Decrease" selected="@(Model.LineForm.AdjustmentDirection == "Decrease" ? "selected" : null)">@UiText["inventory.documents.line.decrease"]</option>
                                                    </select>
                                                </div>
                                                <div class="form-group col-md-4 line-reason">
                                                    <label>@UiText["inventory.documents.line.reason"]</label>
                                                    <input asp-for="LineForm.ReasonCode" class="form-control" />
                                                </div>
                                        </div>
                                        <div class="d-flex justify-content-end">
                                            <a class="btn btn-outline-secondary mr-2" asp-action="@documentAction" asp-controller="InventoryManagement" asp-route-documentId="@Model.SelectedDocumentDetails.DocumentBusinessKey" asp-route-documentType="@Model.SelectedDocumentDetails.DocumentType" data-ajax-target="#documents-page-root">لغو</a>
                                            <button class="btn btn-primary" type="submit">@(string.IsNullOrWhiteSpace(Model.LineForm.LineId) ? "افزودن آیتم" : "ذخیره تغییرات")</button>
                                        </div>
                                    </form>
                                </div>
                            }

                            <div class="border-top pt-3 mt-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0">آیتم های سند</h6>
                                    <span class="text-muted small">@Model.SelectedDocumentDetails.Lines.Count ردیف</span>
                                </div>
                                @if (Model.SelectedDocumentDetails.Lines.Count == 0)
                                {
                                    <div class="alert alert-light mb-0">ردیفی برای این سند ثبت نشده است.</div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm table-striped mb-0">
                                            <thead>
                                                <tr>
                                                    <th>واریانت</th>
                                                    <th>تعداد</th>
                                                    <th>واحد</th>
                                                    <th>مبدا</th>
                                                    <th>مقصد</th>
                                                    @if (showQualityColumn)
                                                    {
                                                        <th>کیفیت</th>
                                                    }
                                                    <th>علت</th>
                                                    @if (canEditLines)
                                                    {
                                                        <th class="text-right">عملیات</th>
                                                    }
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in Model.SelectedDocumentDetails.Lines)
                                                {
                                                    var lineProductId = VariantProductId(line.VariantRef);
                                                    <tr>
                                                        <td>
                                                            @if (!string.IsNullOrWhiteSpace(lineProductId))
                                                            {
                                                                <a asp-controller="VariantManagement"
                                                                   asp-action="Variants"
                                                                   asp-route-productId="@lineProductId"
                                                                   asp-route-variantId="@line.VariantRef">
                                                                    @VariantName(line.VariantRef)
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <span>@VariantName(line.VariantRef)</span>
                                                            }
                                                        </td>
                                                        <td>@line.Qty.ToString("0.####")</td>
                                                        <td>@UomName(line.UomRef)</td>
                                                        <td>@LocationName(line.SourceLocationRef)</td>
                                                        <td>@LocationName(line.DestinationLocationRef)</td>
                                                        @if (showQualityColumn)
                                                        {
                                                            <td>
                                                                @if (string.Equals(selectedDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase))
                                                                {
                                                                    <span>@QualityName(line.FromQualityStatusRef) -> @QualityName(line.ToQualityStatusRef)</span>
                                                                }
                                                                else
                                                                {
                                                                    <span>@QualityName(line.QualityStatusRef)</span>
                                                                }
                                                            </td>
                                                        }
                                                        <td>
                                                            @(string.IsNullOrWhiteSpace(line.ReasonCode) ? AdjustmentDirectionLabel(line.AdjustmentDirection) : line.ReasonCode)
                                                        </td>
                                                        @if (canEditLines)
                                                        {
                                                            <td class="text-right">
                                                                <a class="btn btn-outline-primary btn-xs" asp-action="@documentAction" asp-controller="InventoryManagement" asp-route-documentId="@Model.SelectedDocumentDetails.DocumentBusinessKey" asp-route-editingLineId="@line.LineBusinessKey" asp-route-documentType="@Model.SelectedDocumentDetails.DocumentType" data-ajax-target="#documents-page-root">ویرایش</a>
                                                                <button type="button"
                                                                        class="btn btn-outline-danger btn-xs js-receipt-line-delete"
                                                                        data-document-id="@Model.SelectedDocumentDetails.DocumentBusinessKey"
                                                                        data-document-no="@Model.SelectedDocumentDetails.DocumentNo"
                                                                        data-line-id="@line.LineBusinessKey">حذف</button>
                                                            </td>
                                                        }
                                                    </tr>
                                                    @if (!string.IsNullOrWhiteSpace(line.LotBatchNo) || line.BaseQty != line.Qty || !string.Equals(line.BaseUomRef, line.UomRef, StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <tr>
                                                            <td colspan="@(showQualityColumn ? 8 : 7)" class="text-muted small">
                                                                Base: @line.BaseQty.ToString("0.####") @UomName(line.BaseUomRef)
                                                                @if (!string.IsNullOrWhiteSpace(line.LotBatchNo))
                                                                {
                                                                    <span> | لات/بچ: @line.LotBatchNo</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>

                            var selectedStatus = Model.SelectedDocumentDetails.Status;
                            var canApproveByStatus = string.Equals(selectedStatus, "Draft", StringComparison.OrdinalIgnoreCase);
                            var canRejectByStatus = !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Cancelled", StringComparison.OrdinalIgnoreCase);
                            var canCancelByStatus = !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Rejected", StringComparison.OrdinalIgnoreCase);
                            var canPostByStatus = !string.Equals(selectedStatus, "Cancelled", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Rejected", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase);

                            <div class="border-top pt-3">
                                <div class="mb-2 text-muted small">تغییر وضعیت</div>
                                <div class="d-flex flex-wrap">
                                    <form asp-action="ChangeDocumentStatus" asp-controller="InventoryManagement" method="post" class="mr-1 mb-1" data-loading-form data-ajax-target="#documents-page-root" data-ajax-close-modal-on-success>
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                        <input type="hidden" name="Action" value="approve" />
                                        <button class="btn btn-outline-info btn-xs" type="submit" @(Can("Inventory.Document.Approve", "InventoryDocument.Approve", "Document.Approve") && canApproveByStatus ? null : "disabled")>تایید</button>
                                    </form>
                                    <form asp-action="ChangeDocumentStatus" asp-controller="InventoryManagement" method="post" class="mr-1 mb-1" data-loading-form data-ajax-target="#documents-page-root" data-ajax-close-modal-on-success>
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                        <input type="hidden" name="Action" value="post" />
                                        <button class="btn btn-outline-success btn-xs" type="submit" @(Can("Inventory.Document.Post", "InventoryDocument.Post", "Document.Post") && canPostByStatus ? null : "disabled")>پست</button>
                                    </form>
                                </div>
                                <form asp-action="ChangeDocumentStatus" asp-controller="InventoryManagement" method="post" class="mt-2" data-loading-form data-ajax-target="#documents-page-root" data-ajax-close-modal-on-success>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                    <input type="hidden" name="Action" value="reject" />
                                    <div class="form-group mb-2">
                                        <label class="small">علت رد</label>
                                        <input name="ReasonCode" class="form-control form-control-sm" />
                                    </div>
                                    <button class="btn btn-outline-danger btn-xs" type="submit" @(Can("Inventory.Document.Reject", "InventoryDocument.Reject", "Document.Reject") && canRejectByStatus ? null : "disabled")>رد سند</button>
                                </form>
                                <form asp-action="ChangeDocumentStatus" asp-controller="InventoryManagement" method="post" class="mt-2" data-loading-form data-ajax-target="#documents-page-root" data-ajax-close-modal-on-success>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                    <input type="hidden" name="Action" value="cancel" />
                                    <div class="form-group mb-2">
                                        <label class="small">علت لغو</label>
                                        <input name="ReasonCode" class="form-control form-control-sm" />
                                    </div>
                                    <button class="btn btn-outline-warning btn-xs" type="submit" @(Can("Inventory.Document.Cancel", "InventoryDocument.Cancel", "Document.Cancel") && canCancelByStatus ? null : "disabled")>لغو سند</button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="receipt-document-details-modal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title" id="receipt-document-details-modal-title">جزئیات سند رسید</h5>
                        <div class="small text-muted" id="receipt-document-details-modal-subtitle"></div>
                    </div>
                    <button type="button" class="close" data-dismiss="modal" aria-label="بستن">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body" id="receipt-document-details-modal-body">
                    <div class="text-muted">در حال بارگذاری...</div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="receipt-document-action-modal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title">اقدام روی سند رسید</h5>
                        <div class="small text-muted" id="receipt-document-action-modal-subtitle"></div>
                    </div>
                    <button type="button" class="close" data-dismiss="modal" aria-label="بستن">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="receipt-document-action-id" />
                    <div class="form-group">
                        <label>اقدام</label>
                        <select class="form-control" id="receipt-document-action-select">
                            <option value="approve">تایید</option>
                            <option value="post">پست</option>
                            <option value="reject">رد سند</option>
                            <option value="cancel">لغو سند</option>
                        </select>
                    </div>
                    <div class="form-group" id="receipt-document-action-reason-group">
                        <label>علت</label>
                        <input type="text" class="form-control" id="receipt-document-action-reason" />
                    </div>
                    <div class="d-none mt-3" id="receipt-document-action-post-section">
                        <div class="border rounded p-3 bg-light">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <strong>شناسه‌های ردیف</strong>
                            </div>
                            <div class="small text-muted mb-2">
                                شناسه‌ها هنگام ذخیره ردیف ساخته می‌شوند و در زمان پست فقط ثبت نهایی انجام می‌شود.
                            </div>
                            <div id="receipt-document-action-post-lines">
                                <div class="text-muted small">نیازی به انتخاب شناسه در این بخش نیست.</div>
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-light border mb-0 small">
                        برای تایید و پست، علت اختیاری نیست. برای رد و لغو، علت ثبت می‌شود.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">بستن</button>
                    <button type="button" class="btn btn-primary" id="receipt-document-action-submit">تایید</button>
                </div>
            </div>
    </div>
</div>
<div class="modal fade" id="document-user-create-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title mb-0">ایجاد کاربر</h5>
                    <small class="text-muted">کاربر جدید به سازمان فعال اضافه می‌شود.</small>
                </div>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="alert alert-danger d-none" id="document-user-create-error"></div>
                <form asp-action="CreateDocumentUser" asp-controller="InventoryManagement" method="post" id="document-user-create-form">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label>نام</label>
                        <input type="text" name="UserName" class="form-control" autocomplete="off" required />
                    </div>
                    <div class="form-group">
                        <label>شماره تلفن</label>
                        <input type="text" name="MobileNumber" class="form-control text-monospace" autocomplete="off" required />
                    </div>
                    <div class="form-group">
                        <label>نقش</label>
                        <select name="RoleBusinessKey" class="form-control js-search-select" data-placeholder="انتخاب نقش" required>
                            <option value="">انتخاب نقش</option>
                            @foreach (var role in Model.RoleLookup.OrderBy(x => x.Name))
                            {
                                <option value="@role.RoleBusinessKey">@RoleNameLabel(role)</option>
                            }
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">بستن</button>
                <button type="submit" class="btn btn-primary" form="document-user-create-form">ثبت</button>
            </div>
        </div>
    </div>
</div>
</main>

@section Scripts {
    <script data-ajax-reinit="documents">
        (function () {
            var lineContainer = document.getElementById('document-lines');
            var addLineButton = document.getElementById('add-document-line');
            var documentTypeSelect = document.getElementById('document-type-input');
            var warehouseSelect = document.getElementById('create-warehouse-select');
            var createForm = document.getElementById('document-create-form');
            var linesPanel = document.getElementById('document-lines-panel');
            var toggleLinesButton = document.getElementById('toggle-document-lines');
            var typeGuidance = document.getElementById('document-type-guidance');
            var validationSummary = document.getElementById('document-validation-summary');

            if (!lineContainer) {
                return;
            }

            var documentTypeConfig = {
                Receipt: {
                    title: 'رسید انبار',
                    text: 'برای ورود کالا به انبار استفاده می‌شود. در هر ردیف، لوکیشن مقصد الزامی است.',
                    source: false,
                    destination: true,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                Issue: {
                    title: 'حواله انبار',
                    text: 'برای خروج کالا از انبار استفاده می‌شود. در هر ردیف، لوکیشن مبدا الزامی است.',
                    source: true,
                    destination: false,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                Transfer: {
                    title: 'انتقال بین لوکیشن‌ها',
                    text: 'برای جابه‌جایی داخلی کالا استفاده می‌شود. مبدا و مقصد هر ردیف الزامی و باید متفاوت باشند.',
                    source: true,
                    destination: true,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                Adjustment: {
                    title: 'تعدیل موجودی',
                    text: 'برای اصلاح مقدار موجودی استفاده می‌شود. جهت تعدیل و علت ردیف الزامی است.',
                    source: false,
                    destination: false,
                    quality: false,
                    qualityChange: false,
                    adjustment: true,
                    lineReason: true
                },
                Return: {
                    title: 'برگشت کالا',
                    text: 'برای برگشت کالا به انبار استفاده می‌شود. لوکیشن مقصد هر ردیف الزامی است.',
                    source: false,
                    destination: true,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                QualityChange: {
                    title: 'تغییر کیفیت',
                    text: 'برای تغییر وضعیت کیفی کالا استفاده می‌شود. کیفیت مبدا و مقصد الزامی و باید متفاوت باشند.',
                    source: false,
                    destination: false,
                    quality: false,
                    qualityChange: true,
                    adjustment: false,
                    lineReason: false
                },
                Conversion: {
                    title: 'سند تبدیل',
                    text: 'برای مصرف اجزای سازنده و تولید کالای نهایی استفاده می‌شود. در هر ردیف فقط یکی از مبدا یا مقصد را پر کنید.',
                    source: true,
                    destination: true,
                    quality: true,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false,
                    exclusiveFlow: true
                }
            };

            function setRequired(selectors, isRequired, line) {
                selectors.forEach(function (selector) {
                    line.querySelectorAll(selector).forEach(function (field) {
                        if (isRequired) {
                            field.setAttribute('required', 'required');
                        } else {
                            field.removeAttribute('required');
                        }
                    });
                });
            }

            function setLinesPanelVisible(isVisible) {
                if (!linesPanel) {
                    return;
                }

                linesPanel.classList.toggle('d-none', !isVisible);
                if (toggleLinesButton) {
                    toggleLinesButton.textContent = isVisible ? 'پنهان کردن واریانت' : 'افزودن واریانت';
                }
            }

            function clearValidation() {
                if (validationSummary) {
                    validationSummary.style.display = 'none';
                    validationSummary.textContent = '';
                }

                lineContainer.querySelectorAll('.is-invalid').forEach(function (field) {
                    field.classList.remove('is-invalid');
                });
            }

            function showValidation(message, field) {
                if (validationSummary) {
                    validationSummary.textContent = message;
                    validationSummary.style.display = '';
                }

                if (field) {
                    field.classList.add('is-invalid');
                    field.focus();
                }
            }

            function selectedConfig() {
                var type = documentTypeSelect ? documentTypeSelect.value : 'Receipt';
                return documentTypeConfig[type] || documentTypeConfig.Receipt;
            }

            function renumberLines() {
                var lines = lineContainer.querySelectorAll('.document-line');
                lines.forEach(function (line, index) {
                    line.setAttribute('data-line-index', index);
                    var title = line.querySelector('strong');
                    if (title) {
                        title.textContent = 'ردیف ' + (index + 1);
                    }

                    line.querySelectorAll('input, select, textarea').forEach(function (field) {
                        if (field.name) {
                            field.name = field.name.replace(/CreateForm\.Lines\[\d+\]/g, 'CreateForm.Lines[' + index + ']');
                        }
                    });
                });
            }

            function toggleTypeFields() {
                var config = selectedConfig();
                if (typeGuidance) {
                    typeGuidance.innerHTML = '<strong>' + config.title + '</strong><div class="small mt-1">' + config.text + '</div>';
                }

                lineContainer.querySelectorAll('.document-line').forEach(function (line) {
                    line.querySelectorAll('.line-source').forEach(function (el) { el.style.display = config.source ? '' : 'none'; });
                    line.querySelectorAll('.line-destination').forEach(function (el) { el.style.display = config.destination ? '' : 'none'; });
                    line.querySelectorAll('.line-adjustment').forEach(function (el) { el.style.display = config.adjustment ? '' : 'none'; });
                    line.querySelectorAll('.line-quality').forEach(function (el) { el.style.display = config.quality ? '' : 'none'; });
                    line.querySelectorAll('.line-from-quality, .line-to-quality').forEach(function (el) { el.style.display = config.qualityChange ? '' : 'none'; });
                    line.querySelectorAll('.line-reason').forEach(function (el) { el.style.display = config.lineReason ? '' : 'none'; });

                    setRequired(['.source-location-select'], config.source && !config.exclusiveFlow, line);
                    setRequired(['.destination-location-select'], config.destination && !config.exclusiveFlow, line);
                    setRequired(['.line-adjustment select'], config.adjustment, line);
                    setRequired(['.line-reason input'], config.lineReason, line);
                    setRequired(['.line-from-quality select', '.line-to-quality select'], config.qualityChange, line);
                    setRequired(['.line-quality select'], !!config.quality && !config.qualityChange, line);
                });
            }

            function syncLocationsToWarehouse() {
                var warehouseId = warehouseSelect ? warehouseSelect.value : '';
                lineContainer.querySelectorAll('.document-location-select').forEach(function (select) {
                    Array.prototype.forEach.call(select.options, function (option) {
                        if (!option.value) {
                            option.hidden = false;
                            return;
                        }

                        var optionWarehouse = option.getAttribute('data-warehouse-ref');
                        option.hidden = !!warehouseId && optionWarehouse !== warehouseId;
                    });

                    if (select.value) {
                        var selectedOption = select.options[select.selectedIndex];
                        if (selectedOption && selectedOption.hidden) {
                            select.value = '';
                        }
                    }
                });
            }

            function syncVariantUom(line) {
                var select = line.querySelector('.document-variant-select');
                var uomRef = line.querySelector('.document-uom-ref');
                var baseUomRef = line.querySelector('.document-base-uom-ref');
                var hint = line.querySelector('.document-uom-hint');
                if (!select || !uomRef || !baseUomRef) {
                    return;
                }

                var option = select.options[select.selectedIndex];
                var baseUom = option ? option.getAttribute('data-base-uom-ref') : '';
                uomRef.value = baseUom || '';
                baseUomRef.value = baseUom || '';
                if (hint) {
                    hint.textContent = baseUom ? ('Base UOM: ' + baseUom) : 'UOM از Base UOM واریانت پر می شود.';
                }
            }

            function bindLine(line) {
                var removeButton = line.querySelector('.remove-document-line');
                if (removeButton) {
                    removeButton.addEventListener('click', function () {
                        if (lineContainer.querySelectorAll('.document-line').length === 1) {
                            line.querySelectorAll('input[type="text"], input[type="number"]').forEach(function (input) {
                                input.value = input.type === 'number' ? '1' : '';
                            });
                            line.querySelectorAll('select').forEach(function (select) {
                                select.value = '';
                            });
                            syncVariantUom(line);
                            return;
                        }

                        line.remove();
                        renumberLines();
                        toggleTypeFields();
                        syncLocationsToWarehouse();
                    });
                }

                var variantSelect = line.querySelector('.document-variant-select');
                if (variantSelect) {
                    variantSelect.addEventListener('change', function () {
                        syncVariantUom(line);
                    });
                    syncVariantUom(line);
                }
            }

            function firstField(line, selector) {
                return line.querySelector(selector);
            }

            function validateDocumentForm() {
                clearValidation();

                if (!createForm) {
                    return true;
                }

                var warehouseField = document.getElementById('create-warehouse-select');
                if (warehouseField && !warehouseField.value) {
                    showValidation('انتخاب انبار برای سند الزامی است.', warehouseField);
                    return false;
                }

                var config = selectedConfig();
                var lines = Array.prototype.slice.call(lineContainer.querySelectorAll('.document-line'));
                for (var i = 0; i < lines.length; i++) {
                    var line = lines[i];
                    var lineTitle = 'ردیف ' + (i + 1);
                    var variant = firstField(line, '.document-variant-select');
                    var qty = firstField(line, 'input[name$=".Qty"]');
                    var source = firstField(line, '.source-location-select');
                    var destination = firstField(line, '.destination-location-select');
                    var adjustment = firstField(line, '.line-adjustment select');
                    var reason = firstField(line, '.line-reason input');
                    var fromQuality = firstField(line, '.line-from-quality select');
                    var toQuality = firstField(line, '.line-to-quality select');

                    if (!variant || !variant.value) {
                        showValidation(lineTitle + ': انتخاب واریانت الزامی است.', variant);
                        return false;
                    }

                    if (!qty || Number(qty.value) <= 0) {
                        showValidation(lineTitle + ': تعداد باید بزرگ‌تر از صفر باشد.', qty);
                        return false;
                    }

                    if (config.source && !config.exclusiveFlow && (!source || !source.value)) {
                        showValidation(lineTitle + ': لوکیشن مبدا الزامی است.', source);
                        return false;
                    }

                    if (config.destination && !config.exclusiveFlow && (!destination || !destination.value)) {
                        showValidation(lineTitle + ': لوکیشن مقصد الزامی است.', destination);
                        return false;
                    }

                    if (!config.exclusiveFlow && config.source && config.destination && source && destination && source.value && source.value === destination.value) {
                        showValidation(lineTitle + ': لوکیشن مبدا و مقصد باید متفاوت باشند.', destination);
                        return false;
                    }

                    if (config.exclusiveFlow) {
                        var hasSource = !!(source && source.value);
                        var hasDestination = !!(destination && destination.value);
                        var quality = firstField(line, '.line-quality select');

                        if (hasSource === hasDestination) {
                            showValidation(lineTitle + ': در سند تبدیل، هر ردیف باید یا خروجی باشد یا ورودی.', source || destination);
                            return false;
                        }

                        if (!quality || !quality.value) {
                            showValidation(lineTitle + ': وضعیت کیفیت الزامی است.', quality);
                            return false;
                        }
                    }

                    if (config.adjustment && (!adjustment || !adjustment.value)) {
                        showValidation(lineTitle + ': جهت تعدیل الزامی است.', adjustment);
                        return false;
                    }

                    if (config.lineReason && (!reason || !reason.value.trim())) {
                        showValidation(lineTitle + ': علت ردیف الزامی است.', reason);
                        return false;
                    }

                    if (config.qualityChange && (!fromQuality || !fromQuality.value)) {
                        showValidation(lineTitle + ': کیفیت مبدا الزامی است.', fromQuality);
                        return false;
                    }

                    if (config.qualityChange && (!toQuality || !toQuality.value)) {
                        showValidation(lineTitle + ': کیفیت مقصد الزامی است.', toQuality);
                        return false;
                    }

                    if (config.qualityChange && fromQuality && toQuality && fromQuality.value && fromQuality.value === toQuality.value) {
                        showValidation(lineTitle + ': کیفیت مبدا و مقصد باید متفاوت باشند.', toQuality);
                        return false;
                    }
                }

                return true;
            }

            function addLine() {
                var lines = lineContainer.querySelectorAll('.document-line');
                var lastLine = lines[lines.length - 1];
                var clone = lastLine.cloneNode(true);
                clone.querySelectorAll('.select2').forEach(function (node) {
                    node.remove();
                });
                clone.querySelectorAll('input').forEach(function (input) {
                    input.value = input.type === 'number' ? '1' : '';
                });
                clone.querySelectorAll('select').forEach(function (select) {
                    select.value = '';
                    delete select.dataset.select2Initialized;
                });
                lineContainer.appendChild(clone);
                if (window.appUi && typeof window.appUi.initSearchableSelects === 'function') {
                    window.appUi.initSearchableSelects(clone);
                }
                renumberLines();
                bindLine(clone);
                toggleTypeFields();
                syncLocationsToWarehouse();
            }

            if (addLineButton) {
                addLineButton.addEventListener('click', addLine);
            }

            if (toggleLinesButton) {
                toggleLinesButton.addEventListener('click', function () {
                    setLinesPanelVisible(linesPanel ? linesPanel.classList.contains('d-none') : false);
                });
            }

            if (documentTypeSelect) {
                documentTypeSelect.addEventListener('change', function () {
                    clearValidation();
                    toggleTypeFields();
                });
            }

            if (warehouseSelect) {
                warehouseSelect.addEventListener('change', function () {
                    clearValidation();
                    syncLocationsToWarehouse();
                });
            }

            if (createForm) {
                createForm.addEventListener('submit', function (event) {
                    if (!validateDocumentForm()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                });
            }

            lineContainer.querySelectorAll('.document-line').forEach(bindLine);
            renumberLines();
            toggleTypeFields();
            syncLocationsToWarehouse();
            setLinesPanelVisible(false);
        })();
    </script>
    <script data-ajax-reinit="receipt-documents">
        (function () {
            var modalSelector = '#receipt-document-details-modal';
            var modalBodySelector = '#receipt-document-details-modal-body';
            var modalTitleSelector = '#receipt-document-details-modal-title';
            var modalSubtitleSelector = '#receipt-document-details-modal-subtitle';
            var detailsUrl = '@Url.Action("ReceiptDocumentDetails", "InventoryManagement")';
            var actionModalSelector = '#receipt-document-action-modal';
            var actionIdSelector = '#receipt-document-action-id';
            var actionSelectSelector = '#receipt-document-action-select';
            var actionReasonSelector = '#receipt-document-action-reason';
            var actionReasonGroupSelector = '#receipt-document-action-reason-group';
            var actionPostSectionSelector = '#receipt-document-action-post-section';
            var actionPostLinesSelector = '#receipt-document-action-post-lines';
            var actionSubtitleSelector = '#receipt-document-action-modal-subtitle';
            var actionSubmitSelector = '#receipt-document-action-submit';
            var documentListUrl = '@Url.Action("DocumentList", "InventoryManagement")';
            var documentListFormSelector = '#receipt-document-list-form';
            var documentListCountSelector = '#receipt-document-list-count';
            var documentListBodySelector = '#receipt-document-list-body';
            var documentListPaginationWrapperSelector = '#receipt-document-list-pagination-wrapper';
            var documentListPaginationSelector = '#receipt-document-list-pagination';
            var deleteDocumentUrl = '@Url.Action("DeleteDocument", "InventoryManagement")';
            var deleteReceiptDocumentLineUrl = '@Url.Action("DeleteReceiptDocumentLine", "InventoryManagement")';
            var receiptWarehouseLookupUrl = '@Url.Action("SearchReceiptWarehousesLookup", "InventoryManagement")';
            var receiptLocationLookupUrl = '@Url.Action("SearchReceiptWarehouseLocationsLookup", "InventoryManagement")';
            var receiptWarehouseOptions = [];
            var warehouseDisplayLookup = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.WarehouseLookup.ToDictionary(x => x.WarehouseBusinessKey, x => $"{x.Code} - {x.Name}")));
            var sellerDisplayLookup = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.SellerLookup.ToDictionary(x => x.SellerBusinessKey, x => $"{x.Code} - {x.Name}")));
            var changeStatusUrl = '@Url.Action("ChangeDocumentStatus", "InventoryManagement")';
            var receiptPostPreviewUrl = '@Url.Action("ReceiptDocumentPostPreview", "InventoryManagement")';
            var receiptPostSelectionCache = {};

            function showModal() {
                if (!window.jQuery || !window.jQuery.fn || !window.jQuery.fn.modal) {
                    return;
                }

                window.jQuery(modalSelector).modal('show');
            }

            function escapeHtml(value) {
                return String(value == null ? '' : value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function decodeHtmlEntities(value) {
                var textarea = document.createElement('textarea');
                textarea.innerHTML = String(value == null ? '' : value);
                return textarea.value;
            }

            function formatDocumentDateTime(value) {
                var date = value ? new Date(value) : null;
                if (!date || isNaN(date.getTime())) {
                    return '-';
                }

                var year = date.getFullYear();
                var month = String(date.getMonth() + 1).padStart(2, '0');
                var day = String(date.getDate()).padStart(2, '0');
                var hours = String(date.getHours()).padStart(2, '0');
                var minutes = String(date.getMinutes()).padStart(2, '0');
                return year + '/' + month + '/' + day + ' ' + hours + ':' + minutes;
            }

            function getDocumentTypeLabel(type) {
                switch ((type || '').toLowerCase()) {
                    case 'receipt':
                        return decodeHtmlEntities('@UiText["inventory.documents.type.receipt"]');
                    case 'issue':
                        return decodeHtmlEntities('@UiText["inventory.documents.type.issue"]');
                    case 'transfer':
                        return decodeHtmlEntities('@UiText["inventory.documents.type.transfer"]');
                    case 'adjustment':
                        return decodeHtmlEntities('@UiText["inventory.documents.type.adjustment"]');
                    case 'return':
                        return decodeHtmlEntities('@UiText["inventory.documents.type.return"]');
                    case 'qualitychange':
                        return decodeHtmlEntities('@UiText["inventory.documents.type.qualityChange"]');
                    case 'conversion':
                        return decodeHtmlEntities('@UiText["inventory.documents.type.conversion"]');
                    default:
                        return type || '-';
                }
            }

            function getStatusLabel(status) {
                switch ((status || '').toLowerCase()) {
                    case 'draft':
                        return decodeHtmlEntities('@UiText["inventory.documents.status.draft"]');
                    case 'approved':
                        return decodeHtmlEntities('@UiText["inventory.documents.status.approved"]');
                    case 'rejected':
                        return decodeHtmlEntities('@UiText["inventory.documents.status.rejected"]');
                    case 'cancelled':
                        return decodeHtmlEntities('@UiText["inventory.documents.status.cancelled"]');
                    case 'posted':
                        return decodeHtmlEntities('@UiText["inventory.documents.status.posted"]');
                    default:
                        return status || '-';
                }
            }

            function getStatusClass(status) {
                switch ((status || '').toLowerCase()) {
                    case 'draft':
                        return 'badge-outline-secondary';
                    case 'approved':
                        return 'badge-info';
                    case 'rejected':
                        return 'badge-danger';
                    case 'cancelled':
                        return 'badge-warning';
                    case 'posted':
                        return 'badge-success';
                    default:
                        return 'badge-secondary';
                }
            }

            function getWarehouseLabel(warehouseId) {
                if (!warehouseId) {
                    return '-';
                }

                return warehouseDisplayLookup[warehouseId] || warehouseId;
            }

            function getSellerLabel(sellerId) {
                if (!sellerId) {
                    return '-';
                }

                return sellerDisplayLookup[sellerId] || sellerId;
            }

            function getReceiptListForm() {
                return document.querySelector(documentListFormSelector);
            }

            function getReceiptListValue(name) {
                var form = getReceiptListForm();
                if (!form) {
                    return '';
                }

                var field = form.querySelector('[name="' + name + '"]');
                return field ? (field.value || '') : '';
            }

            function hydrateReceiptInventoryOptions(root) {
                receiptWarehouseOptions = [];
            }

            function getReceiptListQuery(page) {
                var params = new URLSearchParams();
                params.set('documentType', 'Receipt');
                params.set('page', String(page && page > 0 ? page : 1));
                params.set('pageSize', getReceiptListValue('pageSize') || '@Model.DocumentPageSize');
                params.set('documentNo', getReceiptListValue('documentNo'));
                params.set('status', getReceiptListValue('status'));
                params.set('occurredFrom', getReceiptListValue('occurredFrom'));
                params.set('occurredTo', getReceiptListValue('occurredTo'));
                return params;
            }

            function getCurrentReceiptListPage() {
                var activeLink = document.querySelector(documentListPaginationSelector + ' .page-item.active .page-link');
                if (activeLink) {
                    var value = parseInt(activeLink.textContent || '1', 10);
                    if (!isNaN(value) && value > 0) {
                        return value;
                    }
                }

                var currentUrl = new URL(window.location.href);
                var page = parseInt(currentUrl.searchParams.get('page') || '1', 10);
                if (!isNaN(page) && page > 0) {
                    return page;
                }

                return 1;
            }

            function buildReceiptDocumentActionHtml(document, currentPage) {
                var documentId = escapeHtml(document.documentBusinessKey || '');
                var documentNo = escapeHtml(document.documentNo || '');
                var documentType = escapeHtml(document.documentType || '');
                var status = escapeHtml(document.status || '');
                var canEditDocument = String(document.status || '').toLowerCase() === 'draft';
                var canDeleteDocument = String(document.status || '').toLowerCase() === 'draft';
                var canActDocument = String(document.status || '').toLowerCase() !== 'posted';
                var documentNoValue = escapeHtml(getReceiptListValue('documentNo'));
                var statusValue = escapeHtml(getReceiptListValue('status'));
                var occurredFromValue = escapeHtml(getReceiptListValue('occurredFrom'));
                var occurredToValue = escapeHtml(getReceiptListValue('occurredTo'));
                var editUrl = '@Url.Action("ReceiptDocuments", "InventoryManagement")'
                    + '?documentId=' + encodeURIComponent(document.documentBusinessKey || '')
                    + '&documentType=' + encodeURIComponent(document.documentType || 'Receipt')
                    + '&tab=create'
                    + '&page=' + encodeURIComponent(currentPage || 1)
                    + '&pageSize=' + encodeURIComponent(getReceiptListValue('pageSize') || '@Model.DocumentPageSize')
                    + '&documentNo=' + encodeURIComponent(getReceiptListValue('documentNo') || '')
                    + '&status=' + encodeURIComponent(getReceiptListValue('status') || '')
                    + '&occurredFrom=' + encodeURIComponent(getReceiptListValue('occurredFrom') || '')
                    + '&occurredTo=' + encodeURIComponent(getReceiptListValue('occurredTo') || '');

                var html = '';
                html += '<td><span class="text-monospace">' + documentNo + '</span></td>';
                html += '<td>' + escapeHtml(getDocumentTypeLabel(document.documentType)) + '</td>';
                html += '<td>' + escapeHtml(formatDocumentDateTime(document.occurredAt)) + '</td>';
                html += '<td><span class="badge badge-pill ' + getStatusClass(document.status) + '">' + escapeHtml(getStatusLabel(document.status)) + '</span></td>';
                html += '<td class="text-right">';
                html += '<button type="button" class="btn btn-outline-primary btn-xs js-receipt-document-details mr-1" data-document-id="' + documentId + '" data-document-no="' + documentNo + '">جزئیات</button>';

                if (canEditDocument) {
                    html += '<a class="btn btn-outline-secondary btn-xs mr-1" href="' + editUrl + '" data-ajax-target="#documents-page-root">ویرایش</a>';
                }

                if (canDeleteDocument) {
                    html += '<button type="button" class="btn btn-outline-danger btn-xs mr-1 js-receipt-document-delete" data-document-id="' + documentId + '" data-document-no="' + documentNo + '">حذف</button>';
                }

                html += '<button type="button" class="btn btn-outline-info btn-xs js-receipt-document-action" data-document-id="' + documentId + '" data-document-no="' + documentNo + '" data-document-status="' + status + '"' + (canActDocument ? '' : ' disabled') + '>اقدام</button>';
                html += '</td>';
                return html;
            }

            function renderReceiptDocumentRows(items, currentPage) {
                var body = document.querySelector(documentListBodySelector);
                if (!body) {
                    return;
                }

                var rows = Array.isArray(items) ? items : [];
                if (rows.length === 0) {
                    body.innerHTML = '<tr><td colspan="5" class="text-center text-muted">سندی پیدا نشد.</td></tr>';
                    return;
                }

                body.innerHTML = rows.map(function (document) {
                    return '<tr>' + buildReceiptDocumentActionHtml(document, currentPage) + '</tr>';
                }).join('');
            }

            function renderReceiptDocumentPagination(totalPages, currentPage) {
                var wrapper = document.querySelector(documentListPaginationWrapperSelector);
                if (!wrapper) {
                    return;
                }

                var pageCount = parseInt(totalPages || '0', 10) || 0;
                var page = parseInt(currentPage || '1', 10) || 1;
                if (pageCount <= 1) {
                    wrapper.innerHTML = '';
                    return;
                }

                var links = [];
                for (var i = 1; i <= pageCount; i++) {
                    links.push('<li class="page-item ' + (i === page ? 'active' : '') + '"><a class="page-link" href="#" data-page="' + i + '">' + i + '</a></li>');
                }

                wrapper.innerHTML = '<nav id="receipt-document-list-pagination"><ul class="pagination pagination-sm mb-0">' + links.join('') + '</ul></nav>';
            }

            async function refreshReceiptDocumentList(page) {
                var query = getReceiptListQuery(page || getCurrentReceiptListPage());
                var response = await fetch(documentListUrl + '?' + query.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                });

                if (!response.ok) {
                    throw new Error('Document list refresh failed.');
                }

                var payload = await response.json();
                if (!payload) {
                    throw new Error('Document list refresh returned empty payload.');
                }

                var totalCount = typeof payload.totalCount === 'number' ? payload.totalCount : 0;
                var currentPage = typeof payload.page === 'number' ? payload.page : getCurrentReceiptListPage();
                var totalPages = typeof payload.totalPages === 'number' ? payload.totalPages : 1;

                var countElement = document.querySelector(documentListCountSelector);
                if (countElement) {
                    countElement.textContent = totalCount + ' رکورد';
                }

                renderReceiptDocumentRows(payload.items || [], currentPage);
                renderReceiptDocumentPagination(totalPages, currentPage);
            }

            async function deleteReceiptDocument(documentId, documentNo) {
                if (!documentId) {
                    return;
                }

                if (!window.confirm('این سند ' + (documentNo ? '(' + documentNo + ')' : '') + ' و همه آیتم‌های آن حذف شوند؟')) {
                    return;
                }

                var payload = new URLSearchParams();
                payload.append('__RequestVerificationToken', getAntiForgeryToken());
                payload.append('documentId', documentId);
                payload.append('documentType', 'Receipt');
                payload.append('page', String(getCurrentReceiptListPage() || 1));
                payload.append('pageSize', getReceiptListValue('pageSize') || '@Model.DocumentPageSize');
                payload.append('documentNo', getReceiptListValue('documentNo'));
                payload.append('status', getReceiptListValue('status'));
                payload.append('occurredFrom', getReceiptListValue('occurredFrom'));
                payload.append('occurredTo', getReceiptListValue('occurredTo'));

                var response = await fetch(deleteDocumentUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'Accept': 'text/html'
                    },
                    body: payload.toString()
                });

                if (!response.ok) {
                    throw new Error('Delete document request failed.');
                }

                if (window.jQuery) {
                    window.jQuery(modalSelector).modal('hide');
                }

                await refreshReceiptDocumentList();
            }

            async function deleteReceiptDocumentLine(documentId, lineId, documentNo) {
                if (!documentId || !lineId) {
                    return;
                }

                if (!window.confirm('این آیتم حذف شود؟')) {
                    return;
                }

                var payload = new URLSearchParams();
                payload.append('__RequestVerificationToken', getAntiForgeryToken());
                payload.append('documentId', documentId);
                payload.append('lineId', lineId);

                var response = await fetch(deleteReceiptDocumentLineUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'Accept': 'text/html'
                    },
                    body: payload.toString()
                });

                if (!response.ok) {
                    throw new Error('Delete receipt line request failed.');
                }

                var html = await response.text();
                replaceReceiptDetailsModalBody(html, documentId, documentNo);
            }

            function bindReceiptDocumentListForm() {
                var form = document.querySelector(documentListFormSelector);
                if (!form || form.dataset.receiptListBound === 'true') {
                    return;
                }

                form.addEventListener('submit', function (event) {
                    event.preventDefault();
                    event.stopImmediatePropagation();
                    refreshReceiptDocumentList(1).catch(function (error) {
                        console.error(error);
                    });
                }, true);

                form.dataset.receiptListBound = 'true';
            }

            function initModalWidgets(root) {
                if (window.appUi && typeof window.appUi.initSearchableSelects === 'function') {
                    window.appUi.initSearchableSelects(root);
                }
                initializeReceiptVariantSearch(root);
                initializeReceiptInventoryChain(root);
            }

            window.appUi = window.appUi || {};
            window.appUi.initReceiptDocumentsModal = function (root) {
                initModalWidgets(root || document);
            };

            function initializeReceiptVariantSearch(root) {
                if (!window.jQuery || !window.jQuery.fn || !window.jQuery.fn.select2) {
                    return;
                }

                root = root || document;
                var selects = root.querySelectorAll('select.js-search-select[data-ajax-url]');
                selects.forEach(function (select) {
                    if (select.dataset.select2Initialized === 'true') {
                        return;
                    }

                    var ajaxUrl = select.getAttribute('data-ajax-url') || '';
                    if (!ajaxUrl) {
                        return;
                    }

                    var $select = window.jQuery(select);
                    if ($select.data('select2')) {
                        $select.select2('destroy');
                    }

                    $select.select2({
                        theme: 'bootstrap',
                        dir: document.documentElement.getAttribute('dir') || 'rtl',
                        width: select.getAttribute('data-width') || '100%',
                        placeholder: select.getAttribute('data-placeholder') || '',
                        allowClear: true,
                        minimumInputLength: 0,
                        dropdownParent: window.jQuery(modalSelector),
                        ajax: {
                            url: ajaxUrl,
                            dataType: 'json',
                            delay: 250,
                            data: function (params) {
                                return { term: params.term || '' };
                            },
                            processResults: function (data) {
                                var items = data && data.items ? data.items : [];
                                return {
                                    results: items.map(function (item) {
                                        return {
                                            id: item.id,
                                            text: item.text || item.sku || '',
                                            sku: item.sku || '',
                                            name: item.name || '',
                                            barcode: item.barcode || ''
                                        };
                                    })
                                };
                            }
                        }
                    });

                    select.dataset.select2Initialized = 'true';
                });
            }

            function getReceiptLineControls(root) {
                root = root || document;
                return {
                    variantSelect: root.querySelector('select[name="LineForm.VariantId"]'),
                    warehouseSelect: root.querySelector('select[name="LineForm.WarehouseRef"]'),
                    locationSelect: root.querySelector('select[name="LineForm.DestinationLocationRef"]')
                };
            }

            function setSelectOptions(select, items, placeholderText, valueSelector, textSelector, selectedValue) {
                if (!select) {
                    return;
                }

                while (select.firstChild) {
                    select.removeChild(select.firstChild);
                }

                var placeholder = document.createElement('option');
                placeholder.value = '';
                placeholder.textContent = placeholderText || '';
                select.appendChild(placeholder);

                (items || []).forEach(function (item) {
                    var option = document.createElement('option');
                    option.value = item[valueSelector] || '';
                    option.textContent = item[textSelector] || option.value;
                    select.appendChild(option);
                });

                select.value = selectedValue || '';
            }

            function renderReceiptWarehouseOptions(root, selectedWarehouseId) {
                var controls = getReceiptLineControls(root);
                if (!controls.warehouseSelect) {
                    return;
                }

                setSelectOptions(
                    controls.warehouseSelect,
                    receiptWarehouseOptions,
                    receiptWarehouseOptions.length ? 'انتخاب انبار' : 'انبار یافت نشد',
                    'warehouseId',
                    'text',
                    selectedWarehouseId);

                controls.warehouseSelect.disabled = receiptWarehouseOptions.length === 0;
                if (window.jQuery) {
                    window.jQuery(controls.warehouseSelect).trigger('change.select2');
                }
            }

            async function loadReceiptLocationOptions(root, selectedWarehouseId, selectedLocationId) {
                var controls = getReceiptLineControls(root);
                if (!controls.locationSelect) {
                    return;
                }

                if (!selectedWarehouseId) {
                    setSelectOptions(
                        controls.locationSelect,
                        [],
                        'ابتدا انبار را انتخاب کنید',
                        'locationId',
                        'text',
                        '');
                    controls.locationSelect.disabled = true;
                    if (window.jQuery) {
                        window.jQuery(controls.locationSelect).trigger('change.select2');
                    }
                    return;
                }

                var url = new URL(receiptLocationLookupUrl, window.location.origin);
                url.searchParams.set('warehouseId', selectedWarehouseId);

                var response = await fetch(url.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                });

                var payload = await response.json();
                if (!payload || payload.isSuccess === false) {
                    throw new Error((payload && payload.errorMessage) || 'Loading receipt warehouse locations failed.');
                }

                var locations = Array.isArray(payload.locations) ? payload.locations.slice() : [];

                setSelectOptions(
                    controls.locationSelect,
                    locations,
                    locations.length ? 'انتخاب لوکیشن' : 'برای این انبار لوکیشنی یافت نشد',
                    'locationId',
                    'text',
                    selectedLocationId);

                controls.locationSelect.disabled = locations.length === 0;
                if (window.jQuery) {
                    window.jQuery(controls.locationSelect).trigger('change.select2');
                }
            }

            async function loadReceiptWarehouses(root, selectedWarehouseId, selectedLocationId) {
                root = root || document;
                var controls = getReceiptLineControls(root);
                if (!controls.variantSelect || !controls.warehouseSelect || !controls.locationSelect) {
                    return;
                }

                var url = new URL(receiptWarehouseLookupUrl, window.location.origin);

                var response = await fetch(url.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                });

                var payload = await response.json();
                if (!payload || payload.isSuccess === false) {
                    throw new Error((payload && payload.errorMessage) || 'Loading receipt warehouses failed.');
                }

                receiptWarehouseOptions = Array.isArray(payload.warehouses) ? payload.warehouses.slice() : [];

                renderReceiptWarehouseOptions(root, selectedWarehouseId || '');
                var warehouseValue = selectedWarehouseId || controls.warehouseSelect.value || '';
                if (!warehouseValue && receiptWarehouseOptions.length === 1) {
                    warehouseValue = receiptWarehouseOptions[0].warehouseId || receiptWarehouseOptions[0].id || '';
                    controls.warehouseSelect.value = warehouseValue;
                    if (window.jQuery) {
                        window.jQuery(controls.warehouseSelect).trigger('change.select2');
                    }
                }

                await loadReceiptLocationOptions(root, warehouseValue, selectedLocationId || '');
            }

            function initializeReceiptInventoryChain(root) {
                root = root || document;
                var controls = getReceiptLineControls(root);
                if (!controls.variantSelect || !controls.warehouseSelect || !controls.locationSelect) {
                    return;
                }

                if (controls.variantSelect.dataset.receiptInventoryBound === 'true') {
                    return;
                }

                controls.warehouseSelect.addEventListener('change', function () {
                    loadReceiptLocationOptions(root, controls.warehouseSelect.value || '', controls.locationSelect.value || '').catch(function (error) {
                        console.error(error);
                    });
                });

                if (window.jQuery) {
                    window.jQuery(controls.warehouseSelect).off('select2:select.receiptChain select2:clear.receiptChain').on('select2:select.receiptChain select2:clear.receiptChain', function () {
                        window.setTimeout(function () {
                            loadReceiptLocationOptions(root, controls.warehouseSelect.value || '', '').catch(function (error) {
                                console.error(error);
                            });
                        }, 0);
                    });
                }

                controls.variantSelect.dataset.receiptInventoryBound = 'true';

                hydrateReceiptInventoryOptions(root);
                loadReceiptWarehouses(
                    root,
                    controls.warehouseSelect.value || '',
                    controls.locationSelect.value || '').catch(function (error) {
                        console.error(error);
                    });
            }

            function getAntiForgeryToken() {
                var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                return tokenInput ? tokenInput.value : '';
            }

            function replaceReceiptDetailsModalBody(html, documentId, documentNo) {
                var parser = new DOMParser();
                var doc = parser.parseFromString(html, 'text/html');
                var nextBody = doc.querySelector(modalBodySelector);
                var currentBody = document.querySelector(modalBodySelector);
                if (!nextBody || !currentBody) {
                    throw new Error('Receipt details modal body could not be loaded.');
                }

                currentBody.replaceWith(nextBody);
                initModalWidgets(nextBody);

                var titleElement = document.querySelector(modalTitleSelector);
                var subtitleElement = document.querySelector(modalSubtitleSelector);
                if (titleElement) {
                    titleElement.textContent = documentNo ? ('جزئیات سند ' + documentNo) : 'جزئیات سند رسید';
                }
                if (subtitleElement) {
                    subtitleElement.textContent = documentId || '';
                }
            }

            async function loadReceiptDetails(documentId, documentNo) {
                var url = new URL(detailsUrl, window.location.origin);
                url.searchParams.set('documentId', documentId || '');

                var response = await fetch(url.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'text/html'
                    }
                });

                var html = await response.text();
                replaceReceiptDetailsModalBody(html, documentId, documentNo);

                showModal();
            }

            function fillReceiptLineForm(trigger) {
                if (!trigger) {
                    return;
                }

                var modal = document.querySelector(modalSelector);
                if (!modal) {
                    return;
                }

                var lineIdInput = modal.querySelector('input[name="LineForm.LineId"]');
                var variantSelect = modal.querySelector('select[name="LineForm.VariantId"]');
                var warehouseSelect = modal.querySelector('select[name="LineForm.WarehouseRef"]');
                var qualitySelect = modal.querySelector('select[name="LineForm.QualityStatusRef"]');
                var qtyInput = modal.querySelector('input[name="LineForm.Qty"]');
                var useUniqueSerialItemsCheckbox = modal.querySelector('input[name="LineForm.UseUniqueSerialItems"]');
                var destinationInput = modal.querySelector('select[name="LineForm.DestinationLocationRef"]');
                var submitButton = modal.querySelector('.js-receipt-line-submit');
                var cancelButton = modal.querySelector('.js-receipt-line-cancel');
                var warehouseId = trigger.getAttribute('data-warehouse-id') || '';
                var locationId = trigger.getAttribute('data-location-id') || '';
                var qualityId = trigger.getAttribute('data-quality-id') || '';

                if (lineIdInput) {
                    lineIdInput.value = trigger.getAttribute('data-line-id') || '';
                }

                if (variantSelect) {
                    variantSelect.value = trigger.getAttribute('data-variant-id') || '';
                    if (window.jQuery) {
                        window.jQuery(variantSelect).trigger('change.select2');
                    }
                }

                if (qtyInput) {
                    qtyInput.value = trigger.getAttribute('data-qty') || '1';
                }

                if (warehouseSelect) {
                    warehouseSelect.value = warehouseId;
                }

                if (destinationInput) {
                    destinationInput.value = locationId;
                }

                if (qualitySelect) {
                    qualitySelect.value = qualityId;
                    if (window.jQuery) {
                        window.jQuery(qualitySelect).trigger('change.select2');
                    }
                }

                if (useUniqueSerialItemsCheckbox) {
                    useUniqueSerialItemsCheckbox.checked = (trigger.getAttribute('data-use-unique-serial-items') || '').toLowerCase() === 'true';
                }

                if (variantSelect && variantSelect.value) {
                    loadReceiptWarehouses(modal, warehouseId, locationId).catch(function (error) {
                        console.error(error);
                    });
                }

                if (submitButton) {
                    submitButton.textContent = 'ذخیره تغییرات';
                }

                if (cancelButton) {
                    cancelButton.classList.remove('d-none');
                }
            }

            function resetReceiptLineForm() {
                var modal = document.querySelector(modalSelector);
                if (!modal) {
                    return;
                }

                var lineIdInput = modal.querySelector('input[name="LineForm.LineId"]');
                var variantSelect = modal.querySelector('select[name="LineForm.VariantId"]');
                var warehouseSelect = modal.querySelector('select[name="LineForm.WarehouseRef"]');
                var qualitySelect = modal.querySelector('select[name="LineForm.QualityStatusRef"]');
                var qtyInput = modal.querySelector('input[name="LineForm.Qty"]');
                var useUniqueSerialItemsCheckbox = modal.querySelector('input[name="LineForm.UseUniqueSerialItems"]');
                var destinationInput = modal.querySelector('select[name="LineForm.DestinationLocationRef"]');
                var submitButton = modal.querySelector('.js-receipt-line-submit');
                var cancelButton = modal.querySelector('.js-receipt-line-cancel');

                if (lineIdInput) {
                    lineIdInput.value = '';
                }
                if (variantSelect) {
                    variantSelect.value = '';
                    if (window.jQuery) {
                        window.jQuery(variantSelect).trigger('change.select2');
                    }
                }
                if (warehouseSelect) {
                    setSelectOptions(warehouseSelect, [], 'ابتدا واریانت را انتخاب کنید', 'warehouseId', 'text', '');
                    warehouseSelect.disabled = true;
                    if (window.jQuery) {
                        window.jQuery(warehouseSelect).trigger('change.select2');
                    }
                }
                if (qualitySelect) {
                    qualitySelect.value = '';
                    if (window.jQuery) {
                        window.jQuery(qualitySelect).trigger('change.select2');
                    }
                }
                if (qtyInput) {
                    qtyInput.value = '1';
                }
                if (useUniqueSerialItemsCheckbox) {
                    useUniqueSerialItemsCheckbox.checked = false;
                }
                if (destinationInput) {
                    setSelectOptions(destinationInput, [], 'ابتدا انبار را انتخاب کنید', 'locationId', 'text', '');
                    destinationInput.disabled = true;
                    if (window.jQuery) {
                        window.jQuery(destinationInput).trigger('change.select2');
                    }
                }
                if (submitButton) {
                    submitButton.textContent = 'افزودن آیتم';
                }
                if (cancelButton) {
                    cancelButton.classList.add('d-none');
                }
            }

            function updateActionReasonVisibility() {
                var select = document.querySelector(actionSelectSelector);
                var reasonGroup = document.querySelector(actionReasonGroupSelector);
                var reasonInput = document.querySelector(actionReasonSelector);
                var postSection = document.querySelector(actionPostSectionSelector);
                if (!select || !reasonGroup) {
                    return;
                }

                var requiresReason = select.value === 'reject' || select.value === 'cancel';
                reasonGroup.style.display = requiresReason ? '' : 'none';
                if (postSection) {
                    postSection.classList.toggle('d-none', select.value !== 'post');
                    if (select.value === 'post') {
                        var postLines = document.querySelector(actionPostLinesSelector);
                        if (postLines) {
                            postLines.innerHTML = '<div class="text-muted small">شناسه‌های این ردیف هنگام ذخیره ساخته می‌شوند و در زمان پست فقط ثبت نهایی انجام می‌شود.</div>';
                        }
                    }
                }
                if (reasonInput && !requiresReason) {
                    reasonInput.value = '';
                }
            }

            function updateActionDependentSections() {
                var select = document.querySelector(actionSelectSelector);
                var idInput = document.querySelector(actionIdSelector);
                var submitButton = document.querySelector(actionSubmitSelector);
                updateActionReasonVisibility();

                if (!select || !idInput) {
                    return;
                }

                if (submitButton) {
                    var labelMap = {
                        approve: 'تایید',
                        post: 'پست',
                        reject: 'رد سند',
                        cancel: 'لغو سند'
                    };
                    submitButton.textContent = labelMap[select.value || 'approve'] || 'تایید';
                }
            }

            function escapeAttribute(value) {
                return escapeHtml(value).replace(/"/g, '&quot;');
            }

            function getPostSelectionCacheKey(documentId) {
                return String(documentId || '');
            }

            function renderReceiptPostPreviewLines(payload) {
                var container = document.querySelector(actionPostLinesSelector);
                if (!container) {
                    return;
                }

                var lines = payload && Array.isArray(payload.lines) ? payload.lines : [];
                if (lines.length === 0) {
                    container.innerHTML = '<div class="text-muted small">برای این سند ردیفی پیدا نشد.</div>';
                    return;
                }

                container.innerHTML = lines.map(function (line) {
                    var serials = Array.isArray(line.availableSerials) ? line.availableSerials : [];
                    var selectedSerials = Array.isArray(line.selectedSerials) ? line.selectedSerials : [];
                    var selectedLookup = {};
                    selectedSerials.forEach(function (serialId) {
                        selectedLookup[String(serialId || '')] = true;
                    });
                    var lineId = String(line.documentLineBusinessKey || '');
                    var toggleId = 'receipt-post-unique-' + String(line.lineNo || '').replace(/[^0-9A-Za-z_-]/g, '') + '-' + lineId.slice(0, 8);

                    var serialHtml = serials.length
                        ? serials.map(function (serial) {
                            var serialId = String(serial.serialItemBusinessKey || '');
                            var serialNo = escapeHtml(serial.serialNo || serialId || '-');
                            var checked = selectedLookup[serialId] ? ' checked' : '';
                            return '<label class="d-flex align-items-start mb-1 small border rounded px-2 py-1 bg-white">'
                                + '<input type="checkbox" class="mr-2 mt-1 js-receipt-post-serial"'
                                + ' data-line-id="' + escapeAttribute(line.documentLineBusinessKey || '') + '"'
                                + ' data-serial-id="' + escapeAttribute(serialId) + '"'
                                + ' data-serial-no="' + escapeAttribute(serial.serialNo || '') + '"'
                                + checked + ' />'
                                + '<span class="flex-grow-1">'
                                + '<span class="d-block font-weight-bold">' + serialNo + '</span>'
                                + '<span class="d-block text-muted" style="font-size: 11px;">'
                                + escapeHtml(getWarehouseLabel(serial.warehouseRef || '')) + ' / ' + escapeHtml(serial.locationRef || '') + ' / ' + escapeHtml(serial.status || '')
                                + '</span>'
                                + '</span>'
                                + '</label>';
                        }).join('')
                        : '<div class="text-muted small">شناسه یکتایی برای این ردیف در دسترس نیست. اگر این ردیف باید شناسه یکتا داشته باشد، تیک بالای همین ردیف را بزنید تا در ثبت نهایی برای هر واحد شناسه ساخته شود.</div>';

                    return ''
                        + '<div class="mb-3 pb-3 border-bottom">'
                        + '<div class="d-flex justify-content-between align-items-center mb-2">'
                        + '<div>'
                        + '<strong>ردیف ' + escapeHtml(String(line.lineNo || '')) + '</strong>'
                        + '<div class="text-muted small">' + escapeHtml(line.variantLabel || line.variantRef || '-') + '</div>'
                        + '</div>'
                        + '<div class="text-muted small">تعداد: ' + escapeHtml(String(line.qty || '0')) + '</div>'
                        + '</div>'
                        + '<div class="custom-control custom-checkbox mb-2">'
                        + '<input type="checkbox" class="custom-control-input js-receipt-post-line-unique-toggle"'
                        + ' id="' + escapeAttribute(toggleId) + '"'
                        + ' data-line-id="' + escapeAttribute(lineId) + '"' + (selectedSerials.length ? ' checked' : '') + ' />'
                        + '<label class="custom-control-label" for="' + escapeAttribute(toggleId) + '">صدور شناسه یکتا برای این ردیف</label>'
                        + '</div>'
                        + '<div class="pl-1 js-receipt-post-line-serial-container" data-line-id="' + escapeAttribute(lineId) + '">'
                        + serialHtml + '</div>'
                        + '</div>';
                }).join('');

                container.querySelectorAll('.js-receipt-post-line-unique-toggle').forEach(function (checkbox) {
                    checkbox.addEventListener('change', function () {
                        var lineId = checkbox.getAttribute('data-line-id') || '';
                        var serialContainer = container.querySelector('.js-receipt-post-line-serial-container[data-line-id="' + lineId.replace(/"/g, '\\"') + '"]');
                        if (!serialContainer) {
                            return;
                        }

                        serialContainer.classList.toggle('d-none', !checkbox.checked);
                        serialContainer.querySelectorAll('.js-receipt-post-serial').forEach(function (serialCheckbox) {
                            serialCheckbox.checked = checkbox.checked;
                        });
                    });

                    checkbox.dispatchEvent(new Event('change'));
                });

                container.querySelectorAll('.js-receipt-post-serial').forEach(function (serialCheckbox) {
                    serialCheckbox.addEventListener('change', function () {
                        var lineId = serialCheckbox.getAttribute('data-line-id') || '';
                        var serialContainer = container.querySelector('.js-receipt-post-line-serial-container[data-line-id="' + lineId.replace(/"/g, '\\"') + '"]');
                        var lineToggle = container.querySelector('.js-receipt-post-line-unique-toggle[data-line-id="' + lineId.replace(/"/g, '\\"') + '"]');
                        if (!serialContainer || !lineToggle) {
                            return;
                        }

                        var serialCheckboxes = Array.prototype.slice.call(serialContainer.querySelectorAll('.js-receipt-post-serial'));
                        lineToggle.checked = serialCheckboxes.length > 0 && serialCheckboxes.every(function (item) {
                            return item.checked;
                        });
                    });
                });
            }

            async function loadReceiptPostPreview(documentId) {
                var container = document.querySelector(actionPostLinesSelector);
                if (!container || !documentId) {
                    return;
                }

                var cacheKey = getPostSelectionCacheKey(documentId);
                if (receiptPostSelectionCache[cacheKey]) {
                    if (!container.querySelector('.js-receipt-post-serial')) {
                        renderReceiptPostPreviewLines(receiptPostSelectionCache[cacheKey]);
                    }
                    return;
                }

                container.innerHTML = '<div class="text-muted small">در حال بارگذاری...</div>';

                var url = new URL(receiptPostPreviewUrl, window.location.origin);
                url.searchParams.set('documentId', documentId);

                var response = await fetch(url.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                });

                if (!response.ok) {
                    throw new Error('Loading post preview failed.');
                }

                var payload = await response.json();
                if (!payload || payload.isSuccess === false) {
                    throw new Error((payload && payload.errorMessage) || 'Loading post preview failed.');
                }

                receiptPostSelectionCache[cacheKey] = payload;
                renderReceiptPostPreviewLines(payload);
            }

            function collectReceiptPostSelections(documentId) {
                var cacheKey = getPostSelectionCacheKey(documentId);
                var payload = receiptPostSelectionCache[cacheKey];
                if (!payload || !Array.isArray(payload.lines)) {
                    return [];
                }

                return payload.lines.map(function (line) {
                    var lineId = String(line.documentLineBusinessKey || '');
                    var lineToggle = document.querySelector(actionPostLinesSelector + ' .js-receipt-post-line-unique-toggle[data-line-id="' + lineId.replace(/"/g, '\\"') + '"]');
                    var useUniqueSerialItems = !!(lineToggle && lineToggle.checked);
                    var selectedSerials = [];
                    if (useUniqueSerialItems) {
                        document.querySelectorAll(actionPostLinesSelector + ' .js-receipt-post-serial[data-line-id="' + lineId.replace(/"/g, '\\"') + '"]').forEach(function (checkbox) {
                            if (!checkbox.checked) {
                                return;
                            }

                            selectedSerials.push({
                                SerialItemBusinessKey: checkbox.getAttribute('data-serial-id') || '',
                                SerialNo: checkbox.getAttribute('data-serial-no') || ''
                            });
                        });
                    }

                    return {
                        DocumentLineBusinessKey: lineId,
                        UseUniqueSerialItems: useUniqueSerialItems,
                        Serials: selectedSerials
                    };
                }).filter(function (line) {
                    return line.DocumentLineBusinessKey;
                });
            }

            function openActionModal(trigger) {
                var modal = document.querySelector(actionModalSelector);
                if (!modal) {
                    return;
                }

                var idInput = modal.querySelector(actionIdSelector);
                var select = modal.querySelector(actionSelectSelector);
                var reasonInput = modal.querySelector(actionReasonSelector);
                var subtitle = modal.querySelector(actionSubtitleSelector);

                if (idInput) {
                    idInput.value = trigger.getAttribute('data-document-id') || '';
                }

                if (select) {
                    select.value = 'approve';
                }

                if (reasonInput) {
                    reasonInput.value = '';
                }

                if (subtitle) {
                    var documentNo = trigger.getAttribute('data-document-no') || '';
                    var status = trigger.getAttribute('data-document-status') || '';
                    subtitle.textContent = [documentNo, status].filter(Boolean).join(' - ');
                }

                updateActionDependentSections();
                if (window.jQuery) {
                    window.jQuery(modalSelector).modal('hide');
                    window.jQuery(actionModalSelector).modal('show');
                }
            }

            async function submitAction() {
                var modal = document.querySelector(actionModalSelector);
                if (!modal) {
                    return;
                }

                var idInput = modal.querySelector(actionIdSelector);
                var select = modal.querySelector(actionSelectSelector);
                var reasonInput = modal.querySelector(actionReasonSelector);
                if (!idInput || !select) {
                    return;
                }

                var documentId = idInput.value || '';
                var action = select.value || 'approve';
                if (!changeStatusUrl) {
                    return;
                }

                var actionLabelMap = {
                    approve: 'تأیید',
                    post: 'پست',
                    reject: 'رد سند',
                    cancel: 'لغو سند'
                };
                var actionLabel = actionLabelMap[action] || 'اقدام';
                if (!window.confirm('آیا از ' + actionLabel + ' این سند اطمینان دارید؟')) {
                    return;
                }

                var payload = new URLSearchParams();
                payload.append('__RequestVerificationToken', getAntiForgeryToken());
                payload.append('DocumentId', documentId);
                payload.append('Action', action);
                if (action === 'reject' || action === 'cancel') {
                    payload.append('ReasonCode', reasonInput ? reasonInput.value || '' : '');
                }

                var response = await fetch(changeStatusUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'Accept': 'application/json'
                    },
                    body: payload.toString()
                });

                var result = await response.json();
                if (!response.ok || !result || result.isSuccess !== true) {
                    throw new Error((result && result.errorMessage) || 'تغییر وضعیت سند انجام نشد.');
                }

                if (window.jQuery) {
                    window.jQuery(actionModalSelector).modal('hide');
                }

                await refreshReceiptDocumentList();
            }

            bindReceiptDocumentListForm();

            if (!window.__receiptDocumentsModalBound) {
                window.__receiptDocumentsModalBound = true;

                document.addEventListener('click', function (event) {
                    var trigger = event.target && event.target.closest ? event.target.closest('.js-receipt-document-details') : null;
                    if (trigger) {
                        event.preventDefault();
                        var documentId = trigger.getAttribute('data-document-id') || '';
                        var documentNo = trigger.getAttribute('data-document-no') || '';
                        loadReceiptDetails(documentId, documentNo).catch(function (error) {
                            console.error(error);
                        });
                        return;
                    }

                    var deleteButton = event.target && event.target.closest ? event.target.closest('.js-receipt-document-delete') : null;
                    if (deleteButton) {
                        event.preventDefault();
                        deleteReceiptDocument(
                            deleteButton.getAttribute('data-document-id') || '',
                            deleteButton.getAttribute('data-document-no') || '').catch(function (error) {
                                console.error(error);
                            });
                        return;
                    }

                    var editButton = event.target && event.target.closest ? event.target.closest('.js-receipt-line-edit') : null;
                    if (editButton) {
                        event.preventDefault();
                        fillReceiptLineForm(editButton);
                        return;
                    }

                    var deleteLineButton = event.target && event.target.closest ? event.target.closest('.js-receipt-line-delete') : null;
                    if (deleteLineButton) {
                        event.preventDefault();
                        deleteReceiptDocumentLine(
                            deleteLineButton.getAttribute('data-document-id') || '',
                            deleteLineButton.getAttribute('data-line-id') || '',
                            deleteLineButton.getAttribute('data-document-no') || '').catch(function (error) {
                                console.error(error);
                            });
                        return;
                    }

                    var cancelButton = event.target && event.target.closest ? event.target.closest('.js-receipt-line-cancel') : null;
                    if (cancelButton) {
                        event.preventDefault();
                        resetReceiptLineForm();
                        return;
                    }

                    var paginationLink = event.target && event.target.closest ? event.target.closest(documentListPaginationSelector + ' .page-link') : null;
                    if (paginationLink) {
                        event.preventDefault();
                        var page = parseInt(paginationLink.getAttribute('data-page') || '1', 10);
                        refreshReceiptDocumentList(page).catch(function (error) {
                            console.error(error);
                        });
                        return;
                    }

                    var actionButton = event.target && event.target.closest ? event.target.closest('.js-receipt-document-action') : null;
                    if (actionButton) {
                        event.preventDefault();
                        openActionModal(actionButton);
                    }
                }, true);
            }

            if (!window.__receiptDocumentsModalAuxBound) {
                window.__receiptDocumentsModalAuxBound = true;

                var modalElement = document.querySelector(modalSelector);
                if (modalElement) {
                    hydrateReceiptInventoryOptions(modalElement);
                    modalElement.addEventListener('hidden.bs.modal', function () {
                        resetReceiptLineForm();
                    });
                }

                var actionModalElement = document.querySelector(actionModalSelector);
                if (actionModalElement) {
                    actionModalElement.addEventListener('hidden.bs.modal', function () {
                        var subtitle = document.querySelector(actionSubtitleSelector);
                        var reasonInput = document.querySelector(actionReasonSelector);
                        var idInput = document.querySelector(actionIdSelector);
                        var select = document.querySelector(actionSelectSelector);
                        var submitButton = document.querySelector(actionSubmitSelector);
                        var postLines = document.querySelector(actionPostLinesSelector);
                        if (subtitle) {
                            subtitle.textContent = '';
                        }
                        if (reasonInput) {
                            reasonInput.value = '';
                        }
                        if (idInput) {
                            idInput.value = '';
                        }
                        if (select) {
                            select.value = 'approve';
                        }
                        if (submitButton) {
                            submitButton.textContent = 'تایید';
                        }
                        if (postLines) {
                            postLines.innerHTML = '<div class="text-muted small">در این حالت نیازی به انتخاب شناسه یکتا نیست.</div>';
                        }
                        receiptPostSelectionCache = {};
                        updateActionReasonVisibility();
                    });

                    var selectElement = document.querySelector(actionSelectSelector);
                    if (selectElement) {
                        selectElement.addEventListener('change', updateActionDependentSections);
                    }

                    var submitButton = document.querySelector(actionSubmitSelector);
                    if (submitButton) {
                        submitButton.addEventListener('click', function () {
                            submitAction().catch(function (error) {
                                console.error(error);
                            });
                        });
                    }
                }
            }
        })();
    </script>
    <script data-ajax-reinit="document-user-create">
        (function () {
            var modalSelector = '#document-user-create-modal';
            var formSelector = '#document-user-create-form';
            var errorSelector = '#document-user-create-error';
            var createUserUrl = '@Url.Action("CreateDocumentUser", "InventoryManagement")';

            function showModal() {
                if (window.jQuery && window.jQuery.fn && window.jQuery.fn.modal) {
                    window.jQuery(modalSelector).modal('show');
                }
            }

            function hideModal() {
                if (window.jQuery && window.jQuery.fn && window.jQuery.fn.modal) {
                    window.jQuery(modalSelector).modal('hide');
                }
            }

            function setError(message) {
                var errorBox = document.querySelector(errorSelector);
                if (!errorBox) {
                    return;
                }

                if (!message) {
                    errorBox.textContent = '';
                    errorBox.classList.add('d-none');
                    return;
                }

                errorBox.textContent = message;
                errorBox.classList.remove('d-none');
            }

            function resetForm() {
                var form = document.querySelector(formSelector);
                if (!form) {
                    return;
                }

                form.reset();
                if (window.jQuery) {
                    window.jQuery(form).find('select').trigger('change.select2');
                }
                setError('');
            }

            async function submitUserForm(event) {
                event.preventDefault();
                event.stopPropagation();

                var form = event.currentTarget;
                setError('');

                var response = await fetch(createUserUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    body: new FormData(form)
                });

                var payload = await response.json();
                if (!payload || payload.isSuccess === false) {
                    setError((payload && payload.errorMessage) || 'ایجاد کاربر انجام نشد.');
                    return;
                }

                hideModal();
                window.location.reload();
            }

            document.addEventListener('click', function (event) {
                var trigger = event.target && event.target.closest ? event.target.closest('.js-open-document-user-modal') : null;
                if (!trigger) {
                    return;
                }

                event.preventDefault();
                resetForm();
                showModal();
            }, true);

            var form = document.querySelector(formSelector);
            if (form && form.dataset.documentUserCreateBound !== 'true') {
                form.addEventListener('submit', function (event) {
                    submitUserForm(event).catch(function (error) {
                        console.error(error);
                        setError('ایجاد کاربر انجام نشد.');
                    });
                });
                form.dataset.documentUserCreateBound = 'true';
            }

            var modalElement = document.querySelector(modalSelector);
            if (modalElement && modalElement.dataset.documentUserCreateInit !== 'true') {
                if (window.appUi && typeof window.appUi.initSearchableSelects === 'function') {
                    window.appUi.initSearchableSelects(modalElement);
                }
                modalElement.addEventListener('hidden.bs.modal', function () {
                    resetForm();
                });
                modalElement.dataset.documentUserCreateInit = 'true';
            }
        })();
    </script>
}


