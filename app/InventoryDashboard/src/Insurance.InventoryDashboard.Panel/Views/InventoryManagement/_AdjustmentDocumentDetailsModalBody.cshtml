@using System
@using System.Linq
@model Insurance.InventoryDashboard.Panel.Models.InventoryDocumentManagementPageViewModel
@{
    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x => string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) || string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));

    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    string VariantLabel(Insurance.InventoryDashboard.Panel.Models.ProductVariantSummaryModel variant)
    {
        var variantName = (variant.Name ?? string.Empty).Trim();
        var variantSku = (variant.Sku ?? string.Empty).Trim();
        if (!string.IsNullOrWhiteSpace(variantName) && !string.IsNullOrWhiteSpace(variantSku) && !string.Equals(variantName, variantSku, StringComparison.OrdinalIgnoreCase))
        {
            return $"{variantName} ({variantSku})";
        }

        if (!string.IsNullOrWhiteSpace(variantName))
        {
            return variantName;
        }

        if (!string.IsNullOrWhiteSpace(variantSku))
        {
            return variantSku;
        }

        if (!string.IsNullOrWhiteSpace(variant.Barcode))
        {
            return variant.Barcode.Trim();
        }

        return variant.Id;
    }

    string VariantName(string? variantId)
    {
        if (string.IsNullOrWhiteSpace(variantId))
        {
            return "-";
        }

        var variant = Model.VariantLookup.FirstOrDefault(x => string.Equals(x.Id, variantId, StringComparison.OrdinalIgnoreCase));
        return variant is null ? variantId : VariantLabel(variant);
    }

    string LocationName(string? locationId)
    {
        if (string.IsNullOrWhiteSpace(locationId))
        {
            return "-";
        }

        var location = Model.LocationLookup.FirstOrDefault(x => string.Equals(x.LocationBusinessKey, locationId, StringComparison.OrdinalIgnoreCase));
        return location is null ? locationId : $"{location.LocationCode} ({location.LocationType})";
    }

    string UomName(string? uomId)
    {
        if (string.IsNullOrWhiteSpace(uomId))
        {
            return "-";
        }

        var uom = Model.UnitOfMeasureLookup.FirstOrDefault(x => string.Equals(x.Id, uomId, StringComparison.OrdinalIgnoreCase));
        return uom is null ? uomId : $"{uom.Code} - {uom.Name}";
    }

    string AdjustmentDirectionLabel(string? direction) => direction switch
    {
        "Increase" => UiText["inventory.documents.adjustment.increase"],
        "Decrease" => UiText["inventory.documents.adjustment.decrease"],
        _ => string.IsNullOrWhiteSpace(direction) ? "-" : direction
    };

    var selectedDocument = Model.SelectedDocumentDetails;
    var selectedDocumentType = selectedDocument?.DocumentType ?? "Adjustment";
    var canEditLines = selectedDocument is not null && string.Equals(selectedDocument.Status, "Draft", StringComparison.OrdinalIgnoreCase);
    var selectedDirection = Model.LineForm.AdjustmentDirection ?? string.Empty;
    var selectedLocationRef = string.Equals(selectedDirection, "Increase", StringComparison.OrdinalIgnoreCase)
        ? (string.IsNullOrWhiteSpace(Model.LineForm.DestinationLocationRef) ? Model.LineForm.SourceLocationRef : Model.LineForm.DestinationLocationRef)
        : string.Equals(selectedDirection, "Decrease", StringComparison.OrdinalIgnoreCase)
            ? (string.IsNullOrWhiteSpace(Model.LineForm.SourceLocationRef) ? Model.LineForm.DestinationLocationRef : Model.LineForm.SourceLocationRef)
            : !string.IsNullOrWhiteSpace(Model.LineForm.SourceLocationRef)
                ? Model.LineForm.SourceLocationRef
                : Model.LineForm.DestinationLocationRef;
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

@if (selectedDocument is null)
{
    <div class="alert alert-light mb-0">@UiText["inventory.documents.adjustment.noDocumentSelected"]</div>
}
else
{
    <div class="border rounded p-3 bg-light mb-3">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h5 class="mb-1">@(Model.LineForm.LineId is null ? UiText["inventory.documents.adjustment.line.addTitle"] : UiText["inventory.documents.adjustment.line.editTitle"])</h5>
                <div class="text-muted small">@UiText["inventory.documents.adjustment.line.description"]</div>
            </div>
            <span class="badge badge-pill badge-outline-secondary">@selectedDocument.Status</span>
        </div>

        <div class="small text-muted mb-3">
            <span class="text-monospace">@selectedDocument.DocumentNo</span>
            <span class="mx-2">|</span>
            <span>@selectedDocument.OccurredAt.ToString("yyyy/MM/dd HH:mm")</span>
            <span class="mx-2">|</span>
            <span>@(string.IsNullOrWhiteSpace(selectedDocument.ReasonCode) ? "-" : selectedDocument.ReasonCode)</span>
        </div>

        <div class="border rounded p-3 bg-white mb-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <strong>@UiText["inventory.documents.adjustment.inventorySummaryTitle"]</strong>
                <span class="text-muted small">@UiText["inventory.documents.adjustment.inventorySummaryDescription"]</span>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="small text-muted mb-2">@UiText["inventory.documents.adjustment.locationListTitle"]</div>
                    <div class="js-adjustment-location-list">
                        <div class="text-muted small">@UiText["inventory.documents.adjustment.selectVariantToLoadInventory"]</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="small text-muted mb-2">@UiText["inventory.documents.adjustment.lotListTitle"]</div>
                    <div class="js-adjustment-lot-list">
                        <div class="text-muted small">@UiText["inventory.documents.adjustment.selectVariantToLoadInventory"]</div>
                    </div>
                </div>
            </div>
        </div>

        <form asp-action="SaveAdjustmentDocumentLine" asp-controller="InventoryManagement" method="post" data-loading-form data-ajax-target="#adjustment-document-details-modal-body" id="adjustment-document-line-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="LineForm.DocumentId" value="@selectedDocument.DocumentBusinessKey" />
            <input type="hidden" asp-for="LineForm.DocumentType" value="@selectedDocumentType" />
            <input type="hidden" asp-for="LineForm.LineId" value="@Model.LineForm.LineId" />
            <div class="form-row">
                <div class="form-group col-md-3">
                    <label>@UiText["inventory.documents.line.adjustmentDirection"]</label>
                    <select asp-for="LineForm.AdjustmentDirection" class="form-control js-adjustment-direction-select" required>
                        <option value="">@UiText["common.select"]</option>
                        <option value="Increase" selected="@(string.Equals(selectedDirection, "Increase", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["inventory.documents.adjustment.increase"]</option>
                        <option value="Decrease" selected="@(string.Equals(selectedDirection, "Decrease", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UiText["inventory.documents.adjustment.decrease"]</option>
                    </select>
                </div>
                <div class="form-group col-md-6">
                    <label>@UiText["inventory.documents.line.variant"]</label>
                    <select asp-for="LineForm.VariantId" class="form-control js-search-select js-adjustment-variant-select" data-placeholder="@UiText["inventory.documents.line.selectVariant"]" required>
                        <option value="">@UiText["inventory.documents.line.selectVariant"]</option>
                        @foreach (var variant in Model.VariantLookup.OrderBy(x => x.Sku))
                        {
                            <option value="@variant.Id" selected="@(variant.Id == Model.LineForm.VariantId ? "selected" : null)">@VariantLabel(variant)</option>
                        }
                    </select>
                </div>
                <div class="form-group col-md-3">
                    <label>@UiText["common.quantity"]</label>
                    <input asp-for="LineForm.Qty" type="number" step="0.0001" min="0.0001" class="form-control" required />
                </div>
            </div>

            <input type="hidden" asp-for="LineForm.SourceLocationRef" />
            <input type="hidden" asp-for="LineForm.DestinationLocationRef" />
            <div class="form-row">
                <div class="form-group col-md-12 js-adjustment-location-section">
                    <label class="js-adjustment-location-label">@UiText["common.location"]</label>
                    <select class="form-control js-search-select js-adjustment-location-select" data-placeholder="@UiText["inventory.documents.line.selectLocation"]">
                        <option value="">@UiText["inventory.documents.line.selectLocation"]</option>
                        @foreach (var location in Model.LocationLookup.OrderBy(x => x.LocationCode))
                        {
                            <option value="@location.LocationBusinessKey" data-warehouse-ref="@location.WarehouseRef" selected="@(location.LocationBusinessKey == selectedLocationRef ? "selected" : null)">@location.LocationCode (@location.LocationType)</option>
                        }
                    </select>
                    <small class="text-muted d-block mt-1 js-adjustment-location-hint">@UiText["inventory.documents.adjustment.selectDirectionToLoadSerials"]</small>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-md-12">
                    <label>@UiText["common.reason"]</label>
                    <input asp-for="LineForm.ReasonCode" class="form-control" required />
                </div>
            </div>

            <div class="border rounded p-3 bg-white mb-3 js-adjustment-increase-section">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong>@UiText["inventory.documents.adjustment.increaseSerialsDescription"]</strong>
                    <span class="text-muted small">@UiText["inventory.documents.adjustment.increaseSerialsDescription"]</span>
                </div>
                <div class="js-adjustment-increase-serial-list">
                    <div class="text-muted small">@UiText["inventory.documents.adjustment.selectDirectionToLoadSerials"]</div>
                </div>
            </div>

            <div class="border rounded p-3 bg-white mb-3 js-adjustment-decrease-section">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong>@UiText["inventory.documents.adjustment.decreaseSerialsDescription"]</strong>
                    <span class="text-muted small">@UiText["inventory.documents.adjustment.decreaseSerialsDescription"]</span>
                </div>
                <div class="js-adjustment-decrease-serial-list">
                    <div class="text-muted small">@UiText["inventory.documents.adjustment.selectDirectionToLoadSerials"]</div>
                </div>
            </div>

            <div class="border rounded p-3 bg-white mb-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong>@UiText["inventory.documents.adjustment.selectedSerialsTitle"]</strong>
                    <span class="text-muted small">@UiText["inventory.documents.adjustment.selectedSerialsDescription"]</span>
                </div>
                <div class="js-adjustment-selected-serials">
                    @if (Model.LineForm.Serials.Count == 0)
                    {
                        <div class="text-muted small">@UiText["inventory.documents.serial.noSelected"]</div>
                    }
                    else
                    {
                        foreach (var serial in Model.LineForm.Serials)
                        {
                            <div class="badge badge-light border d-inline-flex align-items-center mr-2 mb-2 py-2 px-3 js-adjustment-selected-serial" data-serial-id="@serial.SerialItemBusinessKey">
                                <span class="font-weight-bold">@serial.SerialNo</span>
                                <button type="button" class="btn btn-link btn-sm text-danger ml-2 p-0 js-adjustment-remove-serial">&times;</button>
                                <input type="hidden" name="LineForm.Serials.Index" value="@serial.SerialItemBusinessKey" />
                                <input type="hidden" name="LineForm.Serials[@serial.SerialItemBusinessKey].SerialItemBusinessKey" value="@serial.SerialItemBusinessKey" />
                                <input type="hidden" name="LineForm.Serials[@serial.SerialItemBusinessKey].SerialNo" value="@serial.SerialNo" />
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="d-flex justify-content-end">
                <button class="btn btn-primary" type="submit">@(string.IsNullOrWhiteSpace(Model.LineForm.LineId) ? UiText["common.add"] : UiText["inventory.documents.action.saveChanges"])</button>
            </div>
        </form>
    </div>

    <div class="border rounded p-3 bg-white">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="mb-0">@UiText["inventory.documents.details.title"]</h5>
                <div class="text-muted small">@selectedDocument.DocumentNo</div>
            </div>
            <span class="badge badge-pill badge-outline-secondary">@selectedDocument.Status</span>
        </div>

        <p class="mb-1"><strong>@UiText["inventory.documents.details.number"]:</strong> <span class="text-monospace">@selectedDocument.DocumentNo</span></p>
        <p class="mb-1"><strong>@UiText["inventory.documents.details.type"]:</strong> @UiText["inventory.documents.type.adjustment"]</p>
        <p class="mb-1"><strong>@UiText["common.warehouse"]:</strong> @(string.IsNullOrWhiteSpace(selectedDocument.WarehouseRef) ? "-" : selectedDocument.WarehouseRef)</p>
        <p class="mb-1"><strong>@UiText["common.seller"]:</strong> @(string.IsNullOrWhiteSpace(selectedDocument.SellerRef) ? "-" : selectedDocument.SellerRef)</p>
        <p class="mb-1"><strong>@UiText["inventory.documents.details.occurredAt"]:</strong> @selectedDocument.OccurredAt.ToString("yyyy/MM/dd HH:mm")</p>
        <p class="mb-1"><strong>@UiText["inventory.documents.details.reason"]:</strong> @(string.IsNullOrWhiteSpace(selectedDocument.ReasonCode) ? "-" : selectedDocument.ReasonCode)</p>
        <p class="mb-1"><strong>@UiText["inventory.documents.details.approvedAt"]:</strong> @(selectedDocument.ApprovedAt?.ToString("yyyy/MM/dd HH:mm") ?? "-")</p>
        <p class="mb-3"><strong>@UiText["inventory.documents.details.postedAt"]:</strong> @(selectedDocument.PostedAt?.ToString("yyyy/MM/dd HH:mm") ?? "-")</p>

        <div class="border-top pt-3 mt-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0">@UiText["inventory.documents.lines.title"]</h6>
                <span class="text-muted small">@selectedDocument.Lines.Count @UiText["common.line"]</span>
            </div>
            @if (selectedDocument.Lines.Count == 0)
            {
                <div class="alert alert-light mb-0">@UiText["inventory.documents.lines.noRecords"]</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>@UiText["inventory.documents.line.variant"]</th>
                                <th>@UiText["common.quantity"]</th>
                                <th>@UiText["inventory.documents.line.uom"]</th>
                                <th>@UiText["inventory.documents.line.sourceLocation"]</th>
                                <th>@UiText["inventory.documents.line.destinationLocation"]</th>
                                <th>@UiText["inventory.documents.line.adjustmentDirection"]</th>
                                <th>@UiText["common.reason"]</th>
                                <th class="text-right">@UiText["common.operation"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in selectedDocument.Lines)
                            {
                                <tr>
                                    <td>@VariantName(line.VariantRef)</td>
                                    <td>
                                        <span class="text-monospace">
                                            @(string.Equals(line.AdjustmentDirection, "Decrease", StringComparison.OrdinalIgnoreCase) ? "-" : "+")@line.Qty.ToString("0.####")
                                        </span>
                                    </td>
                                    <td>@UomName(line.UomRef)</td>
                                    <td>@LocationName(line.SourceLocationRef)</td>
                                    <td>@LocationName(line.DestinationLocationRef)</td>
                                    <td>@AdjustmentDirectionLabel(line.AdjustmentDirection)</td>
                                    <td>@(string.IsNullOrWhiteSpace(line.ReasonCode) ? "-" : line.ReasonCode)</td>
                                    <td class="text-right">
                                        @if (canEditLines)
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-primary btn-xs js-adjustment-line-edit mr-1"
                                                    data-document-id="@selectedDocument.DocumentBusinessKey"
                                                    data-line-id="@line.LineBusinessKey">@UiText["common.edit"]</button>
                                            <form asp-action="DeleteAdjustmentDocumentLine"
                                                  asp-controller="InventoryManagement"
                                                  method="post"
                                                  class="d-inline"
                                                  data-loading-form
                                                  data-ajax-target="#adjustment-document-details-modal-body"
                                                  onsubmit="return confirm('@UiText["inventory.documents.confirm.deleteLine"]');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="documentId" value="@selectedDocument.DocumentBusinessKey" />
                                                <input type="hidden" name="lineId" value="@line.LineBusinessKey" />
                                                <button class="btn btn-outline-danger btn-xs" type="submit">@UiText["common.delete"]</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                                @if (!string.IsNullOrWhiteSpace(line.LotBatchNo) || line.BaseQty != line.Qty || !string.Equals(line.BaseUomRef, line.UomRef, StringComparison.OrdinalIgnoreCase))
                                {
                                    <tr>
                                        <td colspan="8" class="text-muted small">
                                            Base: @line.BaseQty.ToString("0.####") @UomName(line.BaseUomRef)
                                            @if (!string.IsNullOrWhiteSpace(line.LotBatchNo))
                                            {
                                                <span> | @UiText["inventory.documents.line.lotBatch"]: @line.LotBatchNo</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @if (canEditLines)
        {
            var selectedStatus = selectedDocument.Status;
            var canApproveByStatus = string.Equals(selectedStatus, "Draft", StringComparison.OrdinalIgnoreCase);
            var canRejectByStatus = !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase)
                && !string.Equals(selectedStatus, "Cancelled", StringComparison.OrdinalIgnoreCase);
            var canCancelByStatus = !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase)
                && !string.Equals(selectedStatus, "Rejected", StringComparison.OrdinalIgnoreCase);
            var canPostByStatus = !string.Equals(selectedStatus, "Cancelled", StringComparison.OrdinalIgnoreCase)
                && !string.Equals(selectedStatus, "Rejected", StringComparison.OrdinalIgnoreCase)
                && !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase);

            <div class="border-top pt-3">
                <div class="mb-2 text-muted small">@UiText["inventory.documents.action.changeStatus"]</div>
                <div class="d-flex flex-wrap">
                    <form asp-action="ApproveDocument" asp-controller="InventoryManagement" method="post" class="mr-1 mb-1" data-loading-form data-ajax-target="#adjustment-document-details-modal-body" data-ajax-close-modal-on-success>
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="documentId" value="@selectedDocument.DocumentBusinessKey" />
                        <button class="btn btn-outline-info btn-xs" type="submit" @(Can("Inventory.Document.Approve", "InventoryDocument.Approve", "Document.Approve") && canApproveByStatus ? null : "disabled")>@UiText["inventory.documents.action.approve"]</button>
                    </form>
                    <form asp-action="PostDocument" asp-controller="InventoryManagement" method="post" class="mr-1 mb-1" data-loading-form data-ajax-target="#adjustment-document-details-modal-body" data-ajax-close-modal-on-success>
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="documentId" value="@selectedDocument.DocumentBusinessKey" />
                        <button class="btn btn-outline-success btn-xs" type="submit" @(Can("Inventory.Document.Post", "InventoryDocument.Post", "Document.Post") && canPostByStatus ? null : "disabled")>@UiText["inventory.documents.action.post"]</button>
                    </form>
                </div>
                <form asp-action="RejectDocument" asp-controller="InventoryManagement" method="post" class="mt-2" data-loading-form data-ajax-target="#adjustment-document-details-modal-body" data-ajax-close-modal-on-success>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="DocumentId" value="@selectedDocument.DocumentBusinessKey" />
                    <div class="form-group mb-2">
                        <label class="small">@UiText["inventory.documents.action.reject"]</label>
                        <input name="ReasonCode" class="form-control form-control-sm" />
                    </div>
                    <button class="btn btn-outline-danger btn-xs" type="submit" @(Can("Inventory.Document.Reject", "InventoryDocument.Reject", "Document.Reject") && canRejectByStatus ? null : "disabled")>@UiText["inventory.documents.action.reject"]</button>
                </form>
                <form asp-action="CancelDocument" asp-controller="InventoryManagement" method="post" class="mt-2" data-loading-form data-ajax-target="#adjustment-document-details-modal-body" data-ajax-close-modal-on-success>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="DocumentId" value="@selectedDocument.DocumentBusinessKey" />
                    <div class="form-group mb-2">
                        <label class="small">@UiText["inventory.documents.action.cancel"]</label>
                        <input name="ReasonCode" class="form-control form-control-sm" />
                    </div>
                    <button class="btn btn-outline-warning btn-xs" type="submit" @(Can("Inventory.Document.Cancel", "InventoryDocument.Cancel", "Document.Cancel") && canCancelByStatus ? null : "disabled")>@UiText["inventory.documents.action.cancel"]</button>
                </form>
            </div>
        }
    </div>
}
