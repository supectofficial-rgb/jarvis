                                                @foreach (var line in Model.SelectedDocumentDetails.Lines)
                                                {
                                                    var lineProductId = VariantProductId(line.VariantRef);
                                                    <tr>
                                                        <td>
                                                            @if (!string.IsNullOrWhiteSpace(lineProductId))
                                                            {
                                                                <a asp-controller="VariantManagement"
                                                                   asp-action="Variants"
                                                                   asp-route-productId="@lineProductId"
                                                                   asp-route-variantId="@line.VariantRef">
                                                                    @VariantName(line.VariantRef)
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <span>@VariantName(line.VariantRef)</span>
                                                            }
                                                        </td>
                                                        <td>@line.Qty.ToString("0.####")</td>
                                                        <td>@UomName(line.UomRef)</td>
                                                        <td>@LocationName(line.SourceLocationRef)</td>
                                                        <td>@LocationName(line.DestinationLocationRef)</td>
                                                        @if (showQualityColumn)
                                                        {
                                                            <td>
                                                                @if (string.Equals(selectedDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase))
                                                                {
                                                                    <span>@QualityName(line.FromQualityStatusRef) -> @QualityName(line.ToQualityStatusRef)</span>
                                                                }
                                                                else
                                                                {
                                                                    <span>@QualityName(line.QualityStatusRef)</span>
                                                                }
                                                            </td>
                                                        }
                                                        <td>
                                                            @(string.IsNullOrWhiteSpace(line.ReasonCode) ? AdjustmentDirectionLabel(line.AdjustmentDirection) : line.ReasonCode)
                                                        </td>
                                                        @if (canEditLines)
                                                        {
                                                            <td class="text-right">
                                                                <a class="btn btn-outline-primary btn-xs" asp-action="@documentAction" asp-controller="InventoryManagement" asp-route-documentId="@Model.SelectedDocumentDetails.DocumentBusinessKey" asp-route-editingLineId="@line.LineBusinessKey" asp-route-documentType="@Model.SelectedDocumentDetails.DocumentType" data-ajax-target="#documents-page-root">ویرایش</a>
                                                                <form asp-action="DeleteDocumentLine" asp-controller="InventoryManagement" method="post" class="d-inline" data-loading-form data-ajax-target="#documents-page-root" onsubmit="return confirm('این آیتم حذف شود؟');">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="documentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                                                    <input type="hidden" name="lineId" value="@line.LineBusinessKey" />
                                                                    <button class="btn btn-outline-danger btn-xs" type="submit">حذف</button>
                                                                </form>
                                                            </td>
                                                        }
                                                    </tr>
                                                    @if (!string.IsNullOrWhiteSpace(line.LotBatchNo) || line.BaseQty != line.Qty || !string.Equals(line.BaseUomRef, line.UomRef, StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <tr>
                                                            <td colspan="@(showQualityColumn ? 8 : 7)" class="text-muted small">
                                                                Base: @line.BaseQty.ToString("0.####") @UomName(line.BaseUomRef)
                                                                @if (!string.IsNullOrWhiteSpace(line.LotBatchNo))
                                                                {
                                                                    <span> | لات/بچ: @line.LotBatchNo</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>

                            var selectedStatus = Model.SelectedDocumentDetails.Status;
                            var canApproveByStatus = string.Equals(selectedStatus, "Draft", StringComparison.OrdinalIgnoreCase);
                            var canRejectByStatus = !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Cancelled", StringComparison.OrdinalIgnoreCase);
                            var canCancelByStatus = !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Rejected", StringComparison.OrdinalIgnoreCase);
                            var canPostByStatus = !string.Equals(selectedStatus, "Cancelled", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Rejected", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase);

                            <div class="border-top pt-3">
                                <div class="mb-2 text-muted small">تغییر وضعیت</div>
                                <div class="d-flex flex-wrap">
                                    <form asp-action="ApproveDocument" asp-controller="InventoryManagement" method="post" class="mr-1 mb-1" data-loading-form data-ajax-target="#documents-page-root" data-ajax-close-modal-on-success>
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="documentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                        <button class="btn btn-outline-info btn-xs" type="submit" @(Can("Inventory.Document.Approve", "InventoryDocument.Approve", "Document.Approve") && canApproveByStatus ? null : "disabled")>تایید</button>
                                    </form>
                                    <form asp-action="PostDocument" asp-controller="InventoryManagement" method="post" class="mr-1 mb-1" data-loading-form data-ajax-target="#documents-page-root" data-ajax-close-modal-on-success>
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="documentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                        <button class="btn btn-outline-success btn-xs" type="submit" @(Can("Inventory.Document.Post", "InventoryDocument.Post", "Document.Post") && canPostByStatus ? null : "disabled")>پست</button>
                                    </form>
                                </div>
                                <form asp-action="RejectDocument" asp-controller="InventoryManagement" method="post" class="mt-2" data-loading-form data-ajax-target="#documents-page-root" data-ajax-close-modal-on-success>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                    <div class="form-group mb-2">
                                        <label class="small">علت رد</label>
                                        <input name="ReasonCode" class="form-control form-control-sm" />
                                    </div>
                                    <button class="btn btn-outline-danger btn-xs" type="submit" @(Can("Inventory.Document.Reject", "InventoryDocument.Reject", "Document.Reject") && canRejectByStatus ? null : "disabled")>رد سند</button>
                                </form>
                                <form asp-action="CancelDocument" asp-controller="InventoryManagement" method="post" class="mt-2" data-loading-form data-ajax-target="#documents-page-root" data-ajax-close-modal-on-success>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                    <div class="form-group mb-2">
                                        <label class="small">علت لغو</label>
                                        <input name="ReasonCode" class="form-control form-control-sm" />
                                    </div>
                                    <button class="btn btn-outline-warning btn-xs" type="submit" @(Can("Inventory.Document.Cancel", "InventoryDocument.Cancel", "Document.Cancel") && canCancelByStatus ? null : "disabled")>لغو سند</button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script data-ajax-reinit="documents">
        (function () {
            var lineContainer = document.getElementById('document-lines');
            var addLineButton = document.getElementById('add-document-line');
            var documentTypeSelect = document.getElementById('document-type-input');
            var warehouseSelect = document.getElementById('create-warehouse-select');
            var createForm = document.getElementById('document-create-form');
            var linesPanel = document.getElementById('document-lines-panel');
            var toggleLinesButton = document.getElementById('toggle-document-lines');
            var typeGuidance = document.getElementById('document-type-guidance');
            var validationSummary = document.getElementById('document-validation-summary');
            var conversionPreviewForm = document.getElementById('conversion-preview-form');
            var conversionPreviewContainer = document.getElementById('conversion-preview-container');

            var documentTypeConfig = {
                Receipt: {
                    title: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.receipt.title"])),
                    text: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.receipt.description"])),
                    source: false,
                    destination: true,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                Issue: {
                    title: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.issue.title"])),
                    text: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.issue.description"])),
                    source: true,
                    destination: false,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                Transfer: {
                    title: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.transfer.title"])),
                    text: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.transfer.description"])),
                    source: true,
                    destination: true,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                Adjustment: {
                    title: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.adjustment.title"])),
                    text: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.adjustment.description"])),
                    source: false,
                    destination: false,
                    quality: false,
                    qualityChange: false,
                    adjustment: true,
                    lineReason: true
                },
                Return: {
                    title: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.return.title"])),
                    text: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.return.description"])),
                    source: false,
                    destination: true,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                QualityChange: {
                    title: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.qualityChange.title"])),
                    text: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.qualityChange.description"])),
                    source: false,
                    destination: false,
                    quality: false,
                    qualityChange: true,
                    adjustment: false,
                    lineReason: false
                },
                Conversion: {
                    title: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.conversion.title"])),
                    text: @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.conversion.createInfo"])),
                    source: true,
                    destination: true,
                    quality: true,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false,
                    exclusiveFlow: true
                }
            };

            function setRequired(selectors, isRequired, line) {
                selectors.forEach(function (selector) {
                    line.querySelectorAll(selector).forEach(function (field) {
                        if (isRequired) {
                            field.setAttribute('required', 'required');
                        } else {
                            field.removeAttribute('required');
                        }
                    });
                });
            }

            function setLinesPanelVisible(isVisible) {
                if (!linesPanel) {
                    return;
                }

                linesPanel.classList.toggle('d-none', !isVisible);
                if (toggleLinesButton) {
                    toggleLinesButton.textContent = isVisible ? 'پنهان کردن واریانت' : 'افزودن واریانت';
                }
            }

            function clearValidation() {
                if (validationSummary) {
                    validationSummary.style.display = 'none';
                    validationSummary.textContent = '';
                }

                lineContainer.querySelectorAll('.is-invalid').forEach(function (field) {
                    field.classList.remove('is-invalid');
                });
            }

            function showValidation(message, field) {
                if (validationSummary) {
                    validationSummary.textContent = message;
                    validationSummary.style.display = '';
                }

                if (field) {
                    field.classList.add('is-invalid');
                    field.focus();
                }
            }

            function selectedConfig() {
                var type = documentTypeSelect ? documentTypeSelect.value : 'Receipt';
                return documentTypeConfig[type] || documentTypeConfig.Receipt;
            }

            function renumberLines() {
                var lines = lineContainer.querySelectorAll('.document-line');
                lines.forEach(function (line, index) {
                    line.setAttribute('data-line-index', index);
                    var title = line.querySelector('strong');
                    if (title) {
                        title.textContent = 'ردیف ' + (index + 1);
                    }

                    line.querySelectorAll('input, select, textarea').forEach(function (field) {
                        if (field.name) {
                            field.name = field.name.replace(/CreateForm\.Lines\[\d+\]/g, 'CreateForm.Lines[' + index + ']');
                        }
                    });
                });
            }

            function toggleTypeFields() {
                var currentType = documentTypeSelect ? documentTypeSelect.value : 'Receipt';
                if (currentType === 'Conversion') {
                    if (typeGuidance) {
                        typeGuidance.innerHTML = '<strong>' + @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.info.conversion.title"])) + '</strong><div class="small mt-1">' + @Html.Raw(JsonSerializer.Serialize(UiText["inventory.documents.conversion.createInfo"])) + '</div>';
                    }

                    if (linesPanel) {
                        linesPanel.classList.add('d-none');
                    }

                    return true;
                }

                var config = selectedConfig();
                if (typeGuidance) {
                    typeGuidance.innerHTML = '<strong>' + config.title + '</strong><div class="small mt-1">' + config.text + '</div>';
                }

                lineContainer.querySelectorAll('.document-line').forEach(function (line) {
                    line.querySelectorAll('.line-source').forEach(function (el) { el.style.display = config.source ? '' : 'none'; });
                    line.querySelectorAll('.line-destination').forEach(function (el) { el.style.display = config.destination ? '' : 'none'; });
                    line.querySelectorAll('.line-adjustment').forEach(function (el) { el.style.display = config.adjustment ? '' : 'none'; });
                    line.querySelectorAll('.line-quality').forEach(function (el) { el.style.display = config.quality ? '' : 'none'; });
                    line.querySelectorAll('.line-from-quality, .line-to-quality').forEach(function (el) { el.style.display = config.qualityChange ? '' : 'none'; });
                    line.querySelectorAll('.line-reason').forEach(function (el) { el.style.display = config.lineReason ? '' : 'none'; });

                    setRequired(['.source-location-select'], config.source && !config.exclusiveFlow, line);
                    setRequired(['.destination-location-select'], config.destination && !config.exclusiveFlow, line);
                    setRequired(['.line-adjustment select'], config.adjustment, line);
                    setRequired(['.line-reason input'], config.lineReason, line);
                    setRequired(['.line-from-quality select', '.line-to-quality select'], config.qualityChange, line);
                    setRequired(['.line-quality select'], !!config.quality && !config.qualityChange, line);
                });
            }

            function syncLocationsToWarehouse() {
                var warehouseId = warehouseSelect ? warehouseSelect.value : '';
                lineContainer.querySelectorAll('.document-location-select').forEach(function (select) {
                    Array.prototype.forEach.call(select.options, function (option) {
                        if (!option.value) {
                            option.hidden = false;
                            return;
                        }

                        var optionWarehouse = option.getAttribute('data-warehouse-ref');
                        option.hidden = !!warehouseId && optionWarehouse !== warehouseId;
                    });

                    if (select.value) {
                        var selectedOption = select.options[select.selectedIndex];
                        if (selectedOption && selectedOption.hidden) {
                            select.value = '';
                        }
                    }
                });
            }

            function syncVariantUom(line) {
                var select = line.querySelector('.document-variant-select');
                var uomRef = line.querySelector('.document-uom-ref');
                var baseUomRef = line.querySelector('.document-base-uom-ref');
                var hint = line.querySelector('.document-uom-hint');
                if (!select || !uomRef || !baseUomRef) {
                    return;
                }

                var option = select.options[select.selectedIndex];
                var baseUom = option ? option.getAttribute('data-base-uom-ref') : '';
                uomRef.value = baseUom || '';
                baseUomRef.value = baseUom || '';
                if (hint) {
                    hint.textContent = baseUom ? ('@UiText["common.uom"]: ' + baseUom) : '@UiText["inventory.documents.line.baseUomHint"]';
                }
            }

            function bindLine(line) {
                var removeButton = line.querySelector('.remove-document-line');
                if (removeButton) {
                    removeButton.addEventListener('click', function () {
                        if (lineContainer.querySelectorAll('.document-line').length === 1) {
                            line.querySelectorAll('input[type="text"], input[type="number"]').forEach(function (input) {
                                input.value = input.type === 'number' ? '1' : '';
                            });
                            line.querySelectorAll('select').forEach(function (select) {
                                select.value = '';
                            });
                            syncVariantUom(line);
                            return;
                        }

                        line.remove();
                        renumberLines();
                        toggleTypeFields();
                        syncLocationsToWarehouse();
                    });
                }

                var variantSelect = line.querySelector('.document-variant-select');
                if (variantSelect) {
                    variantSelect.addEventListener('change', function () {
                        syncVariantUom(line);
                    });
                    syncVariantUom(line);
                }
            }

            function firstField(line, selector) {
                return line.querySelector(selector);
            }

            function validateDocumentForm() {
                clearValidation();

                if (!createForm) {
                    return true;
                }

                var currentType = documentTypeSelect ? documentTypeSelect.value : 'Receipt';
                var warehouseField = document.getElementById('create-warehouse-select');
                if (warehouseField && !warehouseField.value) {
                    showValidation('@UiText["inventory.documents.action.noWarehouseSelected"]', warehouseField);
                    return false;
                }

                var sellerField = createForm.querySelector('[name="CreateForm.SellerRef"]');
                if (sellerField && !sellerField.value) {
                    showValidation('@UiText["inventory.documents.action.noSellerSelected"]', sellerField);
                    return false;
                }

                if (currentType === 'Conversion') {
                    return true;
                }

                var config = selectedConfig();
                var lines = Array.prototype.slice.call(lineContainer.querySelectorAll('.document-line'));
                if (lines.length === 0) {
                    showValidation('حداقل یک ردیف برای سند لازم است.');
                    return false;
                }

                for (var i = 0; i < lines.length; i++) {
                    var line = lines[i];
                    var lineTitle = 'ردیف ' + (i + 1);
                    var variant = firstField(line, '.document-variant-select');
                    var qty = firstField(line, 'input[name$=".Qty"]');
                    var source = firstField(line, '.source-location-select');
                    var destination = firstField(line, '.destination-location-select');
                    var adjustment = firstField(line, '.line-adjustment select');
                    var reason = firstField(line, '.line-reason input');
                    var fromQuality = firstField(line, '.line-from-quality select');
                    var toQuality = firstField(line, '.line-to-quality select');

                    if (!variant || !variant.value) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.action.noVariantSelected"]', variant);
                        return false;
                    }

                    if (!qty || Number(qty.value) <= 0) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.validation.qtyPositive"]', qty);
                        return false;
                    }

                    if (config.source && !config.exclusiveFlow && (!source || !source.value)) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.conversion.validation.sourceLocationRequired"]', source);
                        return false;
                    }

                    if (config.destination && !config.exclusiveFlow && (!destination || !destination.value)) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.conversion.validation.destinationLocationRequired"]', destination);
                        return false;
                    }

                    if (!config.exclusiveFlow && config.source && config.destination && source && destination && source.value && source.value === destination.value) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.conversion.validation.locationsDifferent"]', destination);
                        return false;
                    }

                    if (config.exclusiveFlow) {
                        var hasSource = !!(source && source.value);
                        var hasDestination = !!(destination && destination.value);
                        var quality = firstField(line, '.line-quality select');

                        if (hasSource === hasDestination) {
                            showValidation(lineTitle + ': @UiText["inventory.documents.validation.conversionFlowRequired"]', source || destination);
                            return false;
                        }

                        if (!quality || !quality.value) {
                            showValidation(lineTitle + ': @UiText["inventory.documents.action.noQualitySelected"]', quality);
                            return false;
                        }
                    }

                    if (config.adjustment && (!adjustment || !adjustment.value)) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.validation.adjustmentDirectionRequired"]', adjustment);
                        return false;
                    }

                    if (config.lineReason && (!reason || !reason.value.trim())) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.line.reason"]', reason);
                        return false;
                    }

                    if (config.qualityChange && (!fromQuality || !fromQuality.value)) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.action.noQualitySelected"]', fromQuality);
                        return false;
                    }

                    if (config.qualityChange && (!toQuality || !toQuality.value)) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.action.noQualitySelected"]', toQuality);
                        return false;
                    }

                    if (config.qualityChange && fromQuality && toQuality && fromQuality.value && fromQuality.value === toQuality.value) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.validation.qualitiesDifferent"]', toQuality);
                        return false;
                    }
                }

                return true;
            }

            function setConversionPreviewError(message) {
                if (!conversionPreviewContainer) {
                    return;
                }

                if (!message) {
                    conversionPreviewContainer.innerHTML = '';
                    return;
                }

                conversionPreviewContainer.innerHTML = '<div class="alert alert-danger">' + escapeHtml(message) + '</div>';
            }

            function refreshPreviewWidgets(root) {
                if (window.appUi && typeof window.appUi.initSearchableSelects === 'function' && root) {
                    window.appUi.initSearchableSelects(root);
                }
            }

            function renderConversionPreview(html) {
                if (!conversionPreviewContainer) {
                    return;
                }

                conversionPreviewContainer.innerHTML = html || '';
                refreshPreviewWidgets(conversionPreviewContainer);
            }

            function collectConversionPreviewSelections() {
                var selections = [];
                if (!conversionPreviewContainer) {
                    return selections;
                }

                var lines = conversionPreviewContainer.querySelectorAll('[data-conversion-preview-line]');
                lines.forEach(function (line) {
                    var select = line.querySelector('[data-conversion-preview-location-select]');
                    var selectedOption = select && select.selectedIndex >= 0 ? select.options[select.selectedIndex] : null;
                    var lineKey = line.getAttribute('data-line-key') || '';
                    var variantId = line.getAttribute('data-variant-id') || '';
                    var role = line.getAttribute('data-role') || '';
                    var requiredQty = Number(line.getAttribute('data-required-qty') || '0');
                    var locationRef = selectedOption ? String(selectedOption.value || '').trim() : '';
                    if (!locationRef) {
                        return;
                    }

                    selections.push({
                        lineKey: lineKey,
                        variantId: variantId,
                        role: role,
                        locationRef: locationRef,
                        requiredQty: requiredQty
                    });
                });

                return selections;
            }

            async function submitConversionPreview(event) {
                if (!conversionPreviewForm || !conversionPreviewContainer) {
                    return;
                }

                event.preventDefault();
                setConversionPreviewError('');

                var previewUrl = conversionPreviewForm.getAttribute('data-preview-url') || conversionPreviewForm.action;
                if (!previewUrl) {
                    setConversionPreviewError('@UiText["inventory.documents.conversion.previewUrlMissing"]');
                    return;
                }

                var response = await fetch(previewUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'text/html,application/json'
                    },
                    body: new FormData(conversionPreviewForm)
                });

                var contentType = response.headers.get('content-type') || '';
                if (contentType.indexOf('application/json') > -1) {
                    var json = await response.json();
                    if (!json || json.isSuccess === false) {
                        setConversionPreviewError((json && json.errorMessage) || '@UiText["inventory.documents.conversion.previewFailed"]');
                        return;
                    }
                    setConversionPreviewError('@UiText["inventory.documents.conversion.previewFailed"]');
                    return;
                }

                var html = await response.text();
                if (!response.ok || !html) {
                    setConversionPreviewError('@UiText["inventory.documents.conversion.previewFailed"]');
                    return;
                }

                renderConversionPreview(html);
            }

            async function commitConversionPreview(event) {
                if (!conversionPreviewForm || !conversionPreviewContainer) {
                    return;
                }

                var button = event.target && event.target.closest ? event.target.closest('[data-conversion-preview-commit]') : null;
                if (!button) {
                    return;
                }

                event.preventDefault();
                setConversionPreviewError('');

                var selections = collectConversionPreviewSelections();
                if (!selections.length) {
                    setConversionPreviewError('@UiText["inventory.documents.conversion.selectLocationRequired"]');
                    return;
                }

                var commitUrl = conversionPreviewForm.getAttribute('data-commit-url') || '';
                if (!commitUrl) {
                    setConversionPreviewError('@UiText["inventory.documents.conversion.commitUrlMissing"]');
                    return;
                }

                var payload = new FormData(conversionPreviewForm);
                payload.append('previewSelectionsJson', JSON.stringify(selections));
                var variantField = conversionPreviewForm.querySelector('[name="CreateForm.ConversionVariantId"]');
                var operationField = conversionPreviewForm.querySelector('[name="CreateForm.ConversionOperationType"]');
                var quantityField = conversionPreviewForm.querySelector('[name="CreateForm.ConversionQuantity"]');

                payload.append('variantId', variantField ? variantField.value : '');
                payload.append('operationType', operationField ? operationField.value : '');
                payload.append('quantity', quantityField ? quantityField.value : '0');

                var response = await fetch(commitUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    body: payload
                });

                var result = await response.json().catch(function () {
                    return null;
                });

                if (!response.ok || !result || result.isSuccess === false) {
                    setConversionPreviewError((result && result.errorMessage) || '@UiText["inventory.documents.conversion.commitFailed"]');
                    return;
                }

                if (result.redirectUrl) {
                    window.location.href = result.redirectUrl;
                } else {
                    window.location.reload();
                }
            }

            function addLine() {
                var lines = lineContainer.querySelectorAll('.document-line');
                var lastLine = lines[lines.length - 1];
                var clone = lastLine.cloneNode(true);
                clone.querySelectorAll('.select2').forEach(function (node) {
                    node.remove();
                });
                clone.querySelectorAll('input').forEach(function (input) {
                    input.value = input.type === 'number' ? '1' : '';
                });
                clone.querySelectorAll('select').forEach(function (select) {
                    select.value = '';
                    delete select.dataset.select2Initialized;
                });
                lineContainer.appendChild(clone);
                if (window.appUi && typeof window.appUi.initSearchableSelects === 'function') {
                    window.appUi.initSearchableSelects(clone);
                }
                renumberLines();
                bindLine(clone);
                toggleTypeFields();
                syncLocationsToWarehouse();
            }

            if (addLineButton) {
                addLineButton.addEventListener('click', addLine);
            }

            if (toggleLinesButton) {
                toggleLinesButton.addEventListener('click', function () {
                    setLinesPanelVisible(linesPanel ? linesPanel.classList.contains('d-none') : false);
                });
            }

            if (documentTypeSelect) {
                documentTypeSelect.addEventListener('change', function () {
                    clearValidation();
                    toggleTypeFields();
                });
            }

            if (warehouseSelect) {
                warehouseSelect.addEventListener('change', function () {
                    clearValidation();
                    syncLocationsToWarehouse();
                });
            }

            if (createForm) {
                createForm.addEventListener('submit', function (event) {
                    if (!validateDocumentForm()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                });
            }

            if (conversionPreviewForm) {
                conversionPreviewForm.addEventListener('submit', submitConversionPreview);
            }

            if (conversionPreviewContainer) {
                conversionPreviewContainer.addEventListener('click', commitConversionPreview);
            }

            lineContainer.querySelectorAll('.document-line').forEach(bindLine);
            renumberLines();
            toggleTypeFields();
            syncLocationsToWarehouse();
            setLinesPanelVisible(false);
        })();
    </script>
    <script data-ajax-reinit="document-user-create">
        (function () {
            var modalSelector = '#document-user-create-modal';
            var formSelector = '#document-user-create-form';
            var errorSelector = '#document-user-create-error';
            var createUserUrl = '@Url.Action("CreateDocumentUser", "InventoryManagement")';

            function showModal() {
                if (window.jQuery && window.jQuery.fn && window.jQuery.fn.modal) {
                    window.jQuery(modalSelector).modal('show');
                }
            }

            function hideModal() {
                if (window.jQuery && window.jQuery.fn && window.jQuery.fn.modal) {
                    window.jQuery(modalSelector).modal('hide');
                }
            }

            function setError(message) {
                var errorBox = document.querySelector(errorSelector);
                if (!errorBox) {
                    return;
                }

                if (!message) {
                    errorBox.textContent = '';
                    errorBox.classList.add('d-none');
                    return;
                }

                errorBox.textContent = message;
                errorBox.classList.remove('d-none');
            }

            function resetForm() {
                var form = document.querySelector(formSelector);
                if (!form) {
                    return;
                }

                form.reset();
                if (window.jQuery) {
                    window.jQuery(form).find('select').trigger('change.select2');
                }
                setError('');
            }

            async function submitUserForm(event) {
                event.preventDefault();
                event.stopPropagation();

                var form = event.currentTarget;
                setError('');

                var response = await fetch(createUserUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    body: new FormData(form)
                });

                var payload = await response.json();
                if (!payload || payload.isSuccess === false) {
                    setError((payload && payload.errorMessage) || 'ایجاد کاربر انجام نشد.');
                    return;
                }

                hideModal();
                window.location.reload();
            }

            document.addEventListener('click', function (event) {
                var trigger = event.target && event.target.closest ? event.target.closest('.js-open-document-user-modal') : null;
                if (!trigger) {
                    return;
                }

                event.preventDefault();
                resetForm();
                showModal();
            }, true);

            var form = document.querySelector(formSelector);
            if (form && form.dataset.documentUserCreateBound !== 'true') {
                form.addEventListener('submit', function (event) {
                    submitUserForm(event).catch(function (error) {
                        console.error(error);
                        setError('ایجاد کاربر انجام نشد.');
                    });
                });
                form.dataset.documentUserCreateBound = 'true';
            }

            var modalElement = document.querySelector(modalSelector);
            if (modalElement && modalElement.dataset.documentUserCreateInit !== 'true') {
                if (window.appUi && typeof window.appUi.initSearchableSelects === 'function') {
                    window.appUi.initSearchableSelects(modalElement);
                }
                modalElement.addEventListener('hidden.bs.modal', function () {
                    resetForm();
                });
                modalElement.dataset.documentUserCreateInit = 'true';
            }
        })();
    </script>
}
