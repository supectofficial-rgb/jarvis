                                    <label>نوع سند</label>
                                    <div class="form-control-plaintext pt-2">@TypeLabel(Model.CreateForm.DocumentType)</div>
                                </div>
                                <div class="form-group col-md-2">
                                    <label>@UiText["inventory.documents.documentNo"]</label>
                                    <input asp-for="CreateForm.DocumentNo" class="form-control text-monospace" />
                                </div>
                                <div class="form-group col-md-2">
                                    <label>@UiText["inventory.documents.referenceType"]</label>
                                    <input asp-for="CreateForm.ReferenceType" class="form-control" />
                                </div>
                                <div class="form-group col-md-2">
                                    <label>@UiText["inventory.documents.referenceId"]</label>
                                    <input asp-for="CreateForm.ReferenceBusinessId" class="form-control text-monospace" />
