@using System
@using System.Linq
@using System.Text.Json
@model Insurance.InventoryDashboard.Panel.Models.InventoryDocumentManagementPageViewModel
@{
    ViewData["Title"] = UiText["inventory.documents.title"];
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x => string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) || string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));

    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    string WarehouseName(string? warehouseId)
    {
        if (string.IsNullOrWhiteSpace(warehouseId))
        {
            return "-";
        }

        var warehouse = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, warehouseId, StringComparison.OrdinalIgnoreCase));
        return warehouse is null ? warehouseId : $"{warehouse.Code} - {warehouse.Name}";
    }

    string SellerName(string? sellerId)
    {
        if (string.IsNullOrWhiteSpace(sellerId))
        {
            return "-";
        }

        var seller = Model.SellerLookup.FirstOrDefault(x => string.Equals(x.SellerBusinessKey, sellerId, StringComparison.OrdinalIgnoreCase));
        return seller is null ? sellerId : $"{seller.Code} - {seller.Name}";
    }

    string UserNameLabel(Insurance.InventoryDashboard.Panel.Models.UserSummaryModel user)
    {
        var name = string.IsNullOrWhiteSpace(user.UserName) ? user.MobileNumber : user.UserName;
        var phone = string.IsNullOrWhiteSpace(user.MobileNumber) ? null : user.MobileNumber;
        return string.IsNullOrWhiteSpace(phone) ? (name ?? user.UserBusinessKey) : $"{name} - {phone}";
    }

    string RoleNameLabel(Insurance.InventoryDashboard.Panel.Models.RoleSummaryModel role)
    {
        return string.IsNullOrWhiteSpace(role.Name)
            ? role.RoleBusinessKey
            : string.IsNullOrWhiteSpace(role.Scope)
                ? role.Name
                : $"{role.Name} ({role.Scope})";
    }

    string TypeLabel(string? type) => type switch
    {
        "Receipt" => UiText["inventory.documents.type.receipt"],
        "Issue" => UiText["inventory.documents.type.issue"],
        "Transfer" => UiText["inventory.documents.type.transfer"],
        "Adjustment" => UiText["inventory.documents.type.adjustment"],
        "Return" => UiText["inventory.documents.type.return"],
        "QualityChange" => UiText["inventory.documents.type.qualityChange"],
        "Conversion" => UiText["inventory.documents.type.conversion"],
        _ => type ?? "-"
    };

    string StatusLabel(string? status) => status switch
    {
        "Draft" => UiText["inventory.documents.status.draft"],
        "Approved" => UiText["inventory.documents.status.approved"],
        "Rejected" => UiText["inventory.documents.status.rejected"],
        "Cancelled" => UiText["inventory.documents.status.cancelled"],
        "Posted" => UiText["inventory.documents.status.posted"],
        _ => status ?? "-"
    };

    string StatusClass(string? status) => status switch
    {
        "Draft" => "badge-outline-secondary",
        "Approved" => "badge-info",
        "Rejected" => "badge-danger",
        "Cancelled" => "badge-warning",
        "Posted" => "badge-success",
        _ => "badge-secondary"
    };

    string VariantLabel(Insurance.InventoryDashboard.Panel.Models.ProductVariantSummaryModel variant)
    {
        var variantName = (variant.Name ?? string.Empty).Trim();
        if (!string.IsNullOrWhiteSpace(variantName))
        {
            return variantName;
        }

        if (!string.IsNullOrWhiteSpace(variant.Sku))
        {
            return variant.Sku;
        }

        return variant.Id;
    }

    string VariantName(string? variantId)
    {
        if (string.IsNullOrWhiteSpace(variantId))
        {
            return "-";
        }

        var variant = Model.VariantLookup.FirstOrDefault(x => string.Equals(x.Id, variantId, StringComparison.OrdinalIgnoreCase));
        return variant is null ? variantId : VariantLabel(variant);
    }

    string? VariantProductId(string? variantId)
    {
        if (string.IsNullOrWhiteSpace(variantId))
        {
            return null;
        }

        return Model.VariantLookup.FirstOrDefault(x => string.Equals(x.Id, variantId, StringComparison.OrdinalIgnoreCase))?.ProductId;
    }

    string LocationName(string? locationId)
    {
        if (string.IsNullOrWhiteSpace(locationId))
        {
            return "-";
        }

        var location = Model.LocationLookup.FirstOrDefault(x => string.Equals(x.LocationBusinessKey, locationId, StringComparison.OrdinalIgnoreCase));
        return location is null ? locationId : $"{location.LocationCode} ({location.LocationType})";
    }

    string QualityName(string? qualityId)
    {
        if (string.IsNullOrWhiteSpace(qualityId))
        {
            return "-";
        }

        var quality = Model.QualityStatusLookup.FirstOrDefault(x => string.Equals(x.QualityStatusBusinessKey, qualityId, StringComparison.OrdinalIgnoreCase));
        return quality is null ? qualityId : $"{quality.Code} - {quality.Name}";
    }

    string UomName(string? uomId)
    {
        if (string.IsNullOrWhiteSpace(uomId))
        {
            return "-";
        }

        var uom = Model.UnitOfMeasureLookup.FirstOrDefault(x => string.Equals(x.Id, uomId, StringComparison.OrdinalIgnoreCase));
        return uom is null ? uomId : $"{uom.Code} - {uom.Name}";
    }

    string AdjustmentDirectionLabel(string? direction) => direction switch
    {
        "Increase" => UiText["inventory.documents.adjustment.increase"],
        "Decrease" => UiText["inventory.documents.adjustment.decrease"],
        _ => string.IsNullOrWhiteSpace(direction) ? "-" : direction
    };

    var hasListContext = !string.IsNullOrWhiteSpace(Model.SelectedDocumentId)
        || !string.IsNullOrWhiteSpace(Model.DocumentNoFilter)
        || !string.IsNullOrWhiteSpace(Model.DocumentStatusFilter)
        || !string.IsNullOrWhiteSpace(Model.WarehouseFilter)
        || !string.IsNullOrWhiteSpace(Model.SellerFilter)
        || !string.IsNullOrWhiteSpace(Model.OccurredFromFilter)
        || !string.IsNullOrWhiteSpace(Model.OccurredToFilter)
        || Model.DocumentPage > 1;

    var showListTab = string.Equals(Model.SelectedTab, "list", StringComparison.OrdinalIgnoreCase);
    var currentDocumentType = string.IsNullOrWhiteSpace(Model.DocumentTypeFilter) ? "Receipt" : Model.DocumentTypeFilter;
    var isConversionDocument = string.Equals(currentDocumentType, "Conversion", StringComparison.OrdinalIgnoreCase);
    var documentAction = ViewBag.DocumentAction as string ?? "Documents";
}

<main id="documents-page-root" class="catalog-page">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="mb-4">
                    <h1>@UiText["inventory.documents.title"]</h1>
                    <div class="mb-2">
                        <span class="badge badge-pill badge-primary">@TypeLabel(currentDocumentType)</span>
                    </div>
                    <p class="text-muted">@UiText["inventory.documents.description"]</p>
                    <div>
                        <span class="badge badge-pill badge-outline-primary mb-1">@UiText["inventory.documents.summary.documents"] @Model.DocumentTotalCount</span>
                        @if (!string.IsNullOrWhiteSpace(Model.SelectedDocumentId))
                        {
                            <span class="badge badge-pill badge-outline-secondary mb-1">@UiText["inventory.documents.summary.selectedDocument"] @(Model.SelectedDocumentDetails?.DocumentNo ?? Model.SelectedDocumentId)</span>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-warning">@Model.ErrorMessage</div>
                }
                @if (TempData.ContainsKey("CatalogError"))
                {
                    <div class="alert alert-danger">@TempData["CatalogError"]</div>
                }
                @if (TempData.ContainsKey("CatalogSuccess"))
                {
                    <div class="alert alert-success">@TempData["CatalogSuccess"]</div>
                }

                <ul class="nav nav-tabs mt-4" id="document-management-tabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link @(showListTab ? null : "active")" id="document-create-tab" data-toggle="tab" href="#document-create-pane" role="tab" aria-controls="document-create-pane" aria-selected="@((showListTab ? "false" : "true"))">تولید</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(showListTab ? "active" : null)" id="document-list-tab" data-toggle="tab" href="#document-list-pane" role="tab" aria-controls="document-list-pane" aria-selected="@((showListTab ? "true" : "false"))">لیست اسناد</a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="tab-content">
            <div class="tab-pane fade @(showListTab ? null : "show active")" id="document-create-pane" role="tabpanel" aria-labelledby="document-create-tab">
        <div class="row">
            <div class="col-12 mb-4">
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="card-title mb-0">@UiText["inventory.documents.createTitle"]</h5>
                            <span class="text-muted small">@UiText["inventory.documents.baseUomNotice"]</span>
                        </div>

                        <form asp-action="SaveDocument" asp-controller="InventoryManagement" method="post" data-loading-form data-ajax-target="#documents-page-root" id="document-create-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="CreateForm.DocumentId" />
                            <input type="hidden" asp-for="CreateForm.DocumentType" id="document-type-input" />
                            <div class="form-row">
                                <div class="form-group col-md-3">
                                    <label>@UiText["inventory.documents.documentNo"]</label>
                                    <div class="form-control-plaintext pt-2 text-muted">
                                        شماره سند هنگام ثبت توسط سیستم ایجاد می‌شود.
                                    </div>
                                </div>
                                @await Html.PartialAsync("_DocumentReferenceLookup", Model, new ViewDataDictionary(ViewData) { ["ReferenceLookupPrefix"] = "conversion-reference" })
                                <div class="form-group col-md-3">
                                    <label>@UiText["inventory.documents.warehouse"]</label>
                                    <select asp-for="CreateForm.WarehouseRef" class="form-control js-search-select" id="create-warehouse-select" required>
                                        <option value="">@UiText["inventory.documents.selectWarehouse"]</option>
                                        @foreach (var warehouse in Model.WarehouseLookup.OrderBy(x => x.Code))
                                        {
                                            <option value="@warehouse.WarehouseBusinessKey" selected="@(string.Equals(warehouse.WarehouseBusinessKey, Model.CreateForm.WarehouseRef, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@warehouse.Code - @warehouse.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group col-md-3">
                                    <label>@UiText["inventory.documents.seller"]</label>
                                    <select asp-for="CreateForm.SellerRef" class="form-control js-search-select" required>
                                        <option value="">@UiText["inventory.documents.selectSeller"]</option>
                                        @foreach (var seller in Model.SellerLookup.OrderBy(x => x.Code))
                                        {
                                            <option value="@seller.SellerBusinessKey" selected="@(string.Equals(seller.SellerBusinessKey, Model.CreateForm.SellerRef, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@seller.Code - @seller.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-group col-md-4">
                                    <label>@UiText["inventory.documents.occurredAt"]</label>
                                    <input type="hidden" asp-for="CreateForm.OccurredAt" id="conversion-occurred-at-value" value="@Model.CreateForm.OccurredAt.ToString("yyyy-MM-ddTHH:mm")" />
                                    <input type="text" class="form-control datepicker" data-date-picker-target="#conversion-occurred-at-value" data-date-format="yyyy/mm/dd" value="@Model.CreateForm.OccurredAt.ToString("yyyy/MM/dd")" autocomplete="off" />
                                </div>
                                <div class="form-group col-md-8">
                                    <label>@UiText["inventory.documents.reason"]</label>
                                    <input asp-for="CreateForm.ReasonCode" class="form-control" />
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center border-top pt-3 mb-3">
                                <div>
                                    <h6 class="mb-0">@UiText["inventory.documents.people.title"]</h6>
                                    <div class="text-muted small">@UiText["inventory.documents.people.description"]</div>
                                </div>
                                <button type="button" class="btn btn-outline-primary btn-xs js-open-document-user-modal">+</button>
                            </div>

                            <div class="form-row">
                                <div class="form-group col-md-5">
                                    <label>@UiText["inventory.documents.people.deliveredBy"]</label>
                                    <select asp-for="CreateForm.DeliveredBy" class="form-control js-search-select" data-placeholder="@UiText["inventory.documents.people.selectDeliveredBy"]">
                                        <option value="">@UiText["inventory.documents.people.selectDeliveredBy"]</option>
                                        @foreach (var user in Model.UserLookup.OrderBy(x => x.UserName))
                                        {
                                            <option value="@user.UserBusinessKey" selected="@(string.Equals(user.UserBusinessKey, Model.CreateForm.DeliveredBy, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UserNameLabel(user)</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group col-md-5">
                                    <label>@UiText["inventory.documents.people.receivedBy"]</label>
                                    <select asp-for="CreateForm.ReceivedBy" class="form-control js-search-select" data-placeholder="@UiText["inventory.documents.people.selectReceivedBy"]">
                                        <option value="">@UiText["inventory.documents.people.selectReceivedBy"]</option>
                                        @foreach (var user in Model.UserLookup.OrderBy(x => x.UserName))
                                        {
                                            <option value="@user.UserBusinessKey" selected="@(string.Equals(user.UserBusinessKey, Model.CreateForm.ReceivedBy, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@UserNameLabel(user)</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="alert alert-light border mb-3">
                                @UiText["inventory.documents.conversion.createInfo"]
                            </div>

                            <div id="document-lines" class="d-none"></div>

                            <button class="btn btn-primary" type="submit" @(Can("Inventory.Document.Create", "InventoryDocument.Create", "Document.Create") ? null : "disabled")>ایجاد سند</button>
                        </form>

                        <div class="modal fade" id="document-user-create-modal" tabindex="-1" role="dialog" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered" role="document">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <div>
                                            <h5 class="modal-title mb-0">ایجاد کاربر</h5>
                                            <small class="text-muted">کاربر جدید به سازمان فعال اضافه می‌شود.</small>
                                        </div>
                                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                            <span aria-hidden="true">×</span>
                                        </button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="alert alert-danger d-none" id="document-user-create-error"></div>
                                        <form asp-action="CreateDocumentUser" asp-controller="InventoryManagement" method="post" id="document-user-create-form">
                                            @Html.AntiForgeryToken()
                                            <div class="form-group">
                                                <label>نام</label>
                                                <input type="text" name="UserName" class="form-control" autocomplete="off" required />
                                            </div>
                                            <div class="form-group">
                                                <label>شماره تلفن</label>
                                                <input type="text" name="MobileNumber" class="form-control text-monospace" autocomplete="off" required />
                                            </div>
                                            <div class="form-group">
                                                <label>نقش</label>
                                                <select name="RoleBusinessKey" class="form-control js-search-select" data-placeholder="انتخاب نقش" required>
                                                    <option value="">انتخاب نقش</option>
                                                    @foreach (var role in Model.RoleLookup.OrderBy(x => x.Name))
                                                    {
                                                        <option value="@role.RoleBusinessKey">@RoleNameLabel(role)</option>
                                                    }
                                                </select>
                                            </div>
                                        </form>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">بستن</button>
                                        <button type="submit" class="btn btn-primary" form="document-user-create-form">ثبت</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @*
