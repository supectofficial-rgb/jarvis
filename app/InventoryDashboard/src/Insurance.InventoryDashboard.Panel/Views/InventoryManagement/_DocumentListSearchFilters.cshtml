@model Insurance.InventoryDashboard.Panel.Models.InventoryDocumentManagementPageViewModel

<div class="form-row mb-3" data-document-search-filters data-location-lookup-url="@Url.Action("SearchDocumentWarehouseLocationsLookup", "InventoryManagement")">
    <div class="form-group col-md-2">
        <label>@UiText["common.number"]</label>
        <input name="documentNo" value="@Model.DocumentNoFilter" class="form-control text-monospace" />
    </div>
    <div class="form-group col-md-2">
        <label>@UiText["common.status"]</label>
        <select name="status" class="form-control">
            <option value="">@UiText["common.all"]</option>
            <option value="Draft" selected="@(Model.DocumentStatusFilter == "Draft" ? "selected" : null)">@UiText["inventory.documents.status.draft"]</option>
            <option value="Approved" selected="@(Model.DocumentStatusFilter == "Approved" ? "selected" : null)">@UiText["inventory.documents.status.approved"]</option>
            <option value="Rejected" selected="@(Model.DocumentStatusFilter == "Rejected" ? "selected" : null)">@UiText["inventory.documents.status.rejected"]</option>
            <option value="Cancelled" selected="@(Model.DocumentStatusFilter == "Cancelled" ? "selected" : null)">@UiText["inventory.documents.status.cancelled"]</option>
            <option value="Posted" selected="@(Model.DocumentStatusFilter == "Posted" ? "selected" : null)">@UiText["inventory.documents.status.posted"]</option>
        </select>
    </div>
    <div class="form-group col-md-2">
        <label>@UiText["common.variant"]</label>
        <select name="variantId" class="form-control js-search-select">
            <option value="">@UiText["common.all"]</option>
            @foreach (var variant in Model.VariantLookup.OrderBy(x => x.Sku))
            {
                <option value="@variant.Id" selected="@(variant.Id == Model.VariantFilter ? "selected" : null)">@variant.Sku - @variant.Name</option>
            }
        </select>
    </div>
    <div class="form-group col-md-2">
        <label>@UiText["common.warehouse"]</label>
        <select name="warehouseId" class="form-control js-search-select">
            <option value="">@UiText["common.all"]</option>
            @foreach (var warehouse in Model.WarehouseLookup.OrderBy(x => x.Code))
            {
                <option value="@warehouse.WarehouseBusinessKey" selected="@(warehouse.WarehouseBusinessKey == Model.WarehouseFilter ? "selected" : null)">@warehouse.Code - @warehouse.Name</option>
            }
        </select>
    </div>
    <div class="form-group col-md-2">
        <label>@UiText["common.location"]</label>
        <select name="locationId" class="form-control js-search-select">
            <option value="">@UiText["common.all"]</option>
            @foreach (var location in Model.LocationLookup.OrderBy(x => x.LocationCode))
            {
                <option value="@location.LocationBusinessKey" data-warehouse-ref="@location.WarehouseRef" selected="@(location.LocationBusinessKey == Model.LocationFilter ? "selected" : null)">@location.LocationCode (@location.LocationType)</option>
            }
        </select>
    </div>
    <div class="form-group col-md-2">
        <label>@UiText["common.seller"]</label>
        <select name="sellerId" class="form-control js-search-select">
            <option value="">@UiText["common.all"]</option>
            @foreach (var seller in Model.SellerLookup.OrderBy(x => x.Code))
            {
                <option value="@seller.SellerBusinessKey" selected="@(seller.SellerBusinessKey == Model.SellerFilter ? "selected" : null)">@seller.Code - @seller.Name</option>
            }
        </select>
    </div>
    <div class="form-group col-md-2">
        <label>از تاریخ</label>
        <input name="occurredFrom" type="date" value="@Model.OccurredFromFilter" class="form-control" />
    </div>
    <div class="form-group col-md-2">
        <label>تا تاریخ</label>
        <input name="occurredTo" type="date" value="@Model.OccurredToFilter" class="form-control" />
    </div>
    <div class="form-group col-md-2">
        <label>تعداد</label>
        <select name="pageSize" class="form-control">
            @foreach (var size in Model.PageSizeOptions)
            {
                <option value="@size" selected="@(Model.DocumentPageSize == size ? "selected" : null)">@size</option>
            }
        </select>
    </div>
    <div class="form-group col-md-2 d-flex align-items-end">
        <button class="btn btn-outline-primary btn-block" type="submit">@UiText["common.apply"]</button>
    </div>
</div>

<script>
    (function () {
        var form = document.querySelector('form[data-document-search-filters]');
        if (!form || form.dataset.documentSearchFiltersBound === 'true') {
            return;
        }

        var locationLookupUrl = form.getAttribute('data-location-lookup-url') || '';
        var warehouseSelect = form.querySelector('select[name="warehouseId"]');
        var locationSelect = form.querySelector('select[name="locationId"]');

        function getOptionByValue(select, value) {
            if (!select || !value) {
                return null;
            }

            var escaped = value.replace(/"/g, '\\"');
            return select.querySelector('option[value="' + escaped + '"]');
        }

        function renderLocationOptions(items, placeholderText, selectedValue) {
            if (!locationSelect) {
                return;
            }

            while (locationSelect.firstChild) {
                locationSelect.removeChild(locationSelect.firstChild);
            }

            var placeholder = document.createElement('option');
            placeholder.value = '';
            placeholder.textContent = placeholderText || '';
            locationSelect.appendChild(placeholder);

            (items || []).forEach(function (item) {
                var option = document.createElement('option');
                option.value = item.locationId || item.id || '';
                option.textContent = item.text || option.value;
                if (item && item.warehouseId) {
                    option.setAttribute('data-warehouse-ref', item.warehouseId);
                }
                locationSelect.appendChild(option);
            });

            locationSelect.value = selectedValue || '';
            if (window.jQuery) {
                window.jQuery(locationSelect).trigger('change.select2');
            }
        }

        async function loadLocations(warehouseId, selectedLocationId) {
            if (!locationSelect) {
                return;
            }

            if (!warehouseId) {
                renderLocationOptions([], 'ابتدا انبار را انتخاب کنید', '');
                locationSelect.disabled = true;
                return;
            }

            var url = new URL(locationLookupUrl, window.location.origin);
            url.searchParams.set('warehouseId', warehouseId);

            var response = await fetch(url.toString(), {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json'
                },
                cache: 'no-store'
            });

            if (!response.ok) {
                throw new Error('Loading warehouse locations failed.');
            }

            var payload = await response.json();
            if (!payload || payload.isSuccess === false) {
                throw new Error((payload && payload.errorMessage) || 'Loading warehouse locations failed.');
            }

            var locations = Array.isArray(payload.locations) ? payload.locations.slice() : [];
            renderLocationOptions(locations, locations.length ? 'انتخاب لوکیشن' : 'برای این انبار لوکیشنی یافت نشد', selectedLocationId || '');
            locationSelect.disabled = locations.length === 0;
        }

        if (warehouseSelect) {
            warehouseSelect.addEventListener('change', function () {
                loadLocations(this.value || '', '').catch(function (error) {
                    console.error(error);
                });
            });
        }

        var currentWarehouseId = warehouseSelect ? (warehouseSelect.value || '') : '';
        var currentLocationId = locationSelect ? (locationSelect.value || '') : '';
        if (!currentWarehouseId && currentLocationId && locationSelect) {
            var selectedOption = getOptionByValue(locationSelect, currentLocationId);
            currentWarehouseId = selectedOption ? (selectedOption.getAttribute('data-warehouse-ref') || '') : '';
        }

        loadLocations(currentWarehouseId, currentLocationId).catch(function (error) {
            console.error(error);
        });

        form.dataset.documentSearchFiltersBound = 'true';
    })();
</script>
