@using System
@using System.Linq
@model Insurance.InventoryDashboard.Panel.Models.InventoryDocumentManagementPageViewModel
@{
    ViewData["Title"] = UiText["inventory.documents.title"];
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x => string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) || string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));

    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    string WarehouseName(string? warehouseId)
    {
        if (string.IsNullOrWhiteSpace(warehouseId))
        {
            return "-";
        }

        var warehouse = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, warehouseId, StringComparison.OrdinalIgnoreCase));
        return warehouse is null ? warehouseId : $"{warehouse.Code} - {warehouse.Name}";
    }

    string SellerName(string? sellerId)
    {
        if (string.IsNullOrWhiteSpace(sellerId))
        {
            return "-";
        }

        var seller = Model.SellerLookup.FirstOrDefault(x => string.Equals(x.SellerBusinessKey, sellerId, StringComparison.OrdinalIgnoreCase));
        return seller is null ? sellerId : $"{seller.Code} - {seller.Name}";
    }

    string TypeLabel(string? type) => type switch
    {
        "Receipt" => UiText["inventory.documents.type.receipt"],
        "Issue" => UiText["inventory.documents.type.issue"],
        "Transfer" => UiText["inventory.documents.type.transfer"],
        "Adjustment" => UiText["inventory.documents.type.adjustment"],
        "Return" => UiText["inventory.documents.type.return"],
        "QualityChange" => UiText["inventory.documents.type.qualityChange"],
        "Conversion" => UiText["inventory.documents.type.conversion"],
        _ => type ?? "-"
    };

    string StatusLabel(string? status) => status switch
    {
        "Draft" => UiText["inventory.documents.status.draft"],
        "Approved" => UiText["inventory.documents.status.approved"],
        "Rejected" => UiText["inventory.documents.status.rejected"],
        "Cancelled" => UiText["inventory.documents.status.cancelled"],
        "Posted" => UiText["inventory.documents.status.posted"],
        _ => status ?? "-"
    };

    string StatusClass(string? status) => status switch
    {
        "Draft" => "badge-outline-secondary",
        "Approved" => "badge-info",
        "Rejected" => "badge-danger",
        "Cancelled" => "badge-warning",
        "Posted" => "badge-success",
        _ => "badge-secondary"
    };

    string VariantLabel(Insurance.InventoryDashboard.Panel.Models.ProductVariantSummaryModel variant)
    {
        var productName = Model.ProductLookup.FirstOrDefault(x => x.Id == variant.ProductId)?.Name;
        return string.IsNullOrWhiteSpace(productName)
            ? variant.Sku
            : $"{variant.Sku} - {productName}";
    }

    string VariantName(string? variantId)
    {
        if (string.IsNullOrWhiteSpace(variantId))
        {
            return "-";
        }

        var variant = Model.VariantLookup.FirstOrDefault(x => string.Equals(x.Id, variantId, StringComparison.OrdinalIgnoreCase));
        return variant is null ? variantId : VariantLabel(variant);
    }

    string? VariantProductId(string? variantId)
    {
        if (string.IsNullOrWhiteSpace(variantId))
        {
            return null;
        }

        return Model.VariantLookup.FirstOrDefault(x => string.Equals(x.Id, variantId, StringComparison.OrdinalIgnoreCase))?.ProductId;
    }

    string LocationName(string? locationId)
    {
        if (string.IsNullOrWhiteSpace(locationId))
        {
            return "-";
        }

        var location = Model.LocationLookup.FirstOrDefault(x => string.Equals(x.LocationBusinessKey, locationId, StringComparison.OrdinalIgnoreCase));
        if (location is null)
        {
            return locationId;
        }

        var warehouse = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, location.WarehouseRef, StringComparison.OrdinalIgnoreCase));
        var warehouseLabel = warehouse is null ? location.WarehouseRef : $"{warehouse.Code} - {warehouse.Name}";
        var locationLabel = string.IsNullOrWhiteSpace(location.LocationType)
            ? location.LocationCode
            : $"{location.LocationCode} ({location.LocationType})";
        return string.IsNullOrWhiteSpace(warehouseLabel) ? locationLabel : $"{warehouseLabel} - {locationLabel}";
    }

    string QualityName(string? qualityId)
    {
        if (string.IsNullOrWhiteSpace(qualityId))
        {
            return "-";
        }

        var quality = Model.QualityStatusLookup.FirstOrDefault(x => string.Equals(x.QualityStatusBusinessKey, qualityId, StringComparison.OrdinalIgnoreCase));
        return quality is null ? qualityId : $"{quality.Code} - {quality.Name}";
    }

    string UomName(string? uomId)
    {
        if (string.IsNullOrWhiteSpace(uomId))
        {
            return "-";
        }

        var uom = Model.UnitOfMeasureLookup.FirstOrDefault(x => string.Equals(x.Id, uomId, StringComparison.OrdinalIgnoreCase));
        return uom is null ? uomId : $"{uom.Code} - {uom.Name}";
    }

    string AdjustmentDirectionLabel(string? direction) => direction switch
    {
        "Increase" => UiText["inventory.documents.adjustment.increase"],
        "Decrease" => UiText["inventory.documents.adjustment.decrease"],
        _ => string.IsNullOrWhiteSpace(direction) ? "-" : direction
    };

    var hasListContext = !string.IsNullOrWhiteSpace(Model.SelectedDocumentId)
        || !string.IsNullOrWhiteSpace(Model.DocumentNoFilter)
        || !string.IsNullOrWhiteSpace(Model.DocumentStatusFilter)
        || !string.IsNullOrWhiteSpace(Model.OccurredFromFilter)
        || !string.IsNullOrWhiteSpace(Model.OccurredToFilter)
        || Model.DocumentPage > 1;

    var showListTab = hasListContext;
    var currentDocumentType = string.IsNullOrWhiteSpace(Model.DocumentTypeFilter) ? "Receipt" : Model.DocumentTypeFilter;
    var showConversionQuality = string.Equals(currentDocumentType, "Conversion", StringComparison.OrdinalIgnoreCase);
    var showQualityChangeFields = string.Equals(currentDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase);
    var documentAction = ViewBag.DocumentAction as string ?? "Documents";
}

<main id="documents-page-root" class="catalog-page">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="mb-4">
                    <h1>@UiText["inventory.documents.title"]</h1>
                    <p class="text-muted">@UiText["inventory.documents.description"]</p>
                    <div>
                        <span class="badge badge-pill badge-outline-primary mb-1">@UiText["inventory.documents.summary.documents"] @Model.DocumentTotalCount</span>
                        @if (!string.IsNullOrWhiteSpace(Model.SelectedDocumentId))
                        {
                            <span class="badge badge-pill badge-outline-secondary mb-1">@UiText["inventory.documents.summary.selectedDocument"] @(Model.SelectedDocumentDetails?.DocumentNo ?? Model.SelectedDocumentId)</span>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-warning">@Model.ErrorMessage</div>
                }
                @if (TempData.ContainsKey("CatalogError"))
                {
                    <div class="alert alert-danger">@TempData["CatalogError"]</div>
                }
                @if (TempData.ContainsKey("CatalogSuccess"))
                {
                    <div class="alert alert-success">@TempData["CatalogSuccess"]</div>
                }

                <ul class="nav nav-tabs mt-4" id="document-management-tabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link @(showListTab ? null : "active")" id="document-create-tab" data-toggle="tab" href="#document-create-pane" role="tab" aria-controls="document-create-pane" aria-selected="@((showListTab ? "false" : "true"))">تولید</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(showListTab ? "active" : null)" id="document-list-tab" data-toggle="tab" href="#document-list-pane" role="tab" aria-controls="document-list-pane" aria-selected="@((showListTab ? "true" : "false"))">لیست اسناد</a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="tab-content">
            <div class="tab-pane fade @(showListTab ? null : "show active")" id="document-create-pane" role="tabpanel" aria-labelledby="document-create-tab">
        <div class="row">
            <div class="col-12 mb-4">
                <div class="card mb-4">
                        <div class="card-body">
                        <form asp-action="SaveDocument" asp-controller="InventoryManagement" method="post" data-loading-form data-ajax-target="#documents-page-root" id="document-create-form">
                            @Html.AntiForgeryToken()
                            <div class="alert alert-info border mb-3" role="status">
                                <strong>ثبت هدر سند</strong>
                                <div class="small mt-1">در این فرم فقط اطلاعات هدر ثبت می‌شود. ردیف‌ها و جزئیات سند از تب لیست و جزئیات مدیریت می‌شوند.</div>
                            </div>

                        <button class="btn btn-primary" type="submit" @(Can("Inventory.Document.Create", "InventoryDocument.Create", "Document.Create") ? null : "disabled")>ایجاد سند</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
            </div>

        <div class="tab-pane fade @(showListTab ? "show active" : null)" id="document-list-pane" role="tabpanel" aria-labelledby="document-list-tab">
            <div class="row">
                <div class="col-12 mb-4">
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="card-title mb-0">لیست اسناد</h5>
                            <span class="text-muted small" id="transfer-document-list-count">@Model.DocumentTotalCount رکورد</span>
                        </div>
                        <form asp-action="@documentAction" asp-controller="InventoryManagement" method="get" class="form-row mb-3" data-loading-form data-ajax-target="#documents-page-root" id="transfer-document-list-form">
                            <input type="hidden" name="documentId" value="@Model.SelectedDocumentId" />
                            <input type="hidden" name="documentType" value="@currentDocumentType" />
                            <div class="form-group col-md-2">
                                <label>شماره</label>
                                <input name="documentNo" value="@Model.DocumentNoFilter" class="form-control text-monospace" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>وضعیت</label>
                                <select name="status" class="form-control">
                                    <option value="">همه</option>
                                    <option value="Draft" selected="@(Model.DocumentStatusFilter == "Draft" ? "selected" : null)">پیش نویس</option>
                                    <option value="Approved" selected="@(Model.DocumentStatusFilter == "Approved" ? "selected" : null)">تایید شده</option>
                                    <option value="Rejected" selected="@(Model.DocumentStatusFilter == "Rejected" ? "selected" : null)">رد شده</option>
                                    <option value="Cancelled" selected="@(Model.DocumentStatusFilter == "Cancelled" ? "selected" : null)">لغو شده</option>
                                    <option value="Posted" selected="@(Model.DocumentStatusFilter == "Posted" ? "selected" : null)">پست شده</option>
                                </select>
                            </div>
                            <div class="form-group col-md-2">
                                <label>از تاریخ</label>
                                <input name="occurredFrom" type="date" value="@Model.OccurredFromFilter" class="form-control" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>تا تاریخ</label>
                                <input name="occurredTo" type="date" value="@Model.OccurredToFilter" class="form-control" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>تعداد</label>
                                <select name="pageSize" class="form-control">
                                    @foreach (var size in Model.PageSizeOptions)
                                    {
                                        <option value="@size" selected="@(Model.DocumentPageSize == size ? "selected" : null)">@size</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group col-md-2 d-flex align-items-end">
                                <button class="btn btn-outline-primary btn-block" type="submit">اعمال</button>
                            </div>
                        </form>

                        <div class="table-responsive">
                            <table class="table table-sm table-striped mb-0">
                                <thead>
                                    <tr>
                                        <th>شماره</th>
                                        <th>نوع</th>
                                        <th>تاریخ</th>
                                        <th>وضعیت</th>
                                        <th class="text-right">عملیات</th>
                                    </tr>
                                </thead>
                                <tbody id="transfer-document-list-body">
                                    @if (Model.Documents.Count == 0)
                                    {
                                        <tr><td colspan="5" class="text-center text-muted">سندی پیدا نشد.</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var document in Model.Documents)
                                        {
                                            <tr>
                                                <td><span class="text-monospace">@document.DocumentNo</span></td>
                                                <td>@TypeLabel(document.DocumentType)</td>
                                                <td>@document.OccurredAt.ToString("yyyy/MM/dd HH:mm")</td>
                                                <td><span class="badge badge-pill @StatusClass(document.Status)">@StatusLabel(document.Status)</span></td>
                                                <td class="text-right">
                                                    <button type="button"
                                                            class="btn btn-outline-primary btn-xs js-transfer-document-details"
                                                            data-document-id="@document.DocumentBusinessKey"
                                                            data-document-no="@document.DocumentNo">جزئیات</button>
                                                    @if (string.Equals(document.Status, "Draft", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <a class="btn btn-outline-secondary btn-xs mr-1"
                                                           asp-action="@documentAction"
                                                           asp-controller="InventoryManagement"
                                                           asp-route-documentId="@document.DocumentBusinessKey"
                                                           asp-route-documentType="@document.DocumentType"
                                                           asp-route-tab="create"
                                                           data-ajax-target="#documents-page-root">ویرایش</a>
                                                        <button class="btn btn-outline-danger btn-xs mr-1 js-transfer-document-delete" type="button" data-document-id="@document.DocumentBusinessKey" data-document-no="@document.DocumentNo">حذف</button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (Model.DocumentTotalPages > 1)
                        {
                            <nav class="mt-3" id="transfer-document-list-pagination-wrapper">
                                <ul class="pagination pagination-sm mb-0" id="transfer-document-list-pagination">
                                    @for (var i = 1; i <= Model.DocumentTotalPages; i++)
                                    {
                                        <li class="page-item @(i == Model.DocumentPage ? "active" : null)">
                                            <a class="page-link"
                                               asp-action="@documentAction"
                                               asp-controller="InventoryManagement"
                                               asp-route-documentId="@Model.SelectedDocumentId"
                                               asp-route-documentNo="@Model.DocumentNoFilter"
                                               asp-route-documentType="@Model.DocumentTypeFilter"
                                               asp-route-status="@Model.DocumentStatusFilter"
                                               asp-route-occurredFrom="@Model.OccurredFromFilter"
                                               asp-route-occurredTo="@Model.OccurredToFilter"
                                               asp-route-page="@i"
                                               asp-route-pageSize="@Model.DocumentPageSize"
                                               data-ajax-target="#documents-page-root">@i</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    </div>
                </div>
            </div>

            <div class="d-none">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">جزئیات سند</h5>
                        @if (Model.SelectedDocumentDetails is null)
                        {
                            <div class="alert alert-light mb-0">سندی برای نمایش انتخاب نشده است.</div>
                        }
                        else
                        {
                            var selectedDocumentType = Model.SelectedDocumentDetails.DocumentType;
                            var showQualityColumn = string.Equals(selectedDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase)
                                || string.Equals(selectedDocumentType, "Conversion", StringComparison.OrdinalIgnoreCase);
                            var canEditLines = string.Equals(Model.SelectedDocumentDetails.Status, "Draft", StringComparison.OrdinalIgnoreCase);

                            <p class="mb-1"><strong>شماره:</strong> <span class="text-monospace">@Model.SelectedDocumentDetails.DocumentNo</span></p>
                            <p class="mb-1"><strong>نوع:</strong> @TypeLabel(Model.SelectedDocumentDetails.DocumentType)</p>
                            <p class="mb-1"><strong>وضعیت:</strong> <span class="badge badge-pill @StatusClass(Model.SelectedDocumentDetails.Status)">@StatusLabel(Model.SelectedDocumentDetails.Status)</span></p>
                            <p class="mb-1"><strong>تاریخ وقوع:</strong> @Model.SelectedDocumentDetails.OccurredAt.ToString("yyyy/MM/dd HH:mm")</p>
                            <p class="mb-1"><strong>مرجع:</strong> @(string.IsNullOrWhiteSpace(Model.SelectedDocumentDetails.ReferenceType) ? "-" : $"{Model.SelectedDocumentDetails.ReferenceType} / {Model.SelectedDocumentDetails.ReferenceBusinessId}")</p>
                            <p class="mb-1"><strong>علت:</strong> @(string.IsNullOrWhiteSpace(Model.SelectedDocumentDetails.ReasonCode) ? "-" : Model.SelectedDocumentDetails.ReasonCode)</p>
                            <p class="mb-1"><strong>تاریخ تایید:</strong> @(Model.SelectedDocumentDetails.ApprovedAt?.ToString("yyyy/MM/dd HH:mm") ?? "-")</p>
                            <p class="mb-3"><strong>تاریخ پست:</strong> @(Model.SelectedDocumentDetails.PostedAt?.ToString("yyyy/MM/dd HH:mm") ?? "-")</p>

                            @if (canEditLines)
                            {
                                <div class="border-top pt-3 mt-3">
                                    <h6 class="mb-3">@(string.IsNullOrWhiteSpace(Model.LineForm.LineId) ? "افزودن آیتم سند" : "ویرایش آیتم سند")</h6>
                                    <form asp-action="SaveDocumentLine" asp-controller="InventoryManagement" method="post" class="mb-0" data-loading-form data-ajax-target="#documents-page-root">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" asp-for="LineForm.DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                        <input type="hidden" asp-for="LineForm.DocumentType" value="@selectedDocumentType" />
                                        <input type="hidden" asp-for="LineForm.LineId" value="@Model.LineForm.LineId" />
                                        <div class="form-row">
                                            <div class="form-group col-md-4">
                                                <label>واریانت</label>
                                                <select asp-for="LineForm.VariantId" class="form-control js-search-select" data-placeholder="جستجو با کد یا نام واریانت" required>
                                                    <option value="">انتخاب واریانت</option>
                                                    @foreach (var variant in Model.VariantLookup.OrderBy(x => x.Sku))
                                                    {
                                                        <option value="@variant.Id" selected="@(variant.Id == Model.LineForm.VariantId ? "selected" : null)">@VariantLabel(variant)</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group col-md-2">
                                                <label>تعداد</label>
                                                <input asp-for="LineForm.Qty" type="number" step="0.0001" min="0.0001" class="form-control" />
                                            </div>
                                            <div class="form-group col-md-3 line-source">
                                                <label>لوکیشن مبدا</label>
                                                <select asp-for="LineForm.SourceLocationRef" class="form-control js-search-select" data-placeholder="انتخاب لوکیشن">
                                                    <option value="">انتخاب لوکیشن</option>
                                                    @foreach (var location in Model.LocationLookup.OrderBy(x => x.LocationCode))
                                                    {
                                                        <option value="@location.LocationBusinessKey" selected="@(location.LocationBusinessKey == Model.LineForm.SourceLocationRef ? "selected" : null)">@LocationName(location.LocationBusinessKey)</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group col-md-3 line-destination">
                                                <label>لوکیشن مقصد</label>
                                                <select asp-for="LineForm.DestinationLocationRef" class="form-control js-search-select" data-placeholder="انتخاب لوکیشن">
                                                    <option value="">انتخاب لوکیشن</option>
                                                    @foreach (var location in Model.LocationLookup.OrderBy(x => x.LocationCode))
                                                    {
                                                        <option value="@location.LocationBusinessKey" selected="@(location.LocationBusinessKey == Model.LineForm.DestinationLocationRef ? "selected" : null)">@LocationName(location.LocationBusinessKey)</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group col-md-2">
                                                <label>لات/بچ</label>
                                                <input asp-for="LineForm.LotBatchNo" class="form-control" />
                                            </div>
                                            @if (showQualityColumn)
                                            {
                                                @if (string.Equals(selectedDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <div class="form-group col-md-2 line-from-quality">
                                                        <label>کیفیت مبدأ</label>
                                                        <select asp-for="LineForm.FromQualityStatusRef" class="form-control js-search-select" data-placeholder="انتخاب کیفیت">
                                                            <option value="">انتخاب کیفیت</option>
                                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                                            {
                                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.FromQualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="form-group col-md-2 line-to-quality">
                                                        <label>کیفیت مقصد</label>
                                                        <select asp-for="LineForm.ToQualityStatusRef" class="form-control js-search-select" data-placeholder="انتخاب کیفیت">
                                                            <option value="">انتخاب کیفیت</option>
                                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                                            {
                                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.ToQualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="form-group col-md-2 line-quality">
                                                        <label>کیفیت</label>
                                                        <select asp-for="LineForm.QualityStatusRef" class="form-control js-search-select" data-placeholder="انتخاب کیفیت">
                                                            <option value="">انتخاب کیفیت</option>
                                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                                            {
                                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.QualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                }
                                            }
                                            <div class="form-group col-md-2 line-adjustment">
                                                <label>جهت تعدیل</label>
                                                <select asp-for="LineForm.AdjustmentDirection" class="form-control">
                                                    <option value="">انتخاب</option>
                                                    <option value="Increase" selected="@(Model.LineForm.AdjustmentDirection == "Increase" ? "selected" : null)">افزایش</option>
                                                    <option value="Decrease" selected="@(Model.LineForm.AdjustmentDirection == "Decrease" ? "selected" : null)">کاهش</option>
                                                </select>
                                            </div>
                                            <div class="form-group col-md-4 line-reason">
                                                <label>علت ردیف</label>
                                                <input asp-for="LineForm.ReasonCode" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="d-flex justify-content-end">
                                            <a class="btn btn-outline-secondary mr-2" asp-action="@documentAction" asp-controller="InventoryManagement" asp-route-documentId="@Model.SelectedDocumentDetails.DocumentBusinessKey" asp-route-documentType="@Model.SelectedDocumentDetails.DocumentType" data-ajax-target="#documents-page-root">لغو</a>
                                            <button class="btn btn-primary" type="submit">@(string.IsNullOrWhiteSpace(Model.LineForm.LineId) ? "افزودن آیتم" : "ذخیره تغییرات")</button>
                                        </div>
                                    </form>
                                </div>
                            }

                            <div class="border-top pt-3 mt-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0">آیتم های سند</h6>
                                    <span class="text-muted small">@Model.SelectedDocumentDetails.Lines.Count ردیف</span>
                                </div>
                                @if (Model.SelectedDocumentDetails.Lines.Count == 0)
                                {
                                    <div class="alert alert-light mb-0">ردیفی برای این سند ثبت نشده است.</div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm table-striped mb-0">
                                            <thead>
                                                <tr>
                                                    <th>واریانت</th>
                                                    <th>تعداد</th>
                                                    <th>واحد</th>
                                        <th>مبدا</th>
                                        <th>مقصد</th>
                                                    @if (showQualityColumn)
                                                    {
                                                        <th>کیفیت</th>
                                                    }
                                                    <th>علت</th>
                                                    @if (canEditLines)
                                                    {
                                                        <th class="text-right">عملیات</th>
                                                    }
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in Model.SelectedDocumentDetails.Lines)
                                                {
                                                    var lineProductId = VariantProductId(line.VariantRef);
                                                    <tr>
                                                        <td>
                                                            @if (!string.IsNullOrWhiteSpace(lineProductId))
                                                            {
                                                                <a asp-controller="VariantManagement"
                                                                   asp-action="Variants"
                                                                   asp-route-productId="@lineProductId"
                                                                   asp-route-variantId="@line.VariantRef">
                                                                    @VariantName(line.VariantRef)
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <span>@VariantName(line.VariantRef)</span>
                                                            }
                                                        </td>
                                                        <td>@line.Qty.ToString("0.####")</td>
                                                        <td>@UomName(line.UomRef)</td>
                                                        <td>@LocationName(line.SourceLocationRef)</td>
                                                         <td>@LocationName(line.DestinationLocationRef)</td>
                                                        @if (showQualityColumn)
                                                        {
                                                            <td>
                                                                @if (string.Equals(selectedDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase))
                                                                {
                                                                    <span>@QualityName(line.FromQualityStatusRef) -> @QualityName(line.ToQualityStatusRef)</span>
                                                                }
                                                                else
                                                                {
                                                                    <span>@QualityName(line.QualityStatusRef)</span>
                                                                }
                                                            </td>
                                                        }
                                                        <td>
                                                            @(string.IsNullOrWhiteSpace(line.ReasonCode) ? AdjustmentDirectionLabel(line.AdjustmentDirection) : line.ReasonCode)
                                                        </td>
                                                        @if (canEditLines)
                                                        {
                                                            <td class="text-right">
                                                                <a class="btn btn-outline-primary btn-xs" asp-action="@documentAction" asp-controller="InventoryManagement" asp-route-documentId="@Model.SelectedDocumentDetails.DocumentBusinessKey" asp-route-editingLineId="@line.LineBusinessKey" asp-route-documentType="@Model.SelectedDocumentDetails.DocumentType" data-ajax-target="#documents-page-root">ویرایش</a>
                                                                <button type="button"
                                                                        class="btn btn-outline-danger btn-xs js-transfer-line-delete"
                                                                        data-document-id="@Model.SelectedDocumentDetails.DocumentBusinessKey"
                                                                        data-document-no="@Model.SelectedDocumentDetails.DocumentNo"
                                                                        data-line-id="@line.LineBusinessKey">حذف</button>
                                                            </td>
                                                        }
                                                    </tr>
                                                    @if (!string.IsNullOrWhiteSpace(line.LotBatchNo) || line.BaseQty != line.Qty || !string.Equals(line.BaseUomRef, line.UomRef, StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <tr>
                                                            <td colspan="@(showQualityColumn ? 8 : 7)" class="text-muted small">
                                                                Base: @line.BaseQty.ToString("0.####") @UomName(line.BaseUomRef)
                                                                @if (!string.IsNullOrWhiteSpace(line.LotBatchNo))
                                                                {
                                                                    <span> | لات/بچ: @line.LotBatchNo</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>

                            var selectedStatus = Model.SelectedDocumentDetails.Status;
                            var canApproveByStatus = string.Equals(selectedStatus, "Draft", StringComparison.OrdinalIgnoreCase);
                            var canRejectByStatus = !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Cancelled", StringComparison.OrdinalIgnoreCase);
                            var canCancelByStatus = !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Rejected", StringComparison.OrdinalIgnoreCase);
                            var canPostByStatus = !string.Equals(selectedStatus, "Cancelled", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Rejected", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase);

                            <div class="border-top pt-3">
                                <div class="mb-2 text-muted small">تغییر وضعیت</div>
                                <div class="d-flex flex-wrap">
                                    <form asp-action="ApproveDocument" asp-controller="InventoryManagement" method="post" class="mr-1 mb-1" data-loading-form data-ajax-target="#documents-page-root">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="documentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                        <button class="btn btn-outline-info btn-xs" type="submit" @(Can("Inventory.Document.Approve", "InventoryDocument.Approve", "Document.Approve") && canApproveByStatus ? null : "disabled")>تایید</button>
                                    </form>
                                    <form asp-action="PostDocument" asp-controller="InventoryManagement" method="post" class="mr-1 mb-1" data-loading-form data-ajax-target="#documents-page-root">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="documentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                        <button class="btn btn-outline-success btn-xs" type="submit" @(Can("Inventory.Document.Post", "InventoryDocument.Post", "Document.Post") && canPostByStatus ? null : "disabled")>پست</button>
                                    </form>
                                </div>
                                <form asp-action="RejectDocument" asp-controller="InventoryManagement" method="post" class="mt-2" data-loading-form data-ajax-target="#documents-page-root">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                    <div class="form-group mb-2">
                                        <label class="small">علت رد</label>
                                        <input name="ReasonCode" class="form-control form-control-sm" />
                                    </div>
                                    <button class="btn btn-outline-danger btn-xs" type="submit" @(Can("Inventory.Document.Reject", "InventoryDocument.Reject", "Document.Reject") && canRejectByStatus ? null : "disabled")>رد سند</button>
                                </form>
                                <form asp-action="CancelDocument" asp-controller="InventoryManagement" method="post" class="mt-2" data-loading-form data-ajax-target="#documents-page-root">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                    <div class="form-group mb-2">
                                        <label class="small">علت لغو</label>
                                        <input name="ReasonCode" class="form-control form-control-sm" />
                                    </div>
                                    <button class="btn btn-outline-warning btn-xs" type="submit" @(Can("Inventory.Document.Cancel", "InventoryDocument.Cancel", "Document.Cancel") && canCancelByStatus ? null : "disabled")>لغو سند</button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<div class="modal fade" id="transfer-document-details-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="transfer-document-details-modal-title">جزئیات سند حواله</h5>
                    <div class="small text-muted" id="transfer-document-details-modal-subtitle"></div>
                </div>
                <button type="button" class="close" data-dismiss="modal" aria-label="بستن">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="transfer-document-details-modal-body">
                <div class="text-muted">در حال بارگذاری...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script data-ajax-reinit="documents">
        (function () {
            var lineContainer = document.getElementById('document-lines');
            var addLineButton = document.getElementById('add-document-line');
            var documentTypeSelect = document.getElementById('document-type-input');
            var warehouseSelect = document.getElementById('create-warehouse-select');
            var createForm = document.getElementById('document-create-form');
            var linesPanel = document.getElementById('document-lines-panel');
            var typeGuidance = document.getElementById('document-type-guidance');
            var validationSummary = document.getElementById('document-validation-summary');

            if (!lineContainer) {
                return;
            }

            var documentTypeConfig = {
                Receipt: {
                    title: 'رسید انبار',
                    text: 'برای ورود کالا به انبار استفاده می‌شود. در هر ردیف، لوکیشن مقصد الزامی است.',
                    source: false,
                    destination: false,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                Issue: {
                    title: 'حواله انبار',
                    text: 'برای خروج کالا از انبار استفاده می‌شود. در هر ردیف، لوکیشن مبدا الزامی است.',
                    source: true,
                    destination: false,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                Transfer: {
                    title: 'انتقال بین لوکیشن‌ها',
                    text: 'برای جابه‌جایی داخلی کالا استفاده می‌شود. مبدا و مقصد هر ردیف الزامی و باید متفاوت باشند.',
                    source: true,
                    destination: false,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                Adjustment: {
                    title: 'تعدیل موجودی',
                    text: 'برای اصلاح مقدار موجودی استفاده می‌شود. جهت تعدیل و علت ردیف الزامی است.',
                    source: false,
                    destination: false,
                    quality: false,
                    qualityChange: false,
                    adjustment: true,
                    lineReason: true
                },
                Return: {
                    title: 'برگشت کالا',
                    text: 'برای برگشت کالا به انبار استفاده می‌شود. لوکیشن مقصد هر ردیف الزامی است.',
                    source: false,
                    destination: true,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                QualityChange: {
                    title: 'تغییر کیفیت',
                    text: 'برای تغییر وضعیت کیفی کالا استفاده می‌شود. کیفیت مبدا و مقصد الزامی و باید متفاوت باشند.',
                    source: false,
                    destination: false,
                    quality: false,
                    qualityChange: true,
                    adjustment: false,
                    lineReason: false
                },
                Conversion: {
                    title: 'سند تبدیل',
                    text: 'برای مصرف اجزای سازنده و تولید کالای نهایی استفاده می‌شود. در هر ردیف فقط یکی از مبدا یا مقصد را پر کنید.',
                    source: true,
                    destination: true,
                    quality: true,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false,
                    exclusiveFlow: true
                }
            };

            function setRequired(selectors, isRequired, line) {
                selectors.forEach(function (selector) {
                    line.querySelectorAll(selector).forEach(function (field) {
                        if (isRequired) {
                            field.setAttribute('required', 'required');
                        } else {
                            field.removeAttribute('required');
                        }
                    });
                });
            }

            function clearValidation() {
                if (validationSummary) {
                    validationSummary.style.display = 'none';
                    validationSummary.textContent = '';
                }

                lineContainer.querySelectorAll('.is-invalid').forEach(function (field) {
                    field.classList.remove('is-invalid');
                });
            }

            function showValidation(message, field) {
                if (validationSummary) {
                    validationSummary.textContent = message;
                    validationSummary.style.display = '';
                }

                if (field) {
                    field.classList.add('is-invalid');
                    field.focus();
                }
            }

            function selectedConfig() {
                var type = documentTypeSelect ? documentTypeSelect.value : 'Receipt';
                return documentTypeConfig[type] || documentTypeConfig.Receipt;
            }

            function renumberLines() {
                var lines = lineContainer.querySelectorAll('.document-line');
                lines.forEach(function (line, index) {
                    line.setAttribute('data-line-index', index);
                    var title = line.querySelector('strong');
                    if (title) {
                        title.textContent = 'ردیف ' + (index + 1);
                    }

                    line.querySelectorAll('input, select, textarea').forEach(function (field) {
                        if (field.name) {
                            field.name = field.name.replace(/CreateForm\.Lines\[\d+\]/g, 'CreateForm.Lines[' + index + ']');
                        }
                    });
                });
            }

            function toggleTypeFields() {
                var config = selectedConfig();
                if (typeGuidance) {
                    typeGuidance.innerHTML = '<strong>' + config.title + '</strong><div class="small mt-1">' + config.text + '</div>';
                }

                lineContainer.querySelectorAll('.document-line').forEach(function (line) {
                    line.querySelectorAll('.line-source').forEach(function (el) { el.style.display = config.source ? '' : 'none'; });
                    line.querySelectorAll('.line-destination').forEach(function (el) { el.style.display = config.destination ? '' : 'none'; });
                    line.querySelectorAll('.line-adjustment').forEach(function (el) { el.style.display = config.adjustment ? '' : 'none'; });
                    line.querySelectorAll('.line-quality').forEach(function (el) { el.style.display = config.quality ? '' : 'none'; });
                    line.querySelectorAll('.line-from-quality, .line-to-quality').forEach(function (el) { el.style.display = config.qualityChange ? '' : 'none'; });
                    line.querySelectorAll('.line-reason').forEach(function (el) { el.style.display = config.lineReason ? '' : 'none'; });

                    setRequired(['.source-location-select'], config.source && !config.exclusiveFlow, line);
                    setRequired(['.destination-location-select'], config.destination && !config.exclusiveFlow, line);
                    setRequired(['.line-adjustment select'], config.adjustment, line);
                    setRequired(['.line-reason input'], config.lineReason, line);
                    setRequired(['.line-from-quality select', '.line-to-quality select'], config.qualityChange, line);
                    setRequired(['.line-quality select'], !!config.quality && !config.qualityChange, line);
                });
            }

            function syncLocationsToWarehouse() {
                var warehouseId = warehouseSelect ? warehouseSelect.value : '';
                lineContainer.querySelectorAll('.document-location-select').forEach(function (select) {
                    Array.prototype.forEach.call(select.options, function (option) {
                        if (!option.value) {
                            option.hidden = false;
                            return;
                        }

                        var optionWarehouse = option.getAttribute('data-warehouse-ref');
                        option.hidden = !!warehouseId && optionWarehouse !== warehouseId;
                    });

                    if (select.value) {
                        var selectedOption = select.options[select.selectedIndex];
                        if (selectedOption && selectedOption.hidden) {
                            select.value = '';
                        }
                    }
                });
            }

            function syncVariantUom(line) {
                var select = line.querySelector('.document-variant-select');
                var uomRef = line.querySelector('.document-uom-ref');
                var baseUomRef = line.querySelector('.document-base-uom-ref');
                var hint = line.querySelector('.document-uom-hint');
                if (!select || !uomRef || !baseUomRef) {
                    return;
                }

                var option = select.options[select.selectedIndex];
                var baseUom = option ? option.getAttribute('data-base-uom-ref') : '';
                uomRef.value = baseUom || '';
                baseUomRef.value = baseUom || '';
                if (hint) {
                    hint.textContent = baseUom ? ('Base UOM: ' + baseUom) : 'UOM از Base UOM واریانت پر می شود.';
                }
            }

            function bindLine(line) {
                var removeButton = line.querySelector('.remove-document-line');
                if (removeButton) {
                    removeButton.addEventListener('click', function () {
                        if (lineContainer.querySelectorAll('.document-line').length === 1) {
                            line.querySelectorAll('input[type="text"], input[type="number"]').forEach(function (input) {
                                input.value = input.type === 'number' ? '1' : '';
                            });
                            line.querySelectorAll('select').forEach(function (select) {
                                select.value = '';
                            });
                            syncVariantUom(line);
                            return;
                        }

                        line.remove();
                        renumberLines();
                        toggleTypeFields();
                        syncLocationsToWarehouse();
                    });
                }

                var variantSelect = line.querySelector('.document-variant-select');
                if (variantSelect) {
                    variantSelect.addEventListener('change', function () {
                        syncVariantUom(line);
                    });
                    syncVariantUom(line);
                }
            }

            function firstField(line, selector) {
                return line.querySelector(selector);
            }

            function validateDocumentForm() {
                clearValidation();

                if (!createForm) {
                    return true;
                }

                var warehouseField = document.getElementById('create-warehouse-select');
                if (warehouseField && !warehouseField.value) {
                    showValidation('انتخاب انبار برای سند الزامی است.', warehouseField);
                    return false;
                }

                var sellerField = createForm.querySelector('[name="CreateForm.SellerRef"]');
                if (sellerField && !sellerField.value) {
                    showValidation('انتخاب فروشنده برای سند الزامی است.', sellerField);
                    return false;
                }

                var config = selectedConfig();
                var lines = Array.prototype.slice.call(lineContainer.querySelectorAll('.document-line'));
for (var i = 0; i < lines.length; i++) {
                    var line = lines[i];
                    var lineTitle = 'ردیف ' + (i + 1);
                    var variant = firstField(line, '.document-variant-select');
                    var qty = firstField(line, 'input[name$=".Qty"]');
                    var source = firstField(line, '.source-location-select');
                    var destination = firstField(line, '.destination-location-select');
                    var adjustment = firstField(line, '.line-adjustment select');
                    var reason = firstField(line, '.line-reason input');
                    var fromQuality = firstField(line, '.line-from-quality select');
                    var toQuality = firstField(line, '.line-to-quality select');

                    if (!variant || !variant.value) {
                        showValidation(lineTitle + ': انتخاب واریانت الزامی است.', variant);
                        return false;
                    }

                    if (!qty || Number(qty.value) <= 0) {
                        showValidation(lineTitle + ': تعداد باید بزرگ‌تر از صفر باشد.', qty);
                        return false;
                    }

                    if (config.source && !config.exclusiveFlow && (!source || !source.value)) {
                        showValidation(lineTitle + ': لوکیشن مبدا الزامی است.', source);
                        return false;
                    }

                    if (config.destination && !config.exclusiveFlow && (!destination || !destination.value)) {
                        showValidation(lineTitle + ': لوکیشن مقصد الزامی است.', destination);
                        return false;
                    }

                    if (!config.exclusiveFlow && config.source && config.destination && source && destination && source.value && source.value === destination.value) {
                        showValidation(lineTitle + ': لوکیشن مبدا و مقصد باید متفاوت باشند.', destination);
                        return false;
                    }

                    if (config.exclusiveFlow) {
                        var hasSource = !!(source && source.value);
                        var hasDestination = !!(destination && destination.value);
                        var quality = firstField(line, '.line-quality select');

                        if (hasSource === hasDestination) {
                            showValidation(lineTitle + ': در سند تبدیل، هر ردیف باید یا خروجی باشد یا ورودی.', source || destination);
                            return false;
                        }

                        if (!quality || !quality.value) {
                            showValidation(lineTitle + ': وضعیت کیفیت الزامی است.', quality);
                            return false;
                        }
                    }

                    if (config.adjustment && (!adjustment || !adjustment.value)) {
                        showValidation(lineTitle + ': جهت تعدیل الزامی است.', adjustment);
                        return false;
                    }

                    if (config.lineReason && (!reason || !reason.value.trim())) {
                        showValidation(lineTitle + ': علت ردیف الزامی است.', reason);
                        return false;
                    }

                    if (config.qualityChange && (!fromQuality || !fromQuality.value)) {
                        showValidation(lineTitle + ': کیفیت مبدا الزامی است.', fromQuality);
                        return false;
                    }

                    if (config.qualityChange && (!toQuality || !toQuality.value)) {
                        showValidation(lineTitle + ': کیفیت مقصد الزامی است.', toQuality);
                        return false;
                    }

                    if (config.qualityChange && fromQuality && toQuality && fromQuality.value && fromQuality.value === toQuality.value) {
                        showValidation(lineTitle + ': کیفیت مبدا و مقصد باید متفاوت باشند.', toQuality);
                        return false;
                    }
                }

                return true;
            }

            function addLine() {
                var lines = lineContainer.querySelectorAll('.document-line');
                var lastLine = lines[lines.length - 1];
                var clone = lastLine.cloneNode(true);
                clone.querySelectorAll('.select2').forEach(function (node) {
                    node.remove();
                });
                clone.querySelectorAll('input').forEach(function (input) {
                    input.value = input.type === 'number' ? '1' : '';
                });
                clone.querySelectorAll('select').forEach(function (select) {
                    select.value = '';
                    delete select.dataset.select2Initialized;
                });
                lineContainer.appendChild(clone);
                if (window.appUi && typeof window.appUi.initSearchableSelects === 'function') {
                    window.appUi.initSearchableSelects(clone);
                }
                renumberLines();
                bindLine(clone);
                toggleTypeFields();
                syncLocationsToWarehouse();
            }

            if (addLineButton) {
                addLineButton.addEventListener('click', addLine);
            }

            if (documentTypeSelect) {
                documentTypeSelect.addEventListener('change', function () {
                    clearValidation();
                    toggleTypeFields();
                });
            }

            if (warehouseSelect) {
                warehouseSelect.addEventListener('change', function () {
                    clearValidation();
                    syncLocationsToWarehouse();
                });
            }

            if (createForm) {
                createForm.addEventListener('submit', function (event) {
                    if (!validateDocumentForm()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                });
            }

            lineContainer.querySelectorAll('.document-line').forEach(bindLine);
            renumberLines();
            toggleTypeFields();
            syncLocationsToWarehouse();
        })();
    </script>
    <script data-ajax-reinit="transfer-documents-details">
        (function () {
            var modalSelector = '#transfer-document-details-modal';
            var modalBodySelector = '#transfer-document-details-modal-body';
            var modalTitleSelector = '#transfer-document-details-modal-title';
            var modalSubtitleSelector = '#transfer-document-details-modal-subtitle';
            var detailsUrl = '@Url.Action("TransferDocumentDetails", "InventoryManagement")';
            var variantInventoryLookupUrl = '@Url.Action("SearchTransferVariantInventoryLookup", "InventoryManagement")';
            var variantSerialLookupUrl = '@Url.Action("SearchTransferVariantSerialLookup", "InventoryManagement")';
            var transferSourceLocationOptions = [];
            var transferDestinationLocationOptions = [];
            var documentListUrl = '@Url.Action("DocumentList", "InventoryManagement")';
            var documentListFormSelector = '#transfer-document-list-form';
            var documentListCountSelector = '#transfer-document-list-count';
            var documentListBodySelector = '#transfer-document-list-body';
            var documentListPaginationWrapperSelector = '#transfer-document-list-pagination-wrapper';
            var documentListPaginationSelector = '#transfer-document-list-pagination';
            var deleteDocumentUrl = '@Url.Action("DeleteDocument", "InventoryManagement")';

            function showModal() {
                if (window.jQuery && window.jQuery.fn && window.jQuery.fn.modal) {
                    window.jQuery(modalSelector).modal('show');
                }
            }

            function escapeHtml(value) {
                return String(value == null ? '' : value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function hydrateTransferInventoryOptions(root) {
                root = root || document;
                var locationJson = root.dataset ? root.dataset.locationOptions : '';
                transferDestinationLocationOptions = [];

                if (!locationJson) {
                    return;
                }

                try {
                    transferDestinationLocationOptions = JSON.parse(locationJson) || [];
                } catch (error) {
                    console.error(error);
                    transferDestinationLocationOptions = [];
                }
            }

            function getTransferLineControls(root) {
                root = root || document;
                return {
                    variantSelect: root.querySelector('select[name="LineForm.VariantId"]'),
                    sourceSelect: root.querySelector('select[name="LineForm.SourceLocationRef"]'),
                    warehouseSelect: root.querySelector('select[name="LineForm.WarehouseRef"]'),
                    destinationSelect: root.querySelector('select[name="LineForm.DestinationLocationRef"]'),
                    qtyInput: root.querySelector('input[name="LineForm.Qty"]'),
                    submitButton: root.querySelector('.js-transfer-line-submit'),
                    cancelButton: root.querySelector('.js-transfer-line-cancel')
                };
            }

            function setSelectOptions(select, items, placeholderText, selectedValue) {
                if (!select) {
                    return;
                }

                while (select.firstChild) {
                    select.removeChild(select.firstChild);
                }

                var placeholder = document.createElement('option');
                placeholder.value = '';
                placeholder.textContent = placeholderText || '';
                select.appendChild(placeholder);

                (items || []).forEach(function (item) {
                    var option = document.createElement('option');
                    option.value = item.locationId || item.id || '';
                    option.textContent = item.text || option.value;
                    if (item && item.warehouseId) {
                        option.setAttribute('data-warehouse-id', item.warehouseId);
                    }
                    if (item && item.warehouseText) {
                        option.setAttribute('data-warehouse-text', item.warehouseText);
                    }
                    if (item && item.locationText) {
                        option.setAttribute('data-location-text', item.locationText);
                    }
                    select.appendChild(option);
                });

                select.value = selectedValue || '';
                if (window.jQuery) {
                    window.jQuery(select).trigger('change.select2');
                }
            }

            function getTransferLineSerialControls(root) {
                root = root || document;
                return {
                    section: root.querySelector('.line-serials'),
                    summary: root.querySelector('.js-transfer-line-serial-summary'),
                    container: root.querySelector('.js-transfer-line-serial-container'),
                    hidden: root.querySelector('.js-transfer-line-serial-hidden')
                };
            }

            function parseTransferSerialSelectionJson(serialJson) {
                if (!serialJson) {
                    return [];
                }

                try {
                    var parsed = JSON.parse(serialJson);
                    if (!Array.isArray(parsed)) {
                        return [];
                    }

                    return parsed
                        .map(function (item) {
                            return {
                                serialItemBusinessKey: String(item.serialItemBusinessKey || item.SerialItemBusinessKey || ''),
                                serialNo: String(item.serialNo || item.SerialNo || '')
                            };
                        })
                        .filter(function (item) {
                            return item.serialItemBusinessKey || item.serialNo;
                        });
                } catch (error) {
                    console.error(error);
                    return [];
                }
            }

            function collectTransferSelectedSerialIds(root) {
                var controls = getTransferLineSerialControls(root);
                if (!controls.container) {
                    return [];
                }

                var selected = [];
                controls.container.querySelectorAll('.js-transfer-line-serial-select').forEach(function (checkbox) {
                    if (!checkbox.checked) {
                        return;
                    }

                    selected.push(checkbox.getAttribute('data-serial-id') || '');
                });

                return selected.filter(Boolean);
            }

            function syncTransferLineSerialHiddenInputs(root) {
                var controls = getTransferLineSerialControls(root);
                if (!controls.hidden || !controls.container) {
                    return;
                }

                var selectedSerials = [];
                controls.container.querySelectorAll('.js-transfer-line-serial-select').forEach(function (checkbox) {
                    if (!checkbox.checked) {
                        return;
                    }

                    selectedSerials.push({
                        serialId: checkbox.getAttribute('data-serial-id') || '',
                        serialNo: checkbox.getAttribute('data-serial-no') || ''
                    });
                });

                controls.hidden.innerHTML = '';
                selectedSerials.forEach(function (serial, index) {
                    var idInput = document.createElement('input');
                    idInput.type = 'hidden';
                    idInput.name = 'LineForm.Serials[' + index + '].SerialItemBusinessKey';
                    idInput.value = serial.serialId;
                    controls.hidden.appendChild(idInput);

                    var noInput = document.createElement('input');
                    noInput.type = 'hidden';
                    noInput.name = 'LineForm.Serials[' + index + '].SerialNo';
                    noInput.value = serial.serialNo;
                    controls.hidden.appendChild(noInput);
                });
            }

            function renderTransferSerialOptions(root, serials, selectedSerialIds, sourceSelected) {
                root = root || document;
                var controls = getTransferLineSerialControls(root);
                if (!controls.section || !controls.summary || !controls.container) {
                    return;
                }

                var variantControls = getTransferLineControls(root);
                var hasVariant = !!(variantControls.variantSelect && variantControls.variantSelect.value);
                var hasSource = !!sourceSelected;
                var items = Array.isArray(serials) ? serials : [];
                var selectedLookup = {};
                (selectedSerialIds || []).forEach(function (serialId) {
                    selectedLookup[String(serialId || '')] = true;
                });

                controls.container.innerHTML = '';
                controls.hidden.innerHTML = '';

                if (!hasVariant || !hasSource) {
                    controls.section.classList.add('d-none');
                    controls.summary.textContent = 'ابتدا واریانت و لوکیشن مبدأ را انتخاب کنید.';
                    return;
                }

                controls.section.classList.remove('d-none');

                if (!items.length) {
                    controls.summary.textContent = 'سریالی برای این واریانت در لوکیشن انتخاب‌شده پیدا نشد.';
                    controls.container.innerHTML = '<div class="text-muted small">موردی برای انتخاب وجود ندارد.</div>';
                    return;
                }

                controls.summary.textContent = 'سریال‌های موجود را انتخاب کنید.';

                items.forEach(function (serial) {
                    var serialId = String(serial.serialItemBusinessKey || '');
                    var serialNo = String(serial.serialNo || serialId || '-');
                    var warehouseLabel = serial.warehouseRef || '';
                    var locationLabel = serial.locationRef || '';
                    var qualityLabel = serial.qualityStatusRef || '';

                    var wrapper = document.createElement('label');
                    wrapper.className = 'd-flex align-items-start mb-1 small border rounded px-2 py-1 bg-white';

                    var checkbox = document.createElement('input');
                    checkbox.type = 'checkbox';
                    checkbox.className = 'mr-2 mt-1 js-transfer-line-serial-select';
                    checkbox.setAttribute('data-serial-id', serialId);
                    checkbox.setAttribute('data-serial-no', serial.serialNo || '');
                    checkbox.checked = !!selectedLookup[serialId];

                    checkbox.addEventListener('change', function () {
                        syncTransferLineSerialHiddenInputs(root);
                    });

                    var content = document.createElement('span');
                    content.className = 'flex-grow-1';

                    var title = document.createElement('span');
                    title.className = 'd-block font-weight-bold';
                    title.textContent = serialNo;

                    var meta = document.createElement('span');
                    meta.className = 'd-block text-muted';
                    meta.style.fontSize = '11px';
                    meta.textContent = [warehouseLabel, locationLabel, qualityLabel, serial.status || ''].filter(Boolean).join(' / ');

                    content.appendChild(title);
                    content.appendChild(meta);
                    wrapper.appendChild(checkbox);
                    wrapper.appendChild(content);
                    controls.container.appendChild(wrapper);
                });

                syncTransferLineSerialHiddenInputs(root);
            }

            function renderTransferSourceLocationOptions(root, selectedSourceLocationId, allowedLocationIds) {
                var controls = getTransferLineControls(root);
                if (!controls.sourceSelect || !controls.destinationSelect) {
                    return;
                }

                var allowed = Array.isArray(allowedLocationIds) ? allowedLocationIds.filter(Boolean).map(function (value) {
                    return String(value).toLowerCase();
                }) : [];

                var sourceLocations = transferSourceLocationOptions.filter(function (item) {
                    if (!allowed.length) {
                        return false;
                    }

                    var itemId = String(item.id || item.locationId || '').toLowerCase();
                    return allowed.indexOf(itemId) >= 0;
                });

                var sourcePlaceholderText = controls.variantSelect && controls.variantSelect.value
                    ? (sourceLocations.length ? 'انتخاب لوکیشن' : 'برای این واریانت لوکیشنی یافت نشد')
                    : 'ابتدا واریانت را انتخاب کنید';

                setSelectOptions(controls.sourceSelect, sourceLocations, sourcePlaceholderText, selectedSourceLocationId);
                controls.sourceSelect.disabled = sourceLocations.length === 0;
                if (window.jQuery) {
                    window.jQuery(controls.sourceSelect).trigger('change.select2');
                }
            }

            function renderTransferDestinationLocationOptions(root, selectedWarehouseId, selectedDestinationLocationId) {
                var controls = getTransferLineControls(root);
                if (!controls.warehouseSelect || !controls.destinationSelect) {
                    return;
                }

                var selectedWarehouse = String(selectedWarehouseId || controls.warehouseSelect.value || '');
                var filteredLocations = transferDestinationLocationOptions.filter(function (item) {
                    if (!selectedWarehouse) {
                        return false;
                    }

                    return String(item.warehouseId || '').toLowerCase() === selectedWarehouse.toLowerCase();
                });

                var destinationPlaceholderText = selectedWarehouse
                    ? (filteredLocations.length ? 'انتخاب لوکیشن' : 'برای این انبار لوکیشنی یافت نشد')
                    : 'ابتدا انبار مقصد را انتخاب کنید';

                setSelectOptions(controls.destinationSelect, filteredLocations, destinationPlaceholderText, selectedDestinationLocationId);
                controls.destinationSelect.disabled = !selectedWarehouse || filteredLocations.length === 0;
                if (window.jQuery) {
                    window.jQuery(controls.destinationSelect).trigger('change.select2');
                }
            }

            function resolveTransferWarehouseIdByLocation(locationId) {
                if (!locationId) {
                    return '';
                }

                var match = transferDestinationLocationOptions.find(function (item) {
                    return String(item.id || item.locationId || '').toLowerCase() === String(locationId || '').toLowerCase();
                });

                return match ? (match.warehouseId || '') : '';
            }

            async function loadTransferVariantSerials(root, variantId, sourceLocationId, selectedSerialIds) {
                root = root || document;
                var controls = getTransferLineControls(root);
                if (!controls.variantSelect) {
                    return;
                }

                if (!variantId || !sourceLocationId) {
                    renderTransferSerialOptions(root, [], selectedSerialIds || [], false);
                    return;
                }

                var url = new URL(variantSerialLookupUrl, window.location.origin);
                url.searchParams.set('variantId', variantId);
                url.searchParams.set('sourceLocationId', sourceLocationId);

                var response = await fetch(url.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                });

                var payload = await response.json();
                if (!payload || payload.isSuccess === false) {
                    throw new Error((payload && payload.errorMessage) || 'Loading transfer variant serials failed.');
                }

                renderTransferSerialOptions(root, payload.serials || [], selectedSerialIds || [], sourceLocationId);
            }

            async function loadTransferVariantInventory(root, variantId, selectedSourceLocationId, selectedWarehouseId, selectedDestinationLocationId, selectedSerialIds) {
                root = root || document;
                var controls = getTransferLineControls(root);
                if (!controls.variantSelect || !controls.sourceSelect || !controls.destinationSelect || !controls.warehouseSelect) {
                    return;
                }

                hydrateTransferInventoryOptions(root);

                if (!variantId) {
                    renderTransferSourceLocationOptions(root, selectedSourceLocationId || controls.sourceSelect.value || '', []);
                    renderTransferDestinationLocationOptions(root, selectedWarehouseId || controls.warehouseSelect.value || '', selectedDestinationLocationId || controls.destinationSelect.value || '');
                    renderTransferSerialOptions(root, [], selectedSerialIds || [], false);
                    return;
                }

                var url = new URL(variantInventoryLookupUrl, window.location.origin);
                url.searchParams.set('variantId', variantId);

                var response = await fetch(url.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                });

                var payload = await response.json();
                if (!payload || payload.isSuccess === false) {
                    throw new Error((payload && payload.errorMessage) || 'Loading transfer variant inventory failed.');
                }

                transferSourceLocationOptions = Array.isArray(payload.locations) ? payload.locations.slice() : [];

                renderTransferSourceLocationOptions(
                    root,
                    selectedSourceLocationId || controls.sourceSelect.value || '',
                    transferSourceLocationOptions.map(function (item) { return item.id || item.locationId || ''; }));

                renderTransferDestinationLocationOptions(
                    root,
                    selectedWarehouseId || controls.warehouseSelect.value || '',
                    selectedDestinationLocationId || controls.destinationSelect.value || '');

                if (controls.sourceSelect && controls.sourceSelect.value) {
                    await loadTransferVariantSerials(
                        root,
                        variantId,
                        controls.sourceSelect.value,
                        selectedSerialIds || []);
                } else {
                    renderTransferSerialOptions(root, [], selectedSerialIds || [], false);
                }
            }

            function initializeTransferInventoryChain(root) {
                root = root || document;
                var controls = getTransferLineControls(root);
                if (!controls.variantSelect || !controls.sourceSelect || !controls.destinationSelect) {
                    return;
                }

                if (controls.variantSelect.dataset.transferInventoryBound === 'true') {
                    return;
                }

                controls.variantSelect.addEventListener('change', function () {
                    loadTransferVariantInventory(
                        root,
                        controls.variantSelect.value || '',
                        controls.sourceSelect.value || '',
                        controls.warehouseSelect ? (controls.warehouseSelect.value || '') : '',
                        controls.destinationSelect.value || '',
                        collectTransferSelectedSerialIds(root)).catch(function (error) {
                            console.error(error);
                        });
                });

                if (controls.sourceSelect) {
                    controls.sourceSelect.addEventListener('change', function () {
                        if (!controls.variantSelect.value) {
                            renderTransferSerialOptions(root, [], [], false);
                            return;
                        }

                        loadTransferVariantSerials(
                            root,
                            controls.variantSelect.value || '',
                            controls.sourceSelect.value || '',
                            collectTransferSelectedSerialIds(root)).catch(function (error) {
                                console.error(error);
                            });
                    });
                }

                if (controls.warehouseSelect) {
                    controls.warehouseSelect.addEventListener('change', function () {
                        renderTransferDestinationLocationOptions(
                            root,
                            controls.warehouseSelect.value || '',
                            controls.destinationSelect.value || '');
                    });
                }

                controls.variantSelect.dataset.transferInventoryBound = 'true';

                hydrateTransferInventoryOptions(root);
                renderTransferSourceLocationOptions(
                    root,
                    controls.sourceSelect.value || '',
                    []);
                renderTransferDestinationLocationOptions(
                    root,
                    controls.warehouseSelect ? (controls.warehouseSelect.value || '') : '',
                    controls.destinationSelect.value || '');

                if (controls.variantSelect.value) {
                    loadTransferVariantInventory(
                        root,
                        controls.variantSelect.value,
                        controls.sourceSelect.value || '',
                        controls.warehouseSelect ? (controls.warehouseSelect.value || '') : '',
                        controls.destinationSelect.value || '',
                        parseTransferSerialSelectionJson(root.dataset ? root.dataset.defaultSerialsJson : '')).catch(function (error) {
                            console.error(error);
                        });
                }
            }

            async function loadTransferDetails(documentId, documentNo) {
                var url = new URL(detailsUrl, window.location.origin);
                url.searchParams.set('documentId', documentId || '');

                var response = await fetch(url.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'text/html'
                    }
                });

                var html = await response.text();
                replaceTransferDetailsModalBody(html, documentId, documentNo);

                showModal();
            }

            function fillTransferLineForm(trigger) {
                if (!trigger) {
                    return;
                }

                var modal = document.querySelector(modalSelector);
                if (!modal) {
                    return;
                }

                var lineIdInput = modal.querySelector('input[name="LineForm.LineId"]');
                var variantSelect = modal.querySelector('select[name="LineForm.VariantId"]');
                var sourceSelect = modal.querySelector('select[name="LineForm.SourceLocationRef"]');
                var warehouseSelect = modal.querySelector('select[name="LineForm.WarehouseRef"]');
                var destinationSelect = modal.querySelector('select[name="LineForm.DestinationLocationRef"]');
                var qualitySelect = modal.querySelector('select[name="LineForm.QualityStatusRef"]');
                var qtyInput = modal.querySelector('input[name="LineForm.Qty"]');
                var submitButton = modal.querySelector('.js-transfer-line-submit');
                var cancelButton = modal.querySelector('.js-transfer-line-cancel');
                var destinationLocationId = trigger.getAttribute('data-destination-location-id') || '';
                var qualityId = trigger.getAttribute('data-quality-id') || '';
                var serialsJson = trigger.getAttribute('data-serials-json') || '';
                var selectedSerialIds = parseTransferSerialSelectionJson(serialsJson).map(function (item) {
                    return item.serialItemBusinessKey;
                });
                var destinationWarehouseId = resolveTransferWarehouseIdByLocation(destinationLocationId);

                if (lineIdInput) {
                    lineIdInput.value = trigger.getAttribute('data-line-id') || '';
                }

                if (variantSelect) {
                    variantSelect.value = trigger.getAttribute('data-variant-id') || '';
                }

                if (qtyInput) {
                    qtyInput.value = trigger.getAttribute('data-qty') || '1';
                }

                if (warehouseSelect) {
                    warehouseSelect.value = destinationWarehouseId;
                    if (window.jQuery) {
                        window.jQuery(warehouseSelect).trigger('change.select2');
                    }
                }

                if (qualitySelect) {
                    qualitySelect.value = qualityId;
                    if (window.jQuery) {
                        window.jQuery(qualitySelect).trigger('change.select2');
                    }
                }

                if (variantSelect && variantSelect.value) {
                    loadTransferVariantInventory(
                        modal,
                        variantSelect.value,
                        sourceSelect ? (trigger.getAttribute('data-source-location-id') || '') : '',
                        warehouseSelect ? (warehouseSelect.value || '') : '',
                        destinationLocationId,
                        selectedSerialIds).catch(function (error) {
                            console.error(error);
                        });
                }

                if (submitButton) {
                    submitButton.textContent = 'ذخیره تغییرات';
                }

                if (cancelButton) {
                    cancelButton.classList.remove('d-none');
                }
            }

            function resetTransferLineForm() {
                var modal = document.querySelector(modalSelector);
                if (!modal) {
                    return;
                }

                var lineIdInput = modal.querySelector('input[name="LineForm.LineId"]');
                var variantSelect = modal.querySelector('select[name="LineForm.VariantId"]');
                var sourceSelect = modal.querySelector('select[name="LineForm.SourceLocationRef"]');
                var warehouseSelect = modal.querySelector('select[name="LineForm.WarehouseRef"]');
                var destinationSelect = modal.querySelector('select[name="LineForm.DestinationLocationRef"]');
                var qualitySelect = modal.querySelector('select[name="LineForm.QualityStatusRef"]');
                var qtyInput = modal.querySelector('input[name="LineForm.Qty"]');
                var submitButton = modal.querySelector('.js-transfer-line-submit');
                var cancelButton = modal.querySelector('.js-transfer-line-cancel');

                if (lineIdInput) {
                    lineIdInput.value = '';
                }
                if (variantSelect) {
                    variantSelect.value = '';
                    if (window.jQuery) {
                        window.jQuery(variantSelect).trigger('change');
                    }
                }
                if (sourceSelect) {
                    sourceSelect.value = '';
                    sourceSelect.disabled = true;
                    if (window.jQuery) {
                        window.jQuery(sourceSelect).trigger('change.select2');
                    }
                }
                if (warehouseSelect) {
                    warehouseSelect.value = '';
                    if (window.jQuery) {
                        window.jQuery(warehouseSelect).trigger('change.select2');
                    }
                }
                if (destinationSelect) {
                    destinationSelect.value = '';
                    destinationSelect.disabled = true;
                    if (window.jQuery) {
                        window.jQuery(destinationSelect).trigger('change.select2');
                    }
                }
                if (qualitySelect) {
                    qualitySelect.value = '';
                    if (window.jQuery) {
                        window.jQuery(qualitySelect).trigger('change.select2');
                    }
                }
                var serialControls = getTransferLineSerialControls(modal);
                if (serialControls.section) {
                    serialControls.section.classList.add('d-none');
                }
                if (serialControls.summary) {
                    serialControls.summary.textContent = 'ابتدا واریانت و لوکیشن مبدأ را انتخاب کنید.';
                }
                if (serialControls.container) {
                    serialControls.container.innerHTML = '';
                }
                if (serialControls.hidden) {
                    serialControls.hidden.innerHTML = '';
                }
                if (qtyInput) {
                    qtyInput.value = '1';
                }
                if (submitButton) {
                    submitButton.textContent = 'افزودن آیتم';
                }
                if (cancelButton) {
                    cancelButton.classList.add('d-none');
                }
            }

            function initModalWidgets(root) {
                if (window.appUi && typeof window.appUi.initSearchableSelects === 'function') {
                    window.appUi.initSearchableSelects(root);
                }

                initializeTransferInventoryChain(root);
            }

            function replaceTransferDetailsModalBody(html, documentId, documentNo) {
                var parser = new DOMParser();
                var doc = parser.parseFromString(html, 'text/html');
                var nextBody = doc.querySelector(modalBodySelector);
                var currentBody = document.querySelector(modalBodySelector);
                if (!nextBody || !currentBody) {
                    throw new Error('Transfer details modal body could not be loaded.');
                }

                currentBody.replaceWith(nextBody);
                initModalWidgets(nextBody);

                var titleElement = document.querySelector(modalTitleSelector);
                var subtitleElement = document.querySelector(modalSubtitleSelector);
                if (titleElement) {
                    titleElement.textContent = documentNo ? ('جزئیات سند ' + documentNo) : 'جزئیات سند حواله';
                }
                if (subtitleElement) {
                    subtitleElement.textContent = documentId || '';
                }
            }

            function getTransferListForm() {
                return document.querySelector(documentListFormSelector);
            }

            function getTransferListValue(name) {
                var form = getTransferListForm();
                if (!form) {
                    return '';
                }

                var field = form.querySelector('[name="' + name + '"]');
                return field ? (field.value || '') : '';
            }

            function getCurrentTransferListPage() {
                var activeLink = document.querySelector(documentListPaginationSelector + ' .page-item.active .page-link');
                if (activeLink) {
                    var value = parseInt(activeLink.textContent || '1', 10);
                    if (!isNaN(value) && value > 0) {
                        return value;
                    }
                }

                var currentUrl = new URL(window.location.href);
                var page = parseInt(currentUrl.searchParams.get('page') || '1', 10);
                if (!isNaN(page) && page > 0) {
                    return page;
                }

                return 1;
            }

            function getTransferListQuery(page) {
                var params = new URLSearchParams();
                params.set('documentType', 'Transfer');
                params.set('page', String(page && page > 0 ? page : 1));
                params.set('pageSize', getTransferListValue('pageSize') || '@Model.DocumentPageSize');
                params.set('documentNo', getTransferListValue('documentNo'));
                params.set('status', getTransferListValue('status'));
                params.set('occurredFrom', getTransferListValue('occurredFrom'));
                params.set('occurredTo', getTransferListValue('occurredTo'));
                return params;
            }

            function buildTransferDocumentActionHtml(document, currentPage) {
                var documentId = escapeHtml(document.documentBusinessKey || '');
                var documentNo = escapeHtml(document.documentNo || '');
                var documentType = escapeHtml(document.documentType || '');
                var status = escapeHtml(document.status || '');
                var canEditDocument = String(document.status || '').toLowerCase() === 'draft';
                var canDeleteDocument = String(document.status || '').toLowerCase() === 'draft';
                var canActDocument = String(document.status || '').toLowerCase() !== 'posted';
                var editUrl = '@Url.Action("TransferDocuments", "InventoryManagement")'
                    + '?documentId=' + encodeURIComponent(document.documentBusinessKey || '')
                    + '&documentType=' + encodeURIComponent(document.documentType || 'Transfer')
                    + '&tab=create'
                    + '&page=' + encodeURIComponent(currentPage || 1)
                    + '&pageSize=' + encodeURIComponent(getTransferListValue('pageSize') || '@Model.DocumentPageSize')
                    + '&documentNo=' + encodeURIComponent(getTransferListValue('documentNo') || '')
                    + '&status=' + encodeURIComponent(getTransferListValue('status') || '')
                    + '&occurredFrom=' + encodeURIComponent(getTransferListValue('occurredFrom') || '')
                    + '&occurredTo=' + encodeURIComponent(getTransferListValue('occurredTo') || '');

                var html = '';
                html += '<td><span class="text-monospace">' + documentNo + '</span></td>';
                html += '<td>' + escapeHtml(getDocumentTypeLabel(document.documentType)) + '</td>';
                html += '<td>' + escapeHtml(formatDocumentDateTime(document.occurredAt)) + '</td>';
                html += '<td><span class="badge badge-pill ' + getStatusClass(document.status) + '">' + escapeHtml(getStatusLabel(document.status)) + '</span></td>';
                html += '<td class="text-right">';
                html += '<button type="button" class="btn btn-outline-primary btn-xs js-transfer-document-details mr-1" data-document-id="' + documentId + '" data-document-no="' + documentNo + '">جزئیات</button>';

                if (canEditDocument) {
                    html += '<a class="btn btn-outline-secondary btn-xs mr-1" href="' + editUrl + '" data-ajax-target="#documents-page-root">ویرایش</a>';
                }

                if (canDeleteDocument) {
                    html += '<button type="button" class="btn btn-outline-danger btn-xs mr-1 js-transfer-document-delete" data-document-id="' + documentId + '" data-document-no="' + documentNo + '">حذف</button>';
                }

                html += '</td>';
                return html;
            }

            function renderTransferDocumentRows(items, currentPage) {
                var body = document.querySelector(documentListBodySelector);
                if (!body) {
                    return;
                }

                var rows = Array.isArray(items) ? items : [];
                if (rows.length === 0) {
                    body.innerHTML = '<tr><td colspan="7" class="text-center text-muted">سندی پیدا نشد.</td></tr>';
                    return;
                }

                body.innerHTML = rows.map(function (document) {
                    return '<tr>' + buildTransferDocumentActionHtml(document, currentPage) + '</tr>';
                }).join('');
            }

            function renderTransferDocumentPagination(totalPages, currentPage) {
                var wrapper = document.querySelector(documentListPaginationWrapperSelector);
                if (!wrapper) {
                    return;
                }

                var pageCount = parseInt(totalPages || '0', 10) || 0;
                var page = parseInt(currentPage || '1', 10) || 1;
                if (pageCount <= 1) {
                    wrapper.innerHTML = '';
                    return;
                }

                var links = [];
                for (var i = 1; i <= pageCount; i++) {
                    links.push('<li class="page-item ' + (i === page ? 'active' : '') + '"><a class="page-link" href="#" data-page="' + i + '">' + i + '</a></li>');
                }

                wrapper.innerHTML = '<nav id="transfer-document-list-pagination"><ul class="pagination pagination-sm mb-0">' + links.join('') + '</ul></nav>';
            }

            async function refreshTransferDocumentList(page) {
                var query = getTransferListQuery(page || getCurrentTransferListPage());
                var response = await fetch(documentListUrl + '?' + query.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                });

                if (!response.ok) {
                    throw new Error('Document list refresh failed.');
                }

                var payload = await response.json();
                if (!payload) {
                    throw new Error('Document list refresh returned empty payload.');
                }

                var totalCount = typeof payload.totalCount === 'number' ? payload.totalCount : 0;
                var currentPage = typeof payload.page === 'number' ? payload.page : getCurrentTransferListPage();
                var totalPages = typeof payload.totalPages === 'number' ? payload.totalPages : 1;

                var countElement = document.querySelector(documentListCountSelector);
                if (countElement) {
                    countElement.textContent = totalCount + ' رکورد';
                }

                renderTransferDocumentRows(payload.items || [], currentPage);
                renderTransferDocumentPagination(totalPages, currentPage);
            }

            async function deleteTransferDocument(documentId, documentNo) {
                if (!documentId) {
                    return;
                }

                if (!window.confirm('این سند ' + (documentNo ? '(' + documentNo + ')' : '') + ' و همه آیتم‌های آن حذف شوند؟')) {
                    return;
                }

                var payload = new URLSearchParams();
                payload.append('__RequestVerificationToken', getAntiForgeryToken());
                payload.append('documentId', documentId);
                payload.append('documentType', 'Transfer');
                payload.append('page', String(getCurrentTransferListPage() || 1));
                payload.append('pageSize', getTransferListValue('pageSize') || '@Model.DocumentPageSize');
                payload.append('documentNo', getTransferListValue('documentNo'));
                payload.append('status', getTransferListValue('status'));
                payload.append('occurredFrom', getTransferListValue('occurredFrom'));
                payload.append('occurredTo', getTransferListValue('occurredTo'));

                var response = await fetch(deleteDocumentUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'Accept': 'text/html'
                    },
                    body: payload.toString()
                });

                if (!response.ok) {
                    throw new Error('Delete document request failed.');
                }

                await refreshTransferDocumentList();
            }

            async function deleteTransferDocumentLine(documentId, lineId, documentNo) {
                if (!documentId || !lineId) {
                    return;
                }

                if (!window.confirm('این آیتم حذف شود؟')) {
                    return;
                }

                var payload = new URLSearchParams();
                payload.append('__RequestVerificationToken', getAntiForgeryToken());
                payload.append('documentId', documentId);
                payload.append('lineId', lineId);

                var response = await fetch('@Url.Action("DeleteTransferDocumentLine", "InventoryManagement")', {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'Accept': 'text/html'
                    },
                    body: payload.toString()
                });

                if (!response.ok) {
                    throw new Error('Delete transfer line request failed.');
                }

                var html = await response.text();
                replaceTransferDetailsModalBody(html, documentId, documentNo);
            }

            function bindTransferDocumentListForm() {
                var form = document.querySelector(documentListFormSelector);
                if (!form || form.dataset.transferListBound === 'true') {
                    return;
                }

                form.addEventListener('submit', function (event) {
                    event.preventDefault();
                    event.stopImmediatePropagation();
                    refreshTransferDocumentList(1).catch(function (error) {
                        console.error(error);
                    });
                }, true);

                form.dataset.transferListBound = 'true';
            }

            if (!window.__transferDocumentsModalBound) {
                window.__transferDocumentsModalBound = true;

                document.addEventListener('click', function (event) {
                    var detailsTrigger = event.target && event.target.closest ? event.target.closest('.js-transfer-document-details') : null;
                    if (detailsTrigger) {
                        event.preventDefault();
                        loadTransferDetails(
                            detailsTrigger.getAttribute('data-document-id') || '',
                            detailsTrigger.getAttribute('data-document-no') || '').catch(function (error) {
                            console.error(error);
                        });
                        return;
                    }

                    var deleteTrigger = event.target && event.target.closest ? event.target.closest('.js-transfer-document-delete') : null;
                    if (deleteTrigger) {
                        event.preventDefault();
                        deleteTransferDocument(
                            deleteTrigger.getAttribute('data-document-id') || '',
                            deleteTrigger.getAttribute('data-document-no') || '').catch(function (error) {
                                console.error(error);
                            });
                        return;
                    }

                    var editButton = event.target && event.target.closest ? event.target.closest('.js-transfer-line-edit') : null;
                    if (editButton) {
                        event.preventDefault();
                        fillTransferLineForm(editButton);
                        return;
                    }

                    var lineDeleteButton = event.target && event.target.closest ? event.target.closest('.js-transfer-line-delete') : null;
                    if (lineDeleteButton) {
                        event.preventDefault();
                        deleteTransferDocumentLine(
                            lineDeleteButton.getAttribute('data-document-id') || '',
                            lineDeleteButton.getAttribute('data-line-id') || '',
                            lineDeleteButton.getAttribute('data-document-no') || '').catch(function (error) {
                                console.error(error);
                            });
                        return;
                    }

                    var cancelButton = event.target && event.target.closest ? event.target.closest('.js-transfer-line-cancel') : null;
                    if (cancelButton) {
                        event.preventDefault();
                        resetTransferLineForm();
                        return;
                    }

                    var paginationLink = event.target && event.target.closest ? event.target.closest(documentListPaginationSelector + ' .page-link') : null;
                    if (paginationLink) {
                        event.preventDefault();
                        var page = parseInt(paginationLink.getAttribute('data-page') || '1', 10);
                        refreshTransferDocumentList(page).catch(function (error) {
                            console.error(error);
                        });
                    }
                }, true);
            }

            if (!window.__transferDocumentsModalAuxBound) {
                window.__transferDocumentsModalAuxBound = true;

                var modalElement = document.querySelector(modalSelector);
                if (modalElement) {
                    initModalWidgets(modalElement);
                    modalElement.addEventListener('hidden.bs.modal', function () {
                        resetTransferLineForm();
                    });
                }

                bindTransferDocumentListForm();
            }
        })();
    </script>
}


