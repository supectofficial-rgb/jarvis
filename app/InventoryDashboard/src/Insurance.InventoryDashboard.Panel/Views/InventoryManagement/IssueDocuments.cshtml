                controls.variantSelect.addEventListener('change', onVariantChange);
                controls.sourceSelect.addEventListener('change', onSourceChange);
                if (window.jQuery) {
                    window.jQuery(controls.variantSelect).on('select2:select', onVariantChange);
                    window.jQuery(controls.sourceSelect).on('select2:select', onSourceChange);
