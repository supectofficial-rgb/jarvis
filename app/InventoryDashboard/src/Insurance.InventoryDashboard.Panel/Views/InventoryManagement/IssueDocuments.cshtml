    <script data-ajax-reinit="document-user-create">
        (function () {
            var modalSelector = '#document-user-create-modal';
            var formSelector = '#document-user-create-form';
            var errorSelector = '#document-user-create-error';
            var createUserUrl = '@Url.Action("CreateDocumentUser", "InventoryManagement")';

            function showModal() {
                if (window.jQuery && window.jQuery.fn && window.jQuery.fn.modal) {
                    window.jQuery(modalSelector).modal('show');
                }
            }

            function hideModal() {
                if (window.jQuery && window.jQuery.fn && window.jQuery.fn.modal) {
                    window.jQuery(modalSelector).modal('hide');
                }
            }

            function setError(message) {
                var errorBox = document.querySelector(errorSelector);
                if (!errorBox) {
                    return;
                }

                if (!message) {
                    errorBox.textContent = '';
                    errorBox.classList.add('d-none');
                    return;
                }

                errorBox.textContent = message;
                errorBox.classList.remove('d-none');
            }

            function resetForm() {
                var form = document.querySelector(formSelector);
                if (!form) {
                    return;
                }

                form.reset();
                if (window.jQuery) {
                    window.jQuery(form).find('select').trigger('change.select2');
                }
                setError('');
            }

            async function submitUserForm(event) {
                event.preventDefault();
                event.stopPropagation();

                var form = event.currentTarget;
                setError('');

                var response = await fetch(createUserUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    body: new FormData(form)
                });

                var payload = await response.json();
                if (!payload || payload.isSuccess === false) {
                    setError((payload && payload.errorMessage) || 'Ø§ÛŒØ¬Ø§Ø¯ Ú©Ø§Ø±Ø¨Ø± Ø§Ù†Ø¬Ø§Ù… Ù†Ø´Ø¯.');
                    return;
                }

                hideModal();
                window.location.reload();
            }

            document.addEventListener('click', function (event) {
                var trigger = event.target && event.target.closest ? event.target.closest('.js-open-document-user-modal') : null;
                if (!trigger) {
                    return;
                }

                event.preventDefault();
                resetForm();
                showModal();
            }, true);

            var form = document.querySelector(formSelector);
            if (form && form.dataset.documentUserCreateBound !== 'true') {
                form.addEventListener('submit', function (event) {
                    submitUserForm(event).catch(function (error) {
                        console.error(error);
                        setError('Ø§ÛŒØ¬Ø§Ø¯ Ú©Ø§Ø±Ø¨Ø± Ø§Ù†Ø¬Ø§Ù… Ù†Ø´Ø¯.');
                    });
                });
                form.dataset.documentUserCreateBound = 'true';
            }

            var modalElement = document.querySelector(modalSelector);
