@using System
@using System.Linq
@model Insurance.InventoryDashboard.Panel.Models.InventoryDocumentManagementPageViewModel
@{
    var document = Model.SelectedDocumentDetails;
    var currentDocumentType = document?.DocumentType ?? "Transfer";
    var canEditLines = document is not null && string.Equals(document.Status, "Draft", StringComparison.OrdinalIgnoreCase);
    var showTransferQualityColumns = string.Equals(currentDocumentType, "Transfer", StringComparison.OrdinalIgnoreCase);
    var showQualityColumn = string.Equals(currentDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentDocumentType, "Conversion", StringComparison.OrdinalIgnoreCase);

    string TypeLabel(string? type) => type switch
    {
        "Receipt" => UiText["inventory.documents.type.receipt"],
        "Issue" => UiText["inventory.documents.type.issue"],
        "Transfer" => UiText["inventory.documents.type.transfer"],
        "Adjustment" => UiText["inventory.documents.type.adjustment"],
        "Return" => UiText["inventory.documents.type.return"],
        "QualityChange" => UiText["inventory.documents.type.qualityChange"],
        "Conversion" => UiText["inventory.documents.type.conversion"],
        _ => type ?? "-"
    };

    string StatusLabel(string? status) => status switch
    {
        "Draft" => UiText["inventory.documents.status.draft"],
        "Approved" => UiText["inventory.documents.status.approved"],
        "Rejected" => UiText["inventory.documents.status.rejected"],
        "Cancelled" => UiText["inventory.documents.status.cancelled"],
        "Posted" => UiText["inventory.documents.status.posted"],
        _ => status ?? "-"
    };

    string StatusClass(string? status) => status switch
    {
        "Draft" => "badge-outline-secondary",
        "Approved" => "badge-info",
        "Rejected" => "badge-danger",
        "Cancelled" => "badge-warning",
        "Posted" => "badge-success",
        _ => "badge-secondary"
    };

    string VariantLabel(Insurance.InventoryDashboard.Panel.Models.ProductVariantSummaryModel variant)
    {
        var variantName = (variant.Name ?? string.Empty).Trim();
        var variantSku = (variant.Sku ?? string.Empty).Trim();
        if (!string.IsNullOrWhiteSpace(variantName) && !string.IsNullOrWhiteSpace(variantSku) && !string.Equals(variantName, variantSku, StringComparison.OrdinalIgnoreCase))
        {
            return $"{variantName} ({variantSku})";
        }

        if (!string.IsNullOrWhiteSpace(variantName))
        {
            return variantName;
        }

        if (!string.IsNullOrWhiteSpace(variantSku))
        {
            return variantSku;
        }

        if (!string.IsNullOrWhiteSpace(variant.Barcode))
        {
            return variant.Barcode.Trim();
        }

        return variant.Id;
    }

    string VariantName(string? variantId)
    {
        if (string.IsNullOrWhiteSpace(variantId))
        {
            return "-";
        }

        var variant = Model.VariantLookup.FirstOrDefault(x => string.Equals(x.Id, variantId, StringComparison.OrdinalIgnoreCase));
        return variant is null ? variantId : VariantLabel(variant);
    }

    string UomName(string? uomId)
    {
        if (string.IsNullOrWhiteSpace(uomId))
        {
            return "-";
        }

        var uom = Model.UnitOfMeasureLookup.FirstOrDefault(x => string.Equals(x.Id, uomId, StringComparison.OrdinalIgnoreCase));
        return uom is null ? uomId : $"{uom.Code} - {uom.Name}";
    }

    string QualityName(string? qualityId)
    {
        if (string.IsNullOrWhiteSpace(qualityId))
        {
            return "-";
        }

        var quality = Model.QualityStatusLookup.FirstOrDefault(x => string.Equals(x.QualityStatusBusinessKey, qualityId, StringComparison.OrdinalIgnoreCase));
        return quality is null ? qualityId : $"{quality.Code} - {quality.Name}";
    }

    string LocationName(string? locationId)
    {
        if (string.IsNullOrWhiteSpace(locationId))
        {
            return "-";
        }

        var location = Model.LocationLookup.FirstOrDefault(x => string.Equals(x.LocationBusinessKey, locationId, StringComparison.OrdinalIgnoreCase));
        if (location is null)
        {
            return locationId;
        }

        var warehouse = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, location.WarehouseRef, StringComparison.OrdinalIgnoreCase));
        var warehouseLabel = warehouse is null ? location.WarehouseRef : $"{warehouse.Code} - {warehouse.Name}";
        var locationLabel = string.IsNullOrWhiteSpace(location.LocationType)
            ? location.LocationCode
            : $"{location.LocationCode} ({location.LocationType})";
        return string.IsNullOrWhiteSpace(warehouseLabel) ? locationLabel : $"{warehouseLabel} - {locationLabel}";
    }

    var transferDestinationLocationOptions = Model.LocationLookup.Select(location =>
    {
        var warehouse = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, location.WarehouseRef, StringComparison.OrdinalIgnoreCase));
        var warehouseLabel = warehouse is null ? location.WarehouseRef : $"{warehouse.Code} - {warehouse.Name}";
        var locationLabel = string.IsNullOrWhiteSpace(location.LocationType)
            ? location.LocationCode
            : $"{location.LocationCode} ({location.LocationType})";

        return new
        {
            id = location.LocationBusinessKey,
            locationId = location.LocationBusinessKey,
            warehouseId = location.WarehouseRef,
            warehouseText = warehouseLabel,
            locationText = locationLabel,
            text = string.IsNullOrWhiteSpace(warehouseLabel) ? locationLabel : $"{warehouseLabel} - {locationLabel}"
        };
    }).ToList();

}

<div id="transfer-document-details-modal-body"
     class="modal-body transfer-document-details-modal"
      data-location-options='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(transferDestinationLocationOptions))'
      data-default-source-location-id="@Model.LineForm.SourceLocationRef"
      data-default-destination-location-id="@Model.LineForm.DestinationLocationRef"
      data-default-warehouse-id="@Model.LineForm.WarehouseRef"
      data-default-lot-batch-no="@Model.LineForm.LotBatchNo"
      data-default-serials-json='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineForm.Serials.Select(serial => new { serialItemBusinessKey = serial.SerialItemBusinessKey, serialNo = serial.SerialNo })))'>
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-warning">@Model.ErrorMessage</div>
    }

    @if (document is null)
    {
        <div class="alert alert-light mb-0">سندی برای نمایش پیدا نشد.</div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <div class="text-monospace h5 mb-1">@document.DocumentNo</div>
                <div class="text-muted small">@TypeLabel(currentDocumentType)</div>
            </div>
            <span class="badge badge-pill @StatusClass(document.Status)">@StatusLabel(document.Status)</span>
        </div>

        <div class="row mb-3">
            <div class="col-md-6 mb-2">
                <div class="text-muted small">تاریخ وقوع</div>
                <div>@document.OccurredAt.ToString("yyyy/MM/dd HH:mm")</div>
            </div>
            <div class="col-md-6 mb-2">
                <div class="text-muted small">مرجع</div>
                <div>@(string.IsNullOrWhiteSpace(document.ReferenceType) ? "-" : $"{document.ReferenceType} / {document.ReferenceBusinessId}")</div>
                <div>@(string.IsNullOrWhiteSpace(document.ExternalReferenceNo) ? "-" : document.ExternalReferenceNo)</div>
            </div>
        </div>

        @if (canEditLines)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0">@(string.IsNullOrWhiteSpace(Model.LineForm.LineId) ? "افزودن آیتم" : "ویرایش آیتم")</h6>
                        <button type="button" class="btn btn-outline-secondary btn-xs js-transfer-line-cancel d-none">لغو ویرایش</button>
                    </div>
                    <form asp-action="SaveTransferDocumentLine" asp-controller="InventoryManagement" method="post" data-loading-form data-ajax-target="#transfer-document-details-modal-body" class="mb-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="LineForm.DocumentId" value="@document.DocumentBusinessKey" />
                        <input type="hidden" asp-for="LineForm.DocumentType" value="@currentDocumentType" />
                        <input type="hidden" asp-for="LineForm.LineId" value="@Model.LineForm.LineId" />

                        @if (showTransferQualityColumns)
                        {
                            <div class="form-row mb-3">
                                <div class="form-group col-md-3 line-quality">
                                    <label>@UiText["inventory.documents.line.quality"]</label>
                                    <select asp-for="LineForm.QualityStatusRef" class="form-control js-search-select" data-placeholder='@UiText["inventory.documents.line.selectQuality"]'>
                                        <option value="">@UiText["inventory.documents.line.selectQuality"]</option>
                                        @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                        {
                                            <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.QualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group col-md-3 line-to-quality">
                                    <label>@UiText["inventory.documents.line.toQuality"]</label>
                                    <select asp-for="LineForm.ToQualityStatusRef" class="form-control js-search-select" data-placeholder='@UiText["inventory.documents.line.selectQuality"]' required>
                                        <option value="">@UiText["inventory.documents.line.selectQuality"]</option>
                                        @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                        {
                                            <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.ToQualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        }
                        else if (showQualityColumn)
                        {
                            <div class="form-row mb-3">
                                @if (string.Equals(currentDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase))
                                {
                                    <div class="form-group col-md-3 line-from-quality">
                                        <label>@UiText["inventory.documents.line.fromQuality"]</label>
                                        <select asp-for="LineForm.FromQualityStatusRef" class="form-control js-search-select" data-placeholder='@UiText["inventory.documents.line.selectQuality"]'>
                                            <option value="">@UiText["inventory.documents.line.selectQuality"]</option>
                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                            {
                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.FromQualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group col-md-3 line-to-quality">
                                        <label>@UiText["inventory.documents.line.toQuality"]</label>
                                        <select asp-for="LineForm.ToQualityStatusRef" class="form-control js-search-select" data-placeholder='@UiText["inventory.documents.line.selectQuality"]'>
                                            <option value="">@UiText["inventory.documents.line.selectQuality"]</option>
                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                            {
                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.ToQualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                            }
                                        </select>
                                    </div>
                                }
                                else
                                {
                                    <div class="form-group col-md-3 line-quality">
                                        <label>@UiText["inventory.documents.line.quality"]</label>
                                        <select asp-for="LineForm.QualityStatusRef" class="form-control js-search-select" data-placeholder='@UiText["inventory.documents.line.selectQuality"]'>
                                            <option value="">@UiText["inventory.documents.line.selectQuality"]</option>
                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                            {
                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.QualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                            }
                                        </select>
                                    </div>
                                }
                            </div>
                        }

                        <div class="form-row">
                            <div class="col-lg-6">
                                <div class="form-row">
                                    <div class="form-group col-md-4">
                                        <label>واریانت</label>
                                        <select asp-for="LineForm.VariantId" class="form-control js-search-select js-transfer-line-variant" data-placeholder="جستجو با کد یا نام واریانت" data-ajax-url='@Url.Action("SearchVariantLookup", "InventoryManagement")' required>
                                            <option value="">انتخاب واریانت</option>
                                            @foreach (var variant in Model.VariantLookup.OrderBy(x => x.Sku))
                                            {
                                                <option value="@variant.Id" selected="@(variant.Id == Model.LineForm.VariantId ? "selected" : null)">@VariantLabel(variant)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group col-md-4">
                                        <label>لوکیشن مبدا</label>
                                        <select asp-for="LineForm.SourceLocationRef" class="form-control js-search-select js-transfer-line-source" data-placeholder="انتخاب لوکیشن" disabled>
                                            <option value="">ابتدا واریانت را انتخاب کنید</option>
                                        </select>
                                    </div>
                                    <div class="form-group col-md-4">
                                        <label>انبار مقصد</label>
                                        <select asp-for="LineForm.WarehouseRef" class="form-control js-search-select js-transfer-line-warehouse" data-placeholder="انتخاب انبار">
                                            <option value="">انتخاب انبار</option>
                                            @foreach (var warehouse in Model.WarehouseLookup.OrderBy(x => x.Code))
                                            {
                                                <option value="@warehouse.WarehouseBusinessKey" selected="@(warehouse.WarehouseBusinessKey == Model.LineForm.WarehouseRef ? "selected" : null)">@warehouse.Code - @warehouse.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <div class="form-row">
                                    <div class="form-group col-md-4">
                                        <label>لوکیشن مقصد</label>
                                        <select asp-for="LineForm.DestinationLocationRef" class="form-control js-search-select js-transfer-line-destination" data-placeholder="انتخاب لوکیشن" disabled required>
                                            <option value="">ابتدا انبار مقصد را انتخاب کنید</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <label>لات/بچ</label>
                                <select asp-for="LineForm.LotBatchNo" class="form-control js-search-select js-transfer-line-lot" data-placeholder="انتخاب لات/بچ">
                                    <option value="">انتخاب لات/بچ</option>
                                </select>
                            </div>
                            <div class="form-group col-12 col-lg-8 line-serials d-none">
                                <label>@UiText["inventory.documents.serial.title"]</label>
                                <div class="text-muted small js-transfer-line-serial-summary mb-2" data-select-prompt="@UiText["inventory.documents.action.selectVariantAndLocation"]" data-required-hint="@UiText["inventory.documents.serial.requiredHint"]" data-no-available="@UiText["inventory.documents.serial.noAvailable"]">@UiText["inventory.documents.serial.requiredHint"]</div>
                                <div class="list-group js-transfer-line-serial-container" style="max-height: 240px; overflow:auto;"></div>
                                <div class="js-transfer-line-serial-hidden d-none"></div>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-10 line-qty">
                                <label>@UiText["inventory.documents.line.quantity"]</label>
                                <input asp-for="LineForm.Qty" type="number" step="0.0001" min="0.0001" class="form-control" />
                            </div>
                            <div class="form-group col-md-2 d-flex align-items-end">
                                <button class="btn btn-primary btn-block js-transfer-line-submit" type="submit">@(string.IsNullOrWhiteSpace(Model.LineForm.LineId) ? UiText["inventory.documents.action.addItem"] : UiText["inventory.documents.action.saveChanges"])</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-light border mb-3">این سند در وضعیت پیش‌نویس نیست و آیتم‌ها قابل ویرایش نیستند.</div>
        }

        <div class="border-top pt-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0">آیتم های سند</h6>
                <span class="text-muted small">@document.Lines.Count ردیف</span>
            </div>

            @if (document.Lines.Count == 0)
            {
                <div class="alert alert-light mb-0">ردیفی برای این سند ثبت نشده است.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>واریانت</th>
                                <th>تعداد</th>
                                <th>واحد</th>
                                <th>کیفیت</th>
                                <th>مبدا</th>
                                <th>مقصد</th>
                                <th class="text-right">عملیات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in document.Lines)
                            {
                                <tr>
                                    <td>@VariantName(line.VariantRef)</td>
                                    <td>@line.Qty.ToString("0.####")</td>
                                    <td>@UomName(line.UomRef)</td>
                                    <td>
                                        @if (showTransferQualityColumns)
                                        {
                                            <span>@QualityName(line.QualityStatusRef) -> @QualityName(line.ToQualityStatusRef)</span>
                                        }
                                        else if (string.Equals(currentDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span>@QualityName(line.FromQualityStatusRef) -> @QualityName(line.ToQualityStatusRef)</span>
                                        }
                                        else
                                        {
                                            <span>@QualityName(line.QualityStatusRef)</span>
                                        }
                                    </td>
                                    <td>@LocationName(line.SourceLocationRef)</td>
                                    <td>@LocationName(line.DestinationLocationRef)</td>
                                    <td class="text-right">
                                        @if (canEditLines)
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-primary btn-xs js-transfer-line-edit"
                                                    data-line-id="@line.LineBusinessKey"
                                                    data-variant-id="@line.VariantRef"
                                                    data-source-location-id="@line.SourceLocationRef"
                                                    data-destination-location-id="@line.DestinationLocationRef"
                                                    data-source-quality-id="@line.QualityStatusRef"
                                                    data-destination-quality-id="@line.ToQualityStatusRef"
                                                    data-quality-id="@line.QualityStatusRef"
                                                    data-qty="@line.Qty.ToString("0.####")"
                                                    data-serials-json='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(line.Serials.Select(serial => new { serialItemBusinessKey = serial.SerialItemBusinessKey, serialNo = serial.SerialNo })))'>ویرایش</button>
                                            <form asp-action="DeleteTransferDocumentLine" asp-controller="InventoryManagement" method="post" class="d-inline" data-loading-form data-ajax-target="#transfer-document-details-modal-body" onsubmit="return confirm('این آیتم حذف شود؟');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="documentId" value="@document.DocumentBusinessKey" />
                                                <input type="hidden" name="lineId" value="@line.LineBusinessKey" />
                                                <button class="btn btn-outline-danger btn-xs" type="submit">حذف</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">غیر قابل ویرایش</span>
                                        }
                                    </td>
                                </tr>
                                @if (line.BaseQty != line.Qty || !string.Equals(line.BaseUomRef, line.UomRef, StringComparison.OrdinalIgnoreCase) || !string.IsNullOrWhiteSpace(line.LotBatchNo))
                                {
                                    <tr>
                                        <td colspan="7" class="text-muted small">
                                            Base: @line.BaseQty.ToString("0.####") @UomName(line.BaseUomRef)
                                            @if (!string.IsNullOrWhiteSpace(line.LotBatchNo))
                                            {
                                                <span> | لات/بچ: @line.LotBatchNo</span>
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (line.Serials.Count > 0)
                                {
                                    <tr>
                                        <td colspan="7" class="small">
                                            <div class="d-flex flex-wrap align-items-start">
                                                <span class="text-muted mr-2">سریال‌های این ردیف:</span>
                                                <div class="d-flex flex-wrap">
                                                    @foreach (var serial in line.Serials.OrderBy(x => x.SerialNo))
                                                    {
                                                        <span class="badge badge-light border mr-1 mb-1">
                                                            @(string.IsNullOrWhiteSpace(serial.SerialNo) ? serial.SerialItemBusinessKey : serial.SerialNo)
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</div>

<script data-ajax-reinit="transfer-document-details-body">
    (function () {
        if (!window.appUi || typeof window.appUi.initTransferDocumentsModal !== 'function') {
            return;
        }

        var root = document.getElementById('transfer-document-details-modal-body');
        if (!root) {
            return;
        }

        window.appUi.initTransferDocumentsModal(root);
    })();
</script>
