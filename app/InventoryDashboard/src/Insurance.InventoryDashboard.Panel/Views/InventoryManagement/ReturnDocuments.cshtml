@using System
@using System.Linq
@model Insurance.InventoryDashboard.Panel.Models.InventoryDocumentManagementPageViewModel
@{
    ViewData["Title"] = UiText["inventory.documents.title"];
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x => string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) || string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));

    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    string WarehouseName(string? warehouseId)
    {
        if (string.IsNullOrWhiteSpace(warehouseId))
        {
            return "-";
        }

        var warehouse = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, warehouseId, StringComparison.OrdinalIgnoreCase));
        return warehouse is null ? warehouseId : $"{warehouse.Code} - {warehouse.Name}";
    }

    string SellerName(string? sellerId)
    {
        if (string.IsNullOrWhiteSpace(sellerId))
        {
            return "-";
        }

        var seller = Model.SellerLookup.FirstOrDefault(x => string.Equals(x.SellerBusinessKey, sellerId, StringComparison.OrdinalIgnoreCase));
        return seller is null ? sellerId : $"{seller.Code} - {seller.Name}";
    }

    string TypeLabel(string? type) => type switch
    {
        "Receipt" => UiText["inventory.documents.type.receipt"],
        "Issue" => UiText["inventory.documents.type.issue"],
        "Transfer" => UiText["inventory.documents.type.transfer"],
        "Adjustment" => UiText["inventory.documents.type.adjustment"],
        "Return" => UiText["inventory.documents.type.return"],
        "QualityChange" => UiText["inventory.documents.type.qualityChange"],
        "Conversion" => UiText["inventory.documents.type.conversion"],
        _ => type ?? "-"
    };

    string StatusLabel(string? status) => status switch
    {
        "Draft" => UiText["inventory.documents.status.draft"],
        "Approved" => UiText["inventory.documents.status.approved"],
        "Rejected" => UiText["inventory.documents.status.rejected"],
        "Cancelled" => UiText["inventory.documents.status.cancelled"],
        "Posted" => UiText["inventory.documents.status.posted"],
        _ => status ?? "-"
    };

    string StatusClass(string? status) => status switch
    {
        "Draft" => "badge-outline-secondary",
        "Approved" => "badge-info",
        "Rejected" => "badge-danger",
        "Cancelled" => "badge-warning",
        "Posted" => "badge-success",
        _ => "badge-secondary"
    };

    string VariantLabel(Insurance.InventoryDashboard.Panel.Models.ProductVariantSummaryModel variant)
    {
        var productName = Model.ProductLookup.FirstOrDefault(x => x.Id == variant.ProductId)?.Name;
        return string.IsNullOrWhiteSpace(productName)
            ? variant.Sku
            : $"{variant.Sku} - {productName}";
    }

    string VariantName(string? variantId)
    {
        if (string.IsNullOrWhiteSpace(variantId))
        {
            return "-";
        }

        var variant = Model.VariantLookup.FirstOrDefault(x => string.Equals(x.Id, variantId, StringComparison.OrdinalIgnoreCase));
        return variant is null ? variantId : VariantLabel(variant);
    }

    string? VariantProductId(string? variantId)
    {
        if (string.IsNullOrWhiteSpace(variantId))
        {
            return null;
        }

        return Model.VariantLookup.FirstOrDefault(x => string.Equals(x.Id, variantId, StringComparison.OrdinalIgnoreCase))?.ProductId;
    }

    string LocationName(string? locationId)
    {
        if (string.IsNullOrWhiteSpace(locationId))
        {
            return "-";
        }

        var location = Model.LocationLookup.FirstOrDefault(x => string.Equals(x.LocationBusinessKey, locationId, StringComparison.OrdinalIgnoreCase));
        return location is null ? locationId : $"{location.LocationCode} ({location.LocationType})";
    }

    string QualityName(string? qualityId)
    {
        if (string.IsNullOrWhiteSpace(qualityId))
        {
            return "-";
        }

        var quality = Model.QualityStatusLookup.FirstOrDefault(x => string.Equals(x.QualityStatusBusinessKey, qualityId, StringComparison.OrdinalIgnoreCase));
        return quality is null ? qualityId : $"{quality.Code} - {quality.Name}";
    }

    string UomName(string? uomId)
    {
        if (string.IsNullOrWhiteSpace(uomId))
        {
            return "-";
        }

        var uom = Model.UnitOfMeasureLookup.FirstOrDefault(x => string.Equals(x.Id, uomId, StringComparison.OrdinalIgnoreCase));
        return uom is null ? uomId : $"{uom.Code} - {uom.Name}";
    }

    string AdjustmentDirectionLabel(string? direction) => direction switch
    {
        "Increase" => UiText["inventory.documents.adjustment.increase"],
        "Decrease" => UiText["inventory.documents.adjustment.decrease"],
        _ => string.IsNullOrWhiteSpace(direction) ? "-" : direction
    };

    var hasListContext = !string.IsNullOrWhiteSpace(Model.SelectedDocumentId)
        || !string.IsNullOrWhiteSpace(Model.DocumentNoFilter)
        || !string.IsNullOrWhiteSpace(Model.DocumentStatusFilter)
        || !string.IsNullOrWhiteSpace(Model.WarehouseFilter)
        || !string.IsNullOrWhiteSpace(Model.SellerFilter)
        || !string.IsNullOrWhiteSpace(Model.OccurredFromFilter)
        || !string.IsNullOrWhiteSpace(Model.OccurredToFilter)
        || Model.DocumentPage > 1;

    var showListTab = hasListContext;
    var currentDocumentType = string.IsNullOrWhiteSpace(Model.DocumentTypeFilter) ? "Receipt" : Model.DocumentTypeFilter;
    var showConversionQuality = string.Equals(currentDocumentType, "Conversion", StringComparison.OrdinalIgnoreCase);
    var showQualityChangeFields = string.Equals(currentDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase);
    var documentAction = ViewBag.DocumentAction as string ?? "Documents";
}

<main id="documents-page-root" class="catalog-page">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="mb-4">
                    <h1>@UiText["inventory.documents.title"]</h1>
                    <div class="mb-2">
                        <span class="badge badge-pill badge-primary">@TypeLabel(currentDocumentType)</span>
                    </div>
                    <p class="text-muted">@UiText["inventory.documents.description"]</p>
                    <div>
                        <span class="badge badge-pill badge-outline-primary mb-1">@UiText["inventory.documents.summary.documents"] @Model.DocumentTotalCount</span>
                        @if (!string.IsNullOrWhiteSpace(Model.SelectedDocumentId))
                        {
                            <span class="badge badge-pill badge-outline-secondary mb-1">@UiText["inventory.documents.summary.selectedDocument"] @(Model.SelectedDocumentDetails?.DocumentNo ?? Model.SelectedDocumentId)</span>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-warning">@Model.ErrorMessage</div>
                }
                @if (TempData.ContainsKey("CatalogError"))
                {
                    <div class="alert alert-danger">@TempData["CatalogError"]</div>
                }
                @if (TempData.ContainsKey("CatalogSuccess"))
                {
                    <div class="alert alert-success">@TempData["CatalogSuccess"]</div>
                }

                <ul class="nav nav-tabs mt-4" id="document-management-tabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link @(showListTab ? null : "active")" id="document-create-tab" data-toggle="tab" href="#document-create-pane" role="tab" aria-controls="document-create-pane" aria-selected="@((showListTab ? "false" : "true"))">@UiText["inventory.documents.tab.create"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(showListTab ? "active" : null)" id="document-list-tab" data-toggle="tab" href="#document-list-pane" role="tab" aria-controls="document-list-pane" aria-selected="@((showListTab ? "true" : "false"))">@UiText["inventory.documents.tab.list"]</a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="tab-content">
            <div class="tab-pane fade @(showListTab ? null : "show active")" id="document-create-pane" role="tabpanel" aria-labelledby="document-create-tab">
        <div class="row">
            <div class="col-12 mb-4">
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="card-title mb-0">@UiText["inventory.documents.createTitle"]</h5>
                            <span class="text-muted small">@UiText["inventory.documents.baseUomNotice"]</span>
                        </div>

                        <form asp-action="SaveDocument" asp-controller="InventoryManagement" method="post" data-loading-form data-ajax-target="#documents-page-root" id="document-create-form">
                            @Html.AntiForgeryToken()
                            <div class="form-row">
                                <input type="hidden" asp-for="CreateForm.DocumentType" id="document-type-input" />
                                <div class="form-group col-md-2">
                                    <label>@UiText["inventory.documents.documentNo"]</label>
                                    <input asp-for="CreateForm.DocumentNo" class="form-control text-monospace" />
                                </div>
                                <div class="form-group col-md-4">
                                    <label>@UiText["inventory.documents.return.referenceLabel"]</label>
                                    <div class="input-group">
                                        <input type="text" id="return-reference-search-input" class="form-control text-monospace" placeholder="@UiText["inventory.documents.return.referencePlaceholder"]" autocomplete="off" />
                                        <div class="input-group-append">
                                            <button type="button" class="btn btn-outline-primary" id="return-reference-search-button">@UiText["inventory.documents.return.referenceSearch"]</button>
                                        </div>
                                    </div>
                                    <input type="hidden" asp-for="CreateForm.ReferenceType" id="return-reference-type-input" value="Issue" />
                                    <input type="hidden" asp-for="CreateForm.ReferenceBusinessId" id="return-reference-id-input" />
                                    <input type="hidden" asp-for="CreateForm.WarehouseRef" id="return-warehouse-ref-input" />
                                    <input type="hidden" asp-for="CreateForm.SellerRef" id="return-seller-ref-input" />
                                    <div class="mt-2 d-none" id="return-reference-selected">
                                        <div class="alert alert-light border mb-2 py-2">
                                            <strong>@UiText["inventory.documents.return.referenceSelected"]</strong>
                                            <span id="return-reference-selected-label">-</span>
                                        </div>
                                    </div>
                                    <div class="d-none" id="return-reference-results-panel">
                                        <div class="list-group small" id="return-reference-results"></div>
                                    </div>
                                </div>
                                <div class="form-group col-md-3">
                                    <label>@UiText["inventory.documents.occurredAt"]</label>
                                    <input asp-for="CreateForm.OccurredAt" type="datetime-local" class="form-control" value="@Model.CreateForm.OccurredAt.ToString("yyyy-MM-ddTHH:mm")" />
                                </div>
                                <div class="form-group col-md-3">
                                    <label>@UiText["inventory.documents.reason"]</label>
                                    <input asp-for="CreateForm.ReasonCode" class="form-control" />
                                </div>
                            </div>

                            <div id="document-lines-panel" class="d-none">
                                <div id="document-type-guidance" class="alert alert-light border mb-3" role="status"></div>
                                <div id="document-validation-summary" class="alert alert-danger mb-3" style="display:none" role="alert"></div>

                                <div class="d-flex justify-content-end mb-3">
                                    <button class="btn btn-outline-primary btn-xs" type="button" id="add-document-line">@UiText["inventory.documents.addLine"]</button>
                                </div>

                                <div id="document-lines">
                                @for (var i = 0; i < Model.CreateForm.Lines.Count; i++)
                                {
                                    <div class="card mb-3 document-line" data-line-index="@i">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <strong>@UiText["inventory.documents.list.number"] @(i + 1)</strong>
                                                <button class="btn btn-outline-danger btn-xs remove-document-line" type="button">@UiText["inventory.documents.line.deleteButton"]</button>
                                            </div>
                                            <div class="form-row">
                                                <div class="form-group col-md-4">
                                                    <label>@UiText["inventory.documents.line.variant"]</label>
                                                    <select name="CreateForm.Lines[@i].VariantId" class="form-control document-variant-select js-search-select" data-placeholder="@UiText["inventory.documents.line.selectVariant"]" required>
                                                        <option value="">@UiText["inventory.documents.line.selectVariant"]</option>
                                                        @foreach (var variant in Model.VariantLookup.OrderBy(x => x.Sku))
                                                        {
                                                            <option value="@variant.Id" data-base-uom-ref="@variant.BaseUomRef" data-product-id="@variant.ProductId" selected="@(variant.Id == Model.CreateForm.Lines[i].VariantId ? "selected" : null)">@VariantLabel(variant)</option>
                                                        }
                                                    </select>
                                                    <input type="hidden" name="CreateForm.Lines[@i].UomRef" value="@Model.CreateForm.Lines[i].UomRef" class="document-uom-ref" />
                                                    <input type="hidden" name="CreateForm.Lines[@i].BaseUomRef" value="@Model.CreateForm.Lines[i].BaseUomRef" class="document-base-uom-ref" />
                                                    <div class="text-muted small mt-1 document-uom-hint">@UiText["inventory.documents.line.baseUomHint"]</div>
                                                </div>
                                                <div class="form-group col-md-2">
                                                    <label>@UiText["inventory.documents.line.quantity"]</label>
                                                    <input name="CreateForm.Lines[@i].Qty" type="number" step="0.0001" min="0.0001" value="@Model.CreateForm.Lines[i].Qty.ToString("0.####")" class="form-control" required />
                                                </div>
                                                <div class="form-group col-md-3 line-source">
                                                    <label>@UiText["inventory.documents.line.sourceLocation"]</label>
                                                    <select name="CreateForm.Lines[@i].SourceLocationRef" class="form-control document-location-select source-location-select js-search-select" data-placeholder="@UiText["inventory.documents.line.selectLocation"]">
                                                        <option value="">@UiText["inventory.documents.line.selectLocation"]</option>
                                                        @foreach (var location in Model.LocationLookup.OrderBy(x => x.LocationCode))
                                                        {
                                                            <option value="@location.LocationBusinessKey" data-warehouse-ref="@location.WarehouseRef" selected="@(location.LocationBusinessKey == Model.CreateForm.Lines[i].SourceLocationRef ? "selected" : null)">@location.LocationCode (@location.LocationType)</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="form-group col-md-3 line-destination">
                                                    <label>@UiText["inventory.documents.line.destinationLocation"]</label>
                                                    <select name="CreateForm.Lines[@i].DestinationLocationRef" class="form-control document-location-select destination-location-select js-search-select" data-placeholder="@UiText["inventory.documents.line.selectLocation"]">
                                                        <option value="">@UiText["inventory.documents.line.selectLocation"]</option>
                                                        @foreach (var location in Model.LocationLookup.OrderBy(x => x.LocationCode))
                                                        {
                                                            <option value="@location.LocationBusinessKey" data-warehouse-ref="@location.WarehouseRef" selected="@(location.LocationBusinessKey == Model.CreateForm.Lines[i].DestinationLocationRef ? "selected" : null)">@location.LocationCode (@location.LocationType)</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="form-group col-md-2">
                                                    <label>@UiText["inventory.documents.line.lotBatch"]</label>
                                                    <input name="CreateForm.Lines[@i].LotBatchNo" value="@Model.CreateForm.Lines[i].LotBatchNo" class="form-control" />
                                                </div>
                                                @if (showQualityChangeFields)
                                                {
                                                    <div class="form-group col-md-2 line-from-quality">
                                                        <label>@UiText["inventory.documents.line.sourceLocation"]</label>
                                                        <select name="CreateForm.Lines[@i].FromQualityStatusRef" class="form-control js-search-select" data-placeholder="@UiText["inventory.documents.line.selectQuality"]">
                                                            <option value="">@UiText["inventory.documents.line.selectQuality"]</option>
                                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                                            {
                                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.CreateForm.Lines[i].FromQualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="form-group col-md-2 line-to-quality">
                                                        <label>@UiText["inventory.documents.line.destinationLocation"]</label>
                                                        <select name="CreateForm.Lines[@i].ToQualityStatusRef" class="form-control js-search-select" data-placeholder="@UiText["inventory.documents.line.selectQuality"]">
                                                            <option value="">@UiText["inventory.documents.line.selectQuality"]</option>
                                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                                            {
                                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.CreateForm.Lines[i].ToQualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                }
                                                else if (showConversionQuality)
                                                {
                                                    <div class="form-group col-md-2 line-quality">
                                                        <label>@UiText["inventory.documents.line.quality"]</label>
                                                        <select name="CreateForm.Lines[@i].QualityStatusRef" class="form-control js-search-select" data-placeholder="@UiText["inventory.documents.line.selectQuality"]">
                                                            <option value="">@UiText["inventory.documents.line.selectQuality"]</option>
                                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                                            {
                                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.CreateForm.Lines[i].QualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                }
                                                <div class="form-group col-md-2 line-adjustment">
                                                    <label>@UiText["inventory.documents.line.adjustmentDirection"]</label>
                                                    <select name="CreateForm.Lines[@i].AdjustmentDirection" class="form-control">
                                                        <option value="">@UiText["inventory.documents.line.selectOption"]</option>
                                                        <option value="Increase" selected="@(Model.CreateForm.Lines[i].AdjustmentDirection == "Increase" ? "selected" : null)">@UiText["inventory.documents.line.increase"]</option>
                                                        <option value="Decrease" selected="@(Model.CreateForm.Lines[i].AdjustmentDirection == "Decrease" ? "selected" : null)">@UiText["inventory.documents.line.decrease"]</option>
                                                    </select>
                                                </div>
                                                <div class="form-group col-md-4 line-reason">
                                                    <label>@UiText["inventory.documents.line.reason"]</label>
                                                    <input name="CreateForm.Lines[@i].ReasonCode" value="@Model.CreateForm.Lines[i].ReasonCode" class="form-control" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <button class="btn btn-primary" type="submit" @(Can("Inventory.Document.Create", "InventoryDocument.Create", "Document.Create") ? null : "disabled")>@UiText["inventory.documents.action.createDocument"]</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
            </div>

        <div class="tab-pane fade @(showListTab ? "show active" : null)" id="document-list-pane" role="tabpanel" aria-labelledby="document-list-tab">
            <div class="row">
                <div class="col-xl-8 mb-4">
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="card-title mb-0">@UiText["inventory.documents.list.title"]</h5>
                            <span class="text-muted small">@Model.DocumentTotalCount @UiText["inventory.documents.list.countSuffix"]</span>
                        </div>
                        <form asp-action="@documentAction" asp-controller="InventoryManagement" method="get" class="form-row mb-3" data-loading-form data-ajax-target="#documents-page-root">
                            <input type="hidden" name="documentId" value="@Model.SelectedDocumentId" />
                            <input type="hidden" name="documentType" value="@currentDocumentType" />
                            <div class="form-group col-md-2">
                                <label>@UiText["inventory.documents.list.number"]</label>
                                <input name="documentNo" value="@Model.DocumentNoFilter" class="form-control text-monospace" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>@UiText["inventory.documents.list.status"]</label>
                                <select name="status" class="form-control">
                                    <option value="">@UiText["inventory.documents.list.status.all"]</option>
                                    <option value="Draft" selected="@(Model.DocumentStatusFilter == "Draft" ? "selected" : null)">@UiText["inventory.documents.status.draft"]</option>
                                    <option value="Approved" selected="@(Model.DocumentStatusFilter == "Approved" ? "selected" : null)">@UiText["inventory.documents.status.approved"]</option>
                                    <option value="Rejected" selected="@(Model.DocumentStatusFilter == "Rejected" ? "selected" : null)">@UiText["inventory.documents.status.rejected"]</option>
                                    <option value="Cancelled" selected="@(Model.DocumentStatusFilter == "Cancelled" ? "selected" : null)">@UiText["inventory.documents.status.cancelled"]</option>
                                    <option value="Posted" selected="@(Model.DocumentStatusFilter == "Posted" ? "selected" : null)">@UiText["inventory.documents.status.posted"]</option>
                                </select>
                            </div>
                            <div class="form-group col-md-3">
                                <label>@UiText["inventory.documents.warehouse"]</label>
                                <select name="warehouseId" class="form-control js-search-select">
                                    <option value="">@UiText["inventory.documents.list.status.all"]</option>
                                    @foreach (var warehouse in Model.WarehouseLookup.OrderBy(x => x.Code))
                                    {
                                        <option value="@warehouse.WarehouseBusinessKey" selected="@(warehouse.WarehouseBusinessKey == Model.WarehouseFilter ? "selected" : null)">@warehouse.Code - @warehouse.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group col-md-3">
                                <label>@UiText["inventory.documents.seller"]</label>
                                <select name="sellerId" class="form-control js-search-select">
                                    <option value="">@UiText["inventory.documents.list.status.all"]</option>
                                    @foreach (var seller in Model.SellerLookup.OrderBy(x => x.Code))
                                    {
                                        <option value="@seller.SellerBusinessKey" selected="@(seller.SellerBusinessKey == Model.SellerFilter ? "selected" : null)">@seller.Code - @seller.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group col-md-2">
                                <label>@UiText["inventory.documents.list.filterFromDate"]</label>
                                <input name="occurredFrom" type="date" value="@Model.OccurredFromFilter" class="form-control" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>@UiText["inventory.documents.list.filterToDate"]</label>
                                <input name="occurredTo" type="date" value="@Model.OccurredToFilter" class="form-control" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>@UiText["inventory.documents.list.pageSize"]</label>
                                <select name="pageSize" class="form-control">
                                    @foreach (var size in Model.PageSizeOptions)
                                    {
                                        <option value="@size" selected="@(Model.DocumentPageSize == size ? "selected" : null)">@size</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group col-md-2 d-flex align-items-end">
                                <button class="btn btn-outline-primary btn-block" type="submit">@UiText["inventory.documents.list.apply"]</button>
                            </div>
                        </form>

                        <div class="table-responsive">
                            <table class="table table-sm table-striped mb-0">
                                <thead>
                                    <tr>
                                        <th>@UiText["inventory.documents.list.number"]</th>
                                        <th>@UiText["inventory.documents.list.type"]</th>
                                        <th>@UiText["inventory.documents.warehouse"]</th>
                                        <th>@UiText["inventory.documents.seller"]</th>
                                        <th>@UiText["inventory.documents.list.date"]</th>
                                        <th>@UiText["inventory.documents.list.status"]</th>
                                        <th class="text-right">@UiText["inventory.documents.list.actions"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Documents.Count == 0)
                                    {
                                        <tr><td colspan="7" class="text-center text-muted">@UiText["inventory.documents.action.noDocumentSelected"]</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var document in Model.Documents)
                                        {
                                            <tr>
                                                <td><span class="text-monospace">@document.DocumentNo</span></td>
                                                <td>@TypeLabel(document.DocumentType)</td>
                                                <td>@WarehouseName(document.WarehouseRef)</td>
                                                <td>@SellerName(document.SellerRef)</td>
                                                <td>@document.OccurredAt.ToString("yyyy/MM/dd HH:mm")</td>
                                                <td><span class="badge badge-pill @StatusClass(document.Status)">@StatusLabel(document.Status)</span></td>
                                                <td class="text-right">
                                                    <a class="btn btn-outline-primary btn-xs" asp-action="@documentAction" asp-controller="InventoryManagement" asp-route-documentId="@document.DocumentBusinessKey" asp-route-documentNo="@Model.DocumentNoFilter" asp-route-documentType="@Model.DocumentTypeFilter" asp-route-status="@Model.DocumentStatusFilter" asp-route-warehouseId="@Model.WarehouseFilter" asp-route-sellerId="@Model.SellerFilter" asp-route-occurredFrom="@Model.OccurredFromFilter" asp-route-occurredTo="@Model.OccurredToFilter" asp-route-page="@Model.DocumentPage" asp-route-pageSize="@Model.DocumentPageSize" data-ajax-target="#documents-page-root">@UiText["inventory.documents.action.details"]</a>
                                                    <a class="btn btn-outline-info btn-xs mr-1"
                                                       asp-action="@documentAction"
                                                       asp-controller="InventoryManagement"
                                                       asp-route-documentId="@document.DocumentBusinessKey"
                                                       asp-route-documentNo="@Model.DocumentNoFilter"
                                                       asp-route-documentType="@Model.DocumentTypeFilter"
                                                       asp-route-status="@Model.DocumentStatusFilter"
                                                       asp-route-warehouseId="@Model.WarehouseFilter"
                                                       asp-route-sellerId="@Model.SellerFilter"
                                                       asp-route-occurredFrom="@Model.OccurredFromFilter"
                                                       asp-route-occurredTo="@Model.OccurredToFilter"
                                                       asp-route-page="@Model.DocumentPage"
                                                       asp-route-pageSize="@Model.DocumentPageSize"
                                                       data-ajax-target="#documents-page-root">@UiText["inventory.documents.action.changeStatus"]</a>
                                                    @if (string.Equals(document.Status, "Draft", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <form asp-action="DeleteDocument"
                                                              asp-controller="InventoryManagement"
                                                              method="post"
                                                              class="d-inline"
                                                              data-loading-form
                                                              data-ajax-target="#documents-page-root"
                                                              onsubmit="return confirm('@UiText["inventory.documents.confirm.deleteDocument"]');">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="documentId" value="@document.DocumentBusinessKey" />
                                                            <input type="hidden" name="documentType" value="@document.DocumentType" />
                                                            <input type="hidden" name="documentNo" value="@Model.DocumentNoFilter" />
                                                            <input type="hidden" name="status" value="@Model.DocumentStatusFilter" />
                                                            <input type="hidden" name="warehouseId" value="@Model.WarehouseFilter" />
                                                            <input type="hidden" name="sellerId" value="@Model.SellerFilter" />
                                                            <input type="hidden" name="occurredFrom" value="@Model.OccurredFromFilter" />
                                                            <input type="hidden" name="occurredTo" value="@Model.OccurredToFilter" />
                                                            <input type="hidden" name="page" value="@Model.DocumentPage" />
                                                            <input type="hidden" name="pageSize" value="@Model.DocumentPageSize" />
                                                            <button class="btn btn-outline-danger btn-xs mr-1" type="submit">@UiText["inventory.documents.action.deleteDocument"]</button>
                                                        </form>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (Model.DocumentTotalPages > 1)
                        {
                            <nav class="mt-3">
                                <ul class="pagination pagination-sm mb-0">
                                    @for (var i = 1; i <= Model.DocumentTotalPages; i++)
                                    {
                                        <li class="page-item @(i == Model.DocumentPage ? "active" : null)">
                                            <a class="page-link"
                                               asp-action="@documentAction"
                                               asp-controller="InventoryManagement"
                                               asp-route-documentId="@Model.SelectedDocumentId"
                                               asp-route-documentNo="@Model.DocumentNoFilter"
                                               asp-route-documentType="@Model.DocumentTypeFilter"
                                               asp-route-status="@Model.DocumentStatusFilter"
                                               asp-route-warehouseId="@Model.WarehouseFilter"
                                               asp-route-sellerId="@Model.SellerFilter"
                                               asp-route-occurredFrom="@Model.OccurredFromFilter"
                                               asp-route-occurredTo="@Model.OccurredToFilter"
                                               asp-route-page="@i"
                                               asp-route-pageSize="@Model.DocumentPageSize"
                                               data-ajax-target="#documents-page-root">@i</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    </div>
                </div>
            </div>

            <div class="col-xl-4 mb-4">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">@UiText["inventory.documents.details.title"]</h5>
                        @if (Model.SelectedDocumentDetails is null)
                        {
                            <div class="alert alert-light mb-0">@UiText["inventory.documents.details.noSelection"]</div>
                        }
                        else
                        {
                            var selectedDocumentType = Model.SelectedDocumentDetails.DocumentType;
                            var showQualityColumn = string.Equals(selectedDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase)
                                || string.Equals(selectedDocumentType, "Conversion", StringComparison.OrdinalIgnoreCase);
                            var canEditLines = string.Equals(Model.SelectedDocumentDetails.Status, "Draft", StringComparison.OrdinalIgnoreCase);

                            <p class="mb-1"><strong>@UiText["inventory.documents.details.number"]:</strong> <span class="text-monospace">@Model.SelectedDocumentDetails.DocumentNo</span></p>
                            <p class="mb-1"><strong>@UiText["inventory.documents.details.type"]:</strong> @TypeLabel(Model.SelectedDocumentDetails.DocumentType)</p>
                            <p class="mb-1"><strong>@UiText["inventory.documents.details.status"]:</strong> <span class="badge badge-pill @StatusClass(Model.SelectedDocumentDetails.Status)">@StatusLabel(Model.SelectedDocumentDetails.Status)</span></p>
                            <p class="mb-1"><strong>@UiText["inventory.documents.warehouse"]:</strong> @WarehouseName(Model.SelectedDocumentDetails.WarehouseRef)</p>
                            <p class="mb-1"><strong>@UiText["inventory.documents.seller"]:</strong> @SellerName(Model.SelectedDocumentDetails.SellerRef)</p>
                            <p class="mb-1"><strong>@UiText["inventory.documents.details.occurredAt"]:</strong> @Model.SelectedDocumentDetails.OccurredAt.ToString("yyyy/MM/dd HH:mm")</p>
                            <p class="mb-1"><strong>@UiText["inventory.documents.details.reference"]:</strong> @(string.IsNullOrWhiteSpace(Model.SelectedDocumentDetails.ReferenceType) ? "-" : $"{Model.SelectedDocumentDetails.ReferenceType} / {Model.SelectedDocumentDetails.ReferenceBusinessId}")</p>
                            <p class="mb-1"><strong>@UiText["inventory.documents.details.reason"]:</strong> @(string.IsNullOrWhiteSpace(Model.SelectedDocumentDetails.ReasonCode) ? "-" : Model.SelectedDocumentDetails.ReasonCode)</p>
                            <p class="mb-1"><strong>@UiText["inventory.documents.details.approvedAt"]:</strong> @(Model.SelectedDocumentDetails.ApprovedAt?.ToString("yyyy/MM/dd HH:mm") ?? "-")</p>
                            <p class="mb-3"><strong>@UiText["inventory.documents.details.postedAt"]:</strong> @(Model.SelectedDocumentDetails.PostedAt?.ToString("yyyy/MM/dd HH:mm") ?? "-")</p>

                            @if (canEditLines)
                            {
                                <div class="border-top pt-3 mt-3">
                                    <h6 class="mb-3">@(string.IsNullOrWhiteSpace(Model.LineForm.LineId) ? UiText["inventory.documents.line.addTitle"] : UiText["inventory.documents.line.editTitle"])</h6>
                                    <form asp-action="SaveDocumentLine" asp-controller="InventoryManagement" method="post" class="mb-0" data-loading-form data-ajax-target="#documents-page-root">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" asp-for="LineForm.DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                        <input type="hidden" asp-for="LineForm.DocumentType" value="@selectedDocumentType" />
                                        <input type="hidden" asp-for="LineForm.LineId" value="@Model.LineForm.LineId" />
                                        <div class="form-row">
                                            <div class="form-group col-md-4">
                                                <label>@UiText["inventory.documents.line.variant"]</label>
                                                <select asp-for="LineForm.VariantId" class="form-control js-search-select" data-placeholder="@UiText["inventory.documents.line.selectVariant"]" required>
                                                    <option value="">@UiText["inventory.documents.line.selectVariant"]</option>
                                                    @foreach (var variant in Model.VariantLookup.OrderBy(x => x.Sku))
                                                    {
                                                        <option value="@variant.Id" selected="@(variant.Id == Model.LineForm.VariantId ? "selected" : null)">@VariantLabel(variant)</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group col-md-2">
                                                <label>@UiText["inventory.documents.line.quantity"]</label>
                                                <input asp-for="LineForm.Qty" type="number" step="0.0001" min="0.0001" class="form-control" />
                                            </div>
                                            <div class="form-group col-md-3 line-source">
                                                <label>@UiText["inventory.documents.line.sourceLocation"]</label>
                                                <select asp-for="LineForm.SourceLocationRef" class="form-control js-search-select" data-placeholder="@UiText["inventory.documents.line.selectLocation"]">
                                                    <option value="">@UiText["inventory.documents.line.selectLocation"]</option>
                                                    @foreach (var location in Model.LocationLookup.OrderBy(x => x.LocationCode))
                                                    {
                                                        <option value="@location.LocationBusinessKey" selected="@(location.LocationBusinessKey == Model.LineForm.SourceLocationRef ? "selected" : null)">@location.LocationCode (@location.LocationType)</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group col-md-3 line-destination">
                                                <label>@UiText["inventory.documents.line.destinationLocation"]</label>
                                                <select asp-for="LineForm.DestinationLocationRef" class="form-control js-search-select" data-placeholder="@UiText["inventory.documents.line.selectLocation"]">
                                                    <option value="">@UiText["inventory.documents.line.selectLocation"]</option>
                                                    @foreach (var location in Model.LocationLookup.OrderBy(x => x.LocationCode))
                                                    {
                                                        <option value="@location.LocationBusinessKey" selected="@(location.LocationBusinessKey == Model.LineForm.DestinationLocationRef ? "selected" : null)">@location.LocationCode (@location.LocationType)</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group col-md-2">
                                                <label>@UiText["inventory.documents.line.lotBatch"]</label>
                                                <input asp-for="LineForm.LotBatchNo" class="form-control" />
                                            </div>
                                            @if (showQualityColumn)
                                            {
                                                @if (string.Equals(selectedDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <div class="form-group col-md-2 line-from-quality">
                                                        <label>@UiText["inventory.documents.line.sourceLocation"]</label>
                                                        <select asp-for="LineForm.FromQualityStatusRef" class="form-control js-search-select" data-placeholder="@UiText["inventory.documents.line.selectQuality"]">
                                                            <option value="">@UiText["inventory.documents.line.selectQuality"]</option>
                                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                                            {
                                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.FromQualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="form-group col-md-2 line-to-quality">
                                                        <label>@UiText["inventory.documents.line.destinationLocation"]</label>
                                                        <select asp-for="LineForm.ToQualityStatusRef" class="form-control js-search-select" data-placeholder="@UiText["inventory.documents.line.selectQuality"]">
                                                            <option value="">@UiText["inventory.documents.line.selectQuality"]</option>
                                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                                            {
                                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.ToQualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="form-group col-md-2 line-quality">
                                                        <label>@UiText["inventory.documents.line.quality"]</label>
                                                        <select asp-for="LineForm.QualityStatusRef" class="form-control js-search-select" data-placeholder="@UiText["inventory.documents.line.selectQuality"]">
                                                            <option value="">@UiText["inventory.documents.line.selectQuality"]</option>
                                                            @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                                            {
                                                                <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.QualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                }
                                            }
                                            <div class="form-group col-md-2 line-adjustment">
                                                <label>@UiText["inventory.documents.line.adjustmentDirection"]</label>
                                                <select asp-for="LineForm.AdjustmentDirection" class="form-control">
                                                    <option value="">@UiText["inventory.documents.line.selectOption"]</option>
                                                    <option value="Increase" selected="@(Model.LineForm.AdjustmentDirection == "Increase" ? "selected" : null)">@UiText["inventory.documents.line.increase"]</option>
                                                    <option value="Decrease" selected="@(Model.LineForm.AdjustmentDirection == "Decrease" ? "selected" : null)">@UiText["inventory.documents.line.decrease"]</option>
                                                </select>
                                            </div>
                                            <div class="form-group col-md-4 line-reason">
                                                <label>@UiText["inventory.documents.line.reason"]</label>
                                                <input asp-for="LineForm.ReasonCode" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="d-flex justify-content-end">
                                            <a class="btn btn-outline-secondary mr-2" asp-action="@documentAction" asp-controller="InventoryManagement" asp-route-documentId="@Model.SelectedDocumentDetails.DocumentBusinessKey" asp-route-documentType="@Model.SelectedDocumentDetails.DocumentType" data-ajax-target="#documents-page-root">@UiText["inventory.documents.line.cancelEdit"]</a>
                                            <button class="btn btn-primary" type="submit">@(string.IsNullOrWhiteSpace(Model.LineForm.LineId) ? UiText["inventory.documents.action.addItem"] : UiText["inventory.documents.action.saveChanges"])</button>
                                        </div>
                                    </form>
                                </div>
                            }

                            <div class="border-top pt-3 mt-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0">@UiText["inventory.documents.lines.title"]</h6>
                                    <span class="text-muted small">@Model.SelectedDocumentDetails.Lines.Count @UiText["inventory.documents.list.countSuffix"]</span>
                                </div>
                                @if (Model.SelectedDocumentDetails.Lines.Count == 0)
                                {
                                    <div class="alert alert-light mb-0">@UiText["inventory.documents.line.noLineFound"]</div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm table-striped mb-0">
                                            <thead>
                                                <tr>
                                                    <th>@UiText["inventory.documents.line.variant"]</th>
                                                    <th>@UiText["inventory.documents.line.quantity"]</th>
                                                    <th>UOM</th>
                                                    <th>@UiText["inventory.documents.line.sourceLocation"]</th>
                                                    <th>@UiText["inventory.documents.line.destinationLocation"]</th>
                                                    @if (showQualityColumn)
                                                    {
                                                        <th>@UiText["inventory.documents.line.quality"]</th>
                                                    }
                                                    <th>@UiText["inventory.documents.line.reason"]</th>
                                                    @if (canEditLines)
                                                    {
                                                        <th class="text-right">@UiText["inventory.documents.list.actions"]</th>
                                                    }
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in Model.SelectedDocumentDetails.Lines)
                                                {
                                                    var lineProductId = VariantProductId(line.VariantRef);
                                                    <tr>
                                                        <td>
                                                            @if (!string.IsNullOrWhiteSpace(lineProductId))
                                                            {
                                                                <a asp-controller="VariantManagement"
                                                                   asp-action="Variants"
                                                                   asp-route-productId="@lineProductId"
                                                                   asp-route-variantId="@line.VariantRef">
                                                                    @VariantName(line.VariantRef)
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <span>@VariantName(line.VariantRef)</span>
                                                            }
                                                        </td>
                                                        <td>@line.Qty.ToString("0.####")</td>
                                                        <td>@UomName(line.UomRef)</td>
                                                        <td>@LocationName(line.SourceLocationRef)</td>
                                                        <td>@LocationName(line.DestinationLocationRef)</td>
                                                        @if (showQualityColumn)
                                                        {
                                                            <td>
                                                                @if (string.Equals(selectedDocumentType, "QualityChange", StringComparison.OrdinalIgnoreCase))
                                                                {
                                                                    <span>@QualityName(line.FromQualityStatusRef) -> @QualityName(line.ToQualityStatusRef)</span>
                                                                }
                                                                else
                                                                {
                                                                    <span>@QualityName(line.QualityStatusRef)</span>
                                                                }
                                                            </td>
                                                        }
                                                        <td>
                                                            @(string.IsNullOrWhiteSpace(line.ReasonCode) ? AdjustmentDirectionLabel(line.AdjustmentDirection) : line.ReasonCode)
                                                        </td>
                                                        @if (canEditLines)
                                                        {
                                                            <td class="text-right">
                                                                <a class="btn btn-outline-primary btn-xs" asp-action="@documentAction" asp-controller="InventoryManagement" asp-route-documentId="@Model.SelectedDocumentDetails.DocumentBusinessKey" asp-route-editingLineId="@line.LineBusinessKey" asp-route-documentType="@Model.SelectedDocumentDetails.DocumentType" data-ajax-target="#documents-page-root">@UiText["inventory.documents.action.editDocument"]</a>
                                                                <form asp-action="DeleteDocumentLine" asp-controller="InventoryManagement" method="post" class="d-inline" data-loading-form data-ajax-target="#documents-page-root">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="documentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                                                    <input type="hidden" name="lineId" value="@line.LineBusinessKey" />
                                                                    <button class="btn btn-outline-danger btn-xs js-return-line-delete" type="button">@UiText["inventory.documents.action.deleteDocument"]</button>
                                                                </form>
                                                            </td>
                                                        }
                                                    </tr>
                                                    @if (!string.IsNullOrWhiteSpace(line.LotBatchNo) || line.BaseQty != line.Qty || !string.Equals(line.BaseUomRef, line.UomRef, StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <tr>
                                                            <td colspan="@(showQualityColumn ? 8 : 7)" class="text-muted small">
                                                                Base: @line.BaseQty.ToString("0.####") @UomName(line.BaseUomRef)
                                                                @if (!string.IsNullOrWhiteSpace(line.LotBatchNo))
                                                                {
                                                                    <span> | @UiText["inventory.documents.line.lotBatch"]: @line.LotBatchNo</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>

                            var selectedStatus = Model.SelectedDocumentDetails.Status;
                            var canApproveByStatus = string.Equals(selectedStatus, "Draft", StringComparison.OrdinalIgnoreCase);
                            var canRejectByStatus = !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Cancelled", StringComparison.OrdinalIgnoreCase);
                            var canCancelByStatus = !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Rejected", StringComparison.OrdinalIgnoreCase);
                            var canPostByStatus = !string.Equals(selectedStatus, "Cancelled", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Rejected", StringComparison.OrdinalIgnoreCase)
                                && !string.Equals(selectedStatus, "Posted", StringComparison.OrdinalIgnoreCase);

                            <div class="border-top pt-3">
                                <div class="mb-2 text-muted small">@UiText["inventory.documents.action.changeStatus"]</div>
                                <div class="d-flex flex-wrap">
                                    <form asp-action="ApproveDocument" asp-controller="InventoryManagement" method="post" class="mr-1 mb-1" data-loading-form data-ajax-target="#documents-page-root">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="documentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                        <button class="btn btn-outline-info btn-xs" type="submit" @(Can("Inventory.Document.Approve", "InventoryDocument.Approve", "Document.Approve") && canApproveByStatus ? null : "disabled")>@UiText["inventory.documents.action.approve"]</button>
                                    </form>
                                    <form asp-action="PostDocument" asp-controller="InventoryManagement" method="post" class="mr-1 mb-1" data-loading-form data-ajax-target="#documents-page-root">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="documentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                        <button class="btn btn-outline-success btn-xs" type="submit" @(Can("Inventory.Document.Post", "InventoryDocument.Post", "Document.Post") && canPostByStatus ? null : "disabled")>@UiText["inventory.documents.action.post"]</button>
                                    </form>
                                </div>
                                <form asp-action="RejectDocument" asp-controller="InventoryManagement" method="post" class="mt-2" data-loading-form data-ajax-target="#documents-page-root">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                    <div class="form-group mb-2">
                                        <label class="small">@UiText["common.reason"]</label>
                                        <input name="ReasonCode" class="form-control form-control-sm" />
                                    </div>
                                    <button class="btn btn-outline-danger btn-xs" type="submit" @(Can("Inventory.Document.Reject", "InventoryDocument.Reject", "Document.Reject") && canRejectByStatus ? null : "disabled")>@UiText["inventory.documents.action.reject"]</button>
                                </form>
                                <form asp-action="CancelDocument" asp-controller="InventoryManagement" method="post" class="mt-2" data-loading-form data-ajax-target="#documents-page-root">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="DocumentId" value="@Model.SelectedDocumentDetails.DocumentBusinessKey" />
                                    <div class="form-group mb-2">
                                        <label class="small">@UiText["common.reason"]</label>
                                        <input name="ReasonCode" class="form-control form-control-sm" />
                                    </div>
                                    <button class="btn btn-outline-warning btn-xs" type="submit" @(Can("Inventory.Document.Cancel", "InventoryDocument.Cancel", "Document.Cancel") && canCancelByStatus ? null : "disabled")>@UiText["inventory.documents.action.cancel"]</button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script data-ajax-reinit="documents">
        (function () {
            var lineContainer = document.getElementById('document-lines');
            var addLineButton = document.getElementById('add-document-line');
            var documentTypeSelect = document.getElementById('document-type-input');
            var createWarehouseInput = document.getElementById('return-warehouse-ref-input');
            var createSellerInput = document.getElementById('return-seller-ref-input');
            var createForm = document.getElementById('document-create-form');
            var linesPanel = document.getElementById('document-lines-panel');
            var toggleLinesButton = document.getElementById('toggle-document-lines');
            var typeGuidance = document.getElementById('document-type-guidance');
            var validationSummary = document.getElementById('document-validation-summary');
            var returnReferenceSearchInput = document.getElementById('return-reference-search-input');
            var returnReferenceSearchButton = document.getElementById('return-reference-search-button');
            var returnReferenceSelected = document.getElementById('return-reference-selected');
            var returnReferenceSelectedLabel = document.getElementById('return-reference-selected-label');
            var returnReferenceResultsPanel = document.getElementById('return-reference-results-panel');
            var returnReferenceResults = document.getElementById('return-reference-results');
            var returnReferenceTypeInput = document.getElementById('return-reference-type-input');
            var returnReferenceIdInput = document.getElementById('return-reference-id-input');
            var returnReferenceSearchUrl = '@Url.Action("SearchReturnReferenceDocuments", "InventoryManagement")';
            var returnReferenceDocumentUrl = '@Url.Action("GetReturnReferenceDocument", "InventoryManagement")';
            var returnSourceDocument = null;
            var returnAllowedVariantIds = [];
            var returnVariantSerialLookup = {};
            var returnReferenceSearchDebounce = null;

            var documentTypeConfig = {
                Receipt: {
                    title: '@UiText["inventory.documents.info.receipt.title"]',
                    text: '@UiText["inventory.documents.info.receipt.description"]',
                    source: false,
                    destination: true,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                Issue: {
                    title: '@UiText["inventory.documents.info.issue.title"]',
                    text: '@UiText["inventory.documents.info.issue.description"]',
                    source: true,
                    destination: false,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                Transfer: {
                    title: '@UiText["inventory.documents.info.transfer.title"]',
                    text: '@UiText["inventory.documents.info.transfer.description"]',
                    source: true,
                    destination: true,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                Adjustment: {
                    title: '@UiText["inventory.documents.info.adjustment.title"]',
                    text: '@UiText["inventory.documents.info.adjustment.description"]',
                    source: false,
                    destination: false,
                    quality: false,
                    qualityChange: false,
                    adjustment: true,
                    lineReason: true
                },
                Return: {
                    title: '@UiText["inventory.documents.info.return.title"]',
                    text: '@UiText["inventory.documents.info.return.description"]',
                    source: false,
                    destination: true,
                    quality: false,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false
                },
                QualityChange: {
                    title: '@UiText["inventory.documents.info.qualityChange.title"]',
                    text: '@UiText["inventory.documents.info.qualityChange.description"]',
                    source: false,
                    destination: false,
                    quality: false,
                    qualityChange: true,
                    adjustment: false,
                    lineReason: false
                },
                Conversion: {
                    title: '@UiText["inventory.documents.info.conversion.title"]',
                    text: '@UiText["inventory.documents.info.conversion.description"]',
                    source: true,
                    destination: true,
                    quality: true,
                    qualityChange: false,
                    adjustment: false,
                    lineReason: false,
                    exclusiveFlow: true
                }
            };

            function setRequired(selectors, isRequired, line) {
                selectors.forEach(function (selector) {
                    line.querySelectorAll(selector).forEach(function (field) {
                        if (isRequired) {
                            field.setAttribute('required', 'required');
                        } else {
                            field.removeAttribute('required');
                        }
                    });
                });
            }

            function setLinesPanelVisible(isVisible) {
                if (!linesPanel) {
                    return;
                }

                linesPanel.classList.toggle('d-none', !isVisible);
                if (toggleLinesButton) {
                    toggleLinesButton.textContent = isVisible ? '@UiText["inventory.documents.line.cancelEdit"]' : '@UiText["inventory.documents.action.addItem"]';
                }
            }

            function clearValidation() {
                if (validationSummary) {
                    validationSummary.style.display = 'none';
                    validationSummary.textContent = '';
                }

                lineContainer.querySelectorAll('.is-invalid').forEach(function (field) {
                    field.classList.remove('is-invalid');
                });
            }

            function showValidation(message, field) {
                if (validationSummary) {
                    validationSummary.textContent = message;
                    validationSummary.style.display = '';
                }

                if (field) {
                    field.classList.add('is-invalid');
                    field.focus();
                }
            }

            function selectedConfig() {
                var type = documentTypeSelect ? documentTypeSelect.value : 'Receipt';
                return documentTypeConfig[type] || documentTypeConfig.Receipt;
            }

            function renumberLines() {
                var lines = lineContainer.querySelectorAll('.document-line');
                lines.forEach(function (line, index) {
                    line.setAttribute('data-line-index', index);
                    var title = line.querySelector('strong');
                    if (title) {
                        title.textContent = '@UiText["common.line"] ' + (index + 1);
                    }

                    line.querySelectorAll('input, select, textarea').forEach(function (field) {
                        if (field.name) {
                            field.name = field.name.replace(/CreateForm\.Lines\[\d+\]/g, 'CreateForm.Lines[' + index + ']');
                        }
                    });
                });
            }

            function toggleTypeFields() {
                var config = selectedConfig();
                if (typeGuidance) {
                    typeGuidance.innerHTML = '<strong>' + config.title + '</strong><div class="small mt-1">' + config.text + '</div>';
                }

                lineContainer.querySelectorAll('.document-line').forEach(function (line) {
                    line.querySelectorAll('.line-source').forEach(function (el) { el.style.display = config.source ? '' : 'none'; });
                    line.querySelectorAll('.line-destination').forEach(function (el) { el.style.display = config.destination ? '' : 'none'; });
                    line.querySelectorAll('.line-adjustment').forEach(function (el) { el.style.display = config.adjustment ? '' : 'none'; });
                    line.querySelectorAll('.line-quality').forEach(function (el) { el.style.display = config.quality ? '' : 'none'; });
                    line.querySelectorAll('.line-from-quality, .line-to-quality').forEach(function (el) { el.style.display = config.qualityChange ? '' : 'none'; });
                    line.querySelectorAll('.line-reason').forEach(function (el) { el.style.display = config.lineReason ? '' : 'none'; });

                    setRequired(['.source-location-select'], config.source && !config.exclusiveFlow, line);
                    setRequired(['.destination-location-select'], config.destination && !config.exclusiveFlow, line);
                    setRequired(['.line-adjustment select'], config.adjustment, line);
                    setRequired(['.line-reason input'], config.lineReason, line);
                    setRequired(['.line-from-quality select', '.line-to-quality select'], config.qualityChange, line);
                    setRequired(['.line-quality select'], !!config.quality && !config.qualityChange, line);
                });
            }

            function syncLocationsToWarehouse() {
                var warehouseId = createWarehouseInput ? createWarehouseInput.value : '';
                lineContainer.querySelectorAll('.document-location-select').forEach(function (select) {
                    Array.prototype.forEach.call(select.options, function (option) {
                        if (!option.value) {
                            option.hidden = false;
                            return;
                        }

                        var optionWarehouse = option.getAttribute('data-warehouse-ref');
                        option.hidden = !!warehouseId && optionWarehouse !== warehouseId;
                    });

                    if (select.value) {
                        var selectedOption = select.options[select.selectedIndex];
                        if (selectedOption && selectedOption.hidden) {
                            select.value = '';
                        }
                    }
                });
            }

            function getReturnLineSerialControls(line) {
                if (!line) {
                    return {};
                }

                var section = line.querySelector('.line-serials');
                if (!section) {
                    var formRow = line.querySelector('.form-row');
                    if (!formRow) {
                        return {};
                    }

                    section = document.createElement('div');
                    section.className = 'form-group col-12 line-serials d-none';
                    section.innerHTML = ''
                        + '<div class="border-top pt-3 mt-2">'
                        + '<div class="d-flex justify-content-between align-items-center mb-2">'
                        + '<div>'
                        + '<strong>@UiText["inventory.documents.serial.title"]</strong>'
                        + '<div class="small text-muted js-return-line-serial-summary">@UiText["inventory.documents.serial.requiredHint"]</div>'
                        + '</div>'
                        + '</div>'
                        + '<div class="js-return-line-serial-container"></div>'
                        + '<div class="js-return-line-serial-hidden"></div>'
                        + '</div>';
                    formRow.appendChild(section);
                }

                return {
                    section: section,
                    summary: section.querySelector('.js-return-line-serial-summary'),
                    container: section.querySelector('.js-return-line-serial-container'),
                    hidden: section.querySelector('.js-return-line-serial-hidden')
                };
            }

            function parseReturnSerialSelectionJson(serialJson) {
                if (!serialJson) {
                    return [];
                }

                try {
                    var parsed = JSON.parse(serialJson);
                    if (!Array.isArray(parsed)) {
                        return [];
                    }

                    return parsed
                        .map(function (item) {
                            return {
                                serialItemBusinessKey: String(item.serialItemBusinessKey || item.SerialItemBusinessKey || ''),
                                serialNo: String(item.serialNo || item.SerialNo || '')
                            };
                        })
                        .filter(function (item) {
                            return item.serialItemBusinessKey || item.serialNo;
                        });
                } catch (error) {
                    console.warn('Failed to parse return serial json', error);
                    return [];
                }
            }

            function collectReturnSelectedSerialIds(line) {
                var controls = getReturnLineSerialControls(line);
                if (!controls.container) {
                    return [];
                }

                var selected = [];
                controls.container.querySelectorAll('.js-return-line-serial-select').forEach(function (checkbox) {
                    if (!checkbox.checked) {
                        return;
                    }

                    selected.push(checkbox.getAttribute('data-serial-id') || '');
                });

                return selected.filter(Boolean);
            }

            function syncReturnLineSerialHiddenInputs(line) {
                var controls = getReturnLineSerialControls(line);
                if (!controls.container || !controls.hidden) {
                    return;
                }

                controls.hidden.innerHTML = '';

                var lineIndex = line.getAttribute('data-line-index') || '0';
                var selectedSerials = [];
                controls.container.querySelectorAll('.js-return-line-serial-select').forEach(function (checkbox) {
                    if (!checkbox.checked) {
                        return;
                    }

                    selectedSerials.push({
                        serialId: checkbox.getAttribute('data-serial-id') || '',
                        serialNo: checkbox.getAttribute('data-serial-no') || ''
                    });
                });

                selectedSerials.forEach(function (serial, index) {
                    var idInput = document.createElement('input');
                    idInput.type = 'hidden';
                    idInput.name = 'CreateForm.Lines[' + lineIndex + '].Serials[' + index + '].SerialItemBusinessKey';
                    idInput.value = serial.serialId;
                    controls.hidden.appendChild(idInput);

                    var noInput = document.createElement('input');
                    noInput.type = 'hidden';
                    noInput.name = 'CreateForm.Lines[' + lineIndex + '].Serials[' + index + '].SerialNo';
                    noInput.value = serial.serialNo;
                    controls.hidden.appendChild(noInput);
                });
            }

            function renderReturnLineSerialOptions(line, serials, selectedSerialIds) {
                var controls = getReturnLineSerialControls(line);
                if (!controls.section || !controls.container) {
                    return;
                }

                var items = Array.isArray(serials) ? serials : [];
                var selectedLookup = {};
                (selectedSerialIds || []).forEach(function (serialId) {
                    selectedLookup[String(serialId || '')] = true;
                });

                controls.container.innerHTML = '';
                if (!items.length) {
                    controls.section.classList.add('d-none');
                    if (controls.summary) {
                        controls.summary.textContent = '@UiText["inventory.documents.serial.noAvailable"]';
                    }
                    syncReturnLineSerialHiddenInputs(line);
                    return;
                }

                controls.section.classList.remove('d-none');
                if (controls.summary) {
                    controls.summary.textContent = '@UiText["inventory.documents.serial.selectAll"]';
                }

                items.forEach(function (serial) {
                    var serialId = String(serial.serialItemBusinessKey || '');
                    var serialNo = String(serial.serialNo || serialId || '-');
                    var checkboxId = 'return-serial-' + serialId.replace(/[^a-zA-Z0-9_-]/g, '');
                    var wrapper = document.createElement('label');
                    wrapper.className = 'd-flex align-items-start border rounded p-2 mb-2 bg-white';

                    var checkbox = document.createElement('input');
                    checkbox.type = 'checkbox';
                    checkbox.className = 'mr-2 mt-1 js-return-line-serial-select';
                    checkbox.id = checkboxId;
                    checkbox.setAttribute('data-serial-id', serialId);
                    checkbox.setAttribute('data-serial-no', serial.serialNo || '');
                    checkbox.checked = !!selectedLookup[serialId];
                    checkbox.addEventListener('change', function () {
                        syncReturnLineSerialHiddenInputs(line);
                    });

                    var body = document.createElement('div');
                    body.className = 'flex-grow-1';

                    var title = document.createElement('div');
                    title.className = 'font-weight-medium';
                    title.textContent = serialNo;

                    var meta = document.createElement('div');
                    meta.className = 'small text-muted';
                    meta.textContent = [serial.warehouseRef, serial.locationRef, serial.qualityStatusRef, serial.status || ''].filter(Boolean).join(' / ');

                    body.appendChild(title);
                    body.appendChild(meta);
                    wrapper.appendChild(checkbox);
                    wrapper.appendChild(body);
                    controls.container.appendChild(wrapper);
                });

                syncReturnLineSerialHiddenInputs(line);
            }

            function getReturnVariantSerials(variantId) {
                if (!variantId || !returnVariantSerialLookup) {
                    return [];
                }

                return returnVariantSerialLookup[String(variantId).toLowerCase()] || [];
            }

            function refreshReturnVariantOptions() {
                if (!returnSourceDocument) {
                    lineContainer.querySelectorAll('.document-line').forEach(function (line) {
                        var variantSelect = line.querySelector('.document-variant-select');
                        if (!variantSelect) {
                            return;
                        }

                        Array.prototype.forEach.call(variantSelect.options, function (option) {
                            if (!option.value) {
                                option.hidden = false;
                                option.disabled = false;
                            } else {
                                option.hidden = true;
                                option.disabled = true;
                            }
                        });

                        variantSelect.value = '';
                        var controls = getReturnLineSerialControls(line);
                        if (controls.section) {
                            controls.section.classList.add('d-none');
                        }
                        if (controls.container) {
                            controls.container.innerHTML = '';
                        }
                        if (controls.hidden) {
                            controls.hidden.innerHTML = '';
                        }
                    });
                    return;
                }

                var allowed = returnAllowedVariantIds && returnAllowedVariantIds.length
                    ? returnAllowedVariantIds.reduce(function (lookup, variantId) {
                        lookup[String(variantId || '').toLowerCase()] = true;
                        return lookup;
                    }, {})
                    : null;

                lineContainer.querySelectorAll('.document-line').forEach(function (line) {
                    var variantSelect = line.querySelector('.document-variant-select');
                    if (!variantSelect) {
                        return;
                    }

                    Array.prototype.forEach.call(variantSelect.options, function (option) {
                        if (!option.value) {
                            option.hidden = false;
                            option.disabled = false;
                            return;
                        }

                        var isAllowed = !allowed || !!allowed[String(option.value || '').toLowerCase()];
                        option.hidden = !isAllowed;
                        option.disabled = !isAllowed;
                    });

                    if (variantSelect.value) {
                        var selectedOption = variantSelect.options[variantSelect.selectedIndex];
                        if (selectedOption && selectedOption.hidden) {
                            variantSelect.value = '';
                        }
                    }
                });
            }

            function updateReturnLineSerials(line) {
                var variantSelect = line.querySelector('.document-variant-select');
                if (!variantSelect) {
                    return;
                }

                var variantId = variantSelect.value || '';
                var selectedSerialIds = collectReturnSelectedSerialIds(line);
                var serials = getReturnVariantSerials(variantId);
                renderReturnLineSerialOptions(line, serials, selectedSerialIds);
            }

            async function searchReturnReferenceDocuments() {
                if (!returnReferenceSearchInput || !returnReferenceResults) {
                    return;
                }

                var term = (returnReferenceSearchInput.value || '').trim();
                if (!term) {
                    returnReferenceResults.innerHTML = '';
                    returnReferenceResultsPanel.classList.add('d-none');
                    return;
                }

                var url = new URL(returnReferenceSearchUrl, window.location.origin);
                url.searchParams.set('term', term);

                var response = await fetch(url.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                });

                var payload = await response.json();
                if (!payload || payload.isSuccess === false) {
                    throw new Error((payload && payload.errorMessage) || '@UiText["inventory.documents.action.loadingFailed"]');
                }

                var items = Array.isArray(payload.documents) ? payload.documents : [];
                returnReferenceResults.innerHTML = '';

                if (!items.length) {
                    returnReferenceResults.innerHTML = '<div class="list-group-item text-muted">@UiText["inventory.documents.action.noDocumentSelected"]</div>';
                    returnReferenceResultsPanel.classList.remove('d-none');
                    return;
                }

                items.forEach(function (item) {
                    var button = document.createElement('button');
                    button.type = 'button';
                    button.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center';
                    button.innerHTML = '<span class="text-monospace">' + (item.documentNo || item.documentBusinessKey || '-') + '</span>'
                        + '<small class="text-muted">' + (item.status || '-') + '</small>';
                    button.addEventListener('click', function () {
                        selectReturnReferenceDocument(item);
                    });
                    returnReferenceResults.appendChild(button);
                });

                returnReferenceResultsPanel.classList.remove('d-none');
            }

            function scheduleReturnReferenceSearch() {
                if (!returnReferenceSearchInput) {
                    return;
                }

                if (returnReferenceSearchDebounce) {
                    window.clearTimeout(returnReferenceSearchDebounce);
                }

                returnReferenceSearchDebounce = window.setTimeout(function () {
                    searchReturnReferenceDocuments().catch(function (error) {
                        console.error(error);
                    });
                }, 300);
            }

            async function loadReturnReferenceDocument(documentId) {
                if (!documentId) {
                    return;
                }

                var url = new URL(returnReferenceDocumentUrl, window.location.origin);
                url.searchParams.set('documentId', documentId);

                var response = await fetch(url.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                });

                var payload = await response.json();
                if (!payload || payload.isSuccess === false || !payload.document) {
                    throw new Error((payload && payload.errorMessage) || '@UiText["inventory.documents.action.loadingFailed"]');
                }

                return payload.document;
            }

            async function selectReturnReferenceDocument(item) {
                if (!item || !item.documentBusinessKey) {
                    return;
                }

                var document = await loadReturnReferenceDocument(item.documentBusinessKey);
                returnSourceDocument = document;
                returnAllowedVariantIds = [];
                returnVariantSerialLookup = {};

                (document.lines || []).forEach(function (line) {
                    var variantId = String(line.variantRef || '');
                    if (!variantId) {
                        return;
                    }

                    returnAllowedVariantIds.push(variantId);
                    var key = variantId.toLowerCase();
                    if (!returnVariantSerialLookup[key]) {
                        returnVariantSerialLookup[key] = [];
                    }

                    (line.serials || []).forEach(function (serial) {
                        returnVariantSerialLookup[key].push({
                            serialItemBusinessKey: String(serial.serialItemBusinessKey || ''),
                            serialNo: String(serial.serialNo || ''),
                            warehouseRef: String(document.warehouseRef || ''),
                            locationRef: String(line.destinationLocationRef || line.sourceLocationRef || ''),
                            qualityStatusRef: String(line.qualityStatusRef || ''),
                            status: String(serial.status || 'Available')
                        });
                    });
                });

                if (returnReferenceTypeInput) {
                    returnReferenceTypeInput.value = 'Issue';
                }
                if (returnReferenceIdInput) {
                    returnReferenceIdInput.value = document.documentBusinessKey || item.documentBusinessKey;
                }
                if (createWarehouseInput) {
                    createWarehouseInput.value = String(document.warehouseRef || '');
                }
                if (createSellerInput) {
                    createSellerInput.value = String(document.sellerRef || '');
                }
                if (returnReferenceSelectedLabel) {
                    returnReferenceSelectedLabel.textContent = (document.documentNo || item.documentNo || document.documentBusinessKey);
                }
                if (returnReferenceSelected) {
                    returnReferenceSelected.classList.remove('d-none');
                }
                if (returnReferenceSearchInput) {
                    returnReferenceSearchInput.value = document.documentNo || item.documentNo || '';
                }
                if (returnReferenceResultsPanel) {
                    returnReferenceResultsPanel.classList.add('d-none');
                }
                if (returnReferenceResults) {
                    returnReferenceResults.innerHTML = '';
                }

                refreshReturnVariantOptions();
                lineContainer.querySelectorAll('.document-line').forEach(function (line) {
                    updateReturnLineSerials(line);
                });
            }

            function syncVariantUom(line) {
                var select = line.querySelector('.document-variant-select');
                var uomRef = line.querySelector('.document-uom-ref');
                var baseUomRef = line.querySelector('.document-base-uom-ref');
                var hint = line.querySelector('.document-uom-hint');
                if (!select || !uomRef || !baseUomRef) {
                    return;
                }

                var option = select.options[select.selectedIndex];
                var baseUom = option ? option.getAttribute('data-base-uom-ref') : '';
                uomRef.value = baseUom || '';
                baseUomRef.value = baseUom || '';
                if (hint) {
                    hint.textContent = baseUom ? ('Base UOM: ' + baseUom) : '@UiText["inventory.documents.line.baseUomHint"]';
                }
            }

            function bindLine(line) {
                var removeButton = line.querySelector('.remove-document-line');
                if (removeButton) {
                    removeButton.addEventListener('click', function () {
                        if (lineContainer.querySelectorAll('.document-line').length === 1) {
                            line.querySelectorAll('input[type="text"], input[type="number"]').forEach(function (input) {
                                input.value = input.type === 'number' ? '1' : '';
                            });
                            line.querySelectorAll('select').forEach(function (select) {
                                select.value = '';
                            });
                            syncVariantUom(line);
                            return;
                        }

                        line.remove();
                        renumberLines();
                        toggleTypeFields();
                        syncLocationsToWarehouse();
                    });
                }

                var variantSelect = line.querySelector('.document-variant-select');
                if (variantSelect) {
                    variantSelect.addEventListener('change', function () {
                        syncVariantUom(line);
                        updateReturnLineSerials(line);
                    });
                    syncVariantUom(line);
                    if (returnSourceDocument) {
                        updateReturnLineSerials(line);
                    }
                }

                if (line.querySelector('.line-serials')) {
                    updateReturnLineSerials(line);
                }
            }

            function firstField(line, selector) {
                return line.querySelector(selector);
            }

            function validateDocumentForm() {
                clearValidation();

                if (!createForm) {
                    return true;
                }

                var warehouseField = document.getElementById('create-warehouse-select');
                if (warehouseField && !warehouseField.value) {
                    showValidation('@UiText["inventory.documents.action.noWarehouseSelected"]', warehouseField);
                    return false;
                }

                var sellerField = createForm.querySelector('[name="CreateForm.SellerRef"]');
                if (sellerField && !sellerField.value) {
                    showValidation('@UiText["inventory.documents.action.noSellerSelected"]', sellerField);
                    return false;
                }

                var config = selectedConfig();
                if ((documentTypeSelect ? documentTypeSelect.value : 'Receipt') === 'Return' && (!returnReferenceIdInput || !returnReferenceIdInput.value)) {
                    showValidation('@UiText["inventory.documents.return.referenceLabel"]', returnReferenceSearchInput || createForm);
                    return false;
                }
                var lines = Array.prototype.slice.call(lineContainer.querySelectorAll('.document-line'));
for (var i = 0; i < lines.length; i++) {
                    var line = lines[i];
                    var lineTitle = '@UiText["common.line"] ' + (i + 1);
                    var variant = firstField(line, '.document-variant-select');
                    var qty = firstField(line, 'input[name$=".Qty"]');
                    var source = firstField(line, '.source-location-select');
                    var destination = firstField(line, '.destination-location-select');
                    var adjustment = firstField(line, '.line-adjustment select');
                    var reason = firstField(line, '.line-reason input');
                    var fromQuality = firstField(line, '.line-from-quality select');
                    var toQuality = firstField(line, '.line-to-quality select');

                    if (!variant || !variant.value) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.action.noVariantSelected"]', variant);
                        return false;
                    }

                    if (!qty || Number(qty.value) <= 0) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.validation.qtyPositive"]', qty);
                        return false;
                    }

                    if (config.source && !config.exclusiveFlow && (!source || !source.value)) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.action.noLocationSelected"]', source);
                        return false;
                    }

                    if (config.destination && !config.exclusiveFlow && (!destination || !destination.value)) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.action.noLocationSelected"]', destination);
                        return false;
                    }

                    if (!config.exclusiveFlow && config.source && config.destination && source && destination && source.value && source.value === destination.value) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.validation.locationsDifferent"]', destination);
                        return false;
                    }

                    if (config.exclusiveFlow) {
                        var hasSource = !!(source && source.value);
                        var hasDestination = !!(destination && destination.value);
                        var quality = firstField(line, '.line-quality select');

                        if (hasSource === hasDestination) {
                            showValidation(lineTitle + ': @UiText["inventory.documents.validation.conversionFlowRequired"]', source || destination);
                            return false;
                        }

                        if (!quality || !quality.value) {
                            showValidation(lineTitle + ': @UiText["inventory.documents.action.noQualitySelected"]', quality);
                            return false;
                        }
                    }

                    if (config.adjustment && (!adjustment || !adjustment.value)) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.validation.adjustmentDirectionRequired"]', adjustment);
                        return false;
                    }

                    if (config.lineReason && (!reason || !reason.value.trim())) {
                        showValidation(lineTitle + ': @UiText["common.reason"]', reason);
                        return false;
                    }

                    if (config.qualityChange && (!fromQuality || !fromQuality.value)) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.action.noQualitySelected"]', fromQuality);
                        return false;
                    }

                    if (config.qualityChange && (!toQuality || !toQuality.value)) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.action.noQualitySelected"]', toQuality);
                        return false;
                    }

                    if (config.qualityChange && fromQuality && toQuality && fromQuality.value && fromQuality.value === toQuality.value) {
                        showValidation(lineTitle + ': @UiText["inventory.documents.validation.qualitiesDifferent"]', toQuality);
                        return false;
                    }
                }

                return true;
            }

            function addLine() {
                var lines = lineContainer.querySelectorAll('.document-line');
                var lastLine = lines[lines.length - 1];
                var clone = lastLine.cloneNode(true);
                clone.querySelectorAll('.select2').forEach(function (node) {
                    node.remove();
                });
                clone.querySelectorAll('input').forEach(function (input) {
                    input.value = input.type === 'number' ? '1' : '';
                });
                clone.querySelectorAll('select').forEach(function (select) {
                    select.value = '';
                    delete select.dataset.select2Initialized;
                });
                clone.querySelectorAll('.line-serials').forEach(function (section) {
                    section.classList.add('d-none');
                    var container = section.querySelector('.js-return-line-serial-container');
                    var hidden = section.querySelector('.js-return-line-serial-hidden');
                    if (container) {
                        container.innerHTML = '';
                    }
                    if (hidden) {
                        hidden.innerHTML = '';
                    }
                });
                lineContainer.appendChild(clone);
                if (window.appUi && typeof window.appUi.initSearchableSelects === 'function') {
                    window.appUi.initSearchableSelects(clone);
                }
                renumberLines();
                bindLine(clone);
                toggleTypeFields();
                syncLocationsToWarehouse();
                refreshReturnVariantOptions();
            }

            if (addLineButton) {
                addLineButton.addEventListener('click', addLine);
            }

            if (toggleLinesButton) {
                toggleLinesButton.addEventListener('click', function () {
                    setLinesPanelVisible(linesPanel ? linesPanel.classList.contains('d-none') : false);
                });
            }

            if (documentTypeSelect) {
                documentTypeSelect.addEventListener('change', function () {
                    clearValidation();
                    toggleTypeFields();
                });
            }

            if (warehouseSelect) {
                warehouseSelect.addEventListener('change', function () {
                    clearValidation();
                    syncLocationsToWarehouse();
                });
            }

            if (returnReferenceSearchInput) {
                returnReferenceSearchInput.addEventListener('input', function () {
                    scheduleReturnReferenceSearch();
                });
                returnReferenceSearchInput.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        searchReturnReferenceDocuments().catch(function (error) {
                            console.error(error);
                        });
                    }
                });
            }

            if (returnReferenceSearchButton) {
                returnReferenceSearchButton.addEventListener('click', function () {
                    searchReturnReferenceDocuments().catch(function (error) {
                        console.error(error);
                    });
                });
            }

            if (createForm) {
                createForm.addEventListener('submit', function (event) {
                    if (!validateDocumentForm()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                });
            }

            document.addEventListener('click', function (event) {
                var deleteButton = event.target && event.target.closest ? event.target.closest('.js-return-line-delete') : null;
                if (!(deleteButton instanceof HTMLElement)) {
                    return;
                }

                var form = deleteButton.closest('form');
                if (!form) {
                    return;
                }

                if (!window.confirm('@UiText["inventory.documents.confirm.deleteLine"]')) {
                    return;
                }

                if (typeof form.requestSubmit === 'function') {
                    form.requestSubmit();
                } else {
                    form.submit();
                }
            });

            lineContainer.querySelectorAll('.document-line').forEach(bindLine);
            renumberLines();
            toggleTypeFields();
            syncLocationsToWarehouse();
            refreshReturnVariantOptions();
            if (returnReferenceIdInput && returnReferenceIdInput.value) {
                loadReturnReferenceDocument(returnReferenceIdInput.value)
                    .then(function (document) {
                        if (document) {
                            returnSourceDocument = document;
                            returnAllowedVariantIds = [];
                            returnVariantSerialLookup = {};
                            (document.lines || []).forEach(function (line) {
                                var variantId = String(line.variantRef || '');
                                if (!variantId) {
                                    return;
                                }
                                returnAllowedVariantIds.push(variantId);
                                var key = variantId.toLowerCase();
                                if (!returnVariantSerialLookup[key]) {
                                    returnVariantSerialLookup[key] = [];
                                }
                                (line.serials || []).forEach(function (serial) {
                                    returnVariantSerialLookup[key].push({
                                        serialItemBusinessKey: String(serial.serialItemBusinessKey || ''),
                                        serialNo: String(serial.serialNo || ''),
                                        warehouseRef: String(document.warehouseRef || ''),
                                        locationRef: String(line.destinationLocationRef || line.sourceLocationRef || ''),
                                        qualityStatusRef: String(line.qualityStatusRef || ''),
                                        status: String(serial.status || 'Available')
                                    });
                                });
                            });
                            refreshReturnVariantOptions();
                            lineContainer.querySelectorAll('.document-line').forEach(function (line) {
                                updateReturnLineSerials(line);
                            });
                        }
                    })
                    .catch(function (error) {
                        console.error(error);
                    });
            }
            setLinesPanelVisible(false);
        })();
    </script>
}

