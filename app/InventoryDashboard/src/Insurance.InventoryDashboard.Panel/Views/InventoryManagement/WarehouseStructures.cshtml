@using System
@using System.Linq
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Html
@model Insurance.InventoryDashboard.Panel.Models.WarehouseStructurePageViewModel
@{
    ViewData["Title"] = "ساختار انبار";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x => string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) || string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));
    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    string WarehouseLabel(string? warehouseId)
    {
        if (string.IsNullOrWhiteSpace(warehouseId))
        {
            return "-";
        }

        var warehouse = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, warehouseId, StringComparison.OrdinalIgnoreCase));
        return warehouse is null ? warehouseId : $"{warehouse.Code} - {warehouse.Name}";
    }

    var warehouseStructuresUrl = Url.Action("WarehouseStructures", "InventoryManagement") ?? string.Empty;
    var saveWarehouseStructureValueUrl = Url.Action("SaveWarehouseStructureValue", "InventoryManagement") ?? string.Empty;

    IEnumerable<Insurance.InventoryDashboard.Panel.Models.LocationStructureTreeItemModel> Flatten(IEnumerable<Insurance.InventoryDashboard.Panel.Models.LocationStructureTreeItemModel> nodes)
    {
        foreach (var node in nodes.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name))
        {
            yield return node;
            foreach (var child in Flatten(node.Children))
            {
                yield return child;
            }
        }
    }

    IHtmlContent RenderNode(Insurance.InventoryDashboard.Panel.Models.LocationStructureTreeItemModel node, int depth)
    {
        var padding = depth * 20;
        var childNodes = node.Children.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name).ToList();
        var values = node.Values.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name).ToList();
        var valueFormId = $"structure-value-form-{node.LocationStructureBusinessKey}";
        var valueListId = $"structure-values-{node.LocationStructureBusinessKey}";
        var builder = new HtmlContentBuilder();

        builder.AppendHtml($"<div class=\"border rounded mb-2 p-2\" style=\"margin-right:{padding}px\">");
        builder.AppendHtml("<div class=\"d-flex justify-content-between align-items-start flex-wrap\">");
        builder.AppendHtml("<div>");
        builder.AppendHtml($"<div><strong class=\"text-monospace\">{HtmlEncoder.Default.Encode(node.Code)}</strong> - {HtmlEncoder.Default.Encode(node.Name)}</div>");
        builder.AppendHtml($"<div class=\"small text-muted\">{HtmlEncoder.Default.Encode(WarehouseLabel(node.WarehouseRef))}</div>");
        builder.AppendHtml("</div>");
        builder.AppendHtml("<div class=\"btn-group btn-group-sm\">");
        builder.AppendHtml($"<a class=\"btn btn-outline-primary\" href=\"{HtmlEncoder.Default.Encode($"{warehouseStructuresUrl}?warehouseId={Model.SelectedWarehouseId}&structureId={node.LocationStructureBusinessKey}")}\" data-ajax-target=\"#warehouse-structure-panel\">فرزند</a>");
        builder.AppendHtml($"<button type=\"button\" class=\"btn btn-outline-success\" data-structure-value-toggle=\"{HtmlEncoder.Default.Encode(valueFormId)}\">+ مقدار</button>");
        builder.AppendHtml("</div>");
        builder.AppendHtml("</div>");
        builder.AppendHtml("</div>");

        builder.AppendHtml($"<div class=\"mt-2 d-none\" id=\"{HtmlEncoder.Default.Encode(valueFormId)}\">");
        builder.AppendHtml($"<form action=\"{HtmlEncoder.Default.Encode($"{saveWarehouseStructureValueUrl}?warehouseId={Model.SelectedWarehouseId}")}\" method=\"post\" data-loading-form data-dirty-watch data-ajax-target=\"#warehouse-structure-panel\" class=\"border rounded bg-light p-2\">");
        builder.AppendHtml(Html.AntiForgeryToken());
        builder.AppendHtml($"<input type=\"hidden\" name=\"StructureValueForm.LocationStructureValueBusinessKey\" value=\"\" />");
        builder.AppendHtml($"<input type=\"hidden\" name=\"StructureValueForm.StructureRef\" value=\"{HtmlEncoder.Default.Encode(node.LocationStructureBusinessKey)}\" />");
        builder.AppendHtml($"<input type=\"hidden\" name=\"StructureValueForm.Name\" value=\"\" />");
        builder.AppendHtml("<div class=\"form-row align-items-end\">");
        builder.AppendHtml("<div class=\"form-group col-md-8 mb-2 mb-md-0\">");
        builder.AppendHtml($"<label class=\"small mb-1\" for=\"{HtmlEncoder.Default.Encode($"{valueFormId}-code")}\">مقدار جدید</label>");
        builder.AppendHtml($"<input id=\"{HtmlEncoder.Default.Encode($"{valueFormId}-code")}\" name=\"StructureValueForm.Code\" class=\"form-control form-control-sm text-monospace\" maxlength=\"50\" placeholder=\"مقدار را وارد کنید\" list=\"{HtmlEncoder.Default.Encode(valueListId)}\" />");
        builder.AppendHtml("</div>");
        builder.AppendHtml("<div class=\"form-group col-md-4 mb-2 mb-md-0\">");
        builder.AppendHtml("<button type=\"submit\" class=\"btn btn-success btn-sm btn-block\">ثبت مقدار</button>");
        builder.AppendHtml("</div>");
        builder.AppendHtml("</div>");
        builder.AppendHtml("<div class=\"small text-muted mt-2\">اگر همین مقدار قبلاً وجود داشته باشد، دوباره ساخته نمی‌شود و از همان آیتم قبلی استفاده می‌شود.</div>");
        builder.AppendHtml("</form>");
        if (values.Count > 0)
        {
            builder.AppendHtml($"<datalist id=\"{HtmlEncoder.Default.Encode(valueListId)}\">");
            foreach (var value in values)
            {
                builder.AppendHtml($"<option value=\"{HtmlEncoder.Default.Encode(value.Code)}\">{HtmlEncoder.Default.Encode(value.Name)}</option>");
            }
            builder.AppendHtml("</datalist>");
        }
        builder.AppendHtml("</div>");

        if (values.Count > 0)
        {
            builder.AppendHtml("<div class=\"mt-2 small\">");
            foreach (var value in values)
            {
                builder.AppendHtml($"<button type=\"button\" class=\"badge badge-light border mr-1 mb-1\" data-structure-value-fill=\"{HtmlEncoder.Default.Encode(valueFormId)}\" data-structure-value-code=\"{HtmlEncoder.Default.Encode(value.Code)}\">{HtmlEncoder.Default.Encode(value.Code)} - {HtmlEncoder.Default.Encode(value.Name)}</button>");
            }
            builder.AppendHtml("</div>");
        }

        foreach (var child in childNodes)
        {
            builder.AppendHtml(RenderNode(child, depth + 1));
        }

        builder.AppendHtml("</div>");
        return builder;
    }
}

<main id="inventory-management-root" class="catalog-page">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="mb-4 d-flex justify-content-between align-items-start flex-wrap">
                    <div>
                        <h1>ساختار انبار</h1>
                        <p class="text-muted">تعریف درخت ساختار و مقادیر قابل انتخاب برای لوکیشن‌ها.</p>
                    </div>
                    <div>
                        <a asp-action="Warehouses" class="btn btn-outline-secondary">بازگشت به انبارها</a>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-warning">@Model.ErrorMessage</div>
                }
                @if (TempData.ContainsKey("CatalogError"))
                {
                    <div class="alert alert-danger">@TempData["CatalogError"]</div>
                }
                @if (TempData.ContainsKey("CatalogSuccess"))
                {
                    <div class="alert alert-success">@TempData["CatalogSuccess"]</div>
                }
            </div>
        </div>

        <div class="row">
            <div class="col-lg-4">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">انتخاب انبار</h5>
                        <form method="get" asp-action="WarehouseStructures" class="form-row" data-loading-form data-ajax-target="#warehouse-structure-panel">
                            <div class="form-group col-12">
                                <label>انبار</label>
                                <select name="warehouseId" class="form-control js-search-select" required>
                                    <option value="">انتخاب انبار</option>
                                    @foreach (var warehouse in Model.WarehouseLookup.OrderBy(x => x.Code))
                                    {
                                        if (string.Equals(warehouse.WarehouseBusinessKey, Model.SelectedWarehouseId, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <option value="@warehouse.WarehouseBusinessKey" selected="selected">@warehouse.Code - @warehouse.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@warehouse.WarehouseBusinessKey">@warehouse.Code - @warehouse.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="form-group col-12">
                                <button class="btn btn-primary" type="submit" @(Can("Inventory.Warehouse.View", "Warehouse.Read") ? null : "disabled")>نمایش ساختار</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">افزودن نود ساختار</h5>
                        <form asp-action="SaveWarehouseStructureNode" method="post" data-loading-form data-dirty-watch data-ajax-target="#warehouse-structure-panel">
                            @Html.AntiForgeryToken()
                            <input asp-for="StructureNodeForm.LocationStructureBusinessKey" type="hidden" />
                            <div asp-validation-summary="All" class="text-danger small mb-2"></div>
                            <div class="form-group">
                                <label>انبار</label>
                                <select asp-for="StructureNodeForm.WarehouseRef" class="form-control js-search-select" required>
                                    <option value="">انتخاب انبار</option>
                                    @foreach (var warehouse in Model.WarehouseLookup.OrderBy(x => x.Code))
                                    {
                                        <option value="@warehouse.WarehouseBusinessKey">@warehouse.Code - @warehouse.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label>نود والد</label>
                                <select asp-for="StructureNodeForm.ParentStructureRef" class="form-control js-search-select">
                                    <option value="">بدون والد</option>
                                    @foreach (var structure in Flatten(Model.Structures))
                                    {
                                        <option value="@structure.LocationStructureBusinessKey" selected="@(string.Equals(structure.LocationStructureBusinessKey, Model.SelectedStructureId, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@structure.Code - @structure.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label>کد</label>
                                <input asp-for="StructureNodeForm.Code" class="form-control text-monospace" required maxlength="50" />
                            </div>
                            <div class="form-group">
                                <label>نام</label>
                                <input asp-for="StructureNodeForm.Name" class="form-control" required maxlength="160" />
                            </div>
                            <div class="form-group">
                                <label>ترتیب نمایش</label>
                                <input asp-for="StructureNodeForm.DisplayOrder" class="form-control" type="number" min="0" />
                            </div>
                            <button class="btn btn-primary" type="submit" @(Can("Inventory.Warehouse.Create", "Inventory.Warehouse.Update", "Warehouse.Create", "Warehouse.Update") ? null : "disabled")>ذخیره نود</button>
                        </form>
                    </div>
                </div>

                <div class="card">
                    <div class="card-body" id="warehouse-structure-panel">
                        <h5 class="card-title">مقادیر ساختار</h5>
                        <p class="text-muted mb-2">برای هر نود از دکمه <strong>+ مقدار</strong> همان نود استفاده کنید. مقدارهای تکراری دوباره ساخته نمی‌شوند و از آیتم قبلی استفاده می‌شوند.</p>
                        <div class="small text-muted">مقدارهای هر نود پایین همان نود نمایش داده می‌شوند و با کلیک روی آن‌ها می‌توانی مقدار را برای استفاده دوباره در فرم inline بگذاری.</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="card-title mb-0">درخت ساختار</h5>
                            <span class="text-muted small">@Model.Structures.Count نود ریشه</span>
                        </div>

                        @if (string.IsNullOrWhiteSpace(Model.SelectedWarehouseId))
                        {
                            <div class="alert alert-info">ابتدا یک انبار انتخاب کنید.</div>
                        }
                        else if (Model.Structures.Count == 0)
                        {
                            <div class="text-muted">برای این انبار هنوز ساختاری ثبت نشده است.</div>
                        }
                        else
                        {
                            foreach (var node in Model.Structures.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name))
                            {
                                @RenderNode(node, 0)
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
<script data-ajax-reinit>
    (function () {
        if (window.__warehouseStructureInlineBindingAttached) {
            return;
        }

        window.__warehouseStructureInlineBindingAttached = true;

        function getInlineForm(formId) {
            if (!formId) {
                return null;
            }

            return document.getElementById(formId);
        }

        function getCodeInput(form) {
            return form ? form.querySelector('input[name="StructureValueForm.Code"]') : null;
        }

        function getNameInput(form) {
            return form ? form.querySelector('input[name="StructureValueForm.Name"]') : null;
        }

        function openInlineForm(formId, presetValue) {
            var form = getInlineForm(formId);
            if (!form) {
                return;
            }

            form.classList.remove('d-none');
            var codeInput = getCodeInput(form);
            if (codeInput && typeof presetValue === 'string') {
                codeInput.value = presetValue;
                var nameInput = getNameInput(form);
                if (nameInput) {
                    nameInput.value = presetValue;
                }
                codeInput.focus();
                codeInput.select();
            } else if (codeInput) {
                codeInput.focus();
            }
        }

        document.addEventListener('click', function (event) {
            var toggleButton = event.target && event.target.closest ? event.target.closest('[data-structure-value-toggle]') : null;
            if (toggleButton) {
                event.preventDefault();
                openInlineForm(toggleButton.getAttribute('data-structure-value-toggle'));
                return;
            }

            var fillButton = event.target && event.target.closest ? event.target.closest('[data-structure-value-fill]') : null;
            if (fillButton) {
                event.preventDefault();
                openInlineForm(
                    fillButton.getAttribute('data-structure-value-fill'),
                    fillButton.getAttribute('data-structure-value-code') || ''
                );
            }
        }, true);
    })();
</script>
