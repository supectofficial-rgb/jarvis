@using System
@using System.Linq
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Html
@model Insurance.InventoryDashboard.Panel.Models.WarehouseStructurePageViewModel
@{
    ViewData["Title"] = "ساختار انبار";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x => string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) || string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));

    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

    string WarehouseLabel(string? warehouseId)
    {
        if (string.IsNullOrWhiteSpace(warehouseId))
        {
            return "-";
        }

        var warehouse = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, warehouseId, StringComparison.OrdinalIgnoreCase));
        return warehouse is null ? warehouseId : $"{warehouse.Code} - {warehouse.Name}";
    }

    IEnumerable<Insurance.InventoryDashboard.Panel.Models.LocationStructureTreeItemModel> Flatten(IEnumerable<Insurance.InventoryDashboard.Panel.Models.LocationStructureTreeItemModel> nodes)
    {
        foreach (var node in nodes.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name))
        {
            yield return node;
            foreach (var child in Flatten(node.Children))
            {
                yield return child;
            }
        }
    }

    var saveWarehouseStructureNodeUrl = Url.Action("SaveWarehouseStructureNode", "InventoryManagement", new { mode = Model.StructureMode }) ?? string.Empty;
    var structureAjaxTarget = Model.StructureAjaxTarget;

    IHtmlContent RenderNode(Insurance.InventoryDashboard.Panel.Models.LocationStructureTreeItemModel node, int depth)
    {
        var padding = depth * 20;
        var childNodes = node.Children.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name).ToList();
        var builder = new HtmlContentBuilder();
        var deleteFormId = $"structure-delete-{node.LocationStructureBusinessKey}";
        var canSelectValue = false;
        var targetField = $"level-{depth}";

        builder.AppendHtml($"<div class=\"border rounded mb-2 p-2\" style=\"margin-right:{padding}px\" data-structure-node data-node-key=\"{HtmlEncoder.Default.Encode(node.LocationStructureBusinessKey)}\" data-node-code=\"{HtmlEncoder.Default.Encode(node.Code)}\" data-node-name=\"{HtmlEncoder.Default.Encode(node.Name)}\" data-node-depth=\"{depth}\">");
        builder.AppendHtml("<div class=\"d-flex justify-content-between align-items-start flex-wrap gap-2\">");
        builder.AppendHtml("<div>");
        builder.AppendHtml($"<div><strong class=\"text-monospace\">{HtmlEncoder.Default.Encode(node.Code)}</strong> - {HtmlEncoder.Default.Encode(node.Name)}</div>");
        builder.AppendHtml($"<div class=\"small text-muted\">{HtmlEncoder.Default.Encode(WarehouseLabel(node.WarehouseRef))}</div>");
        builder.AppendHtml($"<div class=\"mt-1\"><span class=\"badge badge-pill {(node.IsActive ? "badge-primary" : "badge-secondary")}\">" + (node.IsActive ? "فعال" : "غیرفعال") + "</span></div>");
        builder.AppendHtml("</div>");
        builder.AppendHtml("<div class=\"btn-group btn-group-sm align-items-start\">");
        if (canSelectValue)
        {
            builder.AppendHtml($"<button type=\"button\" class=\"btn btn-outline-success\" data-structure-node-choose=\"true\" data-structure-target-field=\"{targetField}\" data-node-code=\"{HtmlEncoder.Default.Encode(node.Code)}\" data-node-name=\"{HtmlEncoder.Default.Encode(node.Name)}\">+</button>");
        }
        builder.AppendHtml($"<button type=\"button\" class=\"btn btn-outline-primary\" data-structure-node-edit=\"true\" data-node-key=\"{HtmlEncoder.Default.Encode(node.LocationStructureBusinessKey)}\" data-node-parent=\"{HtmlEncoder.Default.Encode(node.ParentStructureRef ?? string.Empty)}\" data-node-code=\"{HtmlEncoder.Default.Encode(node.Code)}\" data-node-name=\"{HtmlEncoder.Default.Encode(node.Name)}\" data-node-display-order=\"{node.DisplayOrder}\" data-node-active=\"{node.IsActive.ToString().ToLowerInvariant()}\">ویرایش</button>");
        builder.AppendHtml($"<form id=\"{HtmlEncoder.Default.Encode(deleteFormId)}\" action=\"{HtmlEncoder.Default.Encode(saveWarehouseStructureNodeUrl)}\" method=\"post\" class=\"d-inline\" data-loading-form data-ajax-target=\"{HtmlEncoder.Default.Encode(structureAjaxTarget)}\">");
        builder.AppendHtml(Html.AntiForgeryToken());
        builder.AppendHtml($"<input type=\"hidden\" name=\"StructureNodeForm.LocationStructureBusinessKey\" value=\"{HtmlEncoder.Default.Encode(node.LocationStructureBusinessKey)}\" />");
        builder.AppendHtml($"<input type=\"hidden\" name=\"StructureNodeForm.WarehouseRef\" value=\"{HtmlEncoder.Default.Encode(node.WarehouseRef)}\" />");
        builder.AppendHtml($"<input type=\"hidden\" name=\"StructureNodeForm.ParentStructureRef\" value=\"{HtmlEncoder.Default.Encode(node.ParentStructureRef ?? string.Empty)}\" />");
        builder.AppendHtml($"<input type=\"hidden\" name=\"StructureNodeForm.Code\" value=\"{HtmlEncoder.Default.Encode(node.Code)}\" />");
        builder.AppendHtml($"<input type=\"hidden\" name=\"StructureNodeForm.Name\" value=\"{HtmlEncoder.Default.Encode(node.Name)}\" />");
        builder.AppendHtml($"<input type=\"hidden\" name=\"StructureNodeForm.DisplayOrder\" value=\"{node.DisplayOrder}\" />");
        builder.AppendHtml("<input type=\"hidden\" name=\"StructureNodeForm.IsActive\" value=\"false\" />");
        builder.AppendHtml($"<button type=\"submit\" class=\"btn btn-outline-danger\" data-confirm-title=\"حذف ساختار\" data-confirm=\"این ساختار غیرفعال شود؟\">حذف</button>");
        builder.AppendHtml("</form>");
        builder.AppendHtml("</div>");
        builder.AppendHtml("</div>");

        foreach (var child in childNodes)
        {
            builder.AppendHtml(RenderNode(child, depth + 1));
        }

        builder.AppendHtml("</div>");
        return builder;
    }
}

<main id="inventory-management-root" class="catalog-page" data-structure-mode="@Model.StructureMode">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="mb-4 d-flex justify-content-between align-items-start flex-wrap">
                    <div>
                        <h1>ساختار انبار</h1>
                        <p class="text-muted mb-1">تعریف درخت ساختار انبار و مدیریت نودهای آن در همان صفحه.</p>
                        <div class="small text-muted">انبار انتخاب‌شده: <strong>@WarehouseLabel(Model.SelectedWarehouseId)</strong></div>
                    </div>
                    <div>
                        <a asp-action="Warehouses" class="btn btn-outline-secondary">بازگشت به انبارها</a>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-warning">@Model.ErrorMessage</div>
                }
                @if (TempData.ContainsKey("CatalogError"))
                {
                    <div class="alert alert-danger">@TempData["CatalogError"]</div>
                }
                @if (TempData.ContainsKey("CatalogSuccess"))
                {
                    <div class="alert alert-success">@TempData["CatalogSuccess"]</div>
                }
            </div>
        </div>

        <div id="warehouse-structure-content">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h5 class="card-title mb-0">فرم تولید ساختار</h5>
                            <div class="small text-muted">@(Model.StructureMode == "select" ? "در حالت انتخاب، دکمه + کنار نودها مقدار را وارد فیلدهای لوکیشن می‌کند." : "با انتخاب ویرایش، اطلاعات نود بالا برمی‌گردد و همین فرم برای به‌روزرسانی استفاده می‌شود.")</div>
                        </div>
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-structure-node-reset>فرم جدید</button>
                    </div>

                    <form asp-action="SaveWarehouseStructureNode" asp-route-mode="@Model.StructureMode" method="post" data-loading-form data-dirty-watch data-ajax-target="@structureAjaxTarget" data-structure-node-form>
                        @Html.AntiForgeryToken()
                        <input asp-for="StructureNodeForm.LocationStructureBusinessKey" type="hidden" data-structure-field="key" />
                        <input asp-for="StructureNodeForm.WarehouseRef" type="hidden" />
                        <div asp-validation-summary="All" class="text-danger small mb-2"></div>
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <label>نود والد</label>
                                <select asp-for="StructureNodeForm.ParentStructureRef" class="form-control js-search-select" data-structure-field="parent">
                                    <option value="">بدون والد</option>
                                    @foreach (var structure in Flatten(Model.Structures))
                                    {
                                        <option value="@structure.LocationStructureBusinessKey">@structure.Code - @structure.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group col-md-2">
                                <label>کد</label>
                                <input asp-for="StructureNodeForm.Code" class="form-control text-monospace" required maxlength="50" data-structure-field="code" />
                            </div>
                            <div class="form-group col-md-4">
                                <label>نام</label>
                                <input asp-for="StructureNodeForm.Name" class="form-control" required maxlength="160" data-structure-field="name" />
                            </div>
                            <div class="form-group col-md-2">
                                <label>ترتیب</label>
                                <input asp-for="StructureNodeForm.DisplayOrder" class="form-control" type="number" min="0" data-structure-field="displayOrder" />
                            </div>
                        </div>
                        <div class="form-row align-items-end">
                            <div class="form-group col-md-3">
                                <div class="custom-control custom-checkbox mt-2">
                                    <input asp-for="StructureNodeForm.IsActive" class="custom-control-input" data-structure-field="active" />
                                    <label class="custom-control-label" asp-for="StructureNodeForm.IsActive">فعال</label>
                                </div>
                            </div>
                            <div class="form-group col-md-9 text-right">
                                <button class="btn btn-primary" type="submit" @(Can("Inventory.Warehouse.Create", "Inventory.Warehouse.Update", "Warehouse.Create", "Warehouse.Update") ? null : "disabled")>
                                    ذخیره نود
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0">لیست ساختار</h5>
                        <span class="text-muted small">@Model.Structures.Count نود ریشه</span>
                    </div>

                    @if (string.IsNullOrWhiteSpace(Model.SelectedWarehouseId))
                    {
                        <div class="alert alert-info mb-0">ابتدا یک انبار انتخاب کنید.</div>
                    }
                    else if (Model.Structures.Count == 0)
                    {
                        <div class="text-muted">برای این انبار هنوز ساختاری ثبت نشده است.</div>
                    }
                    else
                    {
                        foreach (var node in Model.Structures.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name))
                        {
                            @RenderNode(node, 0)
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</main>

<script data-ajax-reinit>
    (function () {
        if (window.__warehouseStructureBindingAttached) {
            return;
        }

        window.__warehouseStructureBindingAttached = true;

        function getForm() {
            return document.querySelector('[data-structure-node-form]');
        }

        function getField(form, name) {
            return form ? form.querySelector('[data-structure-field="' + name + '"]') : null;
        }

        function resetForm() {
            var form = getForm();
            if (!form) {
                return;
            }

            form.reset();

            var keyField = getField(form, 'key');
            if (keyField) {
                keyField.value = '';
            }

            var activeField = getField(form, 'active');
            if (activeField) {
                activeField.checked = true;
            }
        }

        function fillFormFromButton(button) {
            var form = getForm();
            if (!form || !button) {
                return;
            }

            var keyField = getField(form, 'key');
            var parentField = getField(form, 'parent');
            var codeField = getField(form, 'code');
            var nameField = getField(form, 'name');
            var displayOrderField = getField(form, 'displayOrder');
            var activeField = getField(form, 'active');

            if (keyField) keyField.value = button.getAttribute('data-node-key') || '';
            if (parentField) parentField.value = button.getAttribute('data-node-parent') || '';
            if (codeField) codeField.value = button.getAttribute('data-node-code') || '';
            if (nameField) nameField.value = button.getAttribute('data-node-name') || '';
            if (displayOrderField) displayOrderField.value = button.getAttribute('data-node-display-order') || '0';
            if (activeField) activeField.checked = (button.getAttribute('data-node-active') || 'true') === 'true';

            form.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function applySelectValue(button) {
            var mode = document.querySelector('[data-structure-mode]') ? document.querySelector('[data-structure-mode]').getAttribute('data-structure-mode') : 'manage';
            if (mode !== 'select') {
                return;
            }

            var targetField = button.getAttribute('data-structure-target-field') || '';
            var code = button.getAttribute('data-node-code') || '';
            var locationForm = document.querySelector('form[action*="SaveLocation"]');
            if (!locationForm) {
                return;
            }

            document.dispatchEvent(new CustomEvent('warehouse-structure-selection-changed', {
                detail: {
                    targetField: targetField,
                    value: code
                }
            }));
        }

        document.addEventListener('click', function (event) {
            var chooseButton = event.target && event.target.closest ? event.target.closest('[data-structure-node-choose]') : null;
            if (chooseButton) {
                event.preventDefault();
                applySelectValue(chooseButton);
                return;
            }

            var editButton = event.target && event.target.closest ? event.target.closest('[data-structure-node-edit]') : null;
            if (editButton) {
                event.preventDefault();
                fillFormFromButton(editButton);
                return;
            }

            var resetButton = event.target && event.target.closest ? event.target.closest('[data-structure-node-reset]') : null;
            if (resetButton) {
                event.preventDefault();
                resetForm();
            }
        }, true);
    })();
</script>
