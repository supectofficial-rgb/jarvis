@using System
@using System.Linq
@model Insurance.InventoryDashboard.Panel.Models.InventoryDocumentManagementPageViewModel
@{
    var document = Model.SelectedDocumentDetails;
    var currentDocumentType = document?.DocumentType ?? "Issue";
    var canEditLines = document is not null && string.Equals(document.Status, "Draft", StringComparison.OrdinalIgnoreCase);

    string TypeLabel(string? type) => type switch
    {
        "Receipt" => UiText["inventory.documents.type.receipt"],
        "Issue" => UiText["inventory.documents.type.issue"],
        "Transfer" => UiText["inventory.documents.type.transfer"],
        "Adjustment" => UiText["inventory.documents.type.adjustment"],
        "Return" => UiText["inventory.documents.type.return"],
        "QualityChange" => UiText["inventory.documents.type.qualityChange"],
        "Conversion" => UiText["inventory.documents.type.conversion"],
        _ => type ?? "-"
    };

    string StatusLabel(string? status) => status switch
    {
        "Draft" => UiText["inventory.documents.status.draft"],
        "Approved" => UiText["inventory.documents.status.approved"],
        "Rejected" => UiText["inventory.documents.status.rejected"],
        "Cancelled" => UiText["inventory.documents.status.cancelled"],
        "Posted" => UiText["inventory.documents.status.posted"],
        _ => status ?? "-"
    };

    string StatusClass(string? status) => status switch
    {
        "Draft" => "badge-outline-secondary",
        "Approved" => "badge-info",
        "Rejected" => "badge-danger",
        "Cancelled" => "badge-warning",
        "Posted" => "badge-success",
        _ => "badge-secondary"
    };

    string VariantLabel(Insurance.InventoryDashboard.Panel.Models.ProductVariantSummaryModel variant)
    {
        var productName = Model.ProductLookup.FirstOrDefault(x => x.Id == variant.ProductId)?.Name;
        return string.IsNullOrWhiteSpace(productName)
            ? variant.Sku
            : $"{variant.Sku} - {productName}";
    }

    string VariantName(string? variantId)
    {
        if (string.IsNullOrWhiteSpace(variantId))
        {
            return "-";
        }

        var variant = Model.VariantLookup.FirstOrDefault(x => string.Equals(x.Id, variantId, StringComparison.OrdinalIgnoreCase));
        return variant is null ? variantId : VariantLabel(variant);
    }

    string UomName(string? uomId)
    {
        if (string.IsNullOrWhiteSpace(uomId))
        {
            return "-";
        }

        var uom = Model.UnitOfMeasureLookup.FirstOrDefault(x => string.Equals(x.Id, uomId, StringComparison.OrdinalIgnoreCase));
        return uom is null ? uomId : $"{uom.Code} - {uom.Name}";
    }

    string QualityName(string? qualityId)
    {
        if (string.IsNullOrWhiteSpace(qualityId))
        {
            return "-";
        }

        var quality = Model.QualityStatusLookup.FirstOrDefault(x => string.Equals(x.QualityStatusBusinessKey, qualityId, StringComparison.OrdinalIgnoreCase));
        return quality is null ? qualityId : $"{quality.Code} - {quality.Name}";
    }

    string LocationName(string? locationId)
    {
        if (string.IsNullOrWhiteSpace(locationId))
        {
            return "-";
        }

        var location = Model.LocationLookup.FirstOrDefault(x => string.Equals(x.LocationBusinessKey, locationId, StringComparison.OrdinalIgnoreCase));
        if (location is null)
        {
            return locationId;
        }

        var warehouse = Model.WarehouseLookup.FirstOrDefault(x => string.Equals(x.WarehouseBusinessKey, location.WarehouseRef, StringComparison.OrdinalIgnoreCase));
        var warehouseLabel = warehouse is null ? location.WarehouseRef : $"{warehouse.Code} - {warehouse.Name}";
        var locationLabel = string.IsNullOrWhiteSpace(location.LocationType)
            ? location.LocationCode
            : $"{location.LocationCode} ({location.LocationType})";
        return string.IsNullOrWhiteSpace(warehouseLabel) ? locationLabel : $"{warehouseLabel} - {locationLabel}";
    }

    var issueLocationOptions = Model.LocationLookup.Select(x =>
    {
        var warehouse = Model.WarehouseLookup.FirstOrDefault(w => string.Equals(w.WarehouseBusinessKey, x.WarehouseRef, StringComparison.OrdinalIgnoreCase));
        var warehouseLabel = warehouse is null ? x.WarehouseRef : $"{warehouse.Code} - {warehouse.Name}";
        var locationLabel = string.IsNullOrWhiteSpace(x.LocationType) ? x.LocationCode : $"{x.LocationCode} ({x.LocationType})";
        return new
        {
            id = x.LocationBusinessKey,
            warehouseId = x.WarehouseRef,
            text = string.IsNullOrWhiteSpace(warehouseLabel) ? locationLabel : $"{warehouseLabel} - {locationLabel}"
        };
    }).ToList();
}

<div id="issue-document-details-modal-body"
     class="modal-body issue-document-details-modal"
     data-location-options='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(issueLocationOptions))'
     data-default-source-location-id="@Model.LineForm.SourceLocationRef"
     data-default-serials-json='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineForm.Serials.Select(serial => new { serialItemBusinessKey = serial.SerialItemBusinessKey, serialNo = serial.SerialNo })))'>
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-warning">@Model.ErrorMessage</div>
    }

    @if (document is null)
    {
        <div class="alert alert-light mb-0">سندی برای نمایش پیدا نشد.</div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <div class="text-monospace h5 mb-1">@document.DocumentNo</div>
                <div class="text-muted small">@TypeLabel(currentDocumentType)</div>
            </div>
            <span class="badge badge-pill @StatusClass(document.Status)">@StatusLabel(document.Status)</span>
        </div>

        @if (canEditLines)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0">@(string.IsNullOrWhiteSpace(Model.LineForm.LineId) ? "افزودن آیتم" : "ویرایش آیتم")</h6>
                        <button type="button" class="btn btn-outline-secondary btn-xs js-issue-line-cancel d-none">لغو ویرایش</button>
                    </div>
                    <form asp-action="SaveIssueDocumentLine" asp-controller="InventoryManagement" method="post" data-loading-form data-ajax-target="#issue-document-details-modal-body" class="mb-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="LineForm.DocumentId" value="@document.DocumentBusinessKey" />
                        <input type="hidden" asp-for="LineForm.DocumentType" value="@currentDocumentType" />
                        <input type="hidden" asp-for="LineForm.LineId" value="@Model.LineForm.LineId" />
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <label>واریانت</label>
                                <select asp-for="LineForm.VariantId" class="form-control js-search-select js-issue-line-variant" data-placeholder="جستجو با کد یا نام واریانت" data-ajax-url='@Url.Action("SearchReceiptVariantLookup", "InventoryManagement")' required>
                                    <option value="">انتخاب واریانت</option>
                                    @foreach (var variant in Model.VariantLookup.OrderBy(x => x.Sku))
                                    {
                                        <option value="@variant.Id" selected="@(variant.Id == Model.LineForm.VariantId ? "selected" : null)">@VariantLabel(variant)</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group col-md-4">
                                <label>لوکیشن مبدأ</label>
                                <select asp-for="LineForm.SourceLocationRef" class="form-control js-search-select js-issue-line-source" data-placeholder="انتخاب لوکیشن" disabled required>
                                    <option value="">ابتدا واریانت را انتخاب کنید</option>
                                </select>
                                <label class="mt-2">وضعیت کیفیت</label>
                                <select asp-for="LineForm.QualityStatusRef" class="form-control js-search-select" data-placeholder="انتخاب کیفیت" required>
                                    <option value="">انتخاب کیفیت</option>
                                    @foreach (var quality in Model.QualityStatusLookup.OrderBy(x => x.Code))
                                    {
                                        <option value="@quality.QualityStatusBusinessKey" selected="@(quality.QualityStatusBusinessKey == Model.LineForm.QualityStatusRef ? "selected" : null)">@quality.Code - @quality.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group col-12 col-lg-4 line-serials d-none">
                                <label>@UiText["inventory.documents.issue.serial.title"]</label>
                                <div class="text-muted small js-issue-line-serial-summary mb-2" data-select-prompt="@UiText["inventory.documents.issue.serial.selectLocationPrompt"]" data-no-available="@UiText["inventory.documents.issue.serial.noAvailable"]" data-select-available="@UiText["inventory.documents.issue.serial.selectPrompt"]">@UiText["inventory.documents.issue.serial.selectLocationPrompt"]</div>
                                <div class="list-group js-issue-line-serial-container" style="max-height: 240px; overflow:auto;"></div>
                                <div class="js-issue-line-serial-hidden d-none"></div>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-10">
                                <label>@UiText["inventory.documents.line.quantity"]</label>
                                <input asp-for="LineForm.Qty" type="number" step="0.0001" min="0.0001" class="form-control" />
                            </div>
                            <div class="form-group col-md-2 d-flex align-items-end">
                                <button class="btn btn-primary btn-block js-issue-line-submit" type="submit">@(string.IsNullOrWhiteSpace(Model.LineForm.LineId) ? UiText["inventory.documents.action.addItem"] : UiText["inventory.documents.action.saveChanges"])</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-light border mb-3">این سند در وضعیت پیش‌نویس نیست و آیتم‌ها قابل ویرایش نیستند.</div>
        }

        <div class="border-top pt-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0">آیتم های سند</h6>
                <span class="text-muted small">@document.Lines.Count ردیف</span>
            </div>

            @if (document.Lines.Count == 0)
            {
                <div class="alert alert-light mb-0">ردیفی برای این سند ثبت نشده است.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>@UiText["inventory.documents.line.variant"]</th>
                                <th>@UiText["inventory.documents.line.quantity"]</th>
                                <th>@UiText["inventory.documents.line.uom"]</th>
                                <th>@UiText["inventory.documents.line.quality"]</th>
                                <th>@UiText["inventory.documents.line.sourceLocation"]</th>
                                <th class="text-right">@UiText["inventory.documents.action.action"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in document.Lines)
                            {
                                <tr>
                                    <td>@VariantName(line.VariantRef)</td>
                                    <td>@line.Qty.ToString("0.####")</td>
                                    <td>@UomName(line.UomRef)</td>
                                    <td>@QualityName(line.QualityStatusRef)</td>
                                    <td>@LocationName(line.SourceLocationRef)</td>
                                    <td class="text-right">
                                @if (canEditLines)
                                {
                                    <button type="button"
                                            class="btn btn-outline-primary btn-xs js-issue-line-edit"
                                            data-line-id="@line.LineBusinessKey"
                                            data-variant-id="@line.VariantRef"
                                            data-source-location-id="@line.SourceLocationRef"
                                            data-quality-id="@line.QualityStatusRef"
                                            data-qty="@line.Qty.ToString("0.####")"
                                            data-serials-json='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(line.Serials.Select(serial => new { serialItemBusinessKey = serial.SerialItemBusinessKey, serialNo = serial.SerialNo })))'>@UiText["inventory.documents.action.editDocument"]</button>
                                            <form asp-action="DeleteIssueDocumentLine" asp-controller="InventoryManagement" method="post" class="d-inline" data-loading-form data-ajax-target="#issue-document-details-modal-body" onsubmit="return confirm('@UiText["inventory.documents.confirm.deleteLine"]');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="documentId" value="@document.DocumentBusinessKey" />
                                                <input type="hidden" name="lineId" value="@line.LineBusinessKey" />
                                                <button class="btn btn-outline-danger btn-xs" type="submit">@UiText["inventory.documents.action.deleteDocument"]</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">@UiText["inventory.documents.line.notEditable"]</span>
                                        }
                                    </td>
                                </tr>
                                @if (line.BaseQty != line.Qty || !string.Equals(line.BaseUomRef, line.UomRef, StringComparison.OrdinalIgnoreCase) || !string.IsNullOrWhiteSpace(line.LotBatchNo))
                                {
                                    <tr>
                                        <td colspan="6" class="text-muted small">
                                            Base: @line.BaseQty.ToString("0.####") @UomName(line.BaseUomRef)
                                            @if (!string.IsNullOrWhiteSpace(line.LotBatchNo))
                                            {
                                                <span> | @UiText["inventory.documents.line.lotBatch"]: @line.LotBatchNo</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</div>
