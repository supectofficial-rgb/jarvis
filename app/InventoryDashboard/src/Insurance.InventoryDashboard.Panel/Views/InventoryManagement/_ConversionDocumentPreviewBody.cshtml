@model Insurance.InventoryDashboard.Panel.Models.ConversionDocumentPreviewViewModel
@using System
@using System.Linq

@{
    string OperationLabel(string? operationType) => operationType switch
    {
        "Assemble" => UiText["inventory.documents.conversion.operation.assemble"],
        "Disassemble" => UiText["inventory.documents.conversion.operation.disassemble"],
        _ => operationType ?? "-"
    };

    string RoleLabel(string? role) => role switch
    {
        "Source" => UiText["inventory.documents.conversion.role.source"],
        "Destination" => UiText["inventory.documents.conversion.role.destination"],
        _ => role ?? "-"
    };
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start flex-wrap mb-2">
                <div>
                    <h6 class="mb-1">@UiText["inventory.documents.conversion.previewTitle"]</h6>
                    <div class="text-muted small">@Model.VariantLabel</div>
                </div>
                <div class="text-right">
                    <span class="badge badge-pill badge-info mb-1">@OperationLabel(Model.OperationType)</span>
                    <div class="small text-muted">@UiText["common.quantity"]: @Model.Quantity.ToString("0.####")</div>
                </div>
            </div>

            <div class="alert alert-light border mb-0">
                @UiText["inventory.documents.conversion.previewInstructions"]
            </div>
        </div>
    </div>

    @if (Model.Lines.Count == 0)
    {
        <div class="alert alert-warning mb-0">@UiText["inventory.documents.conversion.previewNoLines"]</div>
    }
    else
    {
        @foreach (var line in Model.Lines)
        {
            <div class="card mb-3" data-conversion-preview-line data-line-key="@line.LineKey" data-variant-id="@line.VariantId" data-role="@line.Role" data-required-qty="@line.RequiredQty.ToString("0.####")">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start flex-wrap mb-3">
                        <div>
                            <strong>@line.VariantLabel</strong>
                            <div class="small text-muted">@RoleLabel(line.Role)</div>
                        </div>
                        <div class="text-right">
                            <div class="small text-muted">@UiText["inventory.documents.conversion.requiredQty"]</div>
                            <div>@line.RequiredQty.ToString("0.####")</div>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-lg-8">
                            <label>@UiText["common.location"]</label>
                            <select class="form-control js-search-select" data-conversion-preview-location-select required>
                                <option value="">@UiText["inventory.documents.line.selectLocation"]</option>
                                @foreach (var option in line.LocationOptions.OrderByDescending(x => x.IsDefault).ThenByDescending(x => x.QuantityOnHand))
                                {
                                    <option value="@option.LocationRef" selected="@(string.Equals(option.LocationRef, line.SelectedLocationRef, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                                        @option.Label @(option.QuantityOnHand > 0 ? $" - {option.QuantityOnHand:0.####}" : null)
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="form-group col-lg-4 d-flex align-items-end">
                        <div class="text-muted small">@UiText["common.uom"]: @(string.IsNullOrWhiteSpace(line.BaseUomLabel) ? line.BaseUomRef : line.BaseUomLabel)</div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="d-flex justify-content-end">
            <button type="button" class="btn btn-success" data-conversion-preview-commit>@UiText["inventory.documents.conversion.confirmAllLocations"]</button>
        </div>
    }
}
