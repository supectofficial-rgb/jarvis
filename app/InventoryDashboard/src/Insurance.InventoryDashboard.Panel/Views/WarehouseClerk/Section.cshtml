@model Insurance.InventoryDashboard.Panel.Models.WarehouseClerkPageViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;
}

<main class="warehouse-clerk-page">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="mb-4">
                    <div class="d-flex align-items-center flex-wrap mb-2">
                        <span class="badge badge-pill badge-primary ml-2">@Model.BadgeText</span>
                        <h1 class="mb-0">@Model.PageTitle</h1>
                    </div>
                    <p class="text-muted mb-2">@Model.PageSubtitle</p>
                    <p class="text-muted">@Model.PageDescription</p>
                </div>
            </div>
        </div>

        <div class="row">
            @foreach (var note in Model.Notes)
            {
                <div class="col-lg-6 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@note.Title</h5>
                            <p class="text-muted mb-0">@note.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="row">
            @foreach (var card in Model.ActionCards)
            {
                <div class="col-md-6 col-xl-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex align-items-center mb-3">
                                <i class="@card.Icon" style="font-size: 1.9rem;"></i>
                                <div>
                                    <h5 class="card-title mb-1">@card.Title</h5>
                                    @if (card.IsPrimary)
                                    {
                                        <span class="badge badge-pill badge-outline-primary">Primary</span>
                                    }
                                </div>
                            </div>
                            <p class="text-muted flex-grow-1">@card.Description</p>
                            @if (!string.IsNullOrWhiteSpace(card.Route))
                            {
                                <a class="btn btn-primary btn-block" href="@card.Route">باز کردن</a>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary btn-block" type="button" disabled>در حال تکمیل</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</main>
