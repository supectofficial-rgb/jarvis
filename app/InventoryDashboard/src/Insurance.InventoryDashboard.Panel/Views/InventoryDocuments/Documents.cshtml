@using System.Text.Json
@model Insurance.InventoryDashboard.Panel.Models.InventoryDocumentManagementPageViewModel
@{
    ViewData["Title"] = "مدیریت اسناد انبار";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var locationsJson = JsonSerializer.Serialize(Model.Locations.Select(x => new
    {
        id = x.LocationBusinessKey,
        warehouseId = x.WarehouseRef,
        text = $"{x.LocationCode} - {x.LocationType}"
    }));
}

<main id="inventory-documents-page" class="catalog-page">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h1>مدیریت اسناد انبار</h1>
                <p class="text-muted">تولید سند با انتخاب واریانت، تعداد و لوکیشن اثر موجودی.</p>
                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) || TempData["CatalogError"] is string)
                {
                    <div class="alert alert-warning">@(TempData["CatalogError"] as string ?? Model.ErrorMessage)</div>
                }
                @if (TempData["CatalogSuccess"] is string success)
                {
                    <div class="alert alert-success">@success</div>
                }
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <ul class="nav nav-tabs separator-tabs ml-0 mb-4" role="tablist">
                    <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#document-create-tab" role="tab">تولید سند</a></li>
                    <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#document-search-tab" role="tab">جستجوی اسناد</a></li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="document-create-tab" role="tabpanel">
                        <form asp-action="SaveDocument" method="post" id="document-form" data-loading-form>
                            @Html.AntiForgeryToken()
                            <input asp-for="DocumentForm.LinesJson" type="hidden" id="document-lines-json" />
                            <input asp-for="DocumentForm.PostAfterCreate" type="hidden" id="document-post-after-create" />

                            <div class="card mb-4">
                                <div class="card-body">
                                    <h5 class="card-title mb-3">اطلاعات سند</h5>
                                    <div class="form-row">
                                        <div class="form-group col-md-3">
                                            <label>نوع سند</label>
                                            <select asp-for="DocumentForm.DocumentType" class="form-control" id="document-type">
                                                <option value="Receipt">ورود</option>
                                                <option value="Issue">خروج</option>
                                                <option value="Transfer">انتقال</option>
                                                <option value="Adjustment">تعدیل</option>
                                            </select>
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label>شماره سند</label>
                                            <input asp-for="DocumentForm.DocumentNo" class="form-control" placeholder="اختیاری" />
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label>انبار</label>
                                            <select asp-for="DocumentForm.WarehouseId" class="form-control js-search-select" id="document-warehouse" required>
                                                <option value="">انتخاب انبار</option>
                                                @foreach (var warehouse in Model.Warehouses.OrderBy(x => x.Code))
                                                {
                                                    <option value="@warehouse.WarehouseBusinessKey">@warehouse.Code - @warehouse.Name</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label>تامین‌کننده/مالک</label>
                                            <select asp-for="DocumentForm.SellerId" class="form-control js-search-select" required>
                                                <option value="">انتخاب</option>
                                                @foreach (var seller in Model.Sellers.OrderBy(x => x.Code))
                                                {
                                                    <option value="@seller.SellerBusinessKey">@seller.Code - @seller.Name</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group col-md-3">
                                            <label>تاریخ سند</label>
                                            <input asp-for="DocumentForm.OccurredAt" class="form-control" type="date" />
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label>کد علت</label>
                                            <input asp-for="DocumentForm.ReasonCode" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card mb-4">
                                <div class="card-body">
                                    <h5 class="card-title mb-3">افزودن واریانت به سند</h5>
                                    <div class="form-row align-items-end">
                                        <div class="form-group col-md-4">
                                            <label>جستجوی واریانت</label>
                                            <input name="variantSearchTerm" value="@Model.VariantSearchTerm" class="form-control" form="variant-search-form" placeholder="نام یا SKU" />
                                        </div>
                                        <div class="form-group col-md-2">
                                            <button class="btn btn-outline-primary btn-block" type="submit" form="variant-search-form">جستجو</button>
                                        </div>
                                        <div class="form-group col-md-2">
                                            <label>تعداد</label>
                                            <input id="line-quantity" class="form-control" type="number" min="0.0001" step="0.0001" value="1" />
                                        </div>
                                        <div class="form-group col-md-2">
                                            <label>وضعیت کیفی</label>
                                            <select id="line-quality" class="form-control">
                                                @foreach (var status in Model.QualityStatuses.OrderBy(x => x.Code))
                                                {
                                                    <option value="@status.QualityStatusBusinessKey">@status.Code - @status.Name</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-group col-md-2">
                                            <label>جهت تعدیل</label>
                                            <select id="line-adjustment-direction" class="form-control">
                                                <option value="Increase">افزایش</option>
                                                <option value="Decrease">کاهش</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group col-md-4">
                                            <label>لوکیشن مبدا</label>
                                            <select id="line-source-location" class="form-control js-search-select"></select>
                                        </div>
                                        <div class="form-group col-md-4">
                                            <label>لوکیشن مقصد</label>
                                            <select id="line-destination-location" class="form-control js-search-select"></select>
                                        </div>
                                        <div class="form-group col-md-4">
                                            <label>Lot/Batch</label>
                                            <input id="line-lot" class="form-control" />
                                        </div>
                                    </div>

                                    <form method="get" asp-action="Documents" id="variant-search-form"></form>
                                    <div class="table-responsive mb-3">
                                        <table class="table table-sm table-striped">
                                            <thead>
                                                <tr>
                                                    <th>SKU</th>
                                                    <th>محصول</th>
                                                    <th>واحد</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (Model.VariantSearchResult.Items.Count == 0)
                                                {
                                                    <tr><td colspan="4" class="text-center text-muted">واریانتی پیدا نشد.</td></tr>
                                                }
                                                else
                                                {
                                                    @foreach (var variant in Model.VariantSearchResult.Items)
                                                    {
                                                        <tr>
                                                            <td><span class="text-monospace">@variant.Sku</span></td>
                                                            <td>@variant.ProductId</td>
                                                            <td>@variant.BaseUomRef</td>
                                                            <td class="text-right">
                                                                <button type="button"
                                                                        class="btn btn-outline-primary btn-xs js-add-line"
                                                                        data-variant-id="@variant.Id"
                                                                        data-variant-sku="@variant.Sku"
                                                                        data-uom-ref="@variant.BaseUomRef">
                                                                    افزودن
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>

                                    <h6 class="mb-2">آیتم‌های سند</h6>
                                    <div class="table-responsive">
                                        <table class="table table-sm table-striped mb-0">
                                            <thead>
                                                <tr>
                                                    <th>واریانت</th>
                                                    <th>تعداد</th>
                                                    <th>مبدا</th>
                                                    <th>مقصد</th>
                                                    <th>کیفیت</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody id="document-lines">
                                                <tr data-empty-row><td colspan="6" class="text-center text-muted">آیتمی اضافه نشده است.</td></tr>
                                            </tbody>
                                        </table>
                                    </div>

                                    <div class="mt-3">
                                        <button class="btn btn-outline-primary" type="submit" data-post-after-create="false">ذخیره پیش‌نویس</button>
                                        <button class="btn btn-primary" type="submit" data-post-after-create="true">نهایی‌سازی سند</button>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>

                    <div class="tab-pane fade" id="document-search-tab" role="tabpanel">
                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">جستجوی اسناد</h5>
                                <form method="get" asp-action="Documents" class="form-row mb-3">
                                    <div class="form-group col-md-2">
                                        <label>شماره</label>
                                        <input name="documentNo" value="@Model.DocumentNoFilter" class="form-control" />
                                    </div>
                                    <div class="form-group col-md-2">
                                        <label>نوع</label>
                                        <select name="documentType" class="form-control">
                                            <option value="">همه</option>
                                            <option value="Receipt" selected="@(Model.DocumentTypeFilter == "Receipt" ? "selected" : null)">ورود</option>
                                            <option value="Issue" selected="@(Model.DocumentTypeFilter == "Issue" ? "selected" : null)">خروج</option>
                                            <option value="Transfer" selected="@(Model.DocumentTypeFilter == "Transfer" ? "selected" : null)">انتقال</option>
                                            <option value="Adjustment" selected="@(Model.DocumentTypeFilter == "Adjustment" ? "selected" : null)">تعدیل</option>
                                        </select>
                                    </div>
                                    <div class="form-group col-md-2">
                                        <label>وضعیت</label>
                                        <select name="status" class="form-control">
                                            <option value="">همه</option>
                                            <option value="Draft" selected="@(Model.StatusFilter == "Draft" ? "selected" : null)">Draft</option>
                                            <option value="Posted" selected="@(Model.StatusFilter == "Posted" ? "selected" : null)">Posted</option>
                                            <option value="Cancelled" selected="@(Model.StatusFilter == "Cancelled" ? "selected" : null)">Cancelled</option>
                                        </select>
                                    </div>
                                    <div class="form-group col-md-3">
                                        <label>انبار</label>
                                        <select name="warehouseId" class="form-control js-search-select">
                                            <option value="">همه</option>
                                            @foreach (var warehouse in Model.Warehouses.OrderBy(x => x.Code))
                                            {
                                                <option value="@warehouse.WarehouseBusinessKey" selected="@(Model.WarehouseFilterId == warehouse.WarehouseBusinessKey ? "selected" : null)">@warehouse.Code - @warehouse.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group col-md-1">
                                        <label>تعداد</label>
                                        <select name="documentPageSize" class="form-control">
                                            @foreach (var size in Model.PageSizeOptions)
                                            {
                                                <option value="@size" selected="@(Model.DocumentPageSize == size ? "selected" : null)">@size</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group col-md-2 d-flex align-items-end">
                                        <button class="btn btn-outline-primary btn-block" type="submit">اعمال</button>
                                    </div>
                                </form>

                                <div class="table-responsive">
                                    <table class="table table-sm table-striped">
                                        <thead>
                                            <tr>
                                                <th>شماره</th>
                                                <th>نوع</th>
                                                <th>وضعیت</th>
                                                <th>انبار</th>
                                                <th>تاریخ</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model.Documents.Items.Count == 0)
                                            {
                                                <tr><td colspan="6" class="text-center text-muted">سندی پیدا نشد.</td></tr>
                                            }
                                            else
                                            {
                                                @foreach (var doc in Model.Documents.Items)
                                                {
                                                    <tr>
                                                        <td><span class="text-monospace">@doc.DocumentNo</span></td>
                                                        <td>@doc.DocumentType</td>
                                                        <td>@doc.Status</td>
                                                        <td>@doc.WarehouseRef</td>
                                                        <td>@doc.OccurredAt.ToString("yyyy-MM-dd")</td>
                                                        <td class="text-right">
                                                            <button type="button"
                                                                    class="btn btn-outline-info btn-xs js-document-items"
                                                                    data-url="@Url.Action("DocumentItems", "InventoryDocuments", new { documentId = doc.DocumentBusinessKey })">
                                                                آیتم‌ها
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<div class="modal fade" id="document-items-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">آیتم‌های سند</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="بستن"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body" id="document-items-modal-body">در حال بارگذاری...</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var locations = @Html.Raw(locationsJson);
            var lines = [];
            var warehouseSelect = document.getElementById('document-warehouse');
            var sourceSelect = document.getElementById('line-source-location');
            var destinationSelect = document.getElementById('line-destination-location');
            var linesBody = document.getElementById('document-lines');
            var linesJson = document.getElementById('document-lines-json');
            var postAfterCreate = document.getElementById('document-post-after-create');
            var form = document.getElementById('document-form');

            function fillLocationSelect(select) {
                var warehouseId = warehouseSelect ? warehouseSelect.value : '';
                select.innerHTML = '<option value="">انتخاب لوکیشن</option>';
                locations.filter(function (item) { return !warehouseId || item.warehouseId === warehouseId; })
                    .forEach(function (item) {
                        var option = document.createElement('option');
                        option.value = item.id;
                        option.textContent = item.text;
                        select.appendChild(option);
                    });
            }

            function locationText(id) {
                var item = locations.find(function (x) { return x.id === id; });
                return item ? item.text : '-';
            }

            function renderLines() {
                linesJson.value = JSON.stringify(lines);
                if (!lines.length) {
                    linesBody.innerHTML = '<tr data-empty-row><td colspan="6" class="text-center text-muted">آیتمی اضافه نشده است.</td></tr>';
                    return;
                }

                linesBody.innerHTML = '';
                lines.forEach(function (line, index) {
                    var row = document.createElement('tr');
                    row.innerHTML =
                        '<td><span class="text-monospace">' + line.variantSku + '</span></td>' +
                        '<td>' + line.quantity + '</td>' +
                        '<td>' + locationText(line.sourceLocationId) + '</td>' +
                        '<td>' + locationText(line.destinationLocationId) + '</td>' +
                        '<td>' + (line.qualityStatusId || '-') + '</td>' +
                        '<td class="text-right"><button type="button" class="btn btn-outline-danger btn-xs">حذف</button></td>';
                    row.querySelector('button').addEventListener('click', function () {
                        lines.splice(index, 1);
                        renderLines();
                    });
                    linesBody.appendChild(row);
                });
            }

            [sourceSelect, destinationSelect].forEach(function (select) {
                if (select) fillLocationSelect(select);
            });
            if (warehouseSelect) {
                warehouseSelect.addEventListener('change', function () {
                    fillLocationSelect(sourceSelect);
                    fillLocationSelect(destinationSelect);
                });
            }

            document.querySelectorAll('.js-add-line').forEach(function (button) {
                button.addEventListener('click', function () {
                    var quantity = parseFloat(document.getElementById('line-quantity').value || '0');
                    if (!quantity || quantity <= 0) return;
                    lines.push({
                        variantId: button.getAttribute('data-variant-id'),
                        variantSku: button.getAttribute('data-variant-sku'),
                        baseUomRef: button.getAttribute('data-uom-ref'),
                        quantity: quantity,
                        sourceLocationId: sourceSelect.value || null,
                        destinationLocationId: destinationSelect.value || null,
                        qualityStatusId: document.getElementById('line-quality').value || null,
                        adjustmentDirection: document.getElementById('line-adjustment-direction').value || null,
                        lotBatchNo: document.getElementById('line-lot').value || null
                    });
                    renderLines();
                });
            });

            if (form) {
                form.querySelectorAll('[data-post-after-create]').forEach(function (button) {
                    button.addEventListener('click', function () {
                        postAfterCreate.value = button.getAttribute('data-post-after-create') === 'true' ? 'true' : 'false';
                    });
                });
                form.addEventListener('submit', renderLines);
            }

            document.querySelectorAll('.js-document-items').forEach(function (button) {
                button.addEventListener('click', function () {
                    var body = document.getElementById('document-items-modal-body');
                    body.innerHTML = 'در حال بارگذاری...';
                    $('#document-items-modal').modal('show');
                    fetch(button.getAttribute('data-url'), { headers: { 'Accept': 'application/json' } })
                        .then(function (response) { return response.json(); })
                        .then(function (items) {
                            if (items.error) {
                                body.innerHTML = '<div class="text-danger">' + items.error + '</div>';
                                return;
                            }
                            if (!items.length) {
                                body.innerHTML = '<div class="text-muted">آیتمی برای این سند پیدا نشد.</div>';
                                return;
                            }
                            body.innerHTML = '<table class="table table-sm table-striped"><thead><tr><th>Variant</th><th>Qty</th><th>Source</th><th>Destination</th><th>Quality</th></tr></thead><tbody>' +
                                items.map(function (x) {
                                    return '<tr><td>' + x.variantRef + '</td><td>' + x.qty + '</td><td>' + (x.sourceLocationRef || '-') + '</td><td>' + (x.destinationLocationRef || '-') + '</td><td>' + (x.qualityStatusRef || '-') + '</td></tr>';
                                }).join('') + '</tbody></table>';
                        });
                });
            });

            renderLines();
        })();
    </script>
}
