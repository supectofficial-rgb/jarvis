@model Insurance.InventoryDashboard.Panel.Models.PricingPageViewModel
@{
    ViewData["Title"] = "مدیریت قیمت";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var priceTypeNames = Model.PriceTypeLookup.ToDictionary(x => x.PriceTypeBusinessKey, x => $"{x.Name} ({x.Code})");
    var priceChannelNames = Model.PriceChannelLookup.ToDictionary(x => x.PriceChannelBusinessKey, x => $"{x.Name} ({x.Code})");
    var sellerNames = Model.Sellers.ToDictionary(x => x.SellerBusinessKey, x => $"{x.Name} ({x.Code})");
    var availableBuckets = Model.AvailableBuckets
        .GroupBy(x => new { x.SellerRef, x.VariantRef })
        .Select(x => new
        {
            x.Key.SellerRef,
            x.Key.VariantRef,
            QuantityOnHand = x.Sum(item => item.QuantityOnHand)
        })
        .OrderByDescending(x => x.QuantityOnHand)
        .ToList();
}

<main id="pricing-management-page" class="catalog-page">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h1>مدیریت قیمت</h1>
                <p class="text-muted">تعریف نوع قیمت، کانال قیمت و قیمت‌گذاری واریانت‌هایی که بالانس قابل فروش دارند.</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert alert-success">@Model.StatusMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <div class="row">
            <div class="col-12 mb-4">
                <ul class="nav nav-tabs separator-tabs ml-0 mb-4 d-none" role="tablist" id="pricing-management-tabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-item-id="variant_prices" data-toggle="tab" href="#variant-prices-tab" role="tab">قیمت‌گذاری واریانت</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-item-id="price_types" data-toggle="tab" href="#price-types-tab" role="tab">نوع قیمت</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-item-id="price_channels" data-toggle="tab" href="#price-channels-tab" role="tab">کانال قیمت</a>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="variant-prices-tab" role="tabpanel">
                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">ثبت قیمت برای بالانس قابل فروش</h5>
                                <form asp-action="CreateVariantPrice" method="post" data-loading-form>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="SellerRef" id="variant-price-seller-ref" />
                                    <input type="hidden" name="VariantRef" id="variant-price-variant-ref" />
                                    <div class="form-row">
                                        <div class="form-group col-lg-3 col-md-6">
                                            <label>بالانس / واریانت</label>
                                            <select id="variant-price-bucket" class="form-control" required>
                                                <option value="">انتخاب کنید...</option>
                                                @foreach (var bucket in availableBuckets)
                                                {
                                                    var sellerTitle = sellerNames.TryGetValue(bucket.SellerRef, out var sellerName) ? sellerName : bucket.SellerRef.ToString("D");
                                                    <option value="@bucket.SellerRef|@bucket.VariantRef">
                                                        @sellerTitle - @bucket.VariantRef.ToString("D") - موجودی @bucket.QuantityOnHand
                                                    </option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-group col-lg-2 col-md-6">
                                            <label>نوع قیمت</label>
                                            <select class="form-control" name="PriceTypeRef" required>
                                                <option value="">انتخاب کنید...</option>
                                                @foreach (var priceType in Model.PriceTypeLookup)
                                                {
                                                    <option value="@priceType.PriceTypeBusinessKey">@priceType.Name (@priceType.Code)</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-group col-lg-2 col-md-6">
                                            <label>کانال</label>
                                            <select class="form-control" name="PriceChannelRef" required>
                                                <option value="">انتخاب کنید...</option>
                                                @foreach (var channel in Model.PriceChannelLookup)
                                                {
                                                    <option value="@channel.PriceChannelBusinessKey">@channel.Name (@channel.Code)</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-group col-lg-2 col-md-6">
                                            <label>قیمت</label>
                                            <input class="form-control" name="Amount" type="number" min="1" step="0.01" required />
                                        </div>
                                        <div class="form-group col-lg-1 col-md-4">
                                            <label>ارز</label>
                                            <input class="form-control" name="Currency" value="IRR" maxlength="8" required />
                                        </div>
                                        <div class="form-group col-lg-1 col-md-4">
                                            <label>حداقل</label>
                                            <input class="form-control" name="MinQty" type="number" min="1" step="0.01" value="1" required />
                                        </div>
                                        <div class="form-group col-lg-1 col-md-4">
                                            <label>اولویت</label>
                                            <input class="form-control" name="Priority" type="number" value="0" />
                                        </div>
                                    </div>
                                    <button class="btn btn-primary" type="submit">ثبت قیمت</button>
                                </form>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">قیمت‌های ثبت‌شده</h5>
                                <div class="table-responsive">
                                    <table class="table table-sm table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th>واریانت</th>
                                                <th>تامین‌کننده</th>
                                                <th>نوع قیمت</th>
                                                <th>کانال</th>
                                                <th>قیمت</th>
                                                <th>فعال</th>
                                                <th class="text-right">عملیات</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model.VariantPrices.Items.Count == 0)
                                            {
                                                <tr>
                                                    <td colspan="7" class="text-center text-muted">هنوز قیمت واریانتی ثبت نشده است.</td>
                                                </tr>
                                            }
                                            @foreach (var price in Model.VariantPrices.Items)
                                            {
                                                <tr>
                                                    <form asp-action="UpdateVariantPrice" asp-route-id="@price.SellerVariantPriceBusinessKey" method="post" data-loading-form>
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="SellerRef" value="@price.SellerRef" />
                                                        <input type="hidden" name="VariantRef" value="@price.VariantRef" />
                                                        <input type="hidden" name="PriceTypeRef" value="@price.PriceTypeRef" />
                                                        <input type="hidden" name="PriceChannelRef" value="@price.PriceChannelRef" />
                                                        <input type="hidden" name="Currency" value="@price.Currency" />
                                                        <input type="hidden" name="MinQty" value="@price.MinQty" />
                                                        <input type="hidden" name="Priority" value="@price.Priority" />
                                                        <td>@price.VariantRef.ToString("D")</td>
                                                        <td>@(sellerNames.TryGetValue(price.SellerRef, out var seller) ? seller : price.SellerRef.ToString("D"))</td>
                                                        <td>@(priceTypeNames.TryGetValue(price.PriceTypeRef, out var type) ? type : price.PriceTypeRef.ToString("D"))</td>
                                                        <td>@(priceChannelNames.TryGetValue(price.PriceChannelRef, out var channel) ? channel : price.PriceChannelRef.ToString("D"))</td>
                                                        <td><input class="form-control form-control-sm" name="Amount" type="number" min="1" step="0.01" value="@price.Amount" /></td>
                                                        <td>
                                                            <input type="checkbox" name="IsActive" value="true" @(price.IsActive ? "checked" : null) />
                                                            <input type="hidden" name="IsActive" value="false" />
                                                        </td>
                                                        <td class="text-right">
                                                            <button class="btn btn-outline-primary btn-xs" type="submit">ذخیره</button>
                                                        </td>
                                                    </form>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="price-types-tab" role="tabpanel">
                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">نوع قیمت</h5>
                                <form asp-action="CreatePriceType" method="post" data-loading-form>
                                    @Html.AntiForgeryToken()
                                    <div class="form-row">
                                        <div class="form-group col-md-4">
                                            <label>کد</label>
                                            <input class="form-control" name="Code" placeholder="Retail / Wholesale" />
                                        </div>
                                        <div class="form-group col-md-5">
                                            <label>عنوان</label>
                                            <input class="form-control" name="Name" placeholder="فروش عادی" required />
                                        </div>
                                        <div class="form-group col-md-3 d-flex align-items-end">
                                            <button class="btn btn-primary btn-block" type="submit">ثبت نوع قیمت</button>
                                        </div>
                                    </div>
                                </form>

                                <div class="table-responsive mt-3">
                                    <table class="table table-sm table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th>کد</th>
                                                <th>عنوان</th>
                                                <th>فعال</th>
                                                <th class="text-right">عملیات</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var priceType in Model.PriceTypes.Items)
                                            {
                                                <tr>
                                                    <form asp-action="UpdatePriceType" asp-route-id="@priceType.PriceTypeBusinessKey" method="post" data-loading-form>
                                                        @Html.AntiForgeryToken()
                                                        <td><input class="form-control form-control-sm" name="Code" value="@priceType.Code" /></td>
                                                        <td><input class="form-control form-control-sm" name="Name" value="@priceType.Name" required /></td>
                                                        <td>
                                                            <input type="checkbox" name="IsActive" value="true" @(priceType.IsActive ? "checked" : null) />
                                                            <input type="hidden" name="IsActive" value="false" />
                                                        </td>
                                                        <td class="text-right">
                                                            <button class="btn btn-outline-primary btn-xs" type="submit">ذخیره</button>
                                                        </td>
                                                    </form>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="price-channels-tab" role="tabpanel">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title mb-3">کانال قیمت</h5>
                                <form asp-action="CreatePriceChannel" method="post" data-loading-form>
                                    @Html.AntiForgeryToken()
                                    <div class="form-row">
                                        <div class="form-group col-md-4">
                                            <label>کد</label>
                                            <input class="form-control" name="Code" placeholder="Web / Store / Partner" />
                                        </div>
                                        <div class="form-group col-md-5">
                                            <label>عنوان</label>
                                            <input class="form-control" name="Name" placeholder="سایت" required />
                                        </div>
                                        <div class="form-group col-md-3 d-flex align-items-end">
                                            <button class="btn btn-primary btn-block" type="submit">ثبت کانال قیمت</button>
                                        </div>
                                    </div>
                                </form>

                                <div class="table-responsive mt-3">
                                    <table class="table table-sm table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th>کد</th>
                                                <th>عنوان</th>
                                                <th>فعال</th>
                                                <th class="text-right">عملیات</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var channel in Model.PriceChannels.Items)
                                            {
                                                <tr>
                                                    <form asp-action="UpdatePriceChannel" asp-route-id="@channel.PriceChannelBusinessKey" method="post" data-loading-form>
                                                        @Html.AntiForgeryToken()
                                                        <td><input class="form-control form-control-sm" name="Code" value="@channel.Code" /></td>
                                                        <td><input class="form-control form-control-sm" name="Name" value="@channel.Name" required /></td>
                                                        <td>
                                                            <input type="checkbox" name="IsActive" value="true" @(channel.IsActive ? "checked" : null) />
                                                            <input type="hidden" name="IsActive" value="false" />
                                                        </td>
                                                        <td class="text-right">
                                                            <button class="btn btn-outline-primary btn-xs" type="submit">ذخیره</button>
                                                        </td>
                                                    </form>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        (function () {
            var activeItemId = '@(ViewBag.ActiveItemId ?? "variant_prices")';
            var activeItemTab = document.querySelector('#pricing-management-tabs .nav-link[data-item-id="' + activeItemId + '"]');
            if (activeItemTab && window.jQuery) {
                window.jQuery(activeItemTab).tab('show');
            }

            var bucketSelect = document.getElementById('variant-price-bucket');
            var sellerInput = document.getElementById('variant-price-seller-ref');
            var variantInput = document.getElementById('variant-price-variant-ref');
            if (!bucketSelect || !sellerInput || !variantInput) {
                return;
            }

            bucketSelect.addEventListener('change', function () {
                var parts = (bucketSelect.value || '').split('|');
                sellerInput.value = parts.length === 2 ? parts[0] : '';
                variantInput.value = parts.length === 2 ? parts[1] : '';
            });
        })();
    </script>
}
