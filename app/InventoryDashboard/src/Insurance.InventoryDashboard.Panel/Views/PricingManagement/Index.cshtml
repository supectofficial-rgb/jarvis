@model Insurance.InventoryDashboard.Panel.Models.PricingPageViewModel
@{
    ViewData["Title"] = "مدیریت قیمت";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;

    var priceTypeNames = Model.PriceTypeLookup.ToDictionary(x => x.PriceTypeBusinessKey, x => $"{x.Name} ({x.Code})");
    var priceChannelNames = Model.PriceChannelLookup.ToDictionary(x => x.PriceChannelBusinessKey, x => $"{x.Name} ({x.Code})");
    var ownerSellerTitle = Model.OwnerSeller is null
        ? "ثبت نشده"
        : $"{Model.OwnerSeller.Name} ({Model.OwnerSeller.Code})";
}

<main id="pricing-management-page" class="catalog-page">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h1>مدیریت قیمت</h1>
                <p class="text-muted">قیمت‌گذاری ثابت برای واریانت‌های انتخاب‌شده فقط روی Seller Owner انجام می‌شود.</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert alert-success">@Model.StatusMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <div class="row">
            <div class="col-12 mb-4">
                <ul class="nav nav-tabs separator-tabs ml-0 mb-4 d-none" role="tablist" id="pricing-management-tabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-item-id="variant_prices" data-toggle="tab" href="#variant-prices-tab" role="tab">قیمت‌گذاری واریانت</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-item-id="price_types" data-toggle="tab" href="#price-types-tab" role="tab">نوع قیمت</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-item-id="price_channels" data-toggle="tab" href="#price-channels-tab" role="tab">کانال قیمت</a>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="variant-prices-tab" role="tabpanel">
                        <div class="card mb-4">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start flex-wrap mb-3">
                                    <div>
                                        <h5 class="card-title mb-1">Seller Owner</h5>
                                        <p class="text-muted mb-0">@ownerSellerTitle</p>
                                    </div>
                                    @if (Model.OwnerSeller is not null)
                                    {
                                        <span class="badge badge-success">فعال</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">الزامی</span>
                                    }
                                </div>

                                <form method="get" asp-action="VariantPrices" class="mb-4">
                                    <div class="form-row align-items-end">
                                        <div class="form-group col-lg-4 col-md-6">
                                            <label>جستجوی واریانت</label>
                                            <input name="variantSearchTerm" value="@Model.VariantSearchTerm" class="form-control" placeholder="SKU یا بارکد" />
                                        </div>
                                        <div class="form-group col-lg-2 col-md-3">
                                            <button class="btn btn-outline-primary btn-block" type="submit">جستجو</button>
                                        </div>
                                    </div>
                                </form>

                                @if (Model.OwnerSeller is not null)
                                {
                                    <form asp-action="ApplyVariantPricing" method="post" data-loading-form>
                                        @Html.AntiForgeryToken()
                                        <div class="row">
                                            <div class="col-xl-7">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <h6 class="mb-0">واریانت‌های قابل انتخاب</h6>
                                                    <button class="btn btn-link btn-sm p-0" type="button" id="toggle-all-variants">انتخاب / لغو همه</button>
                                                </div>
                                                <div class="table-responsive mb-3">
                                                    <table class="table table-sm table-striped">
                                                        <thead>
                                                            <tr>
                                                                <th style="width: 48px;"></th>
                                                                <th>SKU</th>
                                                                <th>بارکد</th>
                                                                <th>واحد</th>
                                                                <th>شناسه محصول</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @if (Model.VariantSearchResult.Items.Count == 0)
                                                            {
                                                                <tr>
                                                                    <td colspan="5" class="text-center text-muted">واریانتی پیدا نشد.</td>
                                                                </tr>
                                                            }
                                                            else
                                                            {
                                                                @foreach (var variant in Model.VariantSearchResult.Items)
                                                                {
                                                                    <tr>
                                                                        <td>
                                                                            <input type="checkbox"
                                                                                   class="js-variant-checkbox"
                                                                                   name="SelectedVariantRefs"
                                                                                   value="@variant.Id" />
                                                                        </td>
                                                                        <td><span class="text-monospace">@variant.Sku</span></td>
                                                                        <td>@(string.IsNullOrWhiteSpace(variant.Barcode) ? "-" : variant.Barcode)</td>
                                                                        <td>@variant.BaseUomRef</td>
                                                                        <td><span class="text-monospace">@variant.ProductId</span></td>
                                                                    </tr>
                                                                }
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>

                                            <div class="col-xl-5">
                                                <h6 class="mb-3">قیمت ثابت برای ترکیب نوع قیمت و کانال</h6>
                                                <div class="form-row">
                                                    <div class="form-group col-md-4">
                                                        <label>مبلغ برای همه</label>
                                                        <input name="ApplyToAllAmount" class="form-control" type="number" min="0" step="0.01" value="@(Model.BulkPricingForm.ApplyToAllAmount?.ToString() ?? string.Empty)" />
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        <label>ارز</label>
                                                        <input name="Currency" class="form-control" maxlength="8" value="@Model.BulkPricingForm.Currency" />
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        <label>حداقل تعداد</label>
                                                        <input name="MinQty" class="form-control" type="number" min="1" step="0.01" value="@Model.BulkPricingForm.MinQty" />
                                                    </div>
                                                </div>
                                                <div class="form-row">
                                                    <div class="form-group col-md-4">
                                                        <label>اولویت</label>
                                                        <input name="Priority" class="form-control" type="number" value="@Model.BulkPricingForm.Priority" />
                                                    </div>
                                                </div>

                                                <div class="table-responsive">
                                                    <table class="table table-sm table-bordered">
                                                        <thead>
                                                            <tr>
                                                                <th>نوع قیمت</th>
                                                                <th>کانال</th>
                                                                <th>مبلغ</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @for (var i = 0; i < Model.BulkPricingForm.Prices.Count; i++)
                                                            {
                                                                var price = Model.BulkPricingForm.Prices[i];
                                                                <tr>
                                                                    <td>
                                                                        <input type="hidden" name="Prices[@i].PriceTypeRef" value="@price.PriceTypeRef" />
                                                                        @(priceTypeNames.TryGetValue(price.PriceTypeRef, out var priceTypeName) ? priceTypeName : price.PriceTypeRef.ToString("D"))
                                                                    </td>
                                                                    <td>
                                                                        <input type="hidden" name="Prices[@i].PriceChannelRef" value="@price.PriceChannelRef" />
                                                                        @(priceChannelNames.TryGetValue(price.PriceChannelRef, out var channelName) ? channelName : price.PriceChannelRef.ToString("D"))
                                                                    </td>
                                                                    <td>
                                                                        <input class="form-control form-control-sm" name="Prices[@i].Amount" type="number" min="0" step="0.01" value="@(price.Amount?.ToString() ?? string.Empty)" />
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>

                                                <button class="btn btn-primary mt-3" type="submit">اعمال قیمت روی واریانت‌های انتخاب‌شده</button>
                                            </div>
                                        </div>
                                    </form>
                                }
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">قیمت‌های ثبت‌شده برای Seller Owner</h5>
                                <div class="table-responsive">
                                    <table class="table table-sm table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th>واریانت</th>
                                                <th>نوع قیمت</th>
                                                <th>کانال</th>
                                                <th>قیمت</th>
                                                <th>فعال</th>
                                                <th class="text-right">عملیات</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model.VariantPrices.Items.Count == 0)
                                            {
                                                <tr>
                                                    <td colspan="6" class="text-center text-muted">هنوز قیمتی برای Seller Owner ثبت نشده است.</td>
                                                </tr>
                                            }
                                            @foreach (var price in Model.VariantPrices.Items)
                                            {
                                                <tr>
                                                    <form asp-action="UpdateVariantPrice" asp-route-id="@price.SellerVariantPriceBusinessKey" method="post" data-loading-form>
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="SellerRef" value="@price.SellerRef" />
                                                        <input type="hidden" name="VariantRef" value="@price.VariantRef" />
                                                        <input type="hidden" name="PriceTypeRef" value="@price.PriceTypeRef" />
                                                        <input type="hidden" name="PriceChannelRef" value="@price.PriceChannelRef" />
                                                        <input type="hidden" name="Currency" value="@price.Currency" />
                                                        <input type="hidden" name="MinQty" value="@price.MinQty" />
                                                        <input type="hidden" name="Priority" value="@price.Priority" />
                                                        <td><span class="text-monospace">@price.VariantRef.ToString("D")</span></td>
                                                        <td>@(priceTypeNames.TryGetValue(price.PriceTypeRef, out var type) ? type : price.PriceTypeRef.ToString("D"))</td>
                                                        <td>@(priceChannelNames.TryGetValue(price.PriceChannelRef, out var channel) ? channel : price.PriceChannelRef.ToString("D"))</td>
                                                        <td><input class="form-control form-control-sm" name="Amount" type="number" min="1" step="0.01" value="@price.Amount" /></td>
                                                        <td>
                                                            <input type="checkbox" name="IsActive" value="true" @(price.IsActive ? "checked" : null) />
                                                            <input type="hidden" name="IsActive" value="false" />
                                                        </td>
                                                        <td class="text-right">
                                                            <button class="btn btn-outline-primary btn-xs" type="submit">ذخیره</button>
                                                        </td>
                                                    </form>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="price-types-tab" role="tabpanel">
                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">نوع قیمت</h5>
                                <form asp-action="CreatePriceType" method="post" data-loading-form>
                                    @Html.AntiForgeryToken()
                                    <div class="form-row">
                                        <div class="form-group col-md-4">
                                            <label>کد</label>
                                            <input class="form-control" name="Code" placeholder="Retail / Wholesale" />
                                        </div>
                                        <div class="form-group col-md-5">
                                            <label>عنوان</label>
                                            <input class="form-control" name="Name" placeholder="فروش عادی" required />
                                        </div>
                                        <div class="form-group col-md-3 d-flex align-items-end">
                                            <button class="btn btn-primary btn-block" type="submit">ثبت نوع قیمت</button>
                                        </div>
                                    </div>
                                </form>

                                <div class="table-responsive mt-3">
                                    <table class="table table-sm table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th>کد</th>
                                                <th>عنوان</th>
                                                <th>فعال</th>
                                                <th class="text-right">عملیات</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var priceType in Model.PriceTypes.Items)
                                            {
                                                <tr>
                                                    <form asp-action="UpdatePriceType" asp-route-id="@priceType.PriceTypeBusinessKey" method="post" data-loading-form>
                                                        @Html.AntiForgeryToken()
                                                        <td><input class="form-control form-control-sm" name="Code" value="@priceType.Code" /></td>
                                                        <td><input class="form-control form-control-sm" name="Name" value="@priceType.Name" required /></td>
                                                        <td>
                                                            <input type="checkbox" name="IsActive" value="true" @(priceType.IsActive ? "checked" : null) />
                                                            <input type="hidden" name="IsActive" value="false" />
                                                        </td>
                                                        <td class="text-right">
                                                            <button class="btn btn-outline-primary btn-xs" type="submit">ذخیره</button>
                                                        </td>
                                                    </form>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="price-channels-tab" role="tabpanel">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title mb-3">کانال قیمت</h5>
                                <form asp-action="CreatePriceChannel" method="post" data-loading-form>
                                    @Html.AntiForgeryToken()
                                    <div class="form-row">
                                        <div class="form-group col-md-4">
                                            <label>کد</label>
                                            <input class="form-control" name="Code" placeholder="Web / Store / Partner" />
                                        </div>
                                        <div class="form-group col-md-5">
                                            <label>عنوان</label>
                                            <input class="form-control" name="Name" placeholder="سایت" required />
                                        </div>
                                        <div class="form-group col-md-3 d-flex align-items-end">
                                            <button class="btn btn-primary btn-block" type="submit">ثبت کانال قیمت</button>
                                        </div>
                                    </div>
                                </form>

                                <div class="table-responsive mt-3">
                                    <table class="table table-sm table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th>کد</th>
                                                <th>عنوان</th>
                                                <th>فعال</th>
                                                <th class="text-right">عملیات</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var channel in Model.PriceChannels.Items)
                                            {
                                                <tr>
                                                    <form asp-action="UpdatePriceChannel" asp-route-id="@channel.PriceChannelBusinessKey" method="post" data-loading-form>
                                                        @Html.AntiForgeryToken()
                                                        <td><input class="form-control form-control-sm" name="Code" value="@channel.Code" /></td>
                                                        <td><input class="form-control form-control-sm" name="Name" value="@channel.Name" required /></td>
                                                        <td>
                                                            <input type="checkbox" name="IsActive" value="true" @(channel.IsActive ? "checked" : null) />
                                                            <input type="hidden" name="IsActive" value="false" />
                                                        </td>
                                                        <td class="text-right">
                                                            <button class="btn btn-outline-primary btn-xs" type="submit">ذخیره</button>
                                                        </td>
                                                    </form>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        (function () {
            var activeItemId = '@(ViewBag.ActiveItemId ?? "variant_prices")';
            var activeItemTab = document.querySelector('#pricing-management-tabs .nav-link[data-item-id="' + activeItemId + '"]');
            if (activeItemTab && window.jQuery) {
                window.jQuery(activeItemTab).tab('show');
            }

            var toggleAllButton = document.getElementById('toggle-all-variants');
            if (!toggleAllButton) {
                return;
            }

            toggleAllButton.addEventListener('click', function () {
                var checkboxes = Array.prototype.slice.call(document.querySelectorAll('.js-variant-checkbox'));
                var shouldCheck = checkboxes.some(function (checkbox) { return !checkbox.checked; });
                checkboxes.forEach(function (checkbox) {
                    checkbox.checked = shouldCheck;
                });
            });
        })();
    </script>
}
