@model Insurance.InventoryDashboard.Panel.Models.DashboardViewModel
@{
    ViewData["Title"] = "مدیریت قیمت";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserDisplayName = Model.UserName;
    ViewBag.MenuModules = Model.Modules;
    ViewBag.ActiveModuleId = Model.ActiveModule?.ModuleId;
    ViewBag.ActiveItemId = Model.ActiveItem?.ItemId;
}

<main id="pricing-management-page" class="catalog-page">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h1>مدیریت قیمت</h1>
                <p class="text-muted">تعریف نوع قیمت، کانال قیمت و قیمت‌گذاری واریانت‌هایی که بالانس قابل فروش دارند.</p>
            </div>
        </div>

        <div class="row">
            <div class="col-12 mb-4">
                <ul class="nav nav-tabs separator-tabs ml-0 mb-4" role="tablist" id="pricing-management-tabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-item-id="variant_prices" data-toggle="tab" href="#variant-prices-tab" role="tab">قیمت‌گذاری واریانت</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-item-id="price_types" data-toggle="tab" href="#price-types-tab" role="tab">نوع قیمت</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-item-id="price_channels" data-toggle="tab" href="#price-channels-tab" role="tab">کانال قیمت</a>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="variant-prices-tab" role="tabpanel">
                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">قیمت‌گذاری واریانت‌های دارای بالانس</h5>
                                <div class="form-row">
                                    <div class="form-group col-lg-3 col-md-6">
                                        <label>جستجوی واریانت</label>
                                        <input id="price-variant-search" class="form-control" placeholder="کد، SKU، بارکد یا نام محصول..." />
                                    </div>
                                    <div class="form-group col-lg-2 col-md-6">
                                        <label>نوع قیمت</label>
                                        <select class="form-control">
                                            <option>فروش عادی</option>
                                            <option>عمده</option>
                                            <option>همکار</option>
                                        </select>
                                    </div>
                                    <div class="form-group col-lg-2 col-md-6">
                                        <label>کانال</label>
                                        <select class="form-control">
                                            <option>سایت</option>
                                            <option>حضوری</option>
                                            <option>نماینده</option>
                                        </select>
                                    </div>
                                    <div class="form-group col-lg-2 col-md-6">
                                        <label>قیمت</label>
                                        <input id="variant-price-amount" class="form-control" type="number" min="0" placeholder="0" />
                                    </div>
                                    <div class="form-group col-lg-3 col-md-12">
                                        <label>تامین‌کننده</label>
                                        <input class="form-control" value="مالک سیستم (Owner Seller)" readonly />
                                    </div>
                                </div>

                                <div class="alert alert-light">
                                    لیست نهایی باید از بالانس‌های باز انبار خوانده شود تا فقط واریانت‌هایی قیمت بگیرند که موجودی قابل فروش دارند.
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-sm table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th>واریانت</th>
                                                <th>بالانس</th>
                                                <th>نوع قیمت</th>
                                                <th>کانال</th>
                                                <th>قیمت</th>
                                                <th class="text-right">عملیات</th>
                                            </tr>
                                        </thead>
                                        <tbody id="variant-price-lines">
                                            <tr data-empty-row>
                                                <td colspan="6" class="text-center text-muted">هنوز قیمت جدیدی برای واریانت انتخاب نشده است.</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <div class="mt-3">
                                    <button id="add-variant-price" class="btn btn-primary" type="button">افزودن قیمت</button>
                                    <button class="btn btn-outline-primary" type="button" disabled>ثبت نهایی قیمت‌ها</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="price-types-tab" role="tabpanel">
                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">نوع قیمت</h5>
                                <div class="form-row">
                                    <div class="form-group col-md-4">
                                        <label>کد</label>
                                        <input class="form-control" placeholder="Retail / Wholesale" />
                                    </div>
                                    <div class="form-group col-md-4">
                                        <label>عنوان</label>
                                        <input class="form-control" placeholder="فروش عادی" />
                                    </div>
                                    <div class="form-group col-md-4 d-flex align-items-end">
                                        <button class="btn btn-primary btn-block" type="button" disabled>ثبت نوع قیمت</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="price-channels-tab" role="tabpanel">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title mb-3">کانال قیمت</h5>
                                <div class="form-row">
                                    <div class="form-group col-md-4">
                                        <label>کد</label>
                                        <input class="form-control" placeholder="Web / Store / Partner" />
                                    </div>
                                    <div class="form-group col-md-4">
                                        <label>عنوان</label>
                                        <input class="form-control" placeholder="سایت" />
                                    </div>
                                    <div class="form-group col-md-4 d-flex align-items-end">
                                        <button class="btn btn-primary btn-block" type="button" disabled>ثبت کانال قیمت</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        (function () {
            var activeItemId = '@(ViewBag.ActiveItemId ?? "variant_prices")';
            var activeItemTab = document.querySelector('#pricing-management-tabs .nav-link[data-item-id="' + activeItemId + '"]');
            if (activeItemTab && window.jQuery) {
                window.jQuery(activeItemTab).tab('show');
            }

            var addButton = document.getElementById('add-variant-price');
            var variantSearch = document.getElementById('price-variant-search');
            var priceAmount = document.getElementById('variant-price-amount');
            var linesBody = document.getElementById('variant-price-lines');

            addButton.addEventListener('click', function () {
                var variantText = (variantSearch.value || '').trim();
                if (!variantText) {
                    variantSearch.focus();
                    return;
                }

                var emptyRow = linesBody.querySelector('[data-empty-row]');
                if (emptyRow) {
                    emptyRow.remove();
                }

                var amount = Math.max(parseFloat(priceAmount.value || '0'), 0);
                var row = document.createElement('tr');
                row.innerHTML =
                    '<td>' + variantText + '</td>' +
                    '<td>دارای بالانس</td>' +
                    '<td>فروش عادی</td>' +
                    '<td>سایت</td>' +
                    '<td>' + amount + '</td>' +
                    '<td class="text-right"><button class="btn btn-outline-danger btn-xs" type="button">حذف</button></td>';
                row.querySelector('button').addEventListener('click', function () {
                    row.remove();
                    if (!linesBody.children.length) {
                        linesBody.innerHTML = '<tr data-empty-row><td colspan="6" class="text-center text-muted">هنوز قیمت جدیدی برای واریانت انتخاب نشده است.</td></tr>';
                    }
                });

                linesBody.appendChild(row);
                variantSearch.value = '';
                priceAmount.value = '';
                variantSearch.focus();
            });
        })();
    </script>
}
