@using System
@using System.Text.Json
@using Insurance.InventoryDashboard.Panel.Models
@using Insurance.InventoryDashboard.Panel.Services.Localization
@{
    var userDisplayName = ViewBag.UserDisplayName as string ?? UiText["common.user"];
    var menuModules = ViewBag.MenuModules as IReadOnlyList<DashboardMenuModule> ?? Array.Empty<DashboardMenuModule>();
    var activeModuleId = ViewBag.ActiveModuleId as string;
    var activeItemId = ViewBag.ActiveItemId as string;
}
<!DOCTYPE html>
<html lang="@UiText.Language" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <title>@ViewData["Title"] - @UiText["app.title"]</title>
    <link rel="shortcut icon" href="@Url.Content("~/favicon.ico")" />

    <link rel="stylesheet" href="@Url.Content("~/font/iconsmind-s/css/iconsminds.css")" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/font/simple-line-icons/css/simple-line-icons.css")" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/css/vendor/bootstrap.min.css")" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/css/vendor/bootstrap.rtl.only.min.css")" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/css/vendor/perfect-scrollbar.css")" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/css/vendor/component-custom-switch.min.css")" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/css/vendor/select2.min.css")" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/css/vendor/select2-bootstrap.min.css")" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/css/vendor/bootstrap-datepicker3.min.css")" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/css/dore.light.bluenavy.min.css")" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/css/main.css")" asp-append-version="true" />
</head>
<body id="app-container" class="menu-default show-spinner">
    <nav class="navbar fixed-top">
        <div class="d-flex align-items-center navbar-left">
            <a href="#" class="menu-button d-none d-md-block">
                <svg class="main" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 9 17">
                    <rect x="0.48" y="0.5" width="7" height="1" />
                    <rect x="0.48" y="7.5" width="7" height="1" />
                    <rect x="0.48" y="15.5" width="7" height="1" />
                </svg>
                <svg class="sub" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 17">
                    <rect x="1.56" y="0.5" width="16" height="1" />
                    <rect x="1.56" y="7.5" width="16" height="1" />
                    <rect x="1.56" y="15.5" width="16" height="1" />
                </svg>
            </a>

            <a href="#" class="menu-button-mobile d-xs-block d-sm-block d-md-none">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 26 17">
                    <rect x="0.5" y="0.5" width="25" height="1" />
                    <rect x="0.5" y="7.5" width="25" height="1" />
                    <rect x="0.5" y="15.5" width="25" height="1" />
                </svg>
            </a>

            <a class="btn btn-sm btn-outline-primary mr-3 d-none d-md-inline-block"
               asp-controller="Dashboard"
               asp-action="Index">
                @UiText["layout.managementPanel"]
            </a>
        </div>

        <a class="navbar-logo" asp-controller="Dashboard" asp-action="Index">
            <span class="logo d-none d-xs-block"></span>
            <span class="logo-mobile d-block d-xs-none"></span>
        </a>

        <div class="navbar-right">
            <div class="user d-inline-block">
                <button class="btn btn-empty p-0" type="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <span class="name">@userDisplayName</span>
                    <span>
                        <img alt="@UiText["layout.profileAlt"]" src="@Url.Content("~/img/profiles/l-1.jpg")" />
                    </span>
                </button>
                <div class="dropdown-menu dropdown-menu-right mt-3">
                    <span class="dropdown-item disabled">@userDisplayName</span>
                    <div class="dropdown-divider"></div>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="px-3 py-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm btn-block">@UiText["layout.logout"]</button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <div class="menu">
        <div class="main-menu">
            <div class="scroll">
                <ul class="list-unstyled">
                    @for (var i = 0; i < menuModules.Count; i++)
                    {
                        var module = menuModules[i];
                        var isActive = module.IsEnabled &&
                                       (string.Equals(module.ModuleId, activeModuleId, StringComparison.OrdinalIgnoreCase)
                                        || (string.IsNullOrWhiteSpace(activeModuleId) && i == 0));

                        <li class="@(!module.IsEnabled ? "disabled-menu" : isActive ? "active" : null)">
                            <a href="#@module.ModuleId">
                                <i class="@module.Icon"></i>
                                <span>@module.Title @(module.IsEnabled ? string.Empty : UiText["layout.inactiveSuffix"])</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="sub-menu">
            <div class="scroll">
                @for (var i = 0; i < menuModules.Count; i++)
                {
                    var module = menuModules[i];
                    var isActiveModule = module.IsEnabled &&
                                         (string.Equals(module.ModuleId, activeModuleId, StringComparison.OrdinalIgnoreCase)
                                          || (string.IsNullOrWhiteSpace(activeModuleId) && i == 0));

                    <ul class="list-unstyled @(isActiveModule ? "d-block" : null)" data-link="@module.ModuleId">
                        @for (var j = 0; j < module.Items.Count; j++)
                        {
                            var menuItem = module.Items[j];
                            var hasActiveChild = menuItem.Children.Any(child => string.Equals(child.ItemId, activeItemId, StringComparison.OrdinalIgnoreCase));
                            var isActiveItem = module.IsEnabled &&
                                               menuItem.IsEnabled &&
                                               (string.Equals(menuItem.ItemId, activeItemId, StringComparison.OrdinalIgnoreCase)
                                                || hasActiveChild
                                                || (string.IsNullOrWhiteSpace(activeItemId) && isActiveModule && j == 0));

                            <li class="@(!menuItem.IsEnabled || !module.IsEnabled ? "disabled-menu" : isActiveItem ? "active" : null)">
                                @if (module.IsEnabled && menuItem.IsEnabled)
                                {
                                    if (!string.IsNullOrWhiteSpace(menuItem.Route))
                                    {
                                        <a href="@menuItem.Route">
                                            <i class="@menuItem.Icon"></i>
                                            <span class="d-inline-block">@menuItem.Title</span>
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Dashboard"
                                           asp-action="Index"
                                           asp-route-module="@module.ModuleId"
                                           asp-route-item="@menuItem.ItemId">
                                            <i class="@menuItem.Icon"></i>
                                            <span class="d-inline-block">@menuItem.Title</span>
                                        </a>
                                    }
                                }
                                else
                                {
                                    <a href="javascript:void(0)">
                                        <i class="@menuItem.Icon"></i>
                                        <span class="d-inline-block">@menuItem.Title</span>
                                    </a>
                                }
                                @if (menuItem.Children.Count > 0)
                                {
                                    <ul class="list-unstyled pl-4 mt-2">
                                        @for (var k = 0; k < menuItem.Children.Count; k++)
                                        {
                                            var childItem = menuItem.Children[k];
                                            var isChildActive = childItem.IsEnabled &&
                                                                (string.Equals(childItem.ItemId, activeItemId, StringComparison.OrdinalIgnoreCase)
                                                                 || (string.IsNullOrWhiteSpace(activeItemId) && hasActiveChild && k == 0));

                                            <li class="@(!childItem.IsEnabled ? "disabled-menu" : isChildActive ? "active" : null)">
                                                @if (childItem.IsEnabled)
                                                {
                                                    if (!string.IsNullOrWhiteSpace(childItem.Route))
                                                    {
                                                        <a href="@childItem.Route">
                                                            <i class="@childItem.Icon"></i>
                                                            <span class="d-inline-block">@childItem.Title</span>
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <a href="javascript:void(0)">
                                                            <i class="@childItem.Icon"></i>
                                                            <span class="d-inline-block">@childItem.Title</span>
                                                        </a>
                                                    }
                                                }
                                                else
                                                {
                                                    <a href="javascript:void(0)">
                                                        <i class="@childItem.Icon"></i>
                                                        <span class="d-inline-block">@childItem.Title</span>
                                                    </a>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    @RenderBody()

    <div class="modal fade" id="globalConfirmModal" tabindex="-1" role="dialog" aria-labelledby="globalConfirmModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="globalConfirmModalLabel">@UiText["layout.confirmOperation"]</h5>
                    <button type="button" class="close p-0" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <p class="mb-0" id="globalConfirmModalMessage">@UiText["layout.confirmMessage"]</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">@UiText["common.cancel"]</button>
                    <button type="button" class="btn btn-danger" id="globalConfirmModalAccept">@UiText["common.confirm"]</button>
                </div>
            </div>
        </div>
    </div>

    <script src="@Url.Content("~/js/vendor/jquery-3.3.1.min.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/vendor/bootstrap.bundle.min.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/vendor/select2.full.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/vendor/bootstrap-datepicker.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/vendor/bootstrap-datepicker.fa.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/vendor/perfect-scrollbar.min.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/vendor/mousetrap.min.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/dore.script.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/scripts.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/inventory-dashboard.ui.js")" asp-append-version="true"></script>
    <script>
        window.appUi = {
            language: @Html.Raw(JsonSerializer.Serialize(UiText.Language)),
            text: @Html.Raw(UiText.ToClientDictionaryJson())
        };
    </script>
    <script>
        (function () {
            function showOnlySubMenu(moduleId) {
                document.querySelectorAll('.sub-menu ul[data-link]').forEach(function (list) {
                    var isTarget = list.getAttribute('data-link') === moduleId;
                    list.classList.toggle('d-block', isTarget);
                    list.style.display = isTarget ? 'block' : 'none';
                });
            }

            document.querySelectorAll('.main-menu a[href^="#"]').forEach(function (link) {
                link.addEventListener('click', function () {
                    var moduleId = (link.getAttribute('href') || '').replace(/^#/, '');
                    if (moduleId) {
                        showOnlySubMenu(moduleId);
                    }
                });
            });

            var activeList = document.querySelector('.sub-menu ul.d-block[data-link]');
            if (activeList) {
                showOnlySubMenu(activeList.getAttribute('data-link'));
            }
        })();
    </script>
    <script>
        (function () {
            var modalElement = document.getElementById('globalConfirmModal');
            var titleElement = document.getElementById('globalConfirmModalLabel');
            var messageElement = document.getElementById('globalConfirmModalMessage');
            var confirmButton = document.getElementById('globalConfirmModalAccept');
            if (!modalElement || !titleElement || !messageElement || !confirmButton) {
                return;
            }

            var modal = null;
            var useBootstrap5 = typeof bootstrap !== 'undefined' && bootstrap.Modal;
            var useBootstrap4 = !useBootstrap5 && typeof window.jQuery !== 'undefined' && typeof window.jQuery.fn.modal === 'function';

            if (useBootstrap5) {
                modal = new bootstrap.Modal(modalElement);
            }

            var pending = null;

            function getSubmitter(event) {
                return event.submitter || document.activeElement;
            }

            function disableSubmitButtons(form) {
                form.querySelectorAll('button[type="submit"]').forEach(function (button) {
                    button.setAttribute('disabled', 'disabled');
                });
            }

            document.addEventListener('submit', function (event) {
                var form = event.target;
                if (!(form instanceof HTMLFormElement) || !form.matches('form[data-loading-form]')) {
                    return;
                }

                if (form.dataset.confirmBypass === 'true') {
                    delete form.dataset.confirmBypass;
                    return;
                }

                var submitter = getSubmitter(event);
                var confirmText = submitter && submitter.getAttribute
                    ? submitter.getAttribute('data-confirm')
                    : null;
                var confirmTitle = submitter && submitter.getAttribute
                    ? submitter.getAttribute('data-confirm-title')
                    : null;

                if (confirmText) {
                    event.preventDefault();
                    pending = { form: form, submitter: submitter };
                    titleElement.textContent = confirmTitle && confirmTitle.trim()
                        ? confirmTitle
                        : @Html.Raw(JsonSerializer.Serialize(UiText["layout.confirmOperation"]));
                    messageElement.textContent = confirmText;

                    if (useBootstrap5) {
                        modal.show();
                    } else if (useBootstrap4) {
                        window.jQuery(modalElement).modal('show');
                    } else {
                        if (window.confirm(confirmText)) {
                            form.dataset.confirmBypass = 'true';
                            form.requestSubmit(submitter instanceof HTMLElement ? submitter : undefined);
                        }
                        pending = null;
                    }
                    return;
                }

                disableSubmitButtons(form);
            }, true);

            confirmButton.addEventListener('click', function () {
                if (!pending) {
                    return;
                }

                var form = pending.form;
                var submitter = pending.submitter;
                form.dataset.confirmBypass = 'true';
                if (useBootstrap5) {
                    modal.hide();
                } else if (useBootstrap4) {
                    window.jQuery(modalElement).modal('hide');
                }
                form.requestSubmit(submitter instanceof HTMLElement ? submitter : undefined);
                pending = null;
            });

            if (useBootstrap5) {
                modalElement.addEventListener('hidden.bs.modal', function () {
                    pending = null;
                });
            } else if (useBootstrap4) {
                window.jQuery(modalElement).on('hidden.bs.modal', function () {
                    pending = null;
                });
            }
        })();
    </script>
    <script>
        (function () {
            function getTargetSelector(element) {
                return element && element.getAttribute ? element.getAttribute('data-ajax-target') : null;
            }

            function refreshWidgets(root) {
                if (!window.appUi) {
                    return;
                }

                if (typeof window.appUi.initSearchableSelects === 'function') {
                    window.appUi.initSearchableSelects(root);
                }

                if (typeof window.appUi.initDatePickers === 'function') {
                    window.appUi.initDatePickers(root);
                }

                if (typeof window.appUi.initAutoSubmit === 'function') {
                    window.appUi.initAutoSubmit(root);
                }

                if (typeof window.appUi.initBulkActions === 'function') {
                    window.appUi.initBulkActions(root);
                }

                if (typeof window.appUi.initInventoryManagementPage === 'function') {
                    window.appUi.initInventoryManagementPage(root);
                }
            }

            function replaceTargetFromHtml(targetSelector, html) {
                if (!targetSelector) {
                    return false;
                }

                var parser = new DOMParser();
                var doc = parser.parseFromString(html, 'text/html');
                var nextRoot = doc.querySelector(targetSelector);
                var currentRoot = document.querySelector(targetSelector);
                if (!nextRoot || !currentRoot) {
                    return false;
                }

                currentRoot.replaceWith(nextRoot);
                refreshWidgets(nextRoot);
                doc.querySelectorAll('script[data-ajax-reinit]').forEach(function (script) {
                    if (script.src) {
                        return;
                    }

                    var scriptType = (script.getAttribute('type') || '').toLowerCase();
                    if (scriptType && scriptType !== 'text/javascript' && scriptType !== 'application/javascript' && scriptType !== 'module') {
                        return;
                    }

                    var code = script.textContent || '';
                    if (!code.trim()) {
                        return;
                    }

                    try {
                        (new Function(code)).call(window);
                    } catch (error) {
                        console.error('Failed to execute refreshed script.', error);
                    }
                });
                return true;
            }

            function hideContainingModal(form) {
                if (!(form instanceof HTMLElement)) {
                    return;
                }

                var modalElement = form.closest('.modal');
                if (!modalElement) {
                    return;
                }

                if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                    var existing = bootstrap.Modal.getInstance(modalElement) || bootstrap.Modal.getOrCreateInstance(modalElement);
                    existing.hide();
                    return;
                }

                if (window.jQuery && window.jQuery.fn && window.jQuery.fn.modal) {
                    window.jQuery(modalElement).modal('hide');
                }
            }

            async function submitAjaxForm(form) {
                var targetSelector = getTargetSelector(form);
                if (!targetSelector) {
                    return;
                }

                var method = (form.getAttribute('method') || 'get').toUpperCase();
                var action = form.getAttribute('action') || window.location.href;
                var url = new URL(action, window.location.origin);
                var requestInit = {
                    method: method,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'text/html'
                    }
                };

                if (method === 'GET') {
                    var params = new URLSearchParams();
                    new FormData(form).forEach(function (value, key) {
                        if (value !== null && value !== undefined && String(value).trim() !== '') {
                            params.append(key, value);
                        }
                    });
                    var query = params.toString();
                    if (query) {
                        url.search = query;
                    }
                } else {
                    requestInit.body = new FormData(form);
                }

                var response = await fetch(url.toString(), requestInit);
                var html = await response.text();
                if (form.hasAttribute('data-ajax-close-modal-on-success')) {
                    hideContainingModal(form);
                }
                var refreshed = replaceTargetFromHtml(targetSelector, html);
                if (refreshed && response.url && form.getAttribute('data-ajax-preserve-url') !== 'true') {
                    try {
                        history.replaceState(null, '', response.url);
                    } catch (error) {
                        // Ignore history update failures.
                    }
                }

                if (!refreshed) {
                    window.location.href = response.url || url.toString();
                }
            }

            async function navigateAjax(link) {
                var targetSelector = getTargetSelector(link);
                if (!targetSelector) {
                    return;
                }

                var href = link.getAttribute('href');
                if (!href || href.indexOf('#') === 0) {
                    return;
                }

                var url = new URL(href, window.location.origin);
                var sourceForm = link.closest('.card') ? link.closest('.card').querySelector('form[data-loading-form][method="get"]') : null;
                if (sourceForm instanceof HTMLFormElement) {
                    new FormData(sourceForm).forEach(function (value, key) {
                        if (value === null || value === undefined || String(value).trim() === '') {
                            return;
                        }

                        if (!url.searchParams.has(key)) {
                            url.searchParams.append(key, value);
                        }
                    });
                }

                var response = await fetch(url.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'text/html'
                    }
                });
                var html = await response.text();
                var refreshed = replaceTargetFromHtml(targetSelector, html);
                if (refreshed && response.url) {
                    try {
                        history.replaceState(null, '', response.url);
                    } catch (error) {
                        // Ignore history update failures.
                    }
                }

                if (!refreshed) {
                    window.location.href = response.url || url.toString();
                }
            }

            document.addEventListener('submit', function (event) {
                var form = event.target;
                if (!(form instanceof HTMLFormElement) || !form.matches('form[data-ajax-target]')) {
                    return;
                }

                event.preventDefault();
                submitAjaxForm(form);
            }, true);

            document.addEventListener('click', function (event) {
                var link = event.target && event.target.closest ? event.target.closest('a[data-ajax-target]') : null;
                if (!(link instanceof HTMLAnchorElement)) {
                    return;
                }

                event.preventDefault();
                navigateAjax(link);
            }, true);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
