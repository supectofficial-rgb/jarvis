@model bool

@if (Model)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-warning mb-3" role="alert" aria-live="polite">
                <h6>برخی عملیات‌ها برای شما در دسترس نیست</h6>
                <p class="small mt-1 mb-0">
                    بخشی از دکمه‌ها یا فرم‌ها براساس سطح دسترسی شما غیرفعال شده‌اند.
                    اگر برای انجام کار به این دسترسی نیاز دارید، با مدیر سامانه یا تیم امنیت هماهنگ کنید.
                </p>
            </div>
        </div>
    </div>
}
