@model ErrorViewModel
@{
    ViewData["Title"] = UiText["error.title"];
}

<h1 class="text-danger">@UiText["error.header"]</h1>
<h2 class="text-danger">@UiText["error.requestProcessingError"]</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>@UiText["error.requestId"]</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>@UiText["error.developmentMode"]</h3>
<p>
    @Html.Raw(UiText["error.developmentDescription"])
</p>
<p>
    @Html.Raw(UiText["error.developmentWarning"])
</p>
