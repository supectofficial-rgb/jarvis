@using System
@using System.Linq
@model Insurance.InventoryDashboard.Panel.Models.VariantManagementPageViewModel
@{
    var permissionSet = Model.Permissions?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isAdmin = Model.Roles.Any(x =>
        string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x, "SysAdmin", StringComparison.OrdinalIgnoreCase));

    bool Can(params string[] names)
    {
        if (isAdmin || permissionSet.Count == 0 || permissionSet.Contains("*"))
        {
            return true;
        }

        return names.Any(permissionSet.Contains);
    }

}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="card-title mb-0">@UiText["catalog.variants.listTitle"]</h5>
    <span class="text-muted small">@Model.VariantTotalCount @UiText["catalog.variants.recordCountSuffix"]</span>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger mb-3">
        @Model.ErrorMessage
    </div>
}

<table class="table table-sm table-striped">
        <thead>
            <tr>
                <th><input type="checkbox" data-bulk-toggle aria-label='@UiText["catalog.variants.selectAll"]' /></th>
                <th>کد</th>
                <th>نام</th>
                <th>@UiText["catalog.variants.barcode"]</th>
                <th>@UiText["catalog.variants.baseUom"]</th>
                <th>@UiText["catalog.variants.trackingPolicy"]</th>
                <th>@UiText["common.status"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Variants.Count == 0)
            {
                <tr>
                    <td colspan="8">
                        <div class="alert alert-light my-2">
                            <h6>@UiText["catalog.variants.noVariantsFound"]</h6>
                            <p class="mb-0 text-muted">@UiText["catalog.variants.reviewFiltersOrCreate"]</p>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                foreach (var variant in Model.Variants)
                {
                    <tr>
                        <td><input type="checkbox" data-bulk-row value="@variant.Id" aria-label='@string.Format(UiText["catalog.variants.rowRequiredFormat"], variant.Sku)' /></td>
                        <td><span class="text-monospace">@variant.Sku</span></td>
                        <td>@(string.IsNullOrWhiteSpace(variant.Name) ? "-" : variant.Name)</td>
                        <td>@(string.IsNullOrWhiteSpace(variant.Barcode) ? "-" : $"#{variant.Barcode}")</td>
                        <td>@variant.BaseUom</td>
                        <td>@variant.TrackingPolicy</td>
                        <td class="variant-status-cell js-variant-status-cell">
                            <div class="d-flex flex-column align-items-start">
                                <form method="post"
                                      class="variant-status-toggle-form"
                                      data-variant-active-toggle-form
                                      data-activate-url="@Url.Action("ActivateVariant", "VariantManagement", new { productId = Model.SelectedProductId, variantId = variant.Id })"
                                      data-deactivate-url="@Url.Action("DeactivateVariant", "VariantManagement", new { productId = Model.SelectedProductId, variantId = variant.Id })">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                                    <input type="hidden" name="variantId" value="@variant.Id" />
                                    <div class="custom-control custom-switch">
                                        <input type="checkbox"
                                               class="custom-control-input js-variant-active-toggle"
                                               id="variant-active-toggle-@variant.Id"
                                               @(variant.IsActive ? "checked" : null)
                                               @(Can("Catalog.Variant.Activate", "ProductVariant.Activate", "Catalog.Variant.Deactivate", "ProductVariant.Deactivate") ? null : "disabled") />
                                        <label class="custom-control-label sr-only" for="variant-active-toggle-@variant.Id">
                                            @(variant.IsActive ? UiText["common.active"] : UiText["common.inactive"])
                                        </label>
                                    </div>
                                </form>
                                @if (variant.InventoryMovementLocked)
                                {
                                    <span class="badge badge-warning mt-2">@UiText["catalog.variants.locked"]</span>
                                }
                            </div>
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm flex-wrap">
                                <button type="button" class="btn btn-outline-info btn-xs js-variant-stock-details"
                                        data-toggle="modal"
                                        data-target="#variant-stock-modal"
                                        data-stock-url="@Url.Action("VariantStocks", "VariantManagement", new { variantId = variant.Id })"
                                        data-detail-title="@UiText["catalog.variants.inventoryAndWarehouses"]">
                                    @UiText["catalog.variants.warehousesButton"]
                                </button>
                                <button type="button"
                                        class="btn btn-outline-success btn-xs js-variant-movement-details"
                                        data-variant-id="@variant.Id"
                                        data-variant-label="@variant.Sku - @(string.IsNullOrWhiteSpace(variant.Name) ? variant.Sku : variant.Name)"
                                        data-detail-title="گردش واریانت">
                                    گردش
                                </button>
                                <button type="button" class="btn btn-outline-info btn-xs js-variant-pricing-details"
                                        data-toggle="modal"
                                        data-target="#variant-prices-modal"
                                        data-prices-url="@Url.Action("VariantPrices", "VariantManagement", new { variantId = variant.Id })"
                                        data-variant-id="@variant.Id"
                                        data-variant-label="@variant.Sku - @(string.IsNullOrWhiteSpace(variant.Name) ? variant.Sku : variant.Name)"
                                        data-pricing-mode="single"
                                        data-detail-title="@UiText["catalog.variants.pricesTitle"]">
                                    @UiText["catalog.variants.pricesButton"]
                                </button>
                                <button type="button"
                                        class="btn btn-outline-secondary btn-xs js-variant-tags"
                                        data-variant-id="@variant.Id"
                                        data-variant-label="@variant.Sku - @(string.IsNullOrWhiteSpace(variant.Name) ? variant.Sku : variant.Name)">
                                    برچسب
                                </button>
                                <button type="button"
                                        class="btn btn-outline-primary btn-xs js-variant-media-details"
                                        data-variant-id="@variant.Id"
                                        data-mode="single"
                                        data-detail-title="@UiText["catalog.variants.variantMediaTitle"]">
                                    @UiText["variant.media.label"]
                                </button>
                                <button type="button"
                                        class="btn btn-outline-primary btn-xs js-variant-addon-details"
                                        data-variant-id="@variant.Id"
                                        data-product-id="@Model.SelectedProductId"
                                        data-mode="single"
                                        data-detail-title="@UiText["catalog.variants.addonListTitle"]">
                                    @UiText["catalog.variants.addonListTitle"]
                                </button>
                                <button type="button"
                                        class="btn btn-outline-primary btn-xs js-variant-components-details"
                                        data-product-id="@variant.ProductId"
                                        data-variant-id="@variant.Id"
                                        data-detail-title="@UiText["catalog.variants.componentsTitle"]">
                                    @UiText["catalog.variants.componentsTitle"]
                                </button>
                                <form asp-action="DeleteVariant" method="post" class="d-inline" data-loading-form>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                                    <input type="hidden" name="variantId" value="@variant.Id" />
                                    <button type="submit"
                                            class="btn btn-outline-danger btn-xs ml-1"
                                            data-confirm-title="@UiText["catalog.variants.deleteTitle"]"
                                            data-confirm="@UiText["catalog.variants.deleteConfirm"]"
                                            @(Can("Catalog.Variant.Delete", "ProductVariant.Delete") ? null : "disabled")>
                                        @UiText["common.delete"]
                                    </button>
                                </form>
                                @if (!variant.InventoryMovementLocked)
                                {
                                    <form asp-action="LockVariantInventoryMovement" method="post" class="d-inline" data-loading-form>
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@Model.SelectedProductId" />
                                        <input type="hidden" name="variantId" value="@variant.Id" />
                                        <button type="submit"
                                                class="btn btn-outline-dark btn-xs ml-1"
                                                data-confirm-title="@UiText["catalog.variants.lockMovementTitle"]"
                                                data-confirm="@UiText["catalog.variants.lockListConfirm"]"
                                                @(Can("Catalog.Variant.LockInventoryMovement", "ProductVariant.LockInventoryMovement") ? null : "disabled")>
                                            @UiText["catalog.variants.lockButtonShort"]
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

@if (Model.VariantTotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm mb-0">
            @for (var i = 1; i <= Model.VariantTotalPages; i++)
            {
                <li class="page-item @(i == Model.VariantPage ? "active" : null)">
                    <a class="page-link"
                       asp-action="VariantList"
                       asp-route-productId="@Model.SelectedProductId"
                       asp-route-variantId="@Model.SelectedVariantId"
                       asp-route-searchTerm="@Model.VariantSearchTerm"
                       asp-route-trackingPolicy="@Model.VariantTrackingFilter"
                       asp-route-statusFilter="@Model.VariantStatusFilter"
                       asp-route-attributeTypeFilter="@Model.SelectedAttributeTypeFilter"
                       asp-route-sort="@Model.VariantSort"
                       asp-route-page="@i"
                       asp-route-pageSize="@Model.VariantPageSize"
                       data-variant-list-link="true">@i</a>
                </li>
            }
        </ul>
    </nav>
}
