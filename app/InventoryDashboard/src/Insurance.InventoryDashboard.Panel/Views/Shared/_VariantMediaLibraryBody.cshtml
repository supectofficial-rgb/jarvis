@model Insurance.InventoryDashboard.Panel.Models.ProductVariantDetailsModel?
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var productId = Model?.ProductId ?? string.Empty;
    var mediaBaseUrl = (Configuration["FileService:BaseUrl"] ?? string.Empty).TrimEnd('/');

    string? ResolveMediaUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return null;
        }

        var trimmed = url.Trim();
        if (Uri.TryCreate(trimmed, UriKind.Absolute, out _))
        {
            if (!string.IsNullOrWhiteSpace(mediaBaseUrl) &&
                Uri.TryCreate(trimmed, UriKind.Absolute, out var absoluteUri) &&
                absoluteUri.AbsolutePath.StartsWith("/media/", StringComparison.OrdinalIgnoreCase))
            {
                return $"{mediaBaseUrl}{absoluteUri.PathAndQuery}{absoluteUri.Fragment}";
            }

            return trimmed;
        }

        var requestHost = Context?.Request?.Host.Host;
        var requestScheme = Context?.Request?.Scheme ?? "http";
        var configuredBaseIsLocalOnly =
            Uri.TryCreate(mediaBaseUrl, UriKind.Absolute, out var configuredUri) &&
            (string.Equals(configuredUri.Host, "localhost", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(configuredUri.Host, "127.0.0.1", StringComparison.OrdinalIgnoreCase)) &&
            !string.IsNullOrWhiteSpace(requestHost) &&
            !string.Equals(requestHost, "localhost", StringComparison.OrdinalIgnoreCase) &&
            !string.Equals(requestHost, "127.0.0.1", StringComparison.OrdinalIgnoreCase);
        var rootUrl = !string.IsNullOrWhiteSpace(requestHost) ? $"{requestScheme}://{requestHost}" : null;
        var baseUrl = !string.IsNullOrWhiteSpace(mediaBaseUrl) && !configuredBaseIsLocalOnly
            ? mediaBaseUrl
            : rootUrl;

        return string.IsNullOrWhiteSpace(baseUrl)
            ? trimmed
            : $"{baseUrl}/{trimmed.TrimStart('/')}";
    }
}

@if (Model is null)
{
    <div class="alert alert-light mb-0">
        <h6>@UiText["catalog.variants.noVariantSelected"]</h6>
        <p class="mb-0 text-muted">@UiText["catalog.variants.selectVariantForMedia"]</p>
    </div>
}
else if (Model.Images.Count == 0)
{
    <div class="alert alert-light mb-0">
        @UiText["catalog.variants.noMediaRegistered"]
    </div>
}
else
{
    <div class="row">
        @foreach (var media in Model.Images.OrderBy(x => x.DisplayOrder))
        {
            var isVideo = !string.IsNullOrWhiteSpace(media.ContentType) && media.ContentType.StartsWith("video/", StringComparison.OrdinalIgnoreCase);
            var originalUrl = ResolveMediaUrl(media.OriginalUrl) ?? media.OriginalUrl;
            var thumbnailUrl = ResolveMediaUrl(media.ThumbnailUrl) ?? media.ThumbnailUrl;
            <div class="col-lg-4 col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        @if (isVideo)
                        {
                            <video src="@originalUrl" class="w-100 rounded border mb-2" style="max-height:200px;" controls preload="metadata"></video>
                        }
                        else
                        {
                            <img src="@thumbnailUrl" alt="@media.OriginalFileName" class="img-fluid rounded border mb-2" style="max-height:200px;" />
                        }
                        <div class="small text-muted mb-2">@media.OriginalFileName</div>
                        <div class="mb-2">
                            <span class="badge badge-pill badge-outline-primary">@UiText["catalog.variants.displayOrder"] @media.DisplayOrder</span>
                            @if (media.IsPrimary)
                            {
                                <span class="badge badge-pill badge-primary">@UiText["catalog.variants.primary"]</span>
                            }
                            <span class="badge badge-pill badge-light">@(isVideo ? UiText["catalog.variants.video"] : UiText["catalog.variants.image"])</span>
                        </div>
                        <div class="btn-group btn-group-sm">
                            <a href="@originalUrl" target="_blank" rel="noopener" class="btn btn-outline-info btn-xs">@UiText["catalog.variants.view"]</a>
                            <form asp-action="RemoveVariantImage" method="post" class="d-inline" data-ajax-submit="variant-media-remove" data-loading-form>
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@productId" />
                                <input type="hidden" name="variantId" value="@Model.Id" />
                                <input type="hidden" name="fileKey" value="@media.FileKey" />
                                <button type="submit" class="btn btn-outline-danger btn-xs">@UiText["catalog.variants.removeRelation"]</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
