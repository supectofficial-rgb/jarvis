{
  "ConnectionStrings": {
    "CommandDb": "Host=localhost;Database=InsuranceHubServiceCommandDb;Username=postgresuser;Password=2wsx@WSX123",
    "QueryDb": "Host=localhost;Database=InsuranceHubServiceQueryDb;Username=postgresuser;Password=2wsx@WSX123"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Elastic.Apm": "Debug"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/hub-service-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "*" ]
  },
  "HubConversation": {
    "MaxHistoryMessages": 20,
    "SessionIdleTimeoutMinutes": 120
  },
  "AiAssistant": {
    "Enabled": true,
    "BaseUrl": "https://localhost:7220/",
    "ProcessPath": "api/AiAssistService/assistant/turn",
    "TranscribePath": "api/stt/transcribe",
    "TimeoutMs": 15000
  },
  "ElasticApm": {
    "ServerUrl": "http://localhost:8200",
    "SecretToken": "your_secret_token",
    "ServiceName": "hub-service-api",
    "Environment": "development",
    "TransactionSampleRate": 1.0,
    "CaptureHeaders": true,
    "CaptureBody": "all",
    "LogLevel": "Debug",
    "Enabled": true,
    "SpanCompressionEnabled": true,
    "UseElasticTraceId": true,
    "CaptureSpanStackTraces": true
  }
}

